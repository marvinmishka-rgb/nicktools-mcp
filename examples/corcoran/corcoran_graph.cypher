CREATE (n4877:Source {archivePath: 'ClaudeFiles\\archives\\gtvnewshd.com\\2026-02-27_5e72b2c470b3.txt', archiveStatus: 'captured-via-wayback', captureStatus: 'captured', capturedAt: date('2026-02-27T06:32:58.308269000+00:00'), domain: 'gtvnewshd.com', lastCaptured: date('2026-02-27T06:32:58.308269000+00:00'), originalUrl: 'https://gtvnewshd.com/biography/2025/09/27/who-is-erika-kirks-father-mother-all-about-lori-frantzve-and-kent-frantzve/', sourceType: 'unclassified', textPreview: 'Skip to content\nFri, 27 Feb 2026\nLIVE\nUR\nHome\nPakistan\nWorld\nBusiness\nSports\nEntertainment\nMore\nAbout Us\nAdvertise\nPrivacy Policy\nWho is Erika Kirk’s Father & Mother? All about Lori Frantzve and Kent Frantzve\nWeb Desk\n\n27 September, 2025 09:35\n\nWho is Erika Kirk’s Father & Mother? All about Lori Frantzve and Kent Frantzve Credit : Erika Kirk/Instagram\n\nErika Kirk, the widow of Turning Point USA founder Charlie Kirk, has often spoken about the strong influence of her parents. Her story is closely', textSize: 5681, title: 'Who is Erika Kirk’s Father & Mother? All about Lori Frantzve and Kent Frantzve', url: 'https://gtvnewshd.com/biography/2025/09/27/who-is-erika-kirks-father-mother-all-about-lori-frantzve-and-kent-frantzve', waybackUrl: 'http://web.archive.org/web/[phone redacted]5335/https://gtvnewshd.com/biography/2025/09/27/who-is-erika-kirks-father-mother-all-about-lori-frantzve-and-kent-frantzve/'})
CREATE (n4878:Source {archivePath: 'ClaudeFiles\\archives\\wltreport.com\\2026-03-03_6e[phone redacted]_article.txt', archiveStatus: 'captured', author: 'Noah', captureCount: 1, captureMethod: 'http-readability', captureStatus: 'captured', capturedAt: date('2026-02-27T06:33:39.899090000+00:00'), domain: 'wltreport.com', htmlPath: 'ClaudeFiles\\archives\\wltreport.com\\2026-03-03_6e[phone redacted].html', lastCaptured: date('2026-03-03T02:42:45.548838000+00:00'), originalUrl: 'https://wltreport.com/2025/10/27/fact-check-erika-kirks-mom-worked-nsa-7/', publishedDate: '2025-10-27T21:14:09+00:00', siteName: 'WLT Report', sourceType: 'blog-factual-substrate', tags: [], textPreview: 'I know some of you are not going to like this article, but we report FAIRLY and OPENLY and HONESTLY around here, and we also do our homework and fact-check things.\nAnd no topic is off-limits.\nLook folks, I want to like Erika and believe the best about her, but I’m telling you my Spidey Senses are off the charts with this one…\nThe constant fake crying (but never any actual tears)…\nThe Devil Horns at Charlie’s Memorial…\nAnd now the backstory.\nYou might have heard some of this before, but most of i', textSize: 14617, title: 'FACT-CHECK: Erika Kirk\'s Mom Worked For NSA, 7+ Aliases, Hidden Grandparents and a Faceless Dad?', url: 'https://wltreport.com/2025/10/27/fact-check-erika-kirks-mom-worked-nsa-7'})
CREATE (n4879:Source {archivePath: 'ClaudeFiles\\archives\\wltreport.com\\2026-03-02_08bbe1ee2cd5_article.txt', archiveStatus: 'captured', author: 'Noah', captureCount: 1, captureMethod: 'http-readability', captureStatus: 'captured', capturedAt: date('2026-02-27T06:34:02.215097000+00:00'), domain: 'wltreport.com', htmlPath: 'ClaudeFiles\\archives\\wltreport.com\\2026-03-02_08bbe1ee2cd5.html', lastCaptured: date('2026-03-02T00:35:55.227793000+00:00'), originalUrl: 'https://wltreport.com/2026/01/09/just-newly-surfaced-video-shows-erika-kirk-hosting/', publishedDate: '2026-01-10T01:22:37+00:00', siteName: 'WLT Report', sourceType: 'blog-factual-substrate', tags: [], textPreview: 'This is hard to believe even for me, but it’s true.\nErika Kirk hosted a CIA video exposing the vulnerabilities of an EMP attack in the United States way back in 2013.\nI always like to do my research and check my assumptions, so I asked Grok if the video is real and authentic.\nGrok confirmed the video is real but downplayed the characterization of it being a “CIA video” despite the video featuring former CIA Director R. James Woolsey:\nDocumentary Overview: Black Start\nYes, the video clip shared i', textSize: 14644, title: 'JUST IN: Newly Surfaced Video Shows Erika Kirk Hosting 2013 CIA Documentary About EMP Attacks', url: 'https://wltreport.com/2026/01/09/just-newly-surfaced-video-shows-erika-kirk-hosting'})
CREATE (n4880:Source {archivePath: 'ClaudeFiles\\archives\\usaspending.gov\\2026-02-27_e6b91232e7f5.txt', archiveStatus: 'captured', captureStatus: 'captured', capturedAt: date('2026-02-27T06:34:56.183029000+00:00'), domain: 'usaspending.gov', lastCaptured: date('2026-02-27T06:34:56.183029000+00:00'), originalUrl: 'https://www.usaspending.gov/recipient/763cb2dc-a0af-2613-a61e-4170b94b9f70-C/latest', sourceType: 'unclassified', textPreview: 'Skip to main content\nAn official website of the United States government\nHere’s how you know\nSearch Award Data\nExplore the Data\nDownload the Data\nFind Resources\nRECIPIENT PROFILE\nE3 ENTERPRISES GROUP, LLC\nTrailing 12 Months\nOverview\nTransactions Over Time\nTop 5\nE3 ENTERPRISES GROUP, LLC\nAlso known by 3 other names\nOverview\nThis recipient is a child of  E3 ENTERPRISES GROUP, LLC\nCHILD RECIPIENT\nTotal Awarded Amount\n$5,225\nfrom 8 transactions\nView awards to this recipient\nFace Value of Loans\n$0\nfr', textSize: 4077, title: 'E3 ENTERPRISES GROUP, LLC | Federal Award Recipient Profile | USAspending', url: 'https://usaspending.gov/recipient/763cb2dc-a0af-2613-a61e-4170b94b9f70-C/latest'})
