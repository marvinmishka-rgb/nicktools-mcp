CREATE (n5007:Organization {addedDate: date('2026-03-01'), esgr: true, esgrAward: 'Patriotic Employer', esgrContext: 'DoD ESGR recognition - employs National Guard/Reserve members', location: 'Scottsdale, AZ', name: 'BSN Security LLC', notes: 'Security systems and equipment company. Owner: Brad Zellers. Started Jan 2011, incorporated Sep 2011. BBB A+ rated, accredited since May 2016. 5 employees. Same address as Bolt Security: 16101 N 82nd St Ste 3A, Scottsdale. Marketing Assistant: Alexa Alsadek (née Zellers). Complementary to Bolt (systems vs. guards).', provenance: 'archived-verified'})
