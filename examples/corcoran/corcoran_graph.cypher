CREATE (n4724:Source {archivePath: 'ClaudeFiles\\archives\\chicagotribune.com\\2026-02-26_ba07970d6322.txt', archiveStatus: 'captured', captureMethod: 'webfetch', captureStatus: 'captured', capturedAt: date('2026-02-26T02:02:16.228000000+00:00'), domain: 'chicagotribune.com', lastCaptured: date('2026-02-26T02:01:09.476137000+00:00'), note: 'nodriver hit paywall; WebFetch bypassed via different IP/UA', sourceType: 'primary-journalism', textFile: 'ClaudeFiles/archives/chicagotribune.com/2026-02-26_ba07970d6322_webfetch.txt', textSize: 5293, title: '`ECLECTIC’ AN UNDERSTATEMENT AT STRAND CAFE – Chicago Tribune', url: 'https://www.chicagotribune.com/1997/07/04/eclectic-an-understatement-at-strand-cafe/', verifiedAt: date('2026-02-26T16:11:27.366000000+00:00')})
CREATE (n4725:Source {archivePath: 'ClaudeFiles\\archives\\chicagotribune.com\\2026-02-25_4499239e0965.txt', archiveStatus: 'captured', captureMethod: 'webfetch', captureStatus: 'captured-unverified', capturedAt: date('2026-02-26T02:03:01.435000000+00:00'), domain: 'chicagotribune.com', lastCaptured: date('2026-02-25T23:23:25.683766000+00:00'), note: 'WebFetch got summarized content; nodriver hit paywall. Older CT articles accessible via WebFetch.', sourceType: 'primary-journalism', textFile: 'ClaudeFiles/archives/chicagotribune.com/2026-02-26_1992_stranded_webfetch.txt', textSize: 0, title: 'STRANDED – Chicago Tribune', url: 'https://www.chicagotribune.com/news/ct-xpm-1992-09-06-[phone redacted]-story.html'})
CREATE (n4726:Source {archivePath: 'ClaudeFiles\\archives\\grokipedia.com\\2026-03-02_63333e35b21a_article.txt', archiveStatus: 'captured', captureCount: 1, captureMethod: 'http-readability', captureStatus: 'captured', domain: 'grokipedia.com', htmlPath: 'ClaudeFiles\\archives\\grokipedia.com\\2026-03-02_63333e35b21a.html', lastCaptured: date('2026-03-02T23:25:33.249377000+00:00'), siteName: 'Grokipedia', sourceType: 'ai-generated', tags: [], textPreview: 'Fact-checked by Grok 2 months ago\nBill Montgomery (activist)\nWilliam Thomas Montgomery (May 29, 1940 – July 28, 2020), known as Bill Montgomery, was an American businessman and conservative activist who co-founded the youth-oriented political organization\nTurning Point USA\nin 2012 alongside\nCharlie Kirk\n.\n[1]\n[2]\nA retired\nmarketing\nexecutive and early Tea Party participant from suburban\nChicago\n, Montgomery mentored the teenage Kirk after encountering him at a local event, advising him to forgo', textSize: 15016, title: 'Bill Montgomery (activist)', url: 'https://grokipedia.com/page/Bill_Montgomery_(activist)', verifiedAt: date('2026-02-26T16:17:17.934000000+00:00')})
CREATE (n4727:Organization {addedDate: date('2026-02-25'), description: 'Printing firm owned by Bill Montgomery. Received over $430,000 from Turning Point USA for printing services between July 2017 and June 2019, per ProPublica investigation. One of three TPUSA insider-connected firms that won lucrative contracts for printing, payroll processing, and fundraising.', name: 'America Consulting & Graphics', source: '', type: 'other'})
CREATE (n4728:Organization {addedDate: date('2026-02-27'), name: 'Independent Journal Review', researchStatus: 'needs-enrichment', source: 'graph-cleanup-20260227'})
