CREATE (n3920:Agent {agentIds: ['8516', '8719'], bio: 'Licensed Associate RE Broker (licensed as Sydney G Blumstein). Native New Yorker, born and raised in Greenwich Village. Parents are Meris and Kenny Blumstein (Top Brokers). Grew up in 2500sqft Village loft purchased mid-70s. Joined family team 2006. Emory University 2006, Friends Seminary 2002. 20 years RE, 28 years travel. Currently listing $82.5M full-building co-op at 303 E 37th St (Murray Hill). Village Team of Year for a Decade. Corcoran Top 25. NRT Top 1% of 47,000.', captureCount: 5, email: '[redacted]', familyRole: 'daughter', firstSeen: '20190104', lastSeen: '20250915', lastVerified: '2026-02-23', name: 'Sydney Blumstein', office: 'Chelsea/Flatiron - 220 West 19th Street', phone: '[redacted]', sampleUrl: 'https://www.corcoran.com/nyc-real-estate/agents/chelsea-flatiron/sydney-blumstein/8719', slug: 'sydney-blumstein'})
