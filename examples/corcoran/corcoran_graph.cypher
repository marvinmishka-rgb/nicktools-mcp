CREATE (n4845:Source {archivePath: 'ClaudeFiles\\archives\\ktar.com\\2026-02-27_011d5304b09b.txt', archiveStatus: 'captured', captureStatus: 'captured', capturedAt: date('2026-02-27T05:41:15.871143000+00:00'), domain: 'ktar.com', lastCaptured: date('2026-02-27T05:41:15.871143000+00:00'), originalUrl: 'https://ktar.com/arizona-news/tyler-bowyer-remembers-charlie-kirk/5750465/', sourceType: 'unclassified', textPreview: 'ARIZONA NEWS\n\n‘I’d give anything to have my friend back’: Turning Point USA’s Tyler Bowyer remembers Charlie Kirk\n\nSep 15, 2025, 1:12 PM\n\nRemembering Charlie Kirk: Turning Point USA\'s Tyler Bowyer shares personal stories, legacy of Kirk\nMike Broomhead speaks with Tyler Bowyer, COO of Turning Point Action and Turning Point USA, about the late Charlie Kirk following his tragic assassination last week. Tyler shares personal stories of what Charlie was really like behind the scenes — a young man wit', textSize: 7893, title: 'Turning Point USA COO Tyler Bowyer remembers Charlie Kirk', url: 'https://ktar.com/arizona-news/tyler-bowyer-remembers-charlie-kirk/5750465'})
CREATE (n4846:Source {archivePath: 'ClaudeFiles\\archives\\kjzz.org\\2026-02-27_c24696657b05.txt', archiveStatus: 'captured', captureStatus: 'captured', capturedAt: date('2026-02-27T05:41:26.036059000+00:00'), domain: 'kjzz.org', lastCaptured: date('2026-02-27T05:41:26.036059000+00:00'), originalUrl: 'https://www.kjzz.org/politics/2025-09-20/how-charlie-kirk-inspired-young-conservatives-and-why-he-picked-arizona-for-turning-points-home', sourceType: 'unclassified', textPreview: 'Menu\nSearch Query\nDonate\n91.5 KJZZ\nQ with Tom Power\nQ with Tom Power\n91.5 KJZZ\nSUPPORT NEWS & ENTERTAINMENT ON KJZZ\nCALL: [phone redacted]\nDONATE NOW\nContest terms and conditions\nHow Charlie Kirk inspired young conservatives, and why he picked Arizona for Turning Point\'s home\nKJZZ | By Camryn Sanchez, Matthew Casey\nPublished September 20, 2025 at 12:05 AM MST\nFacebook\nThreads\nLinkedIn\nBluesky\nEmail\nTim Agne/KJZZ\nThe jumbotron at Turning Point USA’s candlelight vigil for Charlie Kirk at Desert Financ', textSize: 17928, title: 'How Charlie Kirk inspired young conservatives, and why he picked Arizona for Turning Point\'s home', url: 'https://kjzz.org/politics/2025-09-20/how-charlie-kirk-inspired-young-conservatives-and-why-he-picked-arizona-for-turning-points-home'})
