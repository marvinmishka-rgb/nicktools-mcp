CREATE (n4900:Source {archivePath: 'ClaudeFiles\\archives\\deseret.com\\2026-02-27_56525476cd71.txt', archiveStatus: 'captured', captureStatus: 'captured', capturedAt: date('2026-02-27T14:15:58.975631000+00:00'), domain: 'deseret.com', lastCaptured: date('2026-02-27T14:15:58.975631000+00:00'), originalUrl: 'https://www.deseret.com/politics/2025/09/12/college-republicans-turning-point-asu-honors-charlie-kirk-and-his-legacy/', sourceType: 'unclassified', textPreview: 'Deseret NewsDeseret Magazine\nLatest\nPolitics\nUtah \nSports \nMore \nSIGN IN\nGO\nReport ad\nPOLITICS\nErika Kirk speaks out. Young Arizonans plan to honor her husband Charlie Kirk\nHis colleagues honor his memory on ‘The Charlie Kirk Show’\nPublished: Sept 12, 2025, 7:46 p.m. MDT\nVIEW 56 COMMENTS\nSHARE\nA hearse containing the body of Charlie Kirk, the CEO and co-founder of Turning Point USA who was shot and killed on Wednesday, leaves after being removed from Air Force Two at Phoenix Sky Harbor Internati', textSize: 15235, title: 'Erika Kirk speaks out. Students at ASU plan to honor her husband Charlie Kirk – Deseret News', url: 'https://deseret.com/politics/2025/09/12/college-republicans-turning-point-asu-honors-charlie-kirk-and-his-legacy'})
CREATE (n4901:Event {addedDate: date('2026-02-27'), date: '2015-07-11', description: 'Trump\'s first large rally in Arizona, organized by Tyler Bowyer while serving as Maricopa County Republican Committee chairman (youngest chairman to ever serve, age 29). Rally shot Trump to the front of the Republican field. Erika Frantzve (later Kirk) was placed directly behind Trump by Bowyer. Bowyer warmed up the crowd as speaker. This event preceded Bowyer joining TPUSA full-time later in 2015.', eventType: 'political-rally', location: 'Phoenix Convention Center, Phoenix, AZ', name: 'Trump First Arizona Rally 2015', startDate: '2015-07-11'})
CREATE (n4902:EntryRef {streamEntryId: 'ls-20260227-003', title: 'Research sourcing + public report format + quality fixes'})
CREATE (n4903:EntryRef {streamEntryId: 'ls-20260227-004', title: 'System hardening: APOC trigger auto-repair, VPN split tunneling, report enhancements'})
CREATE (n4904:Organization {addedDate: date('2026-02-28'), description: 'Governing body for Arizona\'s three public universities (ASU, UA, NAU). Tyler Bowyer was appointed as student regent by Gov. Jan Brewer in 2011, bypassing the traditional Arizona Students\' Association selection process where 20-25 other students had applied through the official rotation. Bowyer had applied directly to the governor\'s Office of Boards and Commissions. The appointment drew criticism from the UA Daily Wildcat and former ASU Student Regent Ed Hermes.', name: 'Arizona Board of Regents', type: 'government'})
CREATE (n4905:Organization {addedDate: date('2026-02-28'), description: 'County-level Republican Party organization for Maricopa County, Arizona. Tyler Bowyer served as chairman (2014-2015), during which time 14 of his officers voted no confidence in him over allegations of financial misconduct including unauthorized use of the MCRC debit card, violation of FEC filing requirements, and dishonesty in communications about budget amounts. Bowyer cast the deciding vote to defeat the no-confidence resolution rather than recusing himself. He subsequently retaliated by directing an illegal leadership election in LD 30 that violated county and district bylaws. State party legal counsel Tim LaSota determined the rogue meeting was not legally binding. Attorney Kory Langhofer found the election \'deviates substantially\' from bylaws.', name: 'Maricopa County Republican Committee', type: 'political'})
CREATE (n4906:Organization {addedDate: date('2026-02-28'), description: 'College Republicans chapter at Arizona State University. Under Bowyer\'s presidency (2009-2012), grew from about a dozen attendees to thousands of members. Bowyer brought in speakers like Ron Paul during the tea party era. Used LDS mission-trained organizing skills to build the chapter.', name: 'ASU College Republicans', type: 'political'})
CREATE (n4907:Event {addedDate: date('2026-02-28'), date: '2011-07', description: 'Gov. Jan Brewer appointed ASU student Tyler Bowyer as student regent for two-year term, bypassing traditional ASA selection process. Bowyer applied directly through the Office of Boards and Commissions rather than the Arizona Students\' Association application route. An estimated 20-25 other students had applied through ASA. Bowyer was ASU College Republicans president at the time. Daily Wildcat editorial called it \'an all-out power grab.\' Bowyer had also run for ASU student body president that semester and lost badly (winner got 74.46% of the vote).', endDate: '2013-06', location: 'Phoenix, AZ', name: 'Bowyer Appointed to Arizona Board of Regents', significance: 'Early pattern of bypassing established institutional processes to gain position through executive relationships. Foreshadows later career trajectory.', startDate: '2011-07', type: 'career-move'})
CREATE (n4908:Event {addedDate: date('2026-02-28'), date: '2015-11', description: '14 of 29 MCRC officers voted no confidence in Chairman Bowyer. Resolution alleged: misuse of MCRC debit card without receipts, violation of FEC filing and AZ election laws on multiple occasions, inflated fundraising claims, blatant dishonesty in communications. Called for immediate independent audit and that Bowyer cease using MCRC debit card. Vote was deadlocked — Bowyer cast the deciding vote himself to defeat the resolution rather than recusing. One former board member alleged $50,000 in embezzlement/inflated fundraising. Arizona Capitol Times Yellow Sheet covered multiple misrepresentations. After surviving the vote, Bowyer directed retaliation: ordered member-at-large Andrew Costanzo to call a new LD 30 election violating county and district bylaws. Attorney Kory Langhofer opined the election \'deviates substantially\' from bylaws. State Party legal counsel Tim LaSota confirmed nothing legally binding about the rogue meeting.', location: 'Maricopa County, AZ', name: 'MCRC No-Confidence Vote Against Bowyer', significance: 'First documented financial misconduct allegations against Bowyer. Pattern of self-dealing with organizational funds, retaliatory response to internal opposition, and willingness to break rules to maintain power. Bowyer was simultaneously employed by TPUSA at the time.', startDate: '2015', type: 'other'})
CREATE (n4909:EntryRef {streamEntryId: 'ls-20260227-006', title: 'Tyler Bowyer Deep Dive — Early Career, Family, and Political Ascent'})
CREATE (n4910:Source {archivePath: 'ClaudeFiles\\archives\\en.wikipedia.org\\2026-02-28_055e9f82cf27.txt', archiveStatus: 'captured', captureStatus: 'captured', capturedAt: date('2026-02-28T01:57:30.169663000+00:00'), domain: 'en.wikipedia.org', lastCaptured: date('2026-02-28T01:57:30.169663000+00:00'), sourceType: 'unclassified', textPreview: 'Arizona State University - Wikipedia\nJump to content\nMain menu\nMain menu\nmove to sidebar\nhide\nNavigation\nMain page\nContents\nCurrent events\nRandom article\nAbout Wikipedia\nContact us\nContribute\nHelp\nLearn to edit\nCommunity portal\nRecent changes\nUpload file\nSpecial pages\nSearch\nSearch\nAppearance\nAppearance\nmove to sidebar\nhide\nBirthday mode (Baby Globe)\nDisabled\nEnabledLearn more about Birthday mode\nText\nSmall\nStandard\nLargeThis page always uses small font size\nWidth\nStandard\nWideThe content is as ', textSize: 143812, title: 'Arizona State University - Wikipedia', url: 'https://en.wikipedia.org/wiki/Arizona_State_University'})
CREATE (n4911:Event {addedDate: date('2026-02-28'), date: '2024-04-24', description: 'Arizona grand jury indicts 18 people (11 fake electors + 7 Trump aides) in April 2024 on 9 felony counts including fraud, forgery, and conspiracy. They signed a false certificate Dec 14, 2020 claiming to be duly elected electors. Two plea deals: Jenna Ellis and Loraine Pellegrino (pled to misdemeanor, freed from probation Oct 2025). Judge Sam Myers dismissed case May 2025, ruling prosecutors failed to present Electoral Count Act text to grand jury. AZ Court of Appeals upheld dismissal Sept 2025. AG Mayes appealed to AZ Supreme Court Nov 21, 2025 — case pending. Trump pardoned all 11 electors Nov 10, 2025 (federal only, does not affect state charges). Political vulnerability: all 3 GOP AG candidates for 2026 say they would drop the case. 16 defendants remain.', event_type: 'legal-action', location: 'Maricopa County Superior Court, Arizona', name: 'Arizona Fake Electors Indictment', status: 'active-prosecution'})
CREATE (n4912:Event {addedDate: date('2026-02-28'), date: '2025-11', description: 'President Trump pardons Tyler Bowyer and other Arizona fake electors. Federal pardon does not affect state charges brought by Arizona AG Kris Mayes.', event_type: 'legal-action', name: 'Trump Pardons Arizona Fake Electors'})
CREATE (n4913:EntryRef {streamEntryId: 'ls-20260227-009', title: 'Tyler Bowyer: Superfeed Technologies ties and fake electors indictment expand the Turning Point financial picture'})
