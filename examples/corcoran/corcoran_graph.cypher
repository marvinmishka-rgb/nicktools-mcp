CREATE (n4751:Person:Activist:Consultant {addedDate: date('2026-02-26'), description: 'Virginia \'Ginni\' Thomas, wife of Supreme Court Justice Clarence Thomas. Conservative political consultant and activist. TPUSA advisory board member who spoke at Young Women\'s Leadership Summit in Dallas (summer 2016). Employer of Crystal Clanton at her firm Liberty Consulting after Clanton\'s departure from TPUSA. Took Clanton into the Thomas home, informally referring to her as their \'nearly adopted daughter.\'', name: 'Ginni Thomas', source: ''})
CREATE (n4752:Source {archivePath: 'ClaudeFiles\\archives\\afrisignal.com.ng\\2026-02-27_04de9ad37eb3.txt', archiveStatus: 'captured', captureStatus: 'captured', capturedAt: date('2026-02-27T05:29:22.061068000+00:00'), domain: 'afrisignal.com.ng', lastCaptured: date('2026-02-27T05:29:22.061068000+00:00'), originalUrl: 'https://afrisignal.com.ng/stacy-sheridan-biography/', sourceType: 'unclassified', textPreview: 'Skip to content\n\nRead with Ease\n\nHome\nActivists\nStacy Sheridan Biography: From California Roots to Championing Conservative Causes\nActivists\nStacy Sheridan Biography: From California Roots to Championing Conservative Causes\n By AfriS\n September 22, 2025\n #Stacy Sheridan\nStacy Sheridan Biography\nAdvertisements\nStacy Sheridan Biography\n\nTable of Contents\n\nStacy Sheridan Biography\nEarly Life and California Roots\nAge: Date of Birth\nAcademic and Professional Launch at Pepperdine University School of ', textSize: 17689, title: 'Stacy Sheridan Biography: From California Roots to Championing Conservative Causes', url: 'https://afrisignal.com.ng/stacy-sheridan-biography'})
CREATE (n4753:Person:Judge {description: 'Associate Justice of the United States Supreme Court since 1991. Took Crystal Clanton into his home after her departure from TPUSA, referring to her as \'nearly adopted daughter.\' Selected Clanton as his law clerk for the October 2024 term. Wrote to Judge Pryor that Clanton had \'overcome a lot of adversity\' and that media reports about her were \'false.\'', name: 'Clarence Thomas'})
CREATE (n4754:Organization {addedDate: date('2026-02-27'), name: 'United States Supreme Court', researchStatus: 'needs-enrichment', source: 'graph-cleanup-20260227'})
CREATE (n4755:Person:Politician {addedDate: date('2026-02-26'), description: 'Former U.S. Representative for Illinois. Early Kirk supporter who introduced Kirk to Tea Party organizations in April 2012 when Kirk started SOS Liberty. Later joined TPUSA board. Subsequently disavowed TPUSA and Kirk, calling him a \'grifter\'s grifter.\'', name: 'Joe Walsh', source: ''})
CREATE (n4756:Organization {addedDate: date('2026-02-26'), description: 'Ginni Thomas\'s political consulting firm. Crystal Clanton worked there as project manager after leaving TPUSA, handling data, helping clients, and assisting nonprofits.', name: 'Liberty Consulting', source: '', type: 'political'})
CREATE (n4757:Organization {addedDate: date('2026-02-26'), description: 'Law school at George Mason University, renamed in 2016 in honor of Justice Antonin Scalia as part of a $30 million deal with conservative donors. Crystal Clanton enrolled fall 2019 on a full merit scholarship. Justice Thomas has taught there.', name: 'Antonin Scalia Law School', source: '', type: 'educational'})
CREATE (n4758:Organization {addedDate: date('2026-02-26'), description: 'Conservative youth group co-founded by Charlie Kirk in April 2012 as a high school senior in Wheeling, Illinois. Focused on the national debt and combating perceived liberal bias in education. Kirk claimed to have reached 4 million people through SOS Liberty. The name was eventually ditched when the group became Turning Point USA, registered as a non-profit July 23, 2012.', name: 'SOS Liberty', source: '', type: 'political'})
CREATE (n4759:Event {addedDate: date('2026-02-26'), date: '2012-04-26', description: 'Charlie Kirk, then a high school senior at Wheeling High School in District 214, published his first op-ed on Breitbart News criticizing Paul Krugman\'s AP Economics textbook for liberal bias. Kirk was co-founder of SOS Liberty and was referred to Breitbart by a contact from the Chicago Tea Party rally. The article led to Kirk\'s first Fox News appearance in May 2012, which in turn led Bill Montgomery to discover him. Kirk\'s byline noted he \'will be attending Baylor University in the fall.\'', name: 'Kirk Breitbart Op-Ed Published', source: '', type: 'development-milestone'})
CREATE (n4760:Event {addedDate: date('2026-02-26'), date: '2017-07', description: 'Crystal Clanton departed Turning Point USA in summer 2017 after internal controversy over text messages including one reading \'I HATE BLACK PEOPLE.\' The departure was made public when Jane Mayer of The New Yorker reported on it in December 2017. Kirk initially said TPUSA \'took decisive action within 72 hours\' but later claimed Clanton was the victim of fake messages created by a former employee. Clanton moved into the Thomas home at Ginni Thomas\'s urging, and worked at Liberty Consulting.', name: 'Clanton Departs TPUSA After Racist Text Controversy', source: '', type: 'organizational'})
CREATE (n4761:Event {addedDate: date('2026-02-26'), date: '2015-11-17', description: 'Larry Solov published article revealing Breitbart News Network was conceived in Israel during a 2007 trip with Andrew Breitbart. Solov wrote that they were \'blown away by the spirit, tenacity, and resourcefulness of the Israeli people\' and wanted a site \'unapologetically pro-freedom and pro-Israel.\' Solov left his 800-person law firm to partner with Breitbart. The Jerusalem bureau was led by Aaron Klein.', name: 'Breitbart Jerusalem Launch', source: '', type: 'corporate'})
CREATE (n4762:Person:Attorney:Executive {description: 'President and CEO of Breitbart News Network. Andrew Breitbart\'s best friend and lawyer who left an 800-person law firm to co-found Breitbart. Conceived the network with Breitbart during a 2007 media trip to Israel while visiting Benjamin Netanyahu. Their shared vision was for a site \'unapologetically pro-freedom and pro-Israel.\' Started the company from Breitbart\'s basement and Solov\'s home office.', name: 'Larry Solov'})
CREATE (n4763:Organization {addedDate: date('2026-02-27'), name: 'Breitbart News', researchStatus: 'needs-enrichment', source: 'graph-cleanup-20260227'})
CREATE (n4764:Person {description: 'Charlie Kirk\'s mother. Mental health counselor by profession. Along with husband Robert Kirk, were prominent in suburban Chicago Republican circles.', name: 'Kimberly Kirk'})
CREATE (n4765:EntryRef {streamEntryId: 'ls-20260225-009', title: 'Baron Coleman Podcast Sources: Kirk Origin Story Discrepancies and Clanton-Thomas Pipeline'})
CREATE (n4766:Person:Attorney:Activist {addedDate: date('2026-02-26'), description: 'Close friend and frequent public defender of Clarence and Ginni Thomas. Wrote on social media defending Thomas\'s hiring of Crystal Clanton as clerk, stating \'Justice Thomas knows what a racist is\' and \'I will take his word and judgment any day of the week.\' Key figure in conservative legal circles who serves as an intermediary and public advocate for the Thomas orbit.', name: 'Mark Paoletta', source: ''})
CREATE (n4767:Person:Judge {addedDate: date('2026-02-26'), description: 'Chief Judge of the United States Court of Appeals for the 11th Circuit, based in Atlanta. Key figure in the conservative Supreme Court clerk pipeline — has sent roughly two dozen clerks to the Supreme Court, mainly to conservative justices. At Justice Thomas\'s urging, facilitated Crystal Clanton\'s path by recommending two lower-court judges who offered her clerkships. Later hired Clanton himself. Defended the hiring decision, citing her full merit scholarship, top 5% class standing, and top grade in Justice Kavanaugh\'s summer course.', name: 'William H. Pryor Jr.', source: ''})
CREATE (n4768:Organization {addedDate: date('2026-02-27'), name: 'United States Court of Appeals for the 11th Circuit', researchStatus: 'needs-enrichment', source: 'graph-cleanup-20260227'})
CREATE (n4769:Person:Judge {addedDate: date('2026-02-26'), description: 'Trump-appointed judge on Federal District Court in Alabama. Hired Crystal Clanton for her first federal clerkship after her graduation from Scalia Law School in May 2022. One of two judges recommended by Judge Pryor at Justice Thomas\'s behest.', name: 'Corey L. Maze', source: ''})
CREATE (n4770:Organization {addedDate: date('2026-02-27'), name: 'United States District Court for the Northern District of Alabama', researchStatus: 'needs-enrichment', source: 'graph-cleanup-20260227'})
CREATE (n4771:Organization {addedDate: date('2026-02-27'), name: 'Godspeak Calvary Chapel', researchStatus: 'needs-enrichment', source: 'graph-cleanup-20260227'})
CREATE (n4772:Source {archivePath: 'ClaudeFiles\\archives\\ministrywatch.com\\2026-02-27_7b993ecf0fc8.txt', archiveStatus: 'captured', captureStatus: 'captured', capturedAt: date('2026-02-27T05:29:32.472287000+00:00'), domain: 'ministrywatch.com', lastCaptured: date('2026-02-27T05:29:32.472287000+00:00'), originalUrl: 'https://ministrywatch.com/amp/dream-city-church-partners-with-tpusa-for-strong-church-dream-conference-2024/', sourceType: 'unclassified', textPreview: '.wp-block-jetpack-rating-star span:not([aria-hidden="true"]) { display: none; }/* Inline styles */ .amp-wp-inline-138d714e6265bd8f1acd98fc68074908{clear:both;}.amp-wp-inline-bf8783a8de6c7b7c19475883bdb831d2{list-style-type:none;}.amp-wp-inline-445db05251d739006d3b2f616c930234{font-family:Frank Ruhl Libre;height:140px;max-width:150px;}.amp-wp-inline-f57fc2beaba18f45ea9676fda07b26a2{aspect-ratio:1/1;}.amp-wp-inline-2f0158eb062d1ac553a7edcb8a744628{text-align:center;}\nDream City Church Partners Wit', textSize: 6605, title: 'Dream City Church Partners With TPUSA for Strong Church Dream Conference 2024 - MinistryWatch', url: 'https://ministrywatch.com/amp/dream-city-church-partners-with-tpusa-for-strong-church-dream-conference-2024'})
CREATE (n4773:Person:Activist {addedDate: date('2026-02-26'), description: 'Long-time California conservative activist and founder of the American Renewal Project, which holds free conferences for ministers and their spouses to encourage them to run for office. Has attended Rob McCoy\'s Godspeak Calvary Chapel church. Connected to the Christian nationalism network that influenced Kirk\'s ideological pivot.', name: 'David Lane', source: ''})
CREATE (n4774:Event {addedDate: date('2026-02-26'), date: '2021', description: 'During Crystal Clanton\'s second year at Scalia Law School, Justice Clarence Thomas reached out to Judge William H. Pryor Jr., Chief Judge of the 11th Circuit, to facilitate her clerkship path. Thomas told Pryor that Clanton had \'overcome a lot of adversity\' and that media reports about her were \'false.\' Pryor had already hired his clerks but recommended two lower-court judges. Both offered Clanton clerkships. She chose Judge Corey L. Maze (Alabama), clerked there after her May 2022 graduation, then clerked for Judge Pryor. This is the pipeline that led to her Supreme Court clerkship for October Term 2024.', name: 'Thomas Facilitates Clanton Clerkship Pipeline', source: '', type: 'career-move'})
CREATE (n4775:Event {addedDate: date('2026-02-26'), date: '2025-09-10', description: 'Charlie Kirk was fatally shot during a speaking event at Utah Valley University in Orem, Utah. He had just finished answering a question about gun violence when a single shot struck him in the neck. He died shortly after. Tyler Robinson, a 22-year-old Utah man, was apprehended on September 12 and charged with aggravated murder; prosecutors sought the death penalty. On October 14, 2025 (what would have been Kirk\'s 32nd birthday), Trump awarded him the Presidential Medal of Freedom. Erika Kirk became TPUSA CEO on September 18. By the time of the assassination, TPUSA had raised $389 million and had presence at roughly 900 college campuses and 1,200 high schools.', name: 'Kirk Assassination at Utah Valley University', source: '', type: 'other'})
CREATE (n4776:Organization {addedDate: date('2026-02-26'), description: '501(c)(4) social welfare organization. Revenue $27.2M (FY2024). Tyler Bowyer COO, Charlie Kirk President/CEO. Directors: Tom Sodeika, Scott Studebaker, Bob McEwen.', name: 'Turning Point Action', org_type: 'political', source: '', type: 'political'})
CREATE (n4777:Organization {addedDate: date('2026-02-26'), description: 'TPUSA offshoot founded in 2021 to \'restore traditional American values.\' Organized \'Freedom Night in America\' events at megachurches including Dream City Church in Phoenix. Part of Kirk\'s pivot toward Christian nationalism after being mentored by Pastor Rob McCoy.', name: 'Turning Point Faith', source: '', type: 'faith'})
CREATE (n4778:Organization {addedDate: date('2026-02-26'), description: 'Founded by David Lane. Holds free conferences for ministers and their spouses to encourage them to run for office. Connected to the Christian nationalism movement that influenced Charlie Kirk\'s ideological pivot from secular conservatism.', name: 'American Renewal Project', source: '', type: 'political'})
CREATE (n4779:EntryRef {streamEntryId: 'ls-20260225-010', title: 'Verification Pass: Baron Coleman Source Session — All Claims Confirmed'})
