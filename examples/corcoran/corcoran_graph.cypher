CREATE (n4546:Brokerage {address: '[address redacted]', caseFilingDate: '2018-12-31', caseSettlementDate: '2022-04', caseStatus: 'Settled April 2022', caseSummary: 'Regis Roumila sued CIRE, Sarine Atamian, and Kathy Coumou. 17 causes of action including sexual harassment, hostile work environment, retaliation, breach of contract, tortious interference, conversion, unfair competition. Harassment/discrimination claims (1-8) survived motion to dismiss. Business claims (9-17) dismissed. Settled April 2022, appeal withdrawn July 2022. 88 NYSCEF documents. 9 key PDFs extracted totaling ~196K chars of primary source text.', caseTitle: 'Roumila v. Christie\'s International Real Estate Group, Inc.', commissionStructure: '75% on first $500K, 80% above $500K, 65% referrals, 40% post-termination', contractTerms: '6-year independent contractor agreements, mandatory JAMS arbitration', courtDocuments: ['doc_01_Summons_Complaint.pdf (28 pages)', 'doc_05_Amended_Complaint.pdf (33 pages, CORE)', 'doc_08_Exhibit_A_Salesperson_Agreement.pdf (19 pages, FULL CONTRACT)', 'doc_11_Exhibit_D_License.pdf (2 pages)', 'doc_12_Exhibit_E_Defendants_Employment.pdf (6 pages, LinkedIn profiles)', 'doc_13_Exhibit_F_Listings_Change_to_Coumou.pdf (10 pages, StreetEasy)', 'doc_14_Exhibit_G_Unexecuted_Exclusive_Right.pdf (7 pages)', 'doc_15_Exhibit_H_Coumou_Email_Dec18.pdf (3 pages)', 'doc_16_Affirmation_Adam_Levy.pdf (4 pages)'], documentFiles: 'ClaudeFiles/research/roumila_case/', keyPersonnel: ['Dan Conn (CEO)', 'Kathleen Coumou (Exec Dir, Broker of Record)', 'Sarine Atamian (Business Ops Manager)', 'Keisha Carter (In-house Counsel)'], lifestreamRefs: ['ls-20260223-002', 'ls-20260223-006'], name: 'Christie\'s International Real Estate', nyscefCase: '162223/2018', officeOpenedNYC: '2017', parentCompany: 'Christie\'s (auction house)', shortName: 'CIRE', type: 'competitor'})
