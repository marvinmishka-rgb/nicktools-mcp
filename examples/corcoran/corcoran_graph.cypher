CREATE (n4510:Team {name: 'Regis Roumila Team', notes: 'Roumila at Corcoran Chelsea ~Aug 2016 to ~Jan 2017. Paris native, Sorbonne law, ex-advertising (L Oreal, Vivendi). Was #2 at Nest Seekers behind Ryan Serhant 2015. Left Corcoran for Christies then Brown Harris Stevens then founded Roumila Real Estate Jan 2020. Sued Christies for sexual harassment retaliation.', status: 'dissolved'})
