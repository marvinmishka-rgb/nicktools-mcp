CREATE (n5093:Organization {addedDate: date('2026-03-01'), description: 'Utah domestic LLC (entity 11[phone redacted]) formed March 24, 2020, administratively dissolved August 21, 2025. Registered agent: William Robinson. Principal/Member: William Matthew Robinson (Matt Robinson, father of Tyler Robinson). Physical address: 646 N 750 W, Provo, UT 84601. Also operated DBA \'Utah Custom Cabinets\' (entity 12[phone redacted]) at 185 E Saratoga Dr, Saratoga Springs, UT 84045. Kitchen countertop, cabinet, and stone surface installation.', name: '1-Call Handyman LLC', type: 'business'})
