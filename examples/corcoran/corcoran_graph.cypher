CREATE (n4839:Source {archivePath: 'ClaudeFiles\\archives\\ibtimes.co.uk\\2026-02-27_ca62bf281898.txt', archiveStatus: 'captured', captureStatus: 'captured', capturedAt: date('2026-02-27T05:28:28.805574000+00:00'), domain: 'ibtimes.co.uk', lastCaptured: date('2026-02-27T05:28:28.805574000+00:00'), originalUrl: 'https://www.ibtimes.co.uk/candace-owens-erika-kirk-controversy-1779865', sourceType: 'unclassified', textPreview: 'INTERNATIONAL BUSINESS TIMES\nUK\nPLAY\nTRENDING\nErika Kirk\'s \'Bizarre Friendship\' With A 15-Year-Old Girl: Who is Jillian? Candace Owens Makes \'Sex Trafficking\' Claim\nOwens intensifies scrutiny of Erika Kirk\'s friendship with a teen amid trafficking allegations\nBy Adrienne Martinez\n\nPublished 18 February 2026, 9:13 AM GMT\nShare on Facebook\nShare on LinkedIn\nShare on Reddit\nShare on Flipboard\nShare on Pocket\nErika Kirk under scrutiny as Owens raises trafficking concerns GAGE SKIDMORE/FLICKR\n\nThe st', textSize: 10160, title: 'Erika Kirk\'s \'Bizarre Friendship\' With A 15-Year-Old Girl: Who is Jillian? Candace Owens Makes \'Sex Trafficking\' Claim | IBTimes UK', url: 'https://ibtimes.co.uk/candace-owens-erika-kirk-controversy-1779865'})
CREATE (n4840:Source {archivePath: 'ClaudeFiles\\archives\\tpaction.com\\2026-02-27_37b935ddcd04.txt', archiveStatus: 'captured', captureStatus: 'captured', capturedAt: date('2026-02-27T05:28:39.071814000+00:00'), domain: 'tpaction.com', lastCaptured: date('2026-02-27T06:03:30.681082000+00:00'), originalUrl: 'https://www.tpaction.com/bio/tylerbowyer', sourceType: 'unclassified', textPreview: 'RioSlum Studio\nDONATE\nDONATE\nTYLER BOWYER\n\nTyler Bowyer is a 7th Generation Arizonan and conservative activist. He has served as Republican Precinct Committeeman, Congressional Advisory Chairman, Regent, Republican Legislative District Chairman, Republican County Chairman of the largest Republican-held County in America,Arizona RNC National Committeeman, and was a primary organizer and speaker at the first Trump Rally in July of 2015.\n\nTyler joined Charlie Kirk at Turning Point USA in 2015 later', textSize: 1492, title: 'Tyler Bowyer', url: 'https://tpaction.com/bio/tylerbowyer'})
CREATE (n4841:Organization {addedDate: [date('2026-02-27'), date('2026-02-26')], altNames: ['E3tek Group'], azLegislaturePresentation: 'Lori Frantzve presented on EMP threats to AZ House Public Safety, Military and Regulatory Affairs Committee, March 19, 2014. Introduced by State Senator David Farnsworth.', blackStartDocumentary: 'Erika Frantzve (Kirk) appeared as presenter in Black Start (2017, dir. Patrea Patrick / Heartfelt Films LLC) alongside fmr CIA Dir R. James Woolsey.', cageCode: '3J3R1', description: ['EMP-proof solutions. 9743 E Sharon Dr, Scottsdale AZ 85260. Products: EMP-hardened vehicles, light towers, control tech. 8,000+ assessments in 32 countries.', 'Defense technology company co-founded by Lori Frantzve (CEO) and Lawrence R. Guinta Jr. (Co-Founder/VP Operations & Engineering). Specializes in EMP mitigation and network security for government agencies. Holds contracts with DHS, DOD, and Northrop Grumman. Won medal in 2014 for participation in Operation Enduring Freedom (Afghanistan) and Operation Iraqi Freedom. Website provides minimal public information — no team profiles, board of directors, or news releases. Successor to Tech-Metrics International and AZ-Tech International.'], fortHuachucaConnection: 'Claims of E3TEK testing at Fort Huachuca E3 facility for MIL-STD-461 EMP standards. Direct contract evidence not yet verified.', name: 'E3TEK Group', nativeAmericanProgram: 'Assists Native American communities with sustainable housing solutions powered by off-grid solar energy', productsDetailed: 'EMP-hardened vehicles, light towers, control technology, secure networks, drone-related systems, SCADA protection, micro-grid integration', source: '', type: ['technology', 'other']})
CREATE (n4842:Person {addedDate: date('2026-02-27'), description: 'Teenager at center of Candace Owens allegations about Erika Kirk. Owens claims Kirk befriended Jillian in 2013 when Kirk was 25 and Jillian was 15. Met through Kirk\'s then-boyfriend Josh Harrelson\'s house. Kirk allegedly arranged private photo shoot for Jillian without mother\'s consent. Photographer described as \'short\' man whose name \'started with an R\'. No law enforcement investigation confirmed.', name: 'Jillian Falkon', nameVariants: ['Jillian Falcon']})
CREATE (n4843:Organization {addedDate: date('2026-02-27'), description: 'Private Christian university in Malibu, California. School of Law had Kenneth Starr as Dean. Stacy Sheridan worked in advancement 2005-2012.', name: 'Pepperdine University', type: 'educational'})
