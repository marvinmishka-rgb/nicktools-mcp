CREATE (n3415:Agent {agentIds: ['18236', '23718'], bio: 'Licensed RE Salesperson. Native New Yorker. 20 years fashion before RE. Very active — 23 sold listings on Corcoran profile including $2.877M Chelsea condo, $2.475M West Village co-op. Press mentions into 2026 (FiDi article). Glowing client reviews.', bioEvolution: 'KEPT: Fashion industry background as key differentiator - expanded over time with more specific titles and companies. ADDED: More detail on fashion roles (VP-level positions now explicit). ADDED: Client testimonials and success stories. CONSISTENT: "Creative business approach" and "negotiating skills" messaging maintained 2019→present.', bioNotes2019: 'Wayback partial: "native New Yorker joins Corcoran with a creative business approach...seasoned negotiating skills and her honed creative eye..." Mentioned fashion design executive at J.Crew, Club Monaco, Alice + Olivia.', bioNotesCurrent: 'Full current bio: Native New Yorker, extensive fashion industry background (Senior Director Jill Stuart, VP Alice+Olivia, VP Donna Morgan Ali Ro), fabric research/purchasing/development, global textile mill collaboration, seasonal presentation coordination. Now applies creative eye and negotiation skills to real estate. Strong client reviews - sold apartment within one day of listing, above asking price.', captureCount: 1, careerPath: 'Fashion industry (Senior Director at Jill Stuart, VP at Alice + Olivia, VP at Donna Morgan Ali Ro, fabric research/purchasing at J.Crew, Club Monaco) → Corcoran Chelsea-Flatiron (2019-present)', currentBrokerage: 'Corcoran', currentStatus: 'active_corcoran', email: '[redacted]', enrichedAt: '2026-02-19T20:23:00', enrichedFrom: 'wayback-[phone redacted]2202', fashionCompanies: 'Jill Stuart, Alice + Olivia, Donna Morgan Ali Ro, J.Crew, Club Monaco', firstSeen: '20191119', ghostCohort: true, ghostCohortNote: 'DEBUNKED: Single Wayback capture was artifact. Agent is highly active at Corcoran with strong sales record and client reviews.', ghostStatus: 'still-at-corcoran', lastSeen: '20191119', lastVerified: '2026-02-23', legalName: 'Rhonda Vitoulis', movesCount: 0, name: 'Rhonda Vitoulis', newAgentId: '23718', notes: 'Native New Yorker. Top producer in first year. Art collector, music enthusiast. Still at Corcoran Chelsea-Flatiron as of 2026. Ghost in archive (1 capture) but continuously employed.', office: 'Chelsea/Flatiron - 220 West 19th Street', phone: '[redacted]', priorCareer: 'Fashion design executive - Senior Director Jill Stuart, VP Alice + Olivia, VP Donna Morgan Ali Ro. Fabric research, purchasing, development. Collaborated with global textile mills.', sampleUrl: 'https://www.corcoran.com/nyc-real-estate/agents/chelsea-flatiron/rhonda-vitoulis/18236', slug: 'rhonda-vitoulis', status: 'active', title: 'Licensed RE Salesperson'})
