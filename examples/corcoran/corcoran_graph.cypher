CREATE (n5143:Source {archivePath: 'ClaudeFiles\\archives\\projects.propublica.org\\2026-03-02_0c6904f98e68_article.txt', archiveStatus: 'captured', author: 'Andrea Suozzo, Alec Glassford, Ash Ngu, Brandon Roberts', captureCount: 1, captureMethod: 'http-readability', captureStatus: 'captured', capturedAt: date('2026-03-02T04:57:05.437966000+00:00'), domain: 'projects.propublica.org', htmlPath: 'ClaudeFiles\\archives\\projects.propublica.org\\2026-03-02_0c6904f98e68.html', lastCaptured: date('2026-03-02T04:57:05.437966000+00:00'), publishedDate: '2013-05-09', siteName: 'ProPublica', sourceType: 'unclassified', tags: [], textPreview: 'Nonprofit Explorer includes summary data for nonprofit tax returns and\nfull Form 990 documents, in both PDF and digital formats.\nThe summary data contains information processed by the IRS during the\n2012-2019 calendar years; this generally consists of filings for the\n2011-2018 fiscal years, but may include older records. This data release\nincludes only a subset of what can be found in the full Form 990s.\nIn addition to the raw summary data, we link to PDFs and digital copies\nof full Form 990 doc', textSize: 851, title: 'Everyday Heroes Like You Inc', url: 'https://projects.propublica.org/nonprofits/organizations/263416850'})
CREATE (n5144:Source {archivePath: 'ClaudeFiles\\archives\\patents.justia.com\\2026-03-02_0ba84f711e46_article.txt', archiveStatus: 'captured', captureCount: 1, captureMethod: 'chrome-cli', captureStatus: 'captured', capturedAt: date('2026-03-02T04:57:07.865938000+00:00'), domain: 'patents.justia.com', htmlPath: 'ClaudeFiles\\archives\\patents.justia.com\\2026-03-02_0ba84f711e46.html', lastCaptured: date('2026-03-02T04:57:07.865938000+00:00'), sourceType: 'public-record', tags: [], textPreview: 'patents.justia.com\nPerforming security verification\nThis website uses a security service to protect against malicious bots. This page is displayed while the website verifies you are not a bot.\nVerification successful. Waiting for patents.justia.com to respond', textSize: 259, title: 'Just a moment...', url: 'https://patents.justia.com/assignee/tech-metrics-international-inc'})
CREATE (n5145:Source {archivePath: 'ClaudeFiles\\archives\\patents.google.com\\2026-03-02_0a54d8239b0e_article.txt', archiveStatus: 'captured', captureCount: 2, captureMethod: 'http-readability', captureStatus: 'captured', capturedAt: date('2026-03-02T04:57:16.000900000+00:00'), domain: 'patents.google.com', htmlPath: 'ClaudeFiles\\archives\\patents.google.com\\2026-03-02_0a54d8239b0e.html', lastCaptured: date('2026-03-02T05:08:49.343907000+00:00'), sourceType: 'unclassified', tags: [], textPreview: 'BACKGROUND OF THE INVENTION\nI. Field of the Invention\nThis invention relates to various computer-aided methods and apparatus for assessing an organizational process or system. The term "assessing," as used herein, refers to gathering information about, and/or measuring or evaluating, at least one organizational process or system.\nII. Description of the Related Art\nLarge entities such as corporations, professional associations, and government units typically use a wide variety of suppliers of goo', textSize: 73334, title: 'US5737494A - Assessment methods and apparatus for an organizational process or system - Google Patents', url: 'https://patents.google.com/patent/US5737494'})
CREATE (n5146:Source {archivePath: 'ClaudeFiles\\archives\\arizonafoothillsmagazine.com\\2026-03-02_89a825f11b25_article.txt', archiveStatus: 'captured', author: 'Editorial', captureCount: 1, captureMethod: 'chrome-cli', captureStatus: 'captured', capturedAt: date('2026-03-02T04:57:22.480908000+00:00'), domain: 'arizonafoothillsmagazine.com', htmlPath: 'ClaudeFiles\\archives\\arizonafoothillsmagazine.com\\2026-03-02_89a825f11b25.html', lastCaptured: date('2026-03-02T04:57:22.480908000+00:00'), siteName: 'AZFoothills.com', sourceType: 'unclassified', tags: [], textPreview: 'Stemming from a passion to help people and make a positive impact, Everyday Heroes Like You was born. Founder/CEO Erika Frantzve shared with us her inspiration and how being Miss Arizona 2012 has helped her dream of community outreach grow a thousand times over.\nAFM: What inspired you to start Everyday Heroes Like You?\nEF: Ever since I was a little girl my mom would always tell me, “The greatest thing you can ever give someone is your time.”  Her words were the foundation to my constant drive to', textSize: 3266, title: 'AZ Giving Spotlight: Erika Frantzve of Everyday Heroes Like You', url: 'https://arizonafoothillsmagazine.com/features/az-giving/6169--az-giving-spotlight-erika-frantzve-of-everyday-heroes-like-you.html'})
CREATE (n5147:Source {archivePath: 'ClaudeFiles\\archives\\bizapedia.com\\2026-03-02_b5d433c2d2ce.txt', archiveStatus: 'captured', captureStatus: 'captured', capturedAt: date('2026-03-02T04:57:50.035358000+00:00'), domain: 'bizapedia.com', lastCaptured: date('2026-03-02T04:57:50.035358000+00:00'), originalUrl: 'https://www.bizapedia.com/az/desert-spirit-tek-llc.html', sourceType: 'unclassified', textPreview: '	\n	\n	\n	\n	\n	\n	\n	\n	\n	\n	\n	\n	\n	\n\n	\nBIZAPEDIA PRO SEARCH SUBSCRIPTION\n\nWe just need a quick check to confirm you\'re human. Please complete the drag and drop challenge below and then click the "Verify Human" button below to continue. If you would like expanded search options, feel free to take a look at our Bizapedia Pro Search subscription on this page.\n\n\nDrag\nDrop here\n✓\nPOWERED BY ABSHIELD\n\n\n\n\n\n\n\nEXTENSIVE SEARCHES\n\nWith the Bizapedia Pro Search™ service you will get nearly unlimited searches via o', textSize: 2507, title: 'Company Search Subscription Service', url: 'https://bizapedia.com/az/desert-spirit-tek-llc.html'})
CREATE (n5148:Source {archivePath: 'ClaudeFiles\\archives\\en.wikipedia.org\\2026-03-03_372a00779955_article.txt', archiveStatus: 'captured', captureCount: 1, captureMethod: 'nodriver', captureStatus: 'captured', capturedAt: date('2026-03-03T01:59:31.961599000+00:00'), domain: 'en.wikipedia.org', htmlPath: 'ClaudeFiles\\archives\\en.wikipedia.org\\2026-03-03_372a00779955.html', lastCaptured: date('2026-03-03T01:59:31.961599000+00:00'), sourceType: 'unclassified', tags: ['qa-test'], textPreview: 'From Wikipedia, the free encyclopedia\nLook for\nNRT LLC\non one of Wikipedia\'s\nsister projects\n:\nWikipedia does not have an article with this exact name.\nPlease\nsearch for\nNRT LLC\nin Wikipedia\nto check for alternative titles or spellings.\nOther reasons this message may be displayed:', textSize: 281, title: 'NRT LLC - Wikipedia', url: 'https://en.wikipedia.org/wiki/NRT_LLC'})
CREATE (n5149:Source {archivePath: 'ClaudeFiles\\archives\\en.wikipedia.org\\2026-03-03_dc6b83aa9c0c_article.txt', archiveStatus: 'captured', captureCount: 1, captureMethod: 'http-readability', captureStatus: 'captured', capturedAt: date('2026-03-03T01:59:36.066124000+00:00'), domain: 'en.wikipedia.org', htmlPath: 'ClaudeFiles\\archives\\en.wikipedia.org\\2026-03-03_dc6b83aa9c0c.html', lastCaptured: date('2026-03-03T01:59:36.066124000+00:00'), sourceType: 'unclassified', tags: ['qa-test'], textPreview: 'American residential real estate broker\nCompass, Inc.\noperates a residential real estate\nbrokerage\nin the United States.\n[\n4\n]\n[\n5\n]\nIt has approximately 33,000 agents, who are generally\nindependent contractors\n, on its platform.\n[\n2\n]\nIt operates under many brand names including Compass,\nBetter Homes and Gardens Real Estate\n,\nCentury 21 Real Estate\n,\nColdwell Banker\n,\nCorcoran Group\n,\nSotheby\'s International Realty\n, and\nChristie\'s International Real Estate\n.\n[\n2\n]\nIn 2024, the company complete', textSize: 15247, title: 'Compass, Inc. - Wikipedia', url: 'https://en.wikipedia.org/wiki/Compass,_Inc.'})
