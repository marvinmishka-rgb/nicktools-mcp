CREATE (n4733:Source {archiveStatus: 'captured', author: 'Jane Mayer', captureMethod: 'browser-save-extracted', captureStatus: 'captured', capturedAt: date('2026-02-26T02:26:34.504000000+00:00'), context: 'Jane Mayer investigation into TPUSA racial bias and illegal campaign activity', createdAt: date('2026-02-26T02:26:34.504000000+00:00'), domain: 'newyorker.com', extractionMethod: 'json-ld-articleBody', htmlFile: '', paywallPatterns: ['class-based: paywall-modal, consumer-marketing-unit--paywall-bar-call-to-action, PaywallBarWrapper-egYlzP, paywall-bar, consumer-marketing-unit__slot--paywall-bar-call-to-action, PaywallBarThinContentContainer-jedmHv, paywall-modal--incognito, PaywallInlineBarrierWithWrapperGrid-fyrGfS, consumer-marketing-unit--paywall-inline-barrier, consumer-marketing-unit__slot--paywall-inline-barrier, PaywallBarThinWrapper-eTXNWK, consumer-marketing-unit--paywall-modal-call-to-action, PaywallModalWrapper-eIbMpP, consumer-marketing-unit__slot--paywall-modal-call-to-action, PaywallBarThinLink-cVpBVl, paywall-modal__consumer-marketing-unit, PaywallBarThinContentWrapper-fhCAUL, PaywallBarThinCTALink-hypiMz, paywall-modal--paywall, paywall, PaywallInlineBarrierWrapper-iBnuqk, consumer-marketing-unit__slot--paywall-modal-full-barrier, PaywallBarThinCopy-dYJppg, paywall-bar__consumer-marketing-unit, consumer-marketing-unit--paywall-modal-full-barrier (56 elements)', 'sign-in/barrier overlay: 7 elements'], publishedDate: '2017-12-21', sourceType: 'primary-journalism', tags: ['tpusa', 'charlie-kirk', 'jane-mayer', 'new-yorker'], textFile: 'ClaudeFiles/archives/newyorker.com/2026-02-25_dd7b5d345eff_extracted.txt', title: 'Allegations of Racial Bias and Illegal Campaign Activity at a Conservative Nonprofit That Seeks to Transform College Campuses', url: 'https://web.archive.org/web/[phone redacted]4125/https://www.newyorker.com/news/news-desk/a-conservative-nonprofit-that-seeks-to-transform-college-campuses-faces-allegations-of-racial-bias-and-illegal-campaign-activity', verifiedAt: date('2026-02-26T16:17:25.690000000+00:00')})
CREATE (n4734:EntryRef {streamEntryId: 'ls-20260226-004', title: 'Chelsea Office Ghost Cohort: Four Agent Enrichment Passes — Career Trajectories and the Credential-Without-Sales Pattern'})
CREATE (n4735:Person:Donor {addedDate: date('2026-02-26'), description: 'Suburban Chicago jeweler and early Turning Point USA donor. Gave TPUSA $50,000. Co-hosted dinner with Foster Friess for 100 TPUSA activists at Washington\'s Metropolitan Club during the CPAC convention.', name: 'Mike Miller', source: ''})
CREATE (n4736:Person:Executive:Donor:Politician {addedDate: date('2026-02-26'), description: 'Montana-based technology entrepreneur and donor to Christian causes. Financial backer of Turning Point USA as of 2015. Later elected Governor of Montana (2021) and previously served as U.S. Representative for Montana (2017-2021).', name: 'Greg Gianforte', source: ''})
CREATE (n4737:Person:Donor:Politician {addedDate: date('2026-02-26'), description: 'Illinois Republican Governor (2015-2019). Listed as a financial backer of Turning Point USA in 2015 Crain\'s Chicago Business profile of Charlie Kirk.', name: 'Bruce Rauner', source: ''})
CREATE (n4738:Person:Activist {addedDate: date('2026-02-26'), description: 'Turning Point USA Texas field coordinator (as of 2015). Graduated from Eastern Connecticut State University in 2014, moved to Dallas. Recruited students at Texas Christian University and other Texas campuses for TPUSA.', name: 'Stephanie Conway', source: ''})
CREATE (n4739:Person:Activist {addedDate: date('2026-02-26'), description: '7th-generation Arizonan, COO of Turning Point USA and Turning Point Action, Chairman of the Board at Superfeed Technologies, Arizona RNC National Committeeman. Indicted in April 2024 Arizona fake electors case, later pardoned by Trump. Primary organizer of first Trump rally in Arizona (July 2015).', education: 'Arizona State University, BS Political Science (~2008-2012); LDS mission Russia (2005-2007)', faith: 'LDS (Latter-day Saints). Served two-year LDS mission to Russia 2005-2007, stationed near Ukraine border in Donbas region. Credits mission with giving him organizing skills for politics.', family: 'Wife: Lauren. Children: Brooks, Nell, Quincy. Grandfather: Ray Leonard Bowyer (1941-2025). Ray\'s sons: Michael Bowyer, Derron Bowyer.', hometown: 'Gilbert, Arizona', name: 'Tyler Bowyer', personalDetails: 'Resides in Mesa, AZ with wife Lauren and three children: Brooks, Nell, Quincy. Attended ASU. 7th-generation Arizonan. LDS mission to Russia 2005-2007, first area was closest LDS congregation to Ukraine border. Maintains friendships on both sides of the Russia-Ukraine border.', roles: ['Activist', 'Executive', 'Politician', 'RNC Committeeman'], source: ''})
CREATE (n4740:Organization {addedDate: date('2026-02-27'), description: 'AZ LLC registered July 19, 2017. Principal: Lawrence R. Guinta. 9743 E Sharon Dr, Scottsdale AZ 85260. Same address as E3TEK Group (EMP-proof solutions, 8,000+ assessments in 32 countries).', name: 'Desert Spirit Tek LLC', registeredDate: '2017-07-19', type: 'technology'})
CREATE (n4741:Person {addedDate: date('2026-02-26'), description: 'Supervisor at Christie\'s International Real Estate. Named as defendant in Regis Roumila\'s sexual harassment lawsuit. Roumila complained to her about Atamian\'s behavior and she acknowledged it was a problem, but Roumila was subsequently fired.', name: 'Kathy Coumou', source: ''})
CREATE (n4742:Organization {addedDate: date('2026-02-26'), description: 'New York real estate brokerage. Regis Roumila worked there for 5 years and was the firm\'s #2 agent behind Ryan Serhant in 2015.', name: 'Nest Seekers International', source: '', type: 'brokerage'})
CREATE (n4743:Event {addedDate: date('2026-02-26'), date: '2019-01', description: 'Broker Regis Roumila filed a lawsuit in New York Supreme Court against Christie\'s International Real Estate, business operations manager Sarine Atamian, and supervisor Kathy Coumou. Roumila claimed he was fired in December 2018 for rejecting Atamian\'s sexual advances and complaining about harassment. He alleged gender and marital status discrimination, and claimed CIRE lacked an anti-sexual harassment policy. He also claimed $46,000 in outstanding commissions.', name: 'Roumila Sexual Harassment Lawsuit Against CIRE', source: '', type: 'legal'})
CREATE (n4744:Source {archivePath: 'ClaudeFiles\\archives\\breitbart.com\\2026-02-26_a8fd57b2b407.txt', archiveStatus: 'captured', captureStatus: 'captured', capturedAt: date('2026-02-26T03:27:22.297366000+00:00'), domain: 'breitbart.com', lastCaptured: date('2026-02-26T03:27:22.297366000+00:00'), sourceType: 'partisan-media', textSize: 6128, title: 'Liberal Bias Starts in High School Economics Textbooks', url: 'https://www.breitbart.com/politics/2012/04/26/liberal-bias-starts-in-high-school-economics/', verifiedAt: date('2026-02-26T16:11:27.366000000+00:00')})
