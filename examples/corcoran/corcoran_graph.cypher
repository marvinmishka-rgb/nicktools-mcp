CREATE (n4579)-[:SUPPORTED_BY {claim: 'Erika Frantzve born Ohio Nov 1988. Parents Lori and Kent Frantzve, divorced. Raised in Arizona. Basketball at Regis University, ASU degree (poli sci), Liberty University masters (legal studies 2017). Miss Arizona USA 2012. Founded BIBLEin365 (2016), Proclaim Streetwear (2018), Midweek Rise Up podcast (2019). Applied TPUSA job 2018. Engaged Dec 2020, married May 2021. Daughter 2022, son 2024. Named TPUSA CEO after Kirk assassination.', confidence: 'archived-verified', createdAt: date('2026-02-25T23:06:28.839000000+00:00')}]->(n4692)
CREATE (n4581)-[:SUPPORTED_BY {claim: 'Pastor of Godspeak Calvary Chapel Thousand Oaks, city council member. Kirk heard McCoy at 2019 CPAC at Liberty. McCoy argued Christians must engage politically. Over \'a series of conversations\' McCoy \'challenged\' Kirk to rethink separating politics and religion. By April 2019 Kirk was parroting McCoy\'s views.', confidence: 'archived-verified', createdAt: date('2026-02-26T03:40:41.247000000+00:00')}]->(n4750)
CREATE (n4604)-[:SUPPORTED_BY {claim: 'Larry Guinta co-founder of E3TEK with Lori; patents 1994-2011; wrote 2017 DoD white paper on EMP device threat to airliners; BS degree in electromechanical engineering', confidence: 'archived-verified', createdAt: date('2026-02-26T04:06:25.529000000+00:00')}]->(n4794)
CREATE (n4610)-[:SUPPORTED_BY {claim: 'Kent Frantzve serves as Program Research Director at AZ-Tech International; maintains very low digital profile; no photos findable online', confidence: 'archived-verified', createdAt: date('2026-02-26T04:06:38.528000000+00:00')}]->(n4793)
CREATE (n4611)-[:SUPPORTED_BY {claim: 'Kirk co-founded the Falkirk Center for Faith and Liberty at Liberty University with Jerry Falwell Jr. in 2019. Awarded honorary D.Hum. May 2019. Contract not renewed after Falwell resignation. Center renamed Standing for Freedom Center 2021.', confidence: 'archived-verified', createdAt: date('2026-02-25T23:06:45.347000000+00:00')}]->(n4690)
CREATE (n4615)-[:SUPPORTED_BY {claim: 'Kirk co-founded TPUSA in June 2012. Met Montgomery at Benedictine University Youth Government Day May 2012.', confidence: 'archived-verified', createdAt: date('2026-02-25T23:09:23.404000000+00:00')}]->(n4690)
CREATE (n4618)-[:SUPPORTED_BY {claim: 'Erika Frantzve Kirk named as untested new leader of TPUSA; TP had revenue of $85 million in fiscal 2024', confidence: 'archived-verified', createdAt: date('2026-02-27T14:18:50.769000000+00:00')}]->(n4857)
CREATE (n4697)-[:SUPPORTED_BY {claim: 'Kirk met Foster Friess at the 2012 Republican National Convention. Wikipedia describes Friess providing early support to TPUSA.', confidence: 'archived-verified', createdAt: date('2026-02-25T23:05:51.382000000+00:00')}]->(n4690)
CREATE (n4698)-[:SUPPORTED_BY {claim: 'In 2016, Kirk said about TPUSA\'s national director Crystal Clanton, \'Turning Point needs more Crystals; so does America.\' In 2017, it was revealed that Clanton allegedly sent a racist text message. Kirk responded by having Clanton expelled from the organization.', confidence: 'archived-verified', createdAt: date('2026-02-25T23:06:00.363000000+00:00')}]->(n4690)
CREATE (n4699)-[:SUPPORTED_BY {claim: 'Candace Owens was TPUSA\'s communications director. She and Kirk presented at the 2018 Western Conservative Summit.', confidence: 'archived-verified', createdAt: date('2026-02-25T23:06:05.729000000+00:00')}]->(n4690)
CREATE (n4700)-[:SUPPORTED_BY {claim: 'Kirk collaborated with Liberty University president Jerry Falwell Jr. to create the Falkirk Center for Faith and Liberty in 2019. Falwell resigned in August 2020. Liberty did not renew Kirk\'s one-year contract in late 2020.', confidence: 'archived-verified', createdAt: date('2026-02-25T23:06:12.097000000+00:00')}]->(n4690)
CREATE (n4703)-[:SUPPORTED_BY {claim: 'He was 17 when he wrote an op-ed for Breitbart News decrying liberal economists in his textbooks. The piece landed him on Fox News. Bill Montgomery saw Kirk on Fox and they subsequently met.', confidence: 'archived-verified', createdAt: date('2026-02-25T23:07:47.535000000+00:00')}]->(n4692)
CREATE (n4704)-[:SUPPORTED_BY {claim: 'Kirk met Bill Montgomery at Benedictine University Youth Government Day in May 2012.', confidence: 'archived-verified', createdAt: date('2026-02-25T23:07:53.523000000+00:00')}]->(n4690)
CREATE (n4705)-[:SUPPORTED_BY {claim: 'Kirk met Foster Friess at the 2012 RNC.', confidence: 'archived-verified', createdAt: date('2026-02-25T23:08:01.491000000+00:00')}]->(n4690)
CREATE (n4706)-[:SUPPORTED_BY {claim: 'He was 22 when he became the youngest speaker at the 2016 Republican National Convention. Although not initially a Trump supporter, Kirk would come to be a close confidante of the president.', confidence: 'archived-verified', createdAt: date('2026-02-25T23:08:07.366000000+00:00')}]->(n4692)
CREATE (n4707)-[:SUPPORTED_BY {claim: 'Kirk collaborated with Falwell to create Falkirk Center 2019. Spent at least $50K on Facebook ads for Trump. Falwell resigned Aug 2020. Kirk contract not renewed late 2020. Renamed Standing for Freedom Center 2021.', confidence: 'archived-verified', createdAt: date('2026-02-25T23:08:18.540000000+00:00')}]->(n4690)
CREATE (n4708)-[:SUPPORTED_BY {claim: 'Kirk and Rob McCoy founded Turning Point Faith in 2021 after Liberty did not renew Kirk\'s Falkirk Center contract. Budget $6.4M per TPUSA 2021 Investor Prospectus.', confidence: 'archived-verified', createdAt: date('2026-02-25T23:08:27.244000000+00:00')}]->(n4690)
CREATE (n4709)-[:SUPPORTED_BY {claim: 'From October 2020 Kirk hosted The Charlie Kirk Show on Salem Media Group. Downloaded 500-750K times daily in 2024. Brookings study found second-highest false/misleading statements among 79 podcasters.', confidence: 'archived-verified', createdAt: date('2026-02-25T23:08:32.974000000+00:00')}]->(n4690)
CREATE (n4710)-[:SUPPORTED_BY {claim: 'In 2018 Erika applied for a job at TPUSA. During job interview Kirk said \'Forget this job interview, I want to date you.\' Engaged December 2020, married May 2021. Two children, daughter 2022, son 2024.', confidence: 'archived-verified', createdAt: date('2026-02-25T23:08:40.137000000+00:00')}]->(n4692)
CREATE (n4711)-[:SUPPORTED_BY {claim: 'On March 3, 2020, Kirk released The MAGA Doctrine through HarperCollins. Previous books: Time for a Turning Point (2016, co-written with Brent Hamachek, Post Hill Press) and Campus Battlefield (2018, Post Hill Press, foreword by Donald Trump Jr.).', confidence: 'archived-verified', createdAt: date('2026-02-25T23:08:55.444000000+00:00')}]->(n4690)
CREATE (n4712)-[:SUPPORTED_BY {claim: 'Kirk arranged a Stop the Steal rally in Arizona and sent buses of protesters to the January 6, 2021 storming of the U.S. Capitol. Kirk was considered a \'big name\' social influencer in Giuliani\'s communications plan to overturn the 2020 election.', confidence: 'archived-verified', createdAt: date('2026-02-25T23:09:04.500000000+00:00')}]->(n4690)
CREATE (n4713)-[:SUPPORTED_BY {claim: 'On October 14, 2025, Trump posthumously awarded Kirk the Presidential Medal of Freedom. His widow Erika accepted it on his behalf.', confidence: 'archived-verified', createdAt: date('2026-02-25T23:09:09.974000000+00:00')}]->(n4690)
CREATE (n4718)-[:SUPPORTED_BY {claim: 'Hull announced Montgomery\'s death. Called Montgomery \'best friend, mentor, father figure for 5 years.\' Montgomery text to Hull: \'I\'m not in this for myself.\'', confidence: 'archived-verified', createdAt: date('2026-02-25T23:27:32.728000000+00:00')}]->(n4620)
CREATE (n4719)-[:SUPPORTED_BY {claim: 'TPUSA\'s accounting firm discovered to have ties to Montgomery, calling into question audit independence. Kirk and Montgomery both denied the connection was meaningful.', confidence: 'archived-verified', createdAt: date('2026-02-25T23:17:33.118000000+00:00')}]->(n4717)
CREATE (n4720)-[:SUPPORTED_BY {claim: 'Caleb Hull announced death, said Montgomery lost fight against COVID-19. Kirk called him \'An American hero.\'', confidence: 'archived-verified', createdAt: date('2026-02-25T23:17:55.114000000+00:00')}]->(n4620)
CREATE (n4727)-[:SUPPORTED_BY {claim: 'America Consulting & Graphics received over $430,000 from TPUSA for printing between July 2017 and June 2019.', confidence: 'archived-verified', createdAt: date('2026-02-25T23:24:12.930000000+00:00'), upgradedAt: date('2026-02-26T16:18:10.115000000+00:00')}]->(n4726)
CREATE (n4735)-[:SUPPORTED_BY {claim: 'Suburban Chicago jeweler who gave Turning Point $50,000. Co-hosted dinner with Friess for 100 TPUSA activists at Metropolitan Club during CPAC.', confidence: 'archived-verified', createdAt: date('2026-02-26T03:12:41.642000000+00:00')}]->(n4722)
CREATE (n4736)-[:SUPPORTED_BY {claim: 'Montana-based technology entrepreneur, donor to Christian causes, listed as financial backer of TPUSA.', confidence: 'archived-verified', createdAt: date('2026-02-26T03:12:44.496000000+00:00')}]->(n4722)
CREATE (n4737)-[:SUPPORTED_BY {claim: 'Illinois Republican Governor listed as financial backer of TPUSA.', confidence: 'archived-verified', createdAt: date('2026-02-26T03:12:47.074000000+00:00')}]->(n4722)
CREATE (n4738)-[:SUPPORTED_BY {claim: 'Texas field coordinator for TPUSA, graduated Eastern Connecticut State 2014, moved to Dallas, recruited at TCU.', confidence: 'archived-verified', createdAt: date('2026-02-26T03:12:59.593000000+00:00')}]->(n4722)
CREATE (n4739)-[:SUPPORTED_BY {claim: 'TPUSA staffer at UT Arlington dunk tank event, quoted saying \'There are no rules! Just like the federal government!\'', confidence: 'archived-verified', createdAt: date('2026-02-26T03:13:03.527000000+00:00')}]->(n4722)
CREATE (n4755)-[:SUPPORTED_BY {claim: 'Introduced Kirk to Tea Party organizations in April 2012. Joined TPUSA board. Later disavowed Kirk, calling him a \'grifter\'s grifter.\'', confidence: 'archived-verified', createdAt: date('2026-02-26T03:32:38.157000000+00:00')}]->(n4750)
CREATE (n4757)-[:SUPPORTED_BY {claim: 'Renamed 2016, Clanton enrolled fall 2019 on full merit scholarship, Thomas has taught there', confidence: 'archived-verified', createdAt: date('2026-02-26T03:32:49.632000000+00:00')}]->(n4748)
CREATE (n4758)-[:SUPPORTED_BY {claim: 'Kirk\'s original email identifies him as \'Co-Founder of a conservative youth group called SOS Liberty\'', confidence: 'archived-verified', createdAt: date('2026-02-26T03:32:55.589000000+00:00')}]->(n4747)
CREATE (n4759)-[:SUPPORTED_BY {claim: 'Original op-ed by Kirk criticizing Krugman textbook, byline says \'high school senior, will be attending Baylor University in the fall, Co-Founder of SOS Liberty\'', confidence: 'archived-verified', createdAt: date('2026-02-26T03:33:09.970000000+00:00')}]->(n4744)
CREATE (n4760)-[:SUPPORTED_BY {claim: 'Clanton gone by summer 2017, Mayer reported in Dec 2017, Ginni Thomas told husband of \'horrible way\' Clanton was treated, Clanton lived with Thomases almost a year', confidence: 'archived-verified', createdAt: date('2026-02-26T03:33:17.910000000+00:00')}]->(n4748)
CREATE (n4761)-[:SUPPORTED_BY {claim: 'Solov article revealing Breitbart conceived in Israel in 2007, Solov left law firm to partner with Breitbart, pro-Israel mission', confidence: 'archived-verified', createdAt: date('2026-02-26T03:33:23.416000000+00:00')}]->(n4746)
CREATE (n4764)-[:SUPPORTED_BY {claim: 'Kimberly Kirk described as Charlie Kirk\'s mother and a mental health counselor.', confidence: 'archived-verified', createdAt: date('2026-02-26T03:40:47.567000000+00:00')}]->(n4692)
CREATE (n4766)-[:SUPPORTED_BY {claim: 'Described as \'a close friend and frequent defender of the Thomases.\' Wrote social media post defending Clanton hire.', confidence: 'archived-verified', createdAt: date('2026-02-26T03:40:17.684000000+00:00')}]->(n4748)
CREATE (n4767)-[:SUPPORTED_BY {claim: 'Chief Judge, 11th Circuit. Sent ~24 clerks to SCOTUS. Thomas reached out to Pryor in Clanton\'s second year at Scalia Law. Pryor recommended two judges who both offered Clanton clerkships. Later hired Clanton himself. Defended hiring in letter citing merit scholarship, top 5% class rank, top grade in Kavanaugh summer course.', confidence: 'archived-verified', createdAt: date('2026-02-26T03:40:24.992000000+00:00')}]->(n4748)
CREATE (n4769)-[:SUPPORTED_BY {claim: 'Trump appointee to Federal District Court Alabama. One of two judges recommended by Pryor for Clanton. Clanton chose Maze, worked there after May 2022 graduation.', confidence: 'archived-verified', createdAt: date('2026-02-26T03:40:28.487000000+00:00')}]->(n4748)
CREATE (n4773)-[:SUPPORTED_BY {claim: 'Long-time California conservative activist, founder of American Renewal Project. Has attended McCoy\'s church. Project holds conferences to encourage pastors to run for office.', confidence: 'archived-verified', createdAt: date('2026-02-26T03:40:44.652000000+00:00')}]->(n4750)
CREATE (n4774)-[:SUPPORTED_BY {claim: 'Thomas reached out to Pryor in Clanton\'s second year. Thomas wrote that Clanton overcame adversity and media reports were false. Pryor recommended two judges. Clanton chose Maze after May 2022 graduation, then clerked for Pryor. Selected for Thomas OT\'24 clerkship.', confidence: 'archived-verified', createdAt: date('2026-02-26T03:41:02.065000000+00:00')}]->(n4748)
CREATE (n4775)-[:SUPPORTED_BY {claim: 'Shot at Utah Valley University event Sept 10 2025, hit in neck, died shortly after. Tyler Robinson (22, Utah) apprehended Sept 12, charged with aggravated murder. Trump awarded Medal of Freedom Oct 14. Erika Kirk became CEO Sept 18.', confidence: 'archived-verified', createdAt: date('2026-02-26T03:41:09.788000000+00:00')}]->(n4692)
CREATE (n4776)-[:SUPPORTED_BY {claim: 'TPUSA political advocacy arm, raised $11M in 2020 (up from $2M), bused students to DC Jan 6, channeled money to rally speakers, did not play role in march to Capitol.', confidence: 'archived-verified', createdAt: date('2026-02-26T03:41:20.791000000+00:00')}]->(n4750)
CREATE (n4777)-[:SUPPORTED_BY {claim: 'Founded 2021, mission to \'restore traditional American values,\' organized Freedom Night in America events at megachurches.', confidence: 'archived-verified', createdAt: date('2026-02-26T03:41:24.735000000+00:00')}]->(n4750)
CREATE (n4791)-[:SUPPORTED_BY {claim: 'Erika graduated from private Catholic high school in Scottsdale, Notre Dame Preparatory, in 2007', confidence: 'archived-verified', createdAt: date('2026-02-26T03:54:21.618000000+00:00')}]->(n4786)
CREATE (n4797)-[:SUPPORTED_BY {claim: '2007 obituary for Joseph Abbas lists relatives including Lori Abbas and her husband Larry R. Guinta (Frantzve)', confidence: 'archived-verified', createdAt: date('2026-02-26T04:07:05.934000000+00:00')}]->(n4794)
