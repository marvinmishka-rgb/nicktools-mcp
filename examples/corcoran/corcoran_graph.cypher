CREATE (n284:Agent {agentIds: ['17681'], bio: 'Licensed Real Estate Salesperson. Was member of Hechter Bar-Lev Team at Corcoran. Now at Compass NYC. Licensed name: Roberts Amber Marie. Active on StreetEasy and Compass. Active listings including $3.95M Tribeca condo (at Corcoran). Moved to Compass at unknown date.', bioEvolution: 'DROPPED: Any mention of Corcoran affiliation. KEPT: Finance background as differentiator. ADDED: Hamptons market coverage at Compass.', bioNotes2019: 'No 2019 Corcoran bio retrieved (single capture)', bioNotesCurrents: 'At Compass since June 2020. Serves Hamptons & NYC. Prior career as bond broker gives unique finance perspective. Active since Oct 2005 - 19+ years experience.', captureCount: 1, careerPath: 'BGC Partners Eurobrokers (HY Distressed Bond Broker) → TOWN Residential → Corcoran Chelsea-Flatiron (2019) → Compass (June 2020, Hamptons & NYC)', currentBrokerage: 'Compass', currentFirm: 'Compass (formerly Corcoran)', currentStatus: 'moved_compass', education: 'Boston University', email: '[redacted]', enrichedAt: '2026-02-19T20:23:00', enrichedFrom: 'wayback-[phone redacted]3728', firstSeen: '20191019', ghostCohort: true, ghostCohortNote: 'DEBUNKED: Left Corcoran for Compass. Normal brokerage move. Still active in NYC real estate.', ghostStatus: 'departed-to-compass', lastSeen: '20191019', lastVerified: '2026-02-23', legalName: 'Amber Marie Roberts', license: 'NY #[phone redacted]9 (Roberts Amber Marie)', licenseNumber: '[phone redacted]9', licensedName: 'Roberts Amber Marie', movesCount: 3, name: 'Amber Roberts', notes: 'Licensed as Roberts Amber Marie. Now at Compass. StreetEasy profile active. Single capture at Corcoran Oct 19 2019.', office: 'Chelsea/Flatiron - 218 West 18th Street 6th Floor', phone: '[redacted]', priorCareer: 'Finance - HY Distressed Corporate Bond Broker at BGC Partners Eurobrokers', role: 'Licensed Real Estate Salesperson', salesRecord: '7 past sales, 10 past rentals (StreetEasy verified)', sampleUrl: 'https://www.corcoran.com/nyc-real-estate/agents/chelsea-flatiron/amber-roberts/17681', slug: 'amber-roberts', status: 'departed', team: 'Hechter Bar-Lev Team', teamStatusNote: 'Not listed on hechterbarlev.com/team as of 2026-02-23. May have departed HBL team.', title: 'Licensed RE Salesperson', verifiedDate: date('2026-02-27')})
