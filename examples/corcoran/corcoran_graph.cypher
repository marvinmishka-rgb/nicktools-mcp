CREATE (n4783:Person:Executive:Businesswoman {addedDate: date('2026-02-26'), aliases: ['Lori Ann Frantzve', 'Lorin A. Frantzve', 'Lori A. Walstad', 'Lori Ann Guinta', 'Lori W. Frantzve', 'Lori Ann Stanley'], aliasesNote: '7-11 name variations in public records: Lori Ann Frantzve, Lorin A. Frantzve, Lori A. Walstad, Lori Ann Guinta, Lori W. Frantzve. Consistent with marriage history and clerical variation.', altNames: ['Lori Ann Frantzve', 'Lorin A. Frantzve', 'Lori A. Walstad', 'Lori Ann Guinta', 'Lori W. Frantzve', 'Dr. Lorin Frantzve'], birthDate: '1950-04-05', description: 'Erika Kirk\'s mother. Chairman/Founder of AZ-Tech, GTEK, and E3TEK Group — firms specializing in computer/network security, EMP mitigation, and earned value management consulting for DoD, DHS, NASA. Nearly two decades at General Electric in technical marketing and engineering. Master\'s from University of Cincinnati. Director on Superfeed Technologies Inc. board. Family moved to Arizona due to her homeland security work. Lebanese/Syrian and Italian ancestry.', emails: ['[email redacted]'], fullName: 'Loretta \'Lori\' Ann Abbas', geCareerLength: '~20 years', geConnection: 'Stepmother Rita Stubbemann Abbas also worked at GE in Cincinnati. Lori worked ~20 years at GE. GE connection may be familial.', lastVerified: '2026-03-03', maidenName: 'Abbas', marriageHistory: 'Four marriages documented: (1) Mr. Stanley (~late 1960s, daughter Tonya Lynn born Dec 1969), (2) John Robert Walstad (Jan 1974, Cincinnati), (3) Kent Randall Frantzve (before Nov 1988, daughter Erika born 1988, divorced mid-1990s; 1992 book dedicated to "my wife, Lori"), (4) Lawrence R. Guinta Jr. (confirmed as husband in two independent obituaries: Joe Abbas 2007, Evelyn Carrescia 2019; both list "Lori (Larry Guinta) Frantzve"). Retained Frantzve surname after marrying Guinta. Son Travis Guinta from Guinta marriage. First Guinta patent filed Dec 1994. Marriage sequence between Kent and Guinta unresolved — could be Kent→Guinta or Guinta→Kent→Guinta.', maternalFamilyOrigin: 'Western Pennsylvania (Washington, PA / Canonsburg area). Carrescia family: Italian (Lombardi). Abbas family: Lebanese/Syrian. Both families Catholic.', maternalGrandfather: 'Joseph Anthony Abbas (Syrian/Lebanese)', maternalGrandmother: 'Angeline Maria Carresscia (Italian)', maternalGrandparents: 'Mother: Angeline Carrescia (of Washington, PA), daughter of Albert "Sharky" and Anna Lombardi Carrescia. Father: Joseph Anthony Abbas (died April 5, 2007, age 83, Cincinnati). Joseph married second wife Rita M. Stubbemann Abbas (~1980). Lori has siblings: Deborah (Stephen) Fisher, Patrick (Diane) Abbas, Rita (Mark) McCormack.', name: 'Lori Frantzve', notes: 'Full name: Loretta \'Lori\' Ann Abbas. Born Apr 5 1950. Parents: Joseph Anthony Abbas (Syrian/Lebanese, McKeesport PA) and Angeline Maria Carresscia (Italian). Education: Master\'s from University of Cincinnati, MBA from Xavier University. Marriages: (1) John Robert Walstad (Jan 1974, Cincinnati), (2) Lawrence R. Guinta Jr. (produced son Travis Guinta), (3) Kent Randall Frantzve (produced daughter Erika, born Nov 1988, divorced when Erika young). Raised Erika as single mother in Scottsdale. ~20 years at General Electric. Email: [email redacted] per NSA-related document. Listed in NSA officials/employees document as \'Ms. Lorin Frantzve\' with Scottsdale address and IMET Labs email.', notes_stanley: 'The \'Lori Ann Stanley\' name on the 1974 Cincinnati marriage license comes from a first marriage to a Mr. Stanley (first name unknown), not from a family connection. Tonya Lynn (born Dec 1969) is the daughter from this marriage. Stanley does NOT appear in modern public records databases among Lori\'s 11 known aliases, suggesting the name was used only briefly in the early 1970s.', nsaContact: true, nsaDocumentPage: 307, ohioBellNote: 'Helena Glass Substack (conspiracy-framed but factual details) says Lori worked as CBIS-RAB/ISO9000 auditor at Cincinnati Ohio Bell, auditing in Germany, Netherlands, England, and Australia. Unverified — may be pre-GE or concurrent role.', patent2005: 'Co-filed with Lawrence R. Guinta', patentPortfolio: '7 US patent filings (1994-2010) with co-inventor Lawrence R. Guinta. Earliest assigned to Tech-Metrics International Inc, later to Intellimet Inc. Covers VIRTUAL ASSESSOR organizational assessment and cyber security methodology.', priorEmployment: 'Nearly 20 years at General Electric in technical marketing and engineering roles, before founding AZ-Tech', roles: ['Executive', 'Defense Contractor', 'Board Member'], source: '', sourceDiscrepancy: 'Nicki Swift says \'General Electric for almost two decades\' (citing LinkedIn); The List says \'General Motors for 16 years\'. GE more likely correct given LinkedIn citation.'})
CREATE (n4784:Organization {addedDate: date('2026-02-27'), name: 'General Electric', researchStatus: 'needs-enrichment', source: 'graph-cleanup-20260227'})
CREATE (n4785:Source {archivePath: 'ClaudeFiles\\archives\\ibtimes.co.uk\\2026-02-27_5c85e74ed1b8.txt', archiveStatus: 'captured', captureStatus: 'captured', capturedAt: date('2026-02-27T05:29:42.429173000+00:00'), domain: 'ibtimes.co.uk', lastCaptured: date('2026-02-27T05:29:42.429173000+00:00'), originalUrl: 'https://www.ibtimes.co.uk/candace-owens-erika-kirk-feud-allegations-1780023', sourceType: 'unclassified', textPreview: 'INTERNATIONAL BUSINESS TIMES\nUK\nPLAY\nWORLD\nCandace Owens Challenges Erika Kirk After Insider Tips Claim She Had Ties to Several Child Trafficking Hotspots\nOwens urges clarity after tips suggest Kirk may have been connected to multiple trafficking hotspots.\nBy Thea Felicity\n\nPublished 18 February 2026, 2:11 PM GMT\nShare on Facebook\nShare on LinkedIn\nShare on Reddit\nShare on Flipboard\nShare on Pocket\nOwens commands a larger personal fortune while Kirk controls the institutional machinery her late ', textSize: 10315, title: 'Candace Owens Challenges Erika Kirk After Insider Tips Claim She Had Ties to Several Child Trafficking Hotspots | IBTimes UK', url: 'https://ibtimes.co.uk/candace-owens-erika-kirk-feud-allegations-1780023'})
