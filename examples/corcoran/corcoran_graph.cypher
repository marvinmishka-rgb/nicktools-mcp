CREATE (n4748:Source {archiveStatus: 'captured', author: 'https://www.nytimes.com/by/steve-eder', captureMethod: 'browser-save-extracted', captureStatus: 'paywalled', capturedAt: date('2026-02-26T03:30:14.877000000+00:00'), context: 'NYT investigation into Crystal Clanton path from TPUSA scandal to Clarence Thomas law clerk', createdAt: date('2026-02-26T03:30:14.877000000+00:00'), domain: 'nytimes.com', extractionMethod: 'semantic-container', failureReason: 'nytimes-paywall', htmlFile: 'ClaudeFiles/archives/nytimes.com/2026-02-25_e6805d1055bb.html', paywallPatterns: [], publishedDate: '2024-03-28', sourceType: 'primary-journalism', tags: ['crystal-clanton', 'clarence-thomas', 'tpusa', 'baron-coleman'], textFile: 'ClaudeFiles/archives/nytimes.com/2026-02-25_e6805d1055bb_extracted.txt', title: 'How Justice Thomas’s ‘Nearly Adopted Daughter’ Became His Law Clerk (Published 2024)', url: 'https://www.nytimes.com/2024/03/28/us/politics/crystal-clanton-clarence-thomas-clerk.html', verifiedAt: date('2026-02-26T16:17:28.202000000+00:00')})
CREATE (n4749:Source {archivePath: 'ClaudeFiles\\archives\\medium.com\\2026-02-26_7d362657993d.txt', archiveStatus: 'captured', captureStatus: 'captured', capturedAt: date('2026-02-26T03:31:06.673466000+00:00'), domain: 'medium.com', lastCaptured: date('2026-02-26T03:31:06.673466000+00:00'), sourceType: 'unclassified', textSize: 14408, title: 'Debunking the Charlie Kirk Origin Story | by Matthew Boedy | Medium', url: 'https://medium.com/@mboedy/debunking-the-charlie-kirk-origin-story-b718907ce9ca', verifiedAt: date('2026-02-26T16:11:27.366000000+00:00')})
