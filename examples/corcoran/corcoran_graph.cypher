CREATE (n4608:Organization {addedDate: date('2026-02-25'), description: 'Medical device/biotech company. Lawrence Guinta was Director of Advanced Manufacturing.', name: 'Cobe Laboratories', source: 'ls-20260224-022', type: 'other'})
CREATE (n4609:Person {addedDate: date('2026-02-25'), description: 'Charlie Kirk\'s mother. Née Smith. Former trader at the Chicago Mercantile Exchange, later a mental-health counselor. Raised Charlie in Illinois in a Presbyterian household. Family identified as moderate Republicans.', maidenName: 'Smith', name: 'Kathryn Kirk', provenanceTier: 'archived', source: 'ls-20260224-022'})
CREATE (n4610:Person:Investor:Businessman {addedDate: date('2026-02-25'), altNames: ['Kent R. Frantzve', 'Kent Randall Frantzve'], birthDate: '1948-02', birthDateNote: 'People-search aggregator lists Feb 1948, age ~77. Earlier research estimated ~1960 but 1948 more consistent with 1992 book publication.', bookAuthor: 'The Desktop Business Intelligence Sourcebook (1992, Hyde Park Marketing Group, ISBN [phone redacted], 188pp)', bookPublisher: 'Hyde Park Publishing Services (also DBA Hyde Park Marketing Group), 3425 Michigan Ave #3, Cincinnati, OH 45208. Small boutique publisher run by Jeanne Busemeyer. Not Kent\'s own imprint — a legitimate independent publisher.', bookReviews: 'No reviews found anywhere: 0 ratings on Goodreads, no Amazon reviews, no library journal mentions. The book is genuinely obscure — a pre-internet reference guide to business information sources.', description: 'Erika Kirk\'s father. Program Research Director at AZ-Tech International Inc. (Scottsdale, AZ — Lori Frantzve\'s women-owned defense consulting firm). Also worked at INTELLIMET of Arizona LLC (now retired). Founder of CKF Group LLC (private investment firm; CKF likely = Carl Kent Frantzve). Author of \'The Desktop Business Intelligence Sourcebook\' (1992, Hyde Park Marketing Group, Cincinnati OH — likely his own imprint). Book dedicated to \'my wife, Lori.\' Born Feb 1948, Homewood IL area. Family moved: Homewood IL → Cincinnati OH → Scottsdale AZ → Surprise AZ. Reported TPUSA board member (single-source, unconfirmed). Claims of Raytheon Israel chairmanship are unsubstantiated — the $64K Raytheon subcontract (2024) belongs to the unrelated California AzTech International LLC (Luis Contreras). Kent maintains an unusually low digital profile — no photos exist online despite his daughter\'s public prominence.', digitalProfile: 'Extremely low digital profile — no photos exist online, no public appearances, two sparse LinkedIn profiles (one for AZ-Tech, one listing him as retired from INTELLIMET). Multiple sources independently confirm this unusual absence.', ethnicity: 'Swedish descent (per IMDB trivia)', fullName: 'Kent Randall Frantzve', homewoodCareer: 'Complete black hole. No sources — public records, news archives, people-search aggregators, background checks — reveal what Kent did professionally in Homewood, IL. His father worked at American Bank Note Co. (NYC-based) and held national Swedish fraternal leadership.', homewoodContext: 'Grew up in Homewood, IL (south Chicago suburb, ~25mi from Loop). Family rooted in Chicago Swedish-American community — father Carl Kenneth Frantzve was Grand Chief of the Independent Order of Vikings, headquartered in Chicago. Homewood is ~20 miles from Lemont, IL, where TPUSA co-founder Bill Montgomery operated The Strand Café. Same south/southwest suburban ring, potentially overlapping timeframes in 1970s-80s. No direct evidence of a Kent-Montgomery connection found, but geographic proximity is notable.', lastVerified: '2026-03-02', marriageNote: 'Still married to Lori Frantzve as of 1992 (book dedication). Divorced when Erika was young per multiple sources, so divorce likely mid-1990s.', motherName: 'Elaine Wicklund Frantzve', name: 'Kent Frantzve', provenanceTier: 'archived', residence: 'Surprise, Arizona', residentialHistory: 'Homewood, IL (Chicago suburb) → Cincinnati, OH (where Erika was born 1988, where Hyde Park Marketing Group published his book 1992) → Arizona (Scottsdale, then Surprise)', roles: ['Businessman', 'Defense Contractor', 'Board Member'], siblings: 'Kendra, Kimberly, Karla (all K-names, children of Carl Kenneth and Elaine Wicklund Frantzve)', source: 'ls-20260224-022', tpusaBoardClaim: 'DEBUNKED: No evidence Kent Frantzve was ever a TPUSA board member. ProPublica 990 data, tpusa.com governance page, and Baptist News reporting all list the same 4-6 board members with no Frantzve.', tpusaConnection: 'Not a board member. Connection to TPUSA is through daughter Erika Kirk (née Frantzve), who became CEO and board chair Sept 2025. Board members confirmed (Sept 2025): Doug De Groote, Mike Miller, Tom Sodeika, David Engelhardt, Charlie Kirk, Erika Kirk. No Frantzve appears on any 990 filing or board listing.'})
CREATE (n4611:Organization {addedDate: date('2026-02-25'), description: 'Conservative Christian university in Lynchburg, Virginia. Charlie Kirk co-founded the Falkirk Center for Faith and Liberty there with president Jerry Falwell Jr. in 2019. Liberty awarded Kirk an honorary Doctor of Humanities degree in May 2019. After Falwell\'s resignation in Aug 2020, the university did not renew Kirk\'s contract. The Falkirk Center was renamed Standing for Freedom Center in 2021. Erika Kirk earned her master\'s in legal studies from Liberty in 2017.', name: 'Liberty University', source: 'ls-20260224-022', type: 'educational'})
CREATE (n4612:Organization {addedDate: date('2026-02-25'), description: 'Major research university in Tempe, Arizona. School of Earth and Space Exploration conducts subsidence research. Arizona Water Innovation Initiative studies groundwater sustainability.', name: 'Arizona State University', provenance: 'archived-verified', source: 'ls-20260224-019', type: 'educational'})
CREATE (n4613:Organization {addedDate: date('2026-02-25'), description: 'Private Jesuit university in Denver, CO. Erika Kirk (née Frantzve) attended 2007-2009, played NCAA Division II basketball (guard, #20).', name: 'Regis University', source: 'ls-20260224-019', type: 'educational'})
CREATE (n4614:Event {addedDate: date('2026-02-25'), date: '2025-09-10', description: 'Charlie Kirk was shot and killed at a speaking engagement at Utah Valley University in Orem, Utah, by Tyler Robinson, age 22. Kirk was 31 years old. He was the first major conservative figure assassinated since the 2017 Congressional baseball shooting.', name: 'Charlie Kirk Assassination', securityFailures: 'Rooftops unsecured despite flag and promise. No drones. Orem PD not requested. 6 officers for 3,000+ people. No EMS/ambulance. No metal detectors. Emergency radios below standard. No fire marshal. Informal agreements vs written plans.', securitySetup: 'Integrity Security Solutions: 12-13 contractors + Dan Flood (TPUSA). UVU: 6 uniformed + 2 plainclothes = 8. Orem PD (drones, SWAT, MOU) not asked. No drones. Event planned for 600; 3,000+ attended. No EMS on event form. No ambulance. Two UVU EMT with UTV only.', shooterAccess: 'Robinson walked on campus before noon, rifle in jeans. Through tunnel, climbed to Losee Center roof via staircase and wall. Ran to specific prone position (narrow loophole, 3m right or 10m left = no shot) ~142-160 yards. Single .30-06 round at 12:23 PM.', source: 'ls-20260224-022', type: 'other', venue: 'Sorensen Student Center courtyard, outdoor amphitheater with 180-degree elevated exposure. UVU assigned location. FL Quad considered as alternative.'})
CREATE (n4615:Event {addedDate: date('2026-02-25'), date: '2012', description: 'Charlie Kirk co-founded Turning Point USA in June 2012, at age 18, with mentorship and financial backing from Bill Montgomery. Kirk\'s father Robert reportedly suggested the name \'Turning Point.\' Kirk had met Montgomery at Benedictine University Youth Government Day the previous month. Kirk admitted he started with \'no money, no connections and no idea what I was doing.\' TPUSA was conceived as a conservative counterpoint to liberal advocacy groups like MoveOn.org, focused on mobilizing young conservatives.', name: 'TPUSA Founded', source: 'ls-20260224-022', type: 'organizational'})
CREATE (n4616:Event {addedDate: date('2026-02-25'), date: '2012-06-03', description: '61st Miss USA pageant held at Planet Hollywood Las Vegas. Owned by Donald Trump at the time (Trump owned Miss USA 1996-2015). Erika Frantzve competed as Miss Arizona USA. Olivia Culpo of Rhode Island won. This is the structural connection between Erika and the Trump organization ecosystem.', name: 'Miss USA 2012', source: 'ls-20260224-020', type: 'other'})
