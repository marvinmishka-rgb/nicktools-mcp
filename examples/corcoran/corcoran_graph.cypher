CREATE (n5009:Person {addedDate: date('2026-03-01'), location: 'Scottsdale, AZ', name: 'Susan Zellers', notes: 'Wife of Brian Zellers. NDP donor listed alongside Brian in 2009-10, 2010-11, 2011-12 annual reports. Was original co-member of DSZ Enterprises LLC (Bolt Security Guard Services parent entity). Removed as member December 31, 2009 per Articles of Amendment filed January 4, 2010. Address at time of removal: 9420 E Doubletree Ranch Rd Ste C-109, Scottsdale AZ 85258 (same as company address).', provenance: 'archived-verified'})
