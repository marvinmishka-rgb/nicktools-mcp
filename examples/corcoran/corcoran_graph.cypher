CREATE (n5095:Source {archivePath: 'ClaudeFiles\\archives\\boltsecurityguard.com\\2026-03-01_9358b2e8ecf6_article.txt', archiveStatus: 'captured', captureCount: 1, captureMethod: 'http-readability', captureStatus: 'captured', capturedAt: date('2026-03-01T23:42:44.136228000+00:00'), domain: 'boltsecurityguard.com', htmlPath: 'ClaudeFiles\\archives\\boltsecurityguard.com\\2026-03-01_9358b2e8ecf6.html', lastCaptured: date('2026-03-01T23:42:44.136228000+00:00'), sourceType: 'unclassified', tags: [], textPreview: 'Our network is operated by our dedicated support team, available 24/7. You have the peace of mind that someone is keeping an eye on home, business or property. Our training ensures that the dispatcher knows what to look for and respond accordingly. If our dispatchers need to contact local authorities, a verified response can increase response times and reduce the risk of false alarms.', textSize: 387, title: 'Campus Security - Bolt Security Guard', url: 'https://boltsecurityguard.com/campus-security'})
CREATE (n5096:Source {archivePath: 'ClaudeFiles\\archives\\securityguardtucson.com\\2026-03-01_b46644a5af2d_article.txt', archiveStatus: 'captured', captureCount: 1, captureMethod: 'http-readability', captureStatus: 'captured', capturedAt: date('2026-03-01T23:42:46.311188000+00:00'), domain: 'securityguardtucson.com', htmlPath: 'ClaudeFiles\\archives\\securityguardtucson.com\\2026-03-01_b46644a5af2d.html', lastCaptured: date('2026-03-01T23:42:46.311188000+00:00'), siteName: 'Security Guards Tucson AZ', sourceType: 'unclassified', tags: [], textPreview: 'Often I am asked, “How did you start Bolt Security Guard Services?” It gives me pause for reflection. Let me share how the company has evolved over time. During an earlier phase of my professional career, I was in retail management. I found that a majority of my time was spent on risk management and loss control. Quickly I learned that I was very good at minimizing financial and inventory losses. Knowing this, I asked myself, “What should I do next after moving to Arizona?”\nIn 2004, I was approa', textSize: 2949, title: 'About the Leadership Team at Bolt Security Guard Services in Tucson AZ', url: 'https://securityguardtucson.com/about-bolt/leadership'})
CREATE (n5097:Source {archivePath: 'ClaudeFiles\\archives\\securityguardtucson.com\\2026-03-01_23a74a6b54db_article.txt', archiveStatus: 'captured', captureCount: 1, captureMethod: 'http-readability', captureStatus: 'captured', capturedAt: date('2026-03-01T23:42:51.252735000+00:00'), domain: 'securityguardtucson.com', htmlPath: 'ClaudeFiles\\archives\\securityguardtucson.com\\2026-03-01_23a74a6b54db.html', lastCaptured: date('2026-03-01T23:42:51.252735000+00:00'), siteName: 'Security Guards Tucson AZ', sourceType: 'unclassified', tags: [], textPreview: 'Security Solutions for Tucson Area Schools\nSchool security solutions from Bolt Security Guard Services have secured and protected hundreds of school campuses across Tucson and throughout Arizona. Whether a public, private, or charter school, we ensure that your campus safe, secure, and integrity is maintained at all times. Bolt provides well-trained (armed or unarmed) security guard escorts, parking lot patrol and monitoring, as well as emergency and fire watch services. Our security solutions c', textSize: 542, title: 'Security Guards Tucson AZ', url: 'https://securityguardtucson.com/services/campus-security'})
CREATE (n5098:Source {archivePath: 'ClaudeFiles\\archives\\boltsecurityguard.com\\2026-03-01_33438bcd49f0_article.txt', archiveStatus: 'captured', captureCount: 1, captureMethod: 'http-readability', captureStatus: 'captured', capturedAt: date('2026-03-01T23:42:52.971359000+00:00'), domain: 'boltsecurityguard.com', htmlPath: 'ClaudeFiles\\archives\\boltsecurityguard.com\\2026-03-01_33438bcd49f0.html', lastCaptured: date('2026-03-01T23:42:52.971359000+00:00'), sourceType: 'unclassified', tags: [], textPreview: 'Often I am asked, “How did you start Bolt Security Guard Services?” It gives me pause for reflection. Let me share how the company has evolved over time. During an earlier phase of my professional career, I was in retail management. I found that a majority of my time was spent on risk management and loss control. Quickly I learned that I was very good at minimizing financial and inventory losses. Knowing this, I asked myself, “What should I do next after moving to Arizona?”\nIn 2004, I was approa', textSize: 2949, title: 'About Bolt - Bolt Security Guard', url: 'https://boltsecurityguard.com/about-bolt'})
