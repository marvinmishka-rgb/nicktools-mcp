CREATE (n4600)-[:SUPPORTED_BY {claim: '', confidence: 'archived-verified', createdAt: date('2026-03-02T23:28:04.996000000+00:00'), upgradedAt: date('2026-02-26T16:18:10.115000000+00:00')}]->(n4726)
