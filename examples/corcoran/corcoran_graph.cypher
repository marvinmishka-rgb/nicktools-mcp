CREATE (n4704)-[:SUPPORTED_BY {claim: 'PRA/Boedy: Kirk met Montgomery in May 2012 \'while speaking at a youth government day event at Benedictine University in Lisle, Illinois.\' Most specific account — identifies it as youth government day event. Montgomery was \'a retired local restaurant owner and business consultant who\'d become involved in Tea Party activism.\' Told Kirk to start \'an organization to reach out to young people with your message.\' They ditched SOS Liberty name and formed TPUSA.', confidence: 'archived-verified', upgradedAt: date('2026-02-26T16:18:16.548000000+00:00')}]->(n4750)
