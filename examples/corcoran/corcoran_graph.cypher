CREATE (n3463:Agent:Person {addedDate: date('2026-02-24'), agentIds: ['17671'], awards: 'WSJ RealTrends #56 nationwide medium team by volume', bio: '20+ years NYC luxury RE. Wall Street Journal Real Trends #56 nationwide medium team by volume. Pinnacle Award, President\'s Council (Corcoran highest sales honor). Corcoran Chelsea Team of the Year. Co-leads Hechter Bar-Lev Team with Asaf Bar-Lev. Specializes in new development sales for Grid Group: sold out 6 buildings including 124 W 16th (sold out 1 year), 246 W 16th (3 weeks), 147 Ludlow. Current project: The Myles at 142 W 21st St (22 units, $2,360+/sqft, completion Sep 2026). Key mentor figure — recruited Masayo Hashimoto and Amber Roberts to team.', captureCount: 2, experience: '20+ years luxury RE in NYC', firstSeen: '20190822', lastSeen: '20220811', lastVerified: '2026-02-23', licenseType: 'Licensed Associate RE Broker', name: 'Nicole Hechter', notes: 'Wall Street Journal RealTrends #56 nationwide medium team by volume. Corcoran Chelsea Team of the Year.', sampleUrl: 'https://www.corcoran.com/nyc-real-estate/agents/chelsea-flatiron/nicole-hechter/17671', slug: 'nicole-hechter', source: 'ls-20260224-012', title: 'Licensed Associate RE Broker', type: 'person'})
CREATE (n3464:Agent {agentIds: ['8233', '7629'], bio: 'Licensed Associate RE Broker. The Geils Team (with wife Maura Geils). 19 years real estate, 10 years financial planning. Syracuse 1985. Multi-Million Dollar Club 2021-2024. Manhattan Top 25 Sales Feb 2025. Active listings in West Village and UWS. NOT a ghost — established senior broker with continuous Corcoran tenure.', bioEvolution: 'STABLE: Long-tenured at Corcoran. Team-based operation with wife Maura. KEPT: Finance background as credibility marker. GROWN: Promoted to VP Associate Broker. Built independent brand (geilsteam.com). Most established of the ghost cohort.', bioNotes2019: 'Listed as Chelsea-Flatiron agent Dec 2019. Member of Geils Team.', bioNotesCurrent: 'VP Associate Broker. The Geils Team = husband-wife power couple. Specialize in Lower Manhattan, Greenwich Village, West Village. Prior finance career (Chase, MetLife, HSBC). NYC real estate expertise with "decades of sales and marketing experience." West Village parents. Own team website geilsteam.com.', captureCount: 1, careerPath: 'Chase → MetLife → HSBC → NYU Credit Analysis program (2005-2008) → Corcoran Chelsea-Flatiron / The Geils Team (long-standing)', currentBrokerage: 'Corcoran', currentStatus: 'active_corcoran', email: '[redacted]', enrichedAt: '2026-02-19T20:23:00', enrichedFrom: 'wayback-[phone redacted]0347', firstSeen: '20191212', ghostCohort: true, ghostCohortNote: 'DEBUNKED: Single Wayback capture was artifact of data collection, not evidence of brief tenure. Agent has been at Corcoran continuously for 19+ years.', ghostStatus: 'still-at-corcoran', lastSeen: '20221203', lastVerified: '2026-02-23', legalName: 'Robert F Geils', movesCount: 0, name: 'Robert Geils', nameVariants: ['Robert Geils', 'Robert F Geils'], notes: 'At Corcoran since 2001. Runs The Geils Team with wife Maura Geils. West Village parents. Licensed Associate RE Broker. Featured in NYT. Duplicate record exists as robert-f-geils.', office: 'Chelsea/Flatiron - 220 West 19th Street', phone: '[redacted]', priorCareer: 'Finance/Banking - Chase, MetLife, HSBC. NYU Professional Continuing Ed in Credit Analysis (2005-2008).', sampleUrl: 'https://www.corcoran.com/nyc-real-estate/agents/chelsea-flatiron/robert-geils/8233', slug: 'robert-geils', specialties: 'Lower Manhattan, Greenwich Village, West Village', status: 'active', team: 'Geils Team', teamName: 'The Geils Team', teamPartner: 'Maura Geils (wife)', title: 'VP Associate Broker'})
