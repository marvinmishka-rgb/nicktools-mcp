CREATE (n4891:Source {archivePath: 'ClaudeFiles\\archives\\projects.propublica.org\\2026-03-03_6af71353b675_article.txt', archiveStatus: 'captured', author: 'Andrea Suozzo, Alec Glassford, Ash Ngu, Brandon Roberts', captureCount: 1, captureMethod: 'http-readability', captureStatus: 'captured', capturedAt: date('2026-02-27T06:39:54.343197000+00:00'), domain: 'projects.propublica.org', htmlPath: 'ClaudeFiles\\archives\\projects.propublica.org\\2026-03-03_6af71353b675.html', lastCaptured: date('2026-03-03T02:44:00.768869000+00:00'), publishedDate: '2013-05-09', siteName: 'ProPublica', sourceType: 'unclassified', tags: [], textPreview: 'Full text of "Full Filing" for fiscal year ending June 2023\nTax returns filed by nonprofit organizations are public records. The\nInternal Revenue Service releases them in two formats: page images\nand raw data in XML. The raw data is more useful, especially to\nresearchers, because it can be extracted and analyzed more easily.\nThe pages below are a reconstruction of a tax document using raw\ndata from the IRS.\nSelect a schedule\nForm 990\nForm 990, Schedule A\nForm 990, Schedule B\nForm 990, Schedule D', textSize: 663, title: 'Turning Point Usa Inc', url: 'https://projects.propublica.org/nonprofits/organizations/800835023/[phone redacted]49309696/full'})
