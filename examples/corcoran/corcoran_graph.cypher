CREATE (n5242:Source {archivePath: 'ClaudeFiles\\archives\\realestatenews.com\\2026-03-03_215d1ded5028_article.txt', archiveStatus: 'captured', captureCount: 1, captureMethod: 'http-readability', captureStatus: 'captured', capturedAt: date('2026-03-03T02:05:06.909561000+00:00'), domain: 'realestatenews.com', htmlPath: 'ClaudeFiles\\archives\\realestatenews.com\\2026-03-03_215d1ded5028.html', lastCaptured: date('2026-03-03T02:05:06.909561000+00:00'), publishedDate: '2025-09-22T12:24:40.226Z', siteName: 'RealEstateNews.com', sourceType: 'unclassified', tags: ['corcoran', 'compass', 'merger', 'qa-test'], textPreview: 'Compass to acquire Anywhere, creating world’s largest brokerage\nThe combined companies would be worth $10 billion, with roughly 340,000 real estate professionals servicing about 120 countries and territories, Compass said.\nIn a major acquisition move that will forever change the residential real estate industry, Compass announced on Sept. 22 that it has entered into an agreement to acquire key rival Anywhere Real Estate in an all-stock transaction.\nForming a residential mega-brokerage\nIn the com', textSize: 4138, title: 'Compass to acquire Anywhere, creating world’s largest brokerage', url: 'https://realestatenews.com/2025/09/22/compass-to-acquire-anywhere-creating-worlds-largest-brokerage'})
CREATE (n5243:Source {archivePath: 'ClaudeFiles\\archives\\thecityceleb.com\\2026-03-03_16510e613562_article.txt', archiveStatus: 'captured', captureCount: 1, captureMethod: 'nodriver', captureStatus: 'captured', capturedAt: date('2026-03-03T03:02:53.306697000+00:00'), domain: 'thecityceleb.com', htmlPath: 'ClaudeFiles\\archives\\thecityceleb.com\\2026-03-03_16510e613562.html', lastCaptured: date('2026-03-03T03:02:53.306697000+00:00'), siteName: 'TheCityCeleb', sourceType: 'unclassified', tags: [], textPreview: 'Skip to the content\n\nTheCityCeleb\n\nThe Private Lives Of Public Figures\n\nSEARCH FOR:\n \n\nHome »\nTravis Guinta\n\nTravis Guinta\nApril 9, 2025 1 \nCharlie Kirk’s wife Erika Lane Frantzve Biography: Height, Child, Age, Net Worth, Siblings, Parents, Husband, Awards\nPosted By GIFT NWORIE \n\nErika Frantzve Kirk, also known as Erika Lane Frantzve, is an American entrepreneur, podcaster, former beauty queen, and philanthropist widely…\n\n★Recently Viewed\nYou have not viewed any articles on TheCityCeleb yet. Onc', textSize: 683, title: 'Travis Guinta " Bio, Age, Net Worth, Family', url: 'https://thecityceleb.com/profile/travis-guinta'})
CREATE (n5244:Source {archivePath: 'ClaudeFiles\\archives\\paradisevalley.edu\\2026-03-03_afd69f66b99f_article.txt', archiveStatus: 'captured', captureCount: 1, captureMethod: 'wayback', captureStatus: 'captured', capturedAt: date('2026-03-03T03:03:02.610900000+00:00'), domain: 'paradisevalley.edu', htmlPath: 'ClaudeFiles\\archives\\paradisevalley.edu\\2026-03-03_afd69f66b99f.html', lastCaptured: date('2026-03-03T03:03:02.610900000+00:00'), sourceType: 'unclassified', tags: [], textPreview: 'A late-night conversation with his roommate while seated on the kitchen countertop provided the “a-ha” moment for Travis Guinta.  He always had an urge to serve his country...but in what way; this was the unknown.  In the late-night conversation they explored what they were good at, the life-style they wanted to live, and rewarding career options.  After several hours of deep conversation, everything pointed to one pursuit.  From that day forward, Travis would begin his journey to pursue the rew', textSize: 3937, title: 'Paradise Valley Community College', url: 'https://paradisevalley.edu/success-story/travis-guinta'})
CREATE (n5245:Source {archivePath: 'ClaudeFiles\\archives\\helenaglass.substack.com\\2026-03-03_e88f35b7f5eb_article.txt', archiveStatus: 'captured', author: 'Helena Glass', captureCount: 1, captureMethod: 'http-readability', captureStatus: 'captured', capturedAt: date('2026-03-03T03:03:56.975002000+00:00'), domain: 'helenaglass.substack.com', htmlPath: 'ClaudeFiles\\archives\\helenaglass.substack.com\\2026-03-03_e88f35b7f5eb.html', lastCaptured: date('2026-03-03T03:03:56.975002000+00:00'), sourceType: 'unclassified', tags: [], textPreview: 'Erika Kirk:\nMother = Lorin Abbas of Muslim Lebanese descent. Father = Kent Randall Frantzve ‘Swedish’ descent - according to Geneastar a genealogy website. In a 2007 obituary for Lori’s father, Joseph Abbas, the relatives include Lori Abbas and her husband\nLarry R. Guinta\n(Frantzve) – not Kent Randall. The tribute to Erika’s grandfather was from her paternal side, Carl Kenneth Frantzve who died in 2016. There is no genealogy linking Lori to a previous marriage or to Erika having any siblings. Bu', textSize: 4554, title: 'Erika Kirk - TPUSA - Unraveling A Failed PR Saga', url: 'https://helenaglass.substack.com/p/erika-kirk-tpusa-unraveling-a-failed'})
CREATE (n5246:Source {archivePath: 'ClaudeFiles\\archives\\legacy.com\\2026-03-03_ab5f8b25006c_article.txt', archiveStatus: 'captured', captureCount: 1, captureMethod: 'http-readability', captureStatus: 'captured', capturedAt: date('2026-03-03T03:04:45.118826000+00:00'), domain: 'legacy.com', htmlPath: 'ClaudeFiles\\archives\\legacy.com\\2026-03-03_ab5f8b25006c.html', lastCaptured: date('2026-03-03T03:04:45.118826000+00:00'), sourceType: 'unclassified', tags: [], textPreview: 'People and places connected with Joe\nHow to support Joe\'s loved ones\nAttending a Funeral: What to Know\nYou have funeral questions, we have answers.\nRead more\nShould I Send Sympathy Flowers?\nWhat kind of arrangement is appropriate, where should you send it, and when should you send an alternative?\nRead more\nWhat Should I Write in a Sympathy Card?\nWe\'ll help you find the right words to comfort your family member or loved one during this difficult time.\nRead more\nPoems of Mourning and Comfort\nThe b', textSize: 1694, title: 'Joe ABBAS Obituary', url: 'https://legacy.com/us/obituaries/cincinnati/name/joe-abbas-obituary?id=48146743'})
CREATE (n5247:Source {archivePath: 'ClaudeFiles\\archives\\muellerfunerals.com\\2026-03-03_973387ed8041_article.txt', archiveStatus: 'captured', captureCount: 1, captureMethod: 'http-readability', captureStatus: 'captured', capturedAt: date('2026-03-03T03:05:32.622685000+00:00'), domain: 'muellerfunerals.com', htmlPath: 'ClaudeFiles\\archives\\muellerfunerals.com\\2026-03-03_973387ed8041.html', lastCaptured: date('2026-03-03T03:05:32.622685000+00:00'), siteName: 'Mueller Funeral Home', sourceType: 'unclassified', tags: [], textPreview: 'Marie Rita\n(nee Stubbemann)\nAbbas\n, 103 of West Chester Township passed away peacefully on October 6, 2023. Born to Fred and Mary Elizabeth (nee Huelsman) Stubbemann on September 2, 1920, in Cincinnati, Ohio.\nRita worked her entire life, she was dedicated, a go getter and enjoyed spending time with new people. She worked at several places, which included General Electric, The Welcome Center on 71 and devoted countless hours to St John the Evangelist Church. She volunteered on parish council, ser', textSize: 1638, title: 'Rita Abbas Obituary October 6, 2023', url: 'https://muellerfunerals.com/obituaries/rita-abbas'})
CREATE (n5248:Source {archivePath: 'ClaudeFiles\\archives\\salandrafunerals.com\\2026-03-03_[phone redacted]16_article.txt', archiveStatus: 'captured', captureCount: 1, captureMethod: 'http-readability', captureStatus: 'captured', capturedAt: date('2026-03-03T03:06:09.286945000+00:00'), domain: 'salandrafunerals.com', htmlPath: 'ClaudeFiles\\archives\\salandrafunerals.com\\2026-03-03_[phone redacted]16.html', lastCaptured: date('2026-03-03T03:06:09.286945000+00:00'), siteName: 'Salandra Funeral and Cremation, Services', sourceType: 'unclassified', tags: [], textPreview: 'Evelyn Marie Carrescia\nEmployed at Washington hospital/ Brockway glass/ Barber/ beautician\nEvelyn Marie Carrescia, 91, of Washington, was taken to her Father’s house in heaven died Tuesday, April 30, 2019, in Paulin Personal Care home, McDonald .\nShe was born May 18, 1927, in Washington, a daughter of the late Albert (Sharky)and Anna Lombardi Carrescia.\nMs. Carrescia was a graduate of Washington High School, Fal Beauty Academy, Canonsburg and Pittsburgh Barber School.\nMs. Carrescia was a member ', textSize: 2754, title: 'Evelyn M. Carrescia', url: 'https://salandrafunerals.com/obituaries/evelynm-carrescia'})
CREATE (n5249:EntryRef {streamEntryId: 'ls-20260302-012', title: 'Lori Frantzve Marriage Sequence: Two Obituaries Confirm Guinta as Husband, Timeline Still Ambiguous'})
CREATE (n5250:Source {archivePath: 'ClaudeFiles\\archives\\kuer.org\\2026-03-03_364f213221d9_article.txt', archiveStatus: 'captured', author: 'https://www.kuer.org/people/associated-press', captureCount: 1, captureMethod: 'wayback', captureStatus: 'captured', capturedAt: date('2026-03-03T15:03:39.381173000+00:00'), domain: 'kuer.org', htmlPath: 'ClaudeFiles\\archives\\kuer.org\\2026-03-03_364f213221d9.html', lastCaptured: date('2026-03-03T15:03:39.381173000+00:00'), publishedDate: '2025-09-30T17:53:23.55', siteName: 'KUER', sourceType: 'unclassified', tags: [], textPreview: 'Utah Valley University, where conservative leader Charlie Kirk was assassinated, lacked several key public safety measures and practices that have become standard safeguards for security at events around the country, an Associated Press review has found.\nThe university\'s outdoor courtyard, where Kirk showed up on Sept. 10 to\ndebate students\n, was surrounded by several tall buildings, leaving Kirk vulnerable. That was made all the more potent because campus police didn\'t fly a drone to monitor ro', textSize: 9227, title: 'Utah Valley University, where Charlie Kirk was shot, lacked key public safety tools', url: 'https://kuer.org/education/2025-09-30/utah-valley-university-where-charlie-kirk-was-shot-lacked-key-public-safety-tools', waybackUrl: 'http://web.archive.org/web/[phone redacted]3806/https://www.kuer.org/education/2025-09-30/utah-valley-university-where-charlie-kirk-was-shot-lacked-key-public-safety-tools'})
CREATE (n5251:Source {archivePath: 'ClaudeFiles\\archives\\foxnews.com\\2026-03-03_f77b04a6a6f9_article.txt', archiveStatus: 'captured', captureCount: 1, captureMethod: 'http-readability', captureStatus: 'captured', capturedAt: date('2026-03-03T15:03:42.133328000+00:00'), domain: 'foxnews.com', htmlPath: 'ClaudeFiles\\archives\\foxnews.com\\2026-03-03_f77b04a6a6f9.html', lastCaptured: date('2026-03-03T15:03:42.133328000+00:00'), sourceType: 'primary-journalism', tags: [], textPreview: 'Ret. Secret Service senior special agent Timothy Reboulet discusses how the suspect in the Charlie Kirk assassination got access to a roof of a building at Utah Valley University on ‘Fox Report.’\nNEW\nYou can now listen to Fox News articles!\nEXCLUSIVE:\nOREM, Utah — Two weeks after the shooting that killed\nTurning Point USA founder Charlie Kirk,\nFox News Digital accessed the rooftop where the alleged assassin is believed to have taken the shot — stopped only a few feet short of the exact position ', textSize: 7169, title: 'Charlie Kirk assassination exposes campus security flaws at Utah university', url: 'https://foxnews.com/us/charlie-kirk-assassination-exclusive-photos-show-path-campus-rooftop-weeks-later-access-scrutinized'})
CREATE (n5252:Source {archivePath: 'ClaudeFiles\\archives\\utahnewsdispatch.com\\2026-03-03_64c4e95f0631_article.txt', archiveStatus: 'captured', author: 'Annie Knox', captureCount: 1, captureMethod: 'wayback', captureStatus: 'captured', capturedAt: date('2026-03-03T15:03:45.788077000+00:00'), domain: 'utahnewsdispatch.com', htmlPath: 'ClaudeFiles\\archives\\utahnewsdispatch.com\\2026-03-03_64c4e95f0631.html', lastCaptured: date('2026-03-03T15:03:45.788077000+00:00'), publishedDate: '2025-12-02T00:59:21+00:00', siteName: 'Utah News Dispatch', sourceType: 'unclassified', tags: [], textPreview: 'An outside review of Charlie Kirkâ€™s assassination at Utah Valley University and the schoolâ€™s security protocols is expected to begin in January and conclude before summer 2026.Â Â\nThe Orem university laid out the timeline in a request for proposals posted last month on its procurement website for contract vendors. UVU had\nannounced in September\nthat it was â€œinitiating a comprehensive independent review with an external organizationâ€? but didnâ€™t give a timeline or disclose the name of an', textSize: 4155, title: 'Review of Charlie Kirk shooting, UVU campus security expected to start in 2026', url: 'https://utahnewsdispatch.com/2025/12/01/review-of-charlie-kirk-shooting-uvu-campus-security-expected-to-start-in-2026', waybackUrl: 'http://web.archive.org/web/[phone redacted]5709/https://utahnewsdispatch.com/2025/12/01/review-of-charlie-kirk-shooting-uvu-campus-security-expected-to-start-in-2026/'})
CREATE (n5253:Source {archivePath: 'ClaudeFiles\\archives\\americanthinker.com\\2026-03-03_a55bbd666ee7_article.txt', archiveStatus: 'captured', captureCount: 1, captureMethod: 'http-readability', captureStatus: 'captured', capturedAt: date('2026-03-03T15:03:47.296968000+00:00'), domain: 'americanthinker.com', htmlPath: 'ClaudeFiles\\archives\\americanthinker.com\\2026-03-03_a55bbd666ee7.html', lastCaptured: date('2026-03-03T15:03:47.296968000+00:00'), sourceType: 'unclassified', tags: [], textPreview: 'Many theories exist about the assassination of Charlie Kirk. Some are serious inquiries into the unanswered questions surrounding the lone gunman narrative advanced by Utah authorities and the FBI. Others are more sensational, and while I suspect the real story is more mundane, I don’t discount them entirely. Either way, the public has every right to doubt an official narrative that is missing basic documentation, and to follow the facts wherever they lead.\nI cannot claim to know whether Tyler R', textSize: 6695, title: 'The Security Shortfalls Behind Charlie Kirk\'s Assassination', url: 'https://americanthinker.com/articles/2026/01/the_security_shortfalls_behind_charlie_kirk_s_assassination.html'})
CREATE (n5254:Source {archivePath: 'ClaudeFiles\\archives\\singjupost.com\\2026-03-03_36cf83530cf2_article.txt', archiveStatus: 'captured', author: 'Pangambam S', captureCount: 1, captureMethod: 'http-readability', captureStatus: 'captured', capturedAt: date('2026-03-03T15:07:16.106335000+00:00'), domain: 'singjupost.com', htmlPath: 'ClaudeFiles\\archives\\singjupost.com\\2026-03-03_36cf83530cf2.html', lastCaptured: date('2026-03-03T15:07:16.106335000+00:00'), publishedDate: '2025-11-18T01:27:42+00:00', siteName: 'The Singju Post', sourceType: 'unclassified', tags: [], textPreview: 'Thank you.\nSHAWN RYAN:\nMy pleasure.\nBRIAN HARPOLE:\nI believe in that power of prayer is unbelievable.\nSHAWN RYAN:\nMe too.\nBRIAN HARPOLE:\nI’ve received prayers from people from all over the world and text. And I would tell them they’re heard and felt, and they are. They are.\nSHAWN RYAN:\nGood, man. Well, we got a couple of things to get through. And this seems like, I don’t even want to give this to you, but everybody gets one, so I got to do it.\nBRIAN HARPOLE:\nWhat’s that?\nSHAWN RYAN:\nBut, oh, no', textSize: 125569, title: 'Transcript: Charlie Kirk\'s Security Chief Brian Harpole on Shawn Ryan Show (SRS #254)', url: 'https://singjupost.com/transcript-charlie-kirks-security-chief-brian-harpole-on-shawn-ryan-show-srs-254'})
CREATE (n5255:Source {archivePath: 'ClaudeFiles\\archives\\sltrib.com\\2026-03-03_b4def398388c_article.txt', archiveStatus: 'captured', captureCount: 1, captureMethod: 'http-readability', captureStatus: 'captured', capturedAt: date('2026-03-03T15:07:19.000881000+00:00'), domain: 'sltrib.com', htmlPath: 'ClaudeFiles\\archives\\sltrib.com\\2026-03-03_b4def398388c.html', lastCaptured: date('2026-03-03T15:07:19.000881000+00:00'), siteName: 'The Salt Lake Tribune', sourceType: 'unclassified', tags: [], textPreview: 'Two days before Charlie Kirk was set to speak at\nUtah Valley University\n, the head of his contracted security team texted the school’s police chief. He was worried.\nThe student group that invited Kirk\nhad told Brian Harpole that it was aware some of the campus’ rooftops were easily accessible — and some of those roofs were on buildings that looked down on the open courtyard where Kirk was going to speak. Harpole, who was a police officer before starting his own private security company, knew tha', textSize: 8985, title: 'UVU police chief promised to secure roofs, says Charlie Kirk’s contracted security', url: 'https://sltrib.com/news/education/2025/11/18/uvu-police-chief-promised-secure'})
CREATE (n5256:Source {archivePath: 'ClaudeFiles\\archives\\foxnews.com\\2026-03-03_f5b447cede21_article.txt', archiveStatus: 'captured', captureCount: 1, captureMethod: 'http-readability', captureStatus: 'captured', capturedAt: date('2026-03-03T15:07:21.863137000+00:00'), domain: 'foxnews.com', htmlPath: 'ClaudeFiles\\archives\\foxnews.com\\2026-03-03_f5b447cede21.html', lastCaptured: date('2026-03-03T15:07:21.863137000+00:00'), sourceType: 'primary-journalism', tags: [], textPreview: 'Turning Point USA spokesman Andrew Kolvet discussed jurisdictional security issues following the assassination of Turning Point USA founder Charlie Kirk on Sept. 10. (Credit: X/ Charlie Kirk)\nNEW\nYou can now listen to Fox News articles!\nTwo months after Turning Point USA founder Charlie Kirk\'s assassination at\nUtah Valley University\n, his security director said the tragedy exposed preventable flaws in how the event was coordinated and secured.\nBrian Harpole, a veteran law enforcement officer and', textSize: 6663, title: 'Charlie Kirk\'s assassination exposed flaws at UVU, security chief says', url: 'https://foxnews.com/us/charlie-kirk-security-chief-says-police-promise-cover-rooftops-failed-before-assassination'})
CREATE (n5257:Source {archivePath: 'ClaudeFiles\\archives\\sltrib.com\\2026-03-03_8b74a3c2f16f_article.txt', archiveStatus: 'captured', captureCount: 1, captureMethod: 'http-readability', captureStatus: 'captured', capturedAt: date('2026-03-03T15:09:23.942757000+00:00'), domain: 'sltrib.com', htmlPath: 'ClaudeFiles\\archives\\sltrib.com\\2026-03-03_8b74a3c2f16f.html', lastCaptured: date('2026-03-03T15:09:23.942757000+00:00'), siteName: 'The Salt Lake Tribune', sourceType: 'unclassified', tags: [], textPreview: 'When students at\nUtah Valley University\nasked to host conservative commentator Charlie Kirk on campus, they provided little information to indicate it would be a significant event.\nOn the request form, when asked if there would be any high-profile attendees or controversial topics, the students answered: “None that we are aware of.”\nThey gave no indication that Kirk was a well-known debater who’d previously said everyone should be allowed to say\n“outrageous things.”\nAnd there was no mention that', textSize: 12357, title: 'Turning Point club told UVU it didn\'t expect controversial topics at Kirk event', url: 'https://sltrib.com/news/education/2025/11/18/turning-point-club-told-uvu-it'})
CREATE (n5258:Source {archivePath: 'ClaudeFiles\\archives\\abcnews.com\\2026-03-03_cec8adc27321_article.txt', archiveStatus: 'captured', captureCount: 1, captureMethod: 'http-readability', captureStatus: 'captured', capturedAt: date('2026-03-03T15:09:25.323875000+00:00'), domain: 'abcnews.com', htmlPath: 'ClaudeFiles\\archives\\abcnews.com\\2026-03-03_cec8adc27321.html', lastCaptured: date('2026-03-03T15:09:25.323875000+00:00'), sourceType: 'unclassified', tags: [], textPreview: 'When officials at Utah Valley University approved the plans for Charlie Kirk\'s appearance at the school on Sept. 10 as part of his "American Comeback" tour, they expected roughly 600 people would be there, according to newly released records.\nIn reality, police said more than five times as many people showed up to the event where\nKirk was assassinated\nand the records show that event planners didn\'t think emergency medical services would be necessary.\n"We had probably over 3,000 people who were i', textSize: 7719, title: 'Plans estimated 600 people would come to the event where Charlie Kirk was shot. Over 3,000 showed up', url: 'https://abcnews.com/US/plans-estimated-600-people-event-charlie-kirk-shot/story?id=127610821'})
CREATE (n5259:Source {archivePath: 'ClaudeFiles\\archives\\msbprotection.com\\2026-03-03_3b5fdda8f48c_article.txt', archiveStatus: 'captured', captureCount: 1, captureMethod: 'http-readability', captureStatus: 'captured', capturedAt: date('2026-03-03T15:09:28.093088000+00:00'), domain: 'msbprotection.com', htmlPath: 'ClaudeFiles\\archives\\msbprotection.com\\2026-03-03_3b5fdda8f48c.html', lastCaptured: date('2026-03-03T15:09:28.093088000+00:00'), sourceType: 'unclassified', tags: [], textPreview: 'In the aftermath of the Charlie Kirk assassination at Utah Valley University, much of the public discussion has centered on individual decisions, text messages, and perceived failures between agencies. One name that has repeatedly surfaced is\nJeff Long\n, the chief of police at UVU, following public statements made by members of the private security team assigned to protect Kirk.\nAs emotions rise and narratives harden, it is important to separate\nprofessional responsibility\n,\noperational doctrine', textSize: 9252, title: 'What Went Wrong at UVU: Examining Police Chief Jeff Long’s Role in the Charlie Kirk Security Breakdown', url: 'https://msbprotection.com/blog/details/437/what-went-wrong-at-uvu-examining-police-chief-jeff-longs-role-in-the-charlie-kirk-security-breakdown'})
CREATE (n5260:Organization {addedDate: date('2026-03-03'), description: 'Public university in Orem, Utah. Enrollment ~48,000 (including 16,000 high school students). Largest university in Utah by enrollment. Site of Charlie Kirk assassination Sep 10, 2025. Police force of 23 officers (1 per 1,400 students vs national average 1 per 500). Public safety budget $1.6M in 2020 out of $250M campus budget. President: Astrid Tuminez. Initiated independent third-party security review expected to conclude by summer 2026. Hiring 8 additional officers and 2 security managers post-assassination.', location: 'Orem, Utah', name: 'Utah Valley University', type: 'educational'})
CREATE (n5261:Person {addedDate: date('2026-03-03'), description: 'UVU Police Chief appointed December 2024 (9 months before Kirk assassination). 30+ years law enforcement experience. Joined UVU as deputy chief in 2022. Prior: BYU police lieutenant, 20 years Orem PD. Army and Air Force veteran with two Afghanistan deployments, Bronze Star, Purple Heart. MPA from BYU, BA criminal justice from UVU. On the day of Kirk\'s assassination, Long had 6 officers at the event and reportedly texted Kirk\'s security director Brian Harpole \'I got you covered\' regarding rooftop security — but no officers were posted on rooftops. Said afterward: \'You try to get your bases covered and unfortunately today we didn\'t.\' Val Peterson endorsed his appointment as chief.', name: 'Jeff Long', roles: ['law enforcement', 'campus police chief']})
CREATE (n5262:Person {addedDate: date('2026-03-03'), description: 'UVU Vice President for Administration & Strategic Relations. Also a Republican state lawmaker leading state appropriations. 30+ years at UVU. Oversees public safety. Two former campus public safety leaders said Peterson rejected pleas for more safety resources. Both recalled Peterson saying ~10 years ago that because a shooting had not occurred on campus in decades, it would not happen. Former UVU police Sgt. Bryan Cunningham corroborated. Did not respond to AP requests for comment.', name: 'Val Peterson', roles: ['university administrator', 'state legislator']})
CREATE (n5263:EntryRef {streamEntryId: 'ls-20260303-001', title: 'UVU Security Failure Analysis: How a Promised Rooftop Cover Never Materialized'})
CREATE (n5264:Source {archivePath: 'ClaudeFiles\\archives\\msbprotection.com\\2026-03-03_95f93240aee5_article.txt', archiveStatus: 'captured', captureCount: 1, captureMethod: 'http-readability', captureStatus: 'captured', capturedAt: date('2026-03-03T15:19:12.448507000+00:00'), domain: 'msbprotection.com', htmlPath: 'ClaudeFiles\\archives\\msbprotection.com\\2026-03-03_95f93240aee5.html', lastCaptured: date('2026-03-03T15:19:12.448507000+00:00'), sourceType: 'unclassified', tags: [], textPreview: 'After reviewing the first 30 minutes of the Shawn Ryan interview with Brian Harpole, several issues became immediately apparent—particularly regarding his background, mindset, and approach to protective work.\nIf you’re interested in our evaluation of UVU Police Chief Jeff Long’s role, you can find it here.\nThe problem wasn’t just a bad day or a few tactical mistakes.\nThe problem was a fundamental misunderstanding of what professional protection actually is.\n(Click here for a post that will dive ', textSize: 9276, title: 'Unfit for the Role: Why Brian Harpole Lacked the Experience for Charlie Kirk’s Protection', url: 'https://msbprotection.com/blog/details/282/unfit-for-the-role-why-brian-harpole-lacked-the-experience-for-charlie-kirks-protection'})
CREATE (n5265:Source {archivePath: 'ClaudeFiles\\archives\\msbprotection.com\\2026-03-03_175ce26ac8f6_article.txt', archiveStatus: 'captured', captureCount: 1, captureMethod: 'http-readability', captureStatus: 'captured', capturedAt: date('2026-03-03T15:19:17.648986000+00:00'), domain: 'msbprotection.com', htmlPath: 'ClaudeFiles\\archives\\msbprotection.com\\2026-03-03_175ce26ac8f6.html', lastCaptured: date('2026-03-03T15:19:17.648986000+00:00'), sourceType: 'unclassified', tags: [], textPreview: 'In a city where prestige and privacy go hand in hand, Beverly Hills demands more than a typical security presence — it requires discretion, precision, and a standard of professionalism that matches the caliber of those who call this community home.\nAt\nMSB Protection\n, we don’t just offer bodyguard services — we deliver\nstrategic personal protection\ndesigned for\nultra-high-net-worth individuals, public figures, and their estates\n.\nUp until recently, our firm operated solely on a word-of-mouth bas', textSize: 5476, title: 'Best Bodyguard Service in Beverly Hills - Why MSB Protection Stands Out', url: 'https://msbprotection.com/blog/details/228/best-bodyguard-service-in-beverly-hills-why-msb-protection-stands-out'})
CREATE (n5266:Source {archivePath: 'ClaudeFiles\\archives\\en.wikipedia.org\\2026-03-03_c6b69fcc19ac_article.txt', archiveStatus: 'captured', captureCount: 1, captureMethod: 'http-readability', captureStatus: 'captured', capturedAt: date('2026-03-03T15:19:18.429034000+00:00'), domain: 'en.wikipedia.org', htmlPath: 'ClaudeFiles\\archives\\en.wikipedia.org\\2026-03-03_c6b69fcc19ac.html', lastCaptured: date('2026-03-03T15:19:18.429034000+00:00'), sourceType: 'unclassified', tags: [], textPreview: 'American security specialist and author (born 1954)\nGavin de Becker\n(born October 26, 1954)\n[\n2\n]\nis an American security specialist and author. He has worked for governments, large corporations, and public figures.\n[\n3\n]\nReportedly a billionaire,\n[\n4\n]\n[\n5\n]\n[\n6\n]\nhe runs\nGavin de Becker and Associates\n, which he founded in 1978. The firm protects and advises many of the world\'s most prominent public figures. He is the author of several books, most notably\nThe Gift of Fear\n(1997).\n[\n3\n]\nGavin d', textSize: 18885, title: 'Gavin de Becker - Wikipedia', url: 'https://en.wikipedia.org/wiki/Gavin_de_Becker'})
CREATE (n5267:Source {archivePath: 'ClaudeFiles\\archives\\uvu.edu\\2026-03-03_f13cf474ff9b_article.txt', archiveStatus: 'captured', author: '', captureCount: 1, captureMethod: 'http-readability', captureStatus: 'captured', capturedAt: date('2026-03-03T15:20:39.398232000+00:00'), domain: 'uvu.edu', htmlPath: 'ClaudeFiles\\archives\\uvu.edu\\2026-03-03_f13cf474ff9b.html', lastCaptured: date('2026-03-03T15:20:39.398232000+00:00'), sourceType: 'unclassified', tags: [], textPreview: 'There was a police presence on UVU West Campus yesterday afternoon.\nA woman in the National Guard Building called the UVU police dispatch, threatened\nself-harm, claimed to have a gun, and asked for help. UVU police officers responded\nimmediately and contained the person while simultaneously evacuating the building.\nNo gun was involved, and the individual was taken into custody.\nWe know such incidences can cause concern. If you need additional support, please\ncontact\nStudent Health Services\nat 80', textSize: 863, title: 'A Letter From Chief Matt Pedersen', url: 'https://uvu.edu/news/2023/09/2023_09_07_campus_incident.html'})
CREATE (n5268:Source {archivePath: 'ClaudeFiles\\archives\\uvu.edu\\2026-03-03_c782eb31132d_article.txt', archiveStatus: 'captured', author: '', captureCount: 1, captureMethod: 'http-readability', captureStatus: 'captured', capturedAt: date('2026-03-03T15:21:03.788018000+00:00'), domain: 'uvu.edu', htmlPath: 'ClaudeFiles\\archives\\uvu.edu\\2026-03-03_c782eb31132d.html', lastCaptured: date('2026-03-03T15:21:03.788018000+00:00'), sourceType: 'unclassified', tags: [], textPreview: 'Utah Valley University (UVU) announced that Jeffrey Long, a military veteran and law\nenforcement professional, has been appointed as the university’s new chief of police.\nWith over 30 years of experience in law enforcement and public safety, Long has a\nstrong record of leadership and service. He joined UVU in 2022 as deputy chief of\npolice, where he has played a key role in maintaining campus safety, managing officer\ntraining, and collaborating with local, state, and federal law enforcement agen', textSize: 1823, title: 'Utah Valley University Appoints New Chief of Police, Bringing Dedication to Campus Safety', url: 'https://uvu.edu/news/2024/12/uvu-chief-of-police-jeffrey-long-2024.html'})
CREATE (n5269:Source {archivePath: 'ClaudeFiles\\archives\\fox13now.com\\2026-03-03_3525db6dfb64_article.txt', archiveStatus: 'captured', author: 'https://www.fox13now.com/nate-carlisle', captureCount: 1, captureMethod: 'http-readability', captureStatus: 'captured', capturedAt: date('2026-03-03T15:21:40.253628000+00:00'), domain: 'fox13now.com', htmlPath: 'ClaudeFiles\\archives\\fox13now.com\\2026-03-03_3525db6dfb64.html', lastCaptured: date('2026-03-03T15:21:40.253628000+00:00'), publishedDate: '2025-09-11T22:15:09.268', siteName: 'FOX 13 News Utah (KSTU)', sourceType: 'unclassified', tags: [], textPreview: 'DRAPER, Utah — Bryan Cunningham remembers being in a meeting talking about the threat of an active shooter on the campus of Utah Valley University.\n“We begged,” Cunningham recalled. “We begged when I was there. This is going to be an active shooter situation nightmare if you don’t give us more officers.\n“Give us more resources. Help us put together a plan. And it just was not done.”\nOne of the other people in the meeting – Val Peterson, UVU’s vice president of administration and a member of the ', textSize: 3496, title: 'Years before Kirk shooting, concerns about security at Utah Valley University', url: 'https://fox13now.com/news/fox-13-investigates/years-before-kirk-shooting-concerns-about-security-at-utah-valley-university'})
CREATE (n5270:Source {archivePath: 'ClaudeFiles\\archives\\sltrib.com\\2026-03-03_8e96c111918c_article.txt', archiveStatus: 'captured', captureCount: 1, captureMethod: 'http-readability', captureStatus: 'captured', capturedAt: date('2026-03-03T15:21:42.714245000+00:00'), domain: 'sltrib.com', htmlPath: 'ClaudeFiles\\archives\\sltrib.com\\2026-03-03_8e96c111918c.html', lastCaptured: date('2026-03-03T15:21:42.714245000+00:00'), siteName: 'The Salt Lake Tribune', sourceType: 'unclassified', tags: [], textPreview: 'Utah Valley University is looking to hire eight new police officers, a sizable expansion to its relatively small force after\nCharlie Kirk’s killing\nignited concerns about the school’s limited campus security.\nThe extra officers would grow the school’s police force staffing by about 36% — but safety experts say it’s not enough.\nThe school\ndeclined to confirm how many officers it currently employs. But\nUtah salary data\nshows 22 people listed as campus officers this year, not counting police admini', textSize: 10782, title: 'UVU wants to hire more campus police after Charlie Kirk\'s killing', url: 'https://sltrib.com/news/education/2025/11/05/uvu-wants-hire-more-campus-police'})
CREATE (n5271:Person {addedDate: date('2026-03-03'), description: 'Former police special unit operator, former manager at Gavin de Becker & Associates, and CEO of MSB Protection. Published professional analysis of UVU security failure distinguishing police responsibility (campus access control) from protection team responsibility (principal\'s life safety). Argued Jeff Long\'s failure was limited to rooftop access control, while the protection team bore responsibility for Kirk\'s survivability. Leading expert in executive protection and residential security in Beverly Hills and southern California.', ghostCohort: false, name: 'Michael Braun'})
CREATE (n5272:Organization {addedDate: date('2026-03-03'), description: 'Executive protection and residential security firm based in Beverly Hills, California. Founded by Michael Braun (former Gavin de Becker & Associates manager). Published detailed professional analyses of the Charlie Kirk assassination security failures, including critiques of both UVU police chief Jeff Long\'s role and Kirk\'s security director Brian Harpole\'s qualifications. Specializes in close protection doctrine, threat assessment, and security auditing.', name: 'MSB Protection', orgType: 'security'})
CREATE (n5273:Organization {addedDate: date('2026-03-03'), description: 'Prominent threat assessment and protective intelligence firm founded in 1978 by Gavin de Becker. Pioneered MOSAIC threat assessment system used by U.S. Marshals, Supreme Court Police, and CIA. Celebrity and high-profile clients. Michael Braun (now CEO of MSB Protection) was formerly a manager at the firm. De Becker authored The Gift of Fear (1997). The firm represents a gold standard in executive protection methodology.', name: 'Gavin de Becker and Associates', orgType: 'security'})
CREATE (n5274:Person {addedDate: date('2026-03-03'), description: 'Former UVU police sergeant who left the department in 2018. Publicly recalled begging university leadership for more officers and active shooter planning resources years before the Kirk assassination. Described a meeting where VP Val Peterson dismissed concerns saying \'It\'s been 25 years. We haven\'t had one and we\'re not going to have one.\' Cunningham replied \'It\'s not if. It\'s when.\' Contrasted the Kirk event security with the 2017 Love Loud concert (Imagine Dragons) at UVU which had a proper command center, SWAT, Utah County sheriffs, Orem PD, medical personnel, and emergency management trailer.', name: 'Bryan Cunningham'})
CREATE (n5275:EntryRef {streamEntryId: 'ls-20260303-002', title: 'Professional Critique and Institutional History: The Deeper Story Behind UVU\'s Security Posture'})

