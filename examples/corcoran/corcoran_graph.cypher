CREATE (n5237:Source {archivePath: 'ClaudeFiles\\archives\\ecorp.azcc.gov\\2026-03-03_a8dec4a0c7fa_article.txt', archiveStatus: 'captured', captureCount: 1, captureMethod: 'nodriver', captureStatus: 'captured', capturedAt: date('2026-03-03T02:41:38.866109000+00:00'), domain: 'ecorp.azcc.gov', htmlPath: 'ClaudeFiles\\archives\\ecorp.azcc.gov\\2026-03-03_a8dec4a0c7fa.html', lastCaptured: date('2026-03-03T02:41:38.866109000+00:00'), sourceType: 'unclassified', tags: [], textPreview: 'Arizona Business Center\nTranslate\nOnline Services Login\nBack to Home\nArizona Business Center\nOnline filings as easy as A, B, C!\n\nArizona Business Center is your online solution to starting and maintaining your Arizona business. Take advantage of a free online account to access dozens of online filing flows, information bubbles, help text, interactive status updates, 24-hour chatbot, increased security measures, and much more.\n\nDon\'t have an account?\nRegister Here\nARIZONA CORPORATION COMMISSION\nL', textSize: 659, title: 'Arizona | Corporation Commission', url: 'https://ecorp.azcc.gov/BusinessSearch/BusinessInfo?entityNumber=1938928'})
CREATE (n5238:Source {archivePath: 'ClaudeFiles\\archives\\influencewatch.org\\2026-03-03_de1cdbb16491_article.txt', archiveStatus: 'captured', captureCount: 1, captureMethod: 'http-readability', captureStatus: 'captured', capturedAt: date('2026-03-03T02:44:33.404918000+00:00'), domain: 'influencewatch.org', htmlPath: 'ClaudeFiles\\archives\\influencewatch.org\\2026-03-03_de1cdbb16491.html', lastCaptured: date('2026-03-03T02:44:33.404918000+00:00'), siteName: 'InfluenceWatch', sourceType: 'advocacy-research', tags: [], textPreview: 'Turning Point USA (TPUSA) is an ostensibly student-based right-of-center organizing and advocacy group which claims to have a presence on over 3,500 college and high school campuses, though its figures have been previously disputed.  The organization particularly focuses on culture-war issues and has attracted much controversy on college campuses.\nTPUSA primarily organizes events on college campuses to promote right-of-center policies and cultural values. The organization has challenged speech r', textSize: 11157, title: 'Turning Point USA', url: 'https://influencewatch.org/non-profit/turning-point-usa'})
CREATE (n5239:Person {addedDate: date('2026-03-03'), altNames: ['Larry Guinta', 'Lawrence R. Guinta Jr.'], description: 'Co-inventor with Lori Frantzve on 7 US patents (1994-2010) for organizational assessment software. Previously married to Lori (public records list \'Lori Ann Guinta\' as an alias). Co-founded Tech-Metrics International Inc. in Scottsdale, AZ. Email: [email redacted]. Currently associated with AZ-Tech International Inc. Age ~74, lives in Scottsdale, AZ.', lastVerified: '2026-03-03', name: 'Lawrence R. Guinta', provenanceTier: 'archived', residence: 'Scottsdale, Arizona', roles: ['Inventor', 'Businessman']})
CREATE (n5240:Organization {addedDate: date('2026-03-03'), description: 'Patent-holding company in Scottsdale, AZ. Assignee on early Frantzve-Guinta patents (US5737494, US6092060, US6161101) filed 1994-1998. Developed VIRTUAL ASSESSOR (formerly MAXUS/MAXSYS) software for organizational process assessment. Predecessor entity to IMET Laboratories/Intellimet and AZ-Tech International ecosystem. Co-founded by Lawrence R. Guinta and Lori Frantzve.', lastVerified: '2026-03-03', location: 'Scottsdale, AZ', name: 'Tech-Metrics International Inc', provenanceTier: 'archived', type: 'defense-consulting'})
