CREATE (n4578)-[:SUPPORTED_BY {claim: 'Kirk relocated TPUSA from Chicago suburbs to Phoenix in 2018; was 10th biggest superspreader of 2020 election misinformation per EIP; encouraged followers to attend Jan 6 rally', confidence: 'archived-verified', createdAt: date('2026-02-27T14:19:17.163000000+00:00')}]->(n4885)
CREATE (n4579)-[:SUPPORTED_BY {claim: 'Erika Frantzve was a 23-year-old ASU senior majoring in political science when she won Miss Arizona USA', confidence: 'archived-verified', createdAt: date('2026-02-27T14:19:03.845000000+00:00')}]->(n4856)
CREATE (n4601)-[:SUPPORTED_BY {claim: 'Robert Kirk was an architect and major contributor to Mitt Romney\'s 2012 presidential campaign', confidence: 'archived-verified', createdAt: date('2026-02-26T03:33:38.820000000+00:00')}]->(n4692)
CREATE (n4604)-[:SUPPORTED_BY {claim: 'Lawrence R. Guinta co-inventor on all 7 Frantzve patents; first patent filed Dec 1994 assigned to Tech-Metrics International', confidence: 'archived-verified', createdAt: date('2026-02-26T04:06:25.540000000+00:00'), upgradedAt: date('2026-02-26T16:18:10.115000000+00:00')}]->(n4796)
CREATE (n4611)-[:SUPPORTED_BY {claim: 'Erika Frantzve earned master\'s in legal studies from Liberty University 2017.', confidence: 'archived-verified', createdAt: date('2026-02-25T23:06:45.363000000+00:00')}]->(n4692)
CREATE (n4615)-[:SUPPORTED_BY {claim: 'Kirk was 18 when he founded TPUSA. Kirk was supported by his father who reportedly came up with the name Turning Point. Kirk admitted starting with \'no money, no connections.\' Conservative counterpoint to MoveOn.org.', confidence: 'archived-verified', createdAt: date('2026-02-25T23:09:23.416000000+00:00')}]->(n4692)
CREATE (n4688)-[:SUPPORTED_BY {claim: 'ATK Media Inc. is a California corporation (filing C3963322)', confidence: 'archived-verified', createdAt: date('2026-02-25T06:49:46.283000000+00:00'), upgradedAt: date('2026-02-26T16:18:10.115000000+00:00')}]->(n4684)
CREATE (n4698)-[:SUPPORTED_BY {claim: 'Confirmed as \'national field director\' of TPUSA. Reported registering 1,030 voters in Florida in April 2015 (30 more than goal).', confidence: 'archived-verified', upgradedAt: date('2026-02-26T16:18:16.548000000+00:00')}]->(n4722)
CREATE (n4699)-[:SUPPORTED_BY {claim: 'Erika Kirk called on former Turning Point employee and right-wing podcaster Candace Owens to stop spreading conspiracy theories about Kirk\'s death in December 2025.', confidence: 'archived-verified', createdAt: date('2026-02-25T23:06:05.747000000+00:00')}]->(n4692)
CREATE (n4701)-[:SUPPORTED_BY {claim: 'From October 2020 until his assassination, Kirk hosted The Charlie Kirk Show, a daily three-hour radio talk show, on Salem Media Group\'s \'The Answer\' radio channel. According to TPUSA internal data, downloaded 500-750K times daily in 2024.', confidence: 'archived-verified', createdAt: date('2026-02-25T23:06:36.924000000+00:00')}]->(n4690)
CREATE (n4702)-[:SUPPORTED_BY {claim: 'Kirk was the William F. Buckley Jr. council member of the Council for National Policy. Listed in September 2020 membership directory leaked February 2021. Spokesperson for CNP Action.', confidence: 'archived-verified', createdAt: date('2026-02-25T23:06:50.630000000+00:00')}]->(n4690)
CREATE (n4704)-[:SUPPORTED_BY {claim: 'Montgomery and Kirk met, and Kirk outlined his vision. Montgomery encouraged Kirk to skip college and instead launch a political movement.', confidence: 'archived-verified', createdAt: date('2026-02-25T23:07:53.537000000+00:00')}]->(n4692)
CREATE (n4705)-[:SUPPORTED_BY {claim: 'When Kirk attended the 2012 GOP convention, he left with support from a key Republican donor. He also drew the attention of the Trump family, especially Donald Trump Jr., who hired him to work on social media.', confidence: 'archived-verified', createdAt: date('2026-02-25T23:08:01.503000000+00:00')}]->(n4692)
CREATE (n4706)-[:SUPPORTED_BY {claim: 'Kirk flipped to supporting Trump at the convention and spent the remainder of the campaign assisting with travel and media arrangements for Donald Trump Jr.', confidence: 'archived-verified', createdAt: date('2026-02-25T23:08:07.380000000+00:00')}]->(n4690)
CREATE (n4710)-[:SUPPORTED_BY {claim: 'In May 2021, Kirk married Erika Kirk (née Frantzve). Daughter born August 2022, son born May 2024.', confidence: 'archived-verified', createdAt: date('2026-02-25T23:08:40.152000000+00:00')}]->(n4690)
CREATE (n4712)-[:SUPPORTED_BY {claim: 'Kirk arranged a Stop the Steal rally in Arizona and sent buses of protesters to the January 6, 2021, storming of the U.S. Capitol.', confidence: 'archived-verified', createdAt: date('2026-02-25T23:09:04.515000000+00:00')}]->(n4692)
CREATE (n4713)-[:SUPPORTED_BY {claim: 'On October 14, 2025, which would have been Kirk\'s 32nd birthday, Trump awarded him the Presidential Medal of Freedom. Erika Kirk said her husband probably would have run for president at some point.', confidence: 'archived-verified', createdAt: date('2026-02-25T23:09:09.991000000+00:00')}]->(n4692)
CREATE (n4756)-[:SUPPORTED_BY {claim: 'Ginni Thomas\'s political firm where Clanton worked as project manager after TPUSA departure', confidence: 'archived-verified', createdAt: date('2026-02-26T03:32:46.186000000+00:00')}]->(n4748)
CREATE (n4758)-[:SUPPORTED_BY {claim: 'SOS Liberty was the forerunner to TPUSA, eventually ditching the name to form Turning Point USA, registered July 23 2012', confidence: 'archived-verified', createdAt: date('2026-02-26T03:32:55.601000000+00:00')}]->(n4750)
CREATE (n4775)-[:SUPPORTED_BY {claim: 'By Kirk\'s assassination TPUSA had raised $389M, presence at ~900 college and 1,200 high school campuses.', confidence: 'archived-verified', createdAt: date('2026-02-26T03:41:09.803000000+00:00')}]->(n4745)
CREATE (n4778)-[:SUPPORTED_BY {claim: 'Founded by David Lane, holds free conferences for ministers to encourage running for office. McCoy used as example. Lane has attended McCoy\'s church.', confidence: 'archived-verified', createdAt: date('2026-02-26T03:41:27.068000000+00:00')}]->(n4750)
CREATE (n4790)-[:SUPPORTED_BY {claim: 'Kent Frantzve founded CKF Group LLC, a private investment firm', confidence: 'archived-verified', createdAt: date('2026-02-26T03:54:18.538000000+00:00')}]->(n4788)
CREATE (n4791)-[:SUPPORTED_BY {claim: '', confidence: 'archived-verified', createdAt: date('2026-03-01T01:45:49.079000000+00:00')}]->(n4833)
CREATE (n4795)-[:SUPPORTED_BY {claim: '', confidence: 'archived-verified', createdAt: date('2026-03-02T05:11:12.013000000+00:00')}]->(n5145)
CREATE (n4797)-[:SUPPORTED_BY {claim: 'Geneastar lists Lori Abbas parents as Joseph Anthony Abbas (Syrian/Lebanese) and Angeline Maria Carresscia (Italian)', confidence: 'archived-verified', createdAt: date('2026-02-26T04:07:05.944000000+00:00')}]->(n4793)
CREATE (n4841)-[:SUPPORTED_BY {claim: 'E3TEKG contracts with Northrop, DoD, Homeland Security; won 2014 medal for Operation Enduring Freedom and Iraqi Freedom; website provides zero other info — no team, no board, no news releases', confidence: 'archived-verified', createdAt: date('2026-02-26T04:06:53.934000000+00:00')}]->(n4794)
CREATE (n4854)-[:SUPPORTED_BY {claim: 'Delaware corp, $25M authorized offering, $250K sold, principal place: Anthem AZ. Jan 2021 SEC Form D.', confidence: 'archived-verified', createdAt: date('2026-02-27T06:29:40.495000000+00:00')}]->(n4606)
