CREATE (n5216:Source {archivePath: 'ClaudeFiles\\archives\\goodreads.com\\2026-03-02_2ba77344e28f_article.txt', archiveStatus: 'captured', captureCount: 1, captureMethod: 'nodriver', captureStatus: 'captured', capturedAt: date('2026-03-02T23:19:00.399062000+00:00'), domain: 'goodreads.com', htmlPath: 'ClaudeFiles\\archives\\goodreads.com\\2026-03-02_2ba77344e28f.html', lastCaptured: date('2026-03-02T23:19:00.399062000+00:00'), sourceType: 'unclassified', tags: [], textPreview: ',\nSign up\nMy Books\nBrowse ▾\nCommunity ▾\n\n\n\nKENT R FRANTZVE’S FOLLOWERS\nNone yet.\nKent R Frantzve\n\n\nedit data\n\n\nCombine Editions\nKENT R FRANTZVE’S BOOKS\nAverage rating: 0.0 · 0 ratings · 0 reviews · 1 distinct work\n	The desktop business intelligence sourcebook: A comprehensive guidebook for the information age\n\n 0.00 avg rating — 0 ratings\n	\nWant to Read\nRate this book\n1 of 5 stars\n2 of 5 stars\n3 of 5 stars\n4 of 5 stars\n5 of 5 stars\n\n* Note: these are all the books on Goodreads for this author. T', textSize: 781, title: 'Kent R Frantzve (Author of The desktop business intelligence sourcebook)', url: 'https://goodreads.com/author/show/57196751.Kent_R_Frantzve'})
