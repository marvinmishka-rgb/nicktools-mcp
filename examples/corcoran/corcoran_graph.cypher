CREATE (n4618:Event {addedDate: date('2026-02-25'), date: '2025-09-18', description: 'Eight days after Charlie Kirk\'s assassination, the TPUSA board unanimously elected Erika Kirk as CEO and board chair. Board members revealed Charlie had previously prepared this succession plan. Salary approximately $286,000/year.', name: 'Erika Kirk Appointed TPUSA CEO', source: 'ls-20260224-022', type: 'organizational'})
