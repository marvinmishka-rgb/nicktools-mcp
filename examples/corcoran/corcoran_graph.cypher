CREATE (n4853:Event {addedDate: date('2026-02-27'), date: '2018-08-10', description: 'Ribbon-cutting ceremony for TPUSA\'s new Phoenix headquarters. Gov. Doug Ducey attended with Charlie Kirk and Candace Owens. Approximately 30 staff. Erika Frantzve met Charlie Kirk at this event. Ducey: \'This headquarters belongs in the state of Arizona.\'', location: 'Phoenix, AZ', name: 'TPUSA Phoenix HQ Opening'})
CREATE (n4854:Organization {addedDate: date('2026-02-27'), appCount: 20, clientTypes: 'State GOP parties, conservative PACs, conservative media, local community orgs, ballot-chasing operations', description: 'Mobile app platform marketed to conservative groups for political outreach and digital news. Powers apps for TPUSA, TP Action, Republican state parties (AZ, GA, WI, CO), and MAGA influencers. Founded by Floyd and Patrick Brown (Western Journal), later run by Jeff DeWit as CEO. Board includes Tyler Bowyer (chairman), Charlie Kirk\'s mother-in-law, Wayne Newkumet, Lori Klein Corbin. Had AZ business license revoked Dec 2021 while still operating during 2022 campaigns.', formerName: 'FeedMe Inc.', incorporatedIn: 'Delaware', incorporatedYear: '2018', laterAddress: '3219 E Camelback Rd #411, Phoenix AZ 85018', name: 'Superfeed Technologies Inc', orgType: 'tech-company', originalAddress: '41810 N Venture Dr, Building F, Anthem AZ 85086', salesCompensation: '$1.5M estimated to Brown, Gibbons, Lang & Company Securities Inc', secFormD: 'Jan 2021, $25M authorized, $250K sold to Michael Gibbons', securityConcerns: 'GOP insiders flagged minimal protections for voter personal data. App does not share data with Data Trust (GOP main data repository).', type: 'political-tech', website: 'https://superfeedtech.com'})
