CREATE (n4546)-[:SUPPORTED_BY {claim: 'Named as defendant in Roumila harassment lawsuit. Declined to comment on allegations.', confidence: 'archived-verified', sourceUrl: 'https://therealdeal.com/new-york/2019/01/02/broker-claims-christies-international-real-estate-fired-him-after-he-complained-about-sexual-harassment'}]->(n4819)
CREATE (n4718)-[:SUPPORTED_BY {claim: 'Hull was Creative Director at TPUSA. Montgomery \'would set aside time each day to talk to me on the phone.\' Montgomery \'literally changed hundreds of people\'s lives and launched too many careers and businesses to count.\'', confidence: 'archived-verified', sourceUrl: 'https://wikibious.com/bill-montgomery'}]->(n4828)
CREATE (n4718)-[:SUPPORTED_BY {claim: 'Hull described as \'former creative director at TPUSA.\' Montgomerys \'basically adopted me into their family.\' Montgomery \'launched my career and was with me every step of the way.\'', confidence: 'archived-verified', sourceUrl: 'https://primalinformation.com/bill-montgomery-wiki-wife-net-worth'}]->(n4829)
CREATE (n4572)-[:SUPPORTED_BY {claim: 'TPUSA had $8M+ annual budget by 2017. Campus Victory Project aimed to commandeer student government at 300+ Division 1 schools ($2.2M plan). Fossil fuel industry donors. Multiple former employees testified to illegal 501(c)(3) campaign coordination with Cruz and Rubio campaigns in 2016.', confidence: 'archived-verified', sourceUrl: 'https://newyorker.com/news/news-desk/a-conservative-nonprofit-that-seeks-to-transform-college-campuses-faces-allegations-of-racial-bias-and-illegal-campaign-activity'}]->(n4830)
CREATE (n4739)-[:SUPPORTED_BY {claim: '7th-generation Arizonan. Served as Republican Precinct Committeeman, Congressional Advisory Chairman, Regent, Republican County Chairman of largest GOP county, AZ RNC National Committeeman. Primary organizer of first Trump Rally July 2015. Joined TPUSA 2015, became COO. Also COO of TP Action since 2019. Resides in Mesa with wife Lauren and kids Brooks, Nell, Quincy.', confidence: 'archived-verified', createdAt: date('2026-02-28T02:52:59.810000000+00:00')}]->(n4840)
