CREATE (n5222:Source {archivePath: 'ClaudeFiles\\archives\\projects.propublica.org\\2026-03-02_47b411d3af50_article.txt', archiveStatus: 'captured', author: 'Andrea Suozzo, Alec Glassford, Ash Ngu, Brandon Roberts', captureCount: 1, captureMethod: 'http-readability', captureStatus: 'captured', capturedAt: date('2026-03-02T23:33:05.209392000+00:00'), domain: 'projects.propublica.org', htmlPath: 'ClaudeFiles\\archives\\projects.propublica.org\\2026-03-02_47b411d3af50.html', lastCaptured: date('2026-03-02T23:33:05.209392000+00:00'), publishedDate: '2013-05-09', siteName: 'ProPublica', sourceType: 'unclassified', tags: [], textPreview: 'Nonprofit Explorer includes summary data for nonprofit tax returns and\nfull Form 990 documents, in both PDF and digital formats.\nThe summary data contains information processed by the IRS during the\n2012-2019 calendar years; this generally consists of filings for the\n2011-2018 fiscal years, but may include older records. This data release\nincludes only a subset of what can be found in the full Form 990s.\nIn addition to the raw summary data, we link to PDFs and digital copies\nof full Form 990 doc', textSize: 851, title: 'Turning Point Usa Inc', url: 'https://projects.propublica.org/nonprofits/display_990/800835023/05_2021_prefixes_80-81/800835023_202006_990_[phone redacted]152764'})
CREATE (n5223:Source {archivePath: 'ClaudeFiles\\archives\\tpusa.com\\2026-03-02_af7b5c6937f0_article.txt', archiveStatus: 'captured', captureCount: 1, captureMethod: 'http-readability', captureStatus: 'captured', capturedAt: date('2026-03-02T23:33:39.242402000+00:00'), domain: 'tpusa.com', htmlPath: 'ClaudeFiles\\archives\\tpusa.com\\2026-03-02_af7b5c6937f0.html', lastCaptured: date('2026-03-02T23:33:39.242402000+00:00'), siteName: 'Team - TPUSA', sourceType: 'unclassified', tags: [], textPreview: 'Advisory Council Member\nMichele (Mica) Mosbacher, widow of the 28th U.S. Secretary of Commerce and oilman Robert Mosbacher, Sr., was commissioned as an Honorary Consul of Iceland, Houston and Central Texas, in 2010 by the Foreign Ministry of Iceland. She is an author, motivational speaker and proud sponsor of Godstone Ranch Motorsports, a family professional motorsports team that races for charitable causes.\nShe has served  on the boards of the Houston Ballet, University of Houston; and was appo', textSize: 3025, title: 'Team - TPUSA :TPUSA', url: 'https://tpusa.com/governance'})
CREATE (n5224:Source {archivePath: 'ClaudeFiles\\archives\\tpoint.org\\2026-03-02_f390aedb4ed7_article.txt', archiveStatus: 'captured', captureCount: 1, captureMethod: 'http-readability', captureStatus: 'captured', capturedAt: date('2026-03-02T23:35:43.221347000+00:00'), domain: 'tpoint.org', htmlPath: 'ClaudeFiles\\archives\\tpoint.org\\2026-03-02_f390aedb4ed7.html', lastCaptured: date('2026-03-02T23:35:43.221347000+00:00'), siteName: 'Turning Point Site', sourceType: 'unclassified', tags: [], textPreview: 'Brian J. Clarke, JD\nTreasurer\nBrian Clarke is a versatile business executive with expertise in all areas of corporate, legal and administrative affairs. He specializes in businesses undergoing major transitions, including mergers and acquisitions, business integration, strategic planning, litigation management, corporate governance and more. He currently serves as senior vice president and chief purpose officer, responsible for ESG initiatives at Veolia North America, where he previously served ', textSize: 701, title: 'Board of Directors', url: 'https://tpoint.org/about/board-of-directors'})
CREATE (n5225:Source {archivePath: 'ClaudeFiles\\archives\\baptistnews.com\\2026-03-02_5f644fe04244_article.txt', archiveStatus: 'captured', author: 'Steve Rabey and Mark Wingfield', captureCount: 1, captureMethod: 'http-readability', captureStatus: 'captured', capturedAt: date('2026-03-02T23:36:53.616102000+00:00'), domain: 'baptistnews.com', htmlPath: 'ClaudeFiles\\archives\\baptistnews.com\\2026-03-02_5f644fe04244.html', lastCaptured: date('2026-03-02T23:36:53.616102000+00:00'), publishedDate: '2025-09-19T14:53:53+00:00', siteName: 'Baptist News Global', sourceType: 'unclassified', tags: [], textPreview: 'Charlie Kirk’s widow will take over leadership\nof Turning Point USA, the organization said Sept. 18.\nErika Kirk will serve as CEO and chair the group’s board of directors. An\nannouncement\nfrom the board said Charlie Kirk had said he wanted his wife to take over in the event of his death. The vote was unanimous.\nThat letter listed four board members: Doug De Groote, a financial planner in Thousand Oaks, Calif.; Mike Miller, a jeweler in Barrington, Ill.; Tom Sodeika, owner of a payroll management', textSize: 5132, title: 'Erika Kirk will lead Turning Point USA, Sunday memorial planned', url: 'https://baptistnews.com/article/erika-kirk-will-lead-turning-point-usa-sunday-memorial-planned'})
CREATE (n5226:Source {archivePath: 'ClaudeFiles\\archives\\factually.co\\2026-03-02_656586d27651_article.txt', archiveStatus: 'captured', captureCount: 1, captureMethod: 'nodriver', captureStatus: 'captured', capturedAt: date('2026-03-02T23:37:12.732318000+00:00'), domain: 'factually.co', htmlPath: 'ClaudeFiles\\archives\\factually.co\\2026-03-02_656586d27651.html', lastCaptured: date('2026-03-02T23:37:12.732318000+00:00'), siteName: 'Factually', sourceType: 'ai-generated', tags: [], textPreview: '1. Maiden name and basic biographical facts: clear, consistent reporting\nEvery major profile in the provided results lists her birth name as Erika Lane Frantzve (commonly shortened in coverage to Erika Frantzve) and notes she now goes by Erika Kirk after marrying Charlie Kirk in 2021; sources include encyclopedia-style entries and news outlets that repeat the same surname and given names\n[1]\n[4]\n[2]\n.\n2. Family background as described in mainstream profiles\nProfiles say she was born in Ohio on N', textSize: 4272, title: 'What is Erica Kirk\'s maiden name and family background', url: 'https://factually.co/fact-checks/media/erica-kirk-maiden-name-family-background-75cac8'})
CREATE (n5227:Source {archivePath: 'ClaudeFiles\\archives\\famousbirthdays.com\\2026-03-02_e6e6e3394fdd_article.txt', archiveStatus: 'captured', captureCount: 1, captureMethod: 'http-readability', captureStatus: 'captured', capturedAt: date('2026-03-02T23:37:15.466413000+00:00'), domain: 'famousbirthdays.com', htmlPath: 'ClaudeFiles\\archives\\famousbirthdays.com\\2026-03-02_e6e6e3394fdd.html', lastCaptured: date('2026-03-02T23:37:15.466413000+00:00'), siteName: 'Famous Birthdays', sourceType: 'unclassified', tags: [], textPreview: 'About\nHost of Midweek Rise Up, which is a Podcast designed to be a weekly spiritual refresher. The podcast also publishes Monday Meditations, which is a weekly, shorter episode. She became CEO of Turning Point USA in September of 2025.\nBefore fame\nShe graduated from\nArizona State University\nin 2012.\nTrivia\nShe won the Miss Arizona USA beauty pageant in 2012.  She is known as mrserikakirk on Instagram, where she has accumulated over 6 million followers. Her husband was tragically assassinated in ', textSize: 843, title: 'Erika Kirk - Age, Bio, Family', url: 'https://famousbirthdays.com/people/erika-frantzve.html'})
CREATE (n5228:Source {archivePath: 'ClaudeFiles\\archives\\thedailyguardian.com\\2026-03-02_2cffb4fb5eb6_article.txt', archiveStatus: 'captured', author: 'Khushi Kumari', captureCount: 1, captureMethod: 'http-readability', captureStatus: 'captured', capturedAt: date('2026-03-02T23:39:14.270355000+00:00'), domain: 'thedailyguardian.com', htmlPath: 'ClaudeFiles\\archives\\thedailyguardian.com\\2026-03-02_2cffb4fb5eb6.html', lastCaptured: date('2026-03-02T23:39:14.270355000+00:00'), publishedDate: '2025-09-25T03:39:26+00:00', siteName: 'The Daily Guardian', sourceType: 'unclassified', tags: [], textPreview: '3.4K\nErika Kirk is also in the limelight after assuming the role of new CEO of Turning Point USA, succeeding her husband\nCharlie Kirk’s\nassassination. Kirk, 31, and founder of Turning Point USA, was shot dead when he was at an event held at Utah Valley University on September 10, 2025.\nSince Erika’s promotion to the top spot as CEO, a number of rumors have surrounded the 36-year-old lady. One stated she was a casting director for\nDonald Trump\n‘s Miss USA beauty pageants. Another stated that Erik', textSize: 2407, title: 'Who Is Carl Kenneth Frantzve? Tracing the Roots of TPUSA’s New CEO Erika kirk', url: 'https://thedailyguardian.com/world/us/who-is-carl-kenneth-frantzve-tracing-the-roots-of-tpusas-new-ceo-erika-kirk-664040'})
CREATE (n5229:Source {archivePath: 'ClaudeFiles\\archives\\iovikings.org\\2026-03-02_6d7d57121063_article.txt', archiveStatus: 'captured', captureCount: 1, captureMethod: 'http-readability', captureStatus: 'captured', capturedAt: date('2026-03-02T23:39:16.977765000+00:00'), domain: 'iovikings.org', htmlPath: 'ClaudeFiles\\archives\\iovikings.org\\2026-03-02_6d7d57121063.html', lastCaptured: date('2026-03-02T23:39:16.977765000+00:00'), publishedDate: '2019-07-25T20:46:52+00:00', siteName: 'Independent Order of Vikings', sourceType: 'unclassified', tags: [], textPreview: 'Independent Order of Vikings is a registered fraternal membership-based organization, led by an Executive Council elected by lodge delegates at the biannual convention.\nThe Executive Council and lodge delegates (elected by local subordinate lodge membership) comprise the Grand Lodge, which serves as the primary decision-making body for the organization. The Grand Lodge meets every two years during Convention. The Executive Council meets 4 times per year, with designated committees meeting monthl', textSize: 1433, title: 'Independent Order of Vikings', url: 'https://iovikings.org/leadership-administration-2'})
CREATE (n5230:EntryRef {streamEntryId: 'ls-20260302-007', title: 'Kent Frantzve TPUSA Board Claim Debunked: Connection Is Through Daughter Erika Kirk'})
CREATE (n5231:Source {archivePath: 'ClaudeFiles\\archives\\sonorannews.com\\2026-03-03_fbe3e928e863_article.txt', archiveStatus: 'captured', captureCount: 1, captureMethod: 'wayback', captureStatus: 'captured', capturedAt: date('2026-03-03T01:59:59.136491000+00:00'), domain: 'sonorannews.com', htmlPath: 'ClaudeFiles\\archives\\sonorannews.com\\2026-03-03_fbe3e928e863.html', lastCaptured: date('2026-03-03T01:59:59.136491000+00:00'), sourceType: 'unclassified', tags: [], textPreview: 'BY LINDA BENTLEY  |  JULY 15, 2015\nTrump electrifies capacity crowd in Phoenix\nDonald Trump originally planned to hold Saturday afternoon’s event at the Biltmore Hotel. However, tickets were “sold out” for the free event shortly after they were made available, while the wait list quickly grew into the thousands. The venue was subsequently changed to the Phoenix Convention Center.\nPhotos by Linda Bentley\nPHOENIX – After speaking earlier in the day at FreedomFest, a libertarian gathering at Planet', textSize: 4263, title: 'Trump electrifies capacity crowd in Phoenix', url: 'https://sonorannews.com/archives/2015/150715/news-trump.html', waybackUrl: 'http://web.archive.org/web/[phone redacted]2131/https://www.sonorannews.com/archives/2015/150715/news-trump.html'})
CREATE (n5232:Source {archivePath: 'ClaudeFiles\\archives\\imdb.com\\2026-03-03_becf7465521b_article.txt', archiveStatus: 'captured', captureCount: 1, captureMethod: 'nodriver', captureStatus: 'captured', capturedAt: date('2026-03-03T02:00:05.323667000+00:00'), domain: 'imdb.com', htmlPath: 'ClaudeFiles\\archives\\imdb.com\\2026-03-03_becf7465521b.html', lastCaptured: date('2026-03-03T02:00:05.323667000+00:00'), siteName: 'IMDb', sourceType: 'unclassified', tags: [], textPreview: 'All\n8 suggestions available\nSign in\nSign in\nNew customer? Create account\nUse app\nAll topics\nBlack Start\n2017\n1h 33m\nPlay trailer2:09\n1 VIDEO\n1 PHOTO\nNews\nDocumentary\n\nThe power grid\'s vulnerability to natural/human threats poses catastrophic risk. Most people wouldn\'t survive long-term outages. Solutions exist but lack implementation by authorities.\n\n5.0\n/10\n6\nRate\nDirector\nPatrea Patrick\nWriter\nPatrea Patrick\nStars\nErika KirkJeanine PirroPeter Pry\nAdd to Watchlist\nMark as watched\nSee production', textSize: 1966, title: 'Black Start (2017) - IMDb', url: 'https://imdb.com/title/tt5290350'})
