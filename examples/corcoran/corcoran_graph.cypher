CREATE (n5101:Source {archivePath: 'ClaudeFiles\\archives\\newswire.com\\2026-03-02_6bba70bf2130_article.txt', archiveStatus: 'captured', captureCount: 2, captureMethod: 'http-readability', captureStatus: 'captured', capturedAt: date('2026-03-02T00:35:49.016131000+00:00'), domain: 'newswire.com', htmlPath: 'ClaudeFiles\\archives\\newswire.com\\2026-03-02_6bba70bf2130.html', lastCaptured: date('2026-03-02T05:22:13.666346000+00:00'), sourceType: 'unclassified', tags: [], textPreview: 'Scottsdale, Arizona , September 27, 2016 (Newswire.com)\n-\nSaxon Capital Group, Inc. (SCGX-pk) announced the signing of a letter of intent to acquire 100% of the outstanding shares of GTEK Industries, Inc., Scottsdale, Arizona. Closing of the acquisition will occur upon completion of the definitive contract which is expected to occur within the next five to ten days.\nGTEK Industries is a technology company developing products to mitigate the potential devastating damage as the result of an Electr', textSize: 4245, title: 'Saxon Capital Group to Acquire GTEK Industries', url: 'https://newswire.com/news/saxon-capital-group-to-acquire-gtek-industries-14966776'})
CREATE (n5102:Source {archivePath: 'ClaudeFiles\\archives\\newswire.com\\2026-03-02_8ca59c3ee6cb_article.txt', archiveStatus: 'captured', captureCount: 2, captureMethod: 'http-readability', captureStatus: 'captured', capturedAt: date('2026-03-02T00:35:54.006603000+00:00'), domain: 'newswire.com', htmlPath: 'ClaudeFiles\\archives\\newswire.com\\2026-03-02_8ca59c3ee6cb.html', lastCaptured: date('2026-03-02T05:22:17.741667000+00:00'), sourceType: 'unclassified', tags: [], textPreview: 'Scottsdale, Arizona , October 10, 2016 (Newswire.com)\n-\nGTEK Industries, Inc., a wholly owned subsidiary of Saxon Capital Group SCGX, (OTC)  a provider of services and products to the  rapidly evolving Electromagnetic Pulse (EMP) market, today announced a consultant agreement with Murdock Capital Partners Corp., New York, NY.  According to the terms of the agreement, Murdock will act as the investor outreach consultant to GTEK. “After conducting an extensive search for the appropriate capital ma', textSize: 4129, title: 'GTEK Industries, Inc. Announces Alliance With Murdock Capital Partners', url: 'https://newswire.com/news/gtek-industries-inc-announces-alliance-with-murdock-capital-partners-15218811'})
CREATE (n5103:Source {archivePath: 'ClaudeFiles\\archives\\anr.news\\2026-03-02_690a86f3de3d_article.txt', archiveStatus: 'captured', author: 'Australian National Review', captureCount: 1, captureMethod: 'http-readability', captureStatus: 'captured', capturedAt: date('2026-03-02T00:35:58.777721000+00:00'), domain: 'anr.news', htmlPath: 'ClaudeFiles\\archives\\anr.news\\2026-03-02_690a86f3de3d.html', lastCaptured: date('2026-03-02T00:35:58.777721000+00:00'), publishedDate: '2026-01-10T07:18:35+00:00', siteName: 'Australian National Review', sourceType: 'unclassified', tags: [], textPreview: 'BREAKING: New VIDEO Shows Erika Kirk (Frantzve) Spills on Mom’s GTeK DoD Contracts with Homeland Security – DEEP TIES to Fort Huachuca EXPOSED!\nBy\nProject Constitution\nIn this resurfaced 2020 interview clip – Erika Kirk (then Frantzve) casually drops that her family relocated to Arizona because her mom, Lori Frantzve, was diving deep into DoD (Department of Defense) work. She specifically name-drops GTeK as part of her mom’s ventures securing government contracts with Homeland Security for netwo', textSize: 2914, title: 'DEEP TIES to Fort Huachuca EXPOSED!', url: 'https://anr.news/world-news/breaking-new-video-shows-erika-kirk-frantzve-spills-on-moms-gtek-dod-contracts-with-homeland-security-deep-ties-to-fort-huachuca-exposed'})
CREATE (n5104:Source {archivePath: 'ClaudeFiles\\archives\\otcmarkets.com\\financialReportViewer.pdf', archiveStatus: 'captured', captureMethod: 'search_pdf', captureStatus: 'captured', capturedAt: date('2026-03-02T00:36:32.823237000+00:00'), domain: 'otcmarkets.com', lastCaptured: date('2026-03-02T00:36:32.823237000+00:00'), sourceType: 'unclassified', textSize: 9, title: 'Microsoft Word - GTEK - 6.30.16 OTC Disclosure Final.docx', url: 'https://otcmarkets.com/financialReportViewer?symbol=SCGX&id=160114'})
CREATE (n5105:Person {addedDate: date('2026-03-02'), altNames: ['Clifford Paul'], description: 'President, Secretary, Treasurer, and Chairman of the Board of GTEK Industries Inc (fka Saxon Capital Group), appointed June 21, 2016. Front-man CEO for the shell company while Lorin Frantzve held 86.8% controlling ownership.', name: 'Clifford R. Paul', notes: 'Also CEO of PK Associates, described as \'one of the largest structural engineers in Arizona\' — designed Banner Estrella Medical Center, CityScape, other AZ landmarks. Signed GTEK Industries OTC Pink disclosure Jul 26 2016 as President. Currently running Energy Glass Solar business through Saxon.', role: 'President/CEO of Saxon Capital Group (2016-present)', roles: ['Executive', 'Corporate Officer']})
CREATE (n5106:Person {addedDate: date('2026-03-02'), description: 'Original sole officer of Saxon Capital Group Inc (later GTEK Industries). Appointed May 18, 2015. Held 86.2% ownership (pre-split). Address: 1500 Market, Philadelphia PA 19102. Replaced by Clifford R. Paul June 21, 2016.', location: 'Philadelphia, PA', name: 'Brian Chamberlain', notes: 'Appointed President, Secretary, PEO, and Chairman May 18, 2015 (same day as XSilent→Saxon rename). Issued 5,032,324 shares for \'service\', giving him 86.2% ownership. Address: 1500 Market, Philadelphia PA 19102. Replaced by Clifford Paul by Jul 2016.', role: 'Former President/CEO of Saxon Capital Group (2015-2016)', roles: ['Executive', 'Corporate Officer']})
CREATE (n5107:Organization {addedDate: date('2026-03-02'), description: 'Private merchant banking firm, NYC. 25 years experience advising high-tech and energy companies. Assisted listing ~24 companies on major exchanges. Signed consultant agreement with GTEK Industries Oct 10, 2016.', keyPersons: 'Luis J. Mejia (MD), Thomas M. Dean (MD)', location: 'New York, NY', name: 'Murdock Capital Partners Corp', notes: 'New York-based capital markets advisory firm. 25 years experience in high-tech and energy sectors. Managing Director: Luis J. Mejia. Signed consultant agreement with GTEK Industries Oct 10 2016 for investor outreach.', orgType: 'financial-advisory', phone: '[redacted]'})
CREATE (n5108:Person {addedDate: date('2026-03-02'), description: 'Arizona State Senator (R), District 10. Introduced Lori Frantzve to present on EMP threats to AZ House committee March 19 2014. Later connected to Charlie Kirk case through relative Terryl Farnsworth.', name: 'David Farnsworth'})
CREATE (n5109:Person {addedDate: date('2026-03-02'), description: 'Independent filmmaker, director/producer of Black Start (2017) through Heartfelt Films LLC. Documentary focuses on US electrical grid vulnerabilities including EMP threats.', name: 'Patrea Patrick', occupation: 'filmmaker'})
CREATE (n5110:EntryRef {streamEntryId: 'ls-20260301-012', title: 'GTEK Industries: The Penny Stock Shell Behind Lori Frantzve\'s EMP Empire'})
CREATE (n5111:Source {archivePath: 'ClaudeFiles\\archives\\en.wikipedia.org\\2026-03-02_485008f1d839_article.txt', archiveStatus: 'captured', captureCount: 1, captureMethod: 'http-readability', captureStatus: 'captured', capturedAt: date('2026-03-02T02:08:08.526382000+00:00'), domain: 'en.wikipedia.org', htmlPath: 'ClaudeFiles\\archives\\en.wikipedia.org\\2026-03-02_485008f1d839.html', lastCaptured: date('2026-03-02T02:08:08.526382000+00:00'), sourceType: 'unclassified', tags: [], textPreview: 'American football player (born 1990)\nSean Patrick Renfree\n(born April 28, 1990) is an American former professional\nfootball\nplayer who was a\nquarterback\nin the\nNational Football League\n(NFL). After playing\ncollege football\nfor the\nDuke Blue Devils\n, he was selected by the\nAtlanta Falcons\nin the seventh round of the\n2013 NFL draft\n.\nRenfree attended\nNotre Dame Preparatory High School\nin\nScottsdale, Arizona\n, where he was a four-year letterman in\nfootball\n. He was voted as the team\'s "Most Valuabl', textSize: 8560, title: 'Sean Renfree - Wikipedia', url: 'https://en.wikipedia.org/wiki/Sean_Renfree'})
CREATE (n5112:Source {archivePath: 'ClaudeFiles\\archives\\en.wikipedia.org\\2026-03-02_64e10fe4b853_article.txt', archiveStatus: 'captured', captureCount: 1, captureMethod: 'http-readability', captureStatus: 'captured', capturedAt: date('2026-03-02T02:08:12.607469000+00:00'), domain: 'en.wikipedia.org', htmlPath: 'ClaudeFiles\\archives\\en.wikipedia.org\\2026-03-02_64e10fe4b853.html', lastCaptured: date('2026-03-02T02:08:12.607469000+00:00'), sourceType: 'unclassified', tags: [], textPreview: 'American baseball player (born 1987)\nBaseball player\nPeter Christopher Bourjos\n(born March 31, 1987) is an American former professional\nbaseball\ncenter fielder\n. He played in\nMajor League Baseball\n(MLB) for the\nLos Angeles Angels of Anaheim / Los Angeles Angels\n,\nSt. Louis Cardinals\n,\nPhiladelphia Phillies\n,\nTampa Bay Rays\n, and\nAtlanta Braves\n.\nThe Angels selected him in the tenth round of the\n2005 amateur draft\nfrom\nNotre Dame Preparatory High School\nin\nScottsdale, Arizona\n. He made his MLB de', textSize: 18025, title: 'Peter Bourjos - Wikipedia', url: 'https://en.wikipedia.org/wiki/Peter_Bourjos'})
CREATE (n5113:Source {archivePath: 'ClaudeFiles\\archives\\en.wikipedia.org\\2026-03-02_f7eea5cca21c_article.txt', archiveStatus: 'captured', captureCount: 1, captureMethod: 'http-readability', captureStatus: 'captured', capturedAt: date('2026-03-02T02:08:16.461262000+00:00'), domain: 'en.wikipedia.org', htmlPath: 'ClaudeFiles\\archives\\en.wikipedia.org\\2026-03-02_f7eea5cca21c.html', lastCaptured: date('2026-03-02T02:08:16.461262000+00:00'), sourceType: 'unclassified', tags: [], textPreview: 'American drag performer and make-up artist (born 1996)\nKade Gottlieb\n(born August 19, 1996),\n[\n1\n]\nbetter known as\nGottmik\n, is an American\ndrag\nperformer and\nmake-up artist\n. Gottmik was the first\ntrans man\nto compete on\nRuPaul\'s Drag Race\n, coming in shared 3rd/4th place on the\nthirteenth season\nwith fellow contestant\nRosé\n. Gottmik later returned to compete in the\nninth season\nof\nRuPaul\'s Drag Race All Stars\n.\n[\n2\n]\n[\n3\n]\nGottmik co-hosts the podcast\nNo Gorge\nalongside\nViolet Chachki\n.\nKade G', textSize: 14272, title: 'Gottmik - Wikipedia', url: 'https://en.wikipedia.org/wiki/Gottmik'})
CREATE (n5114:Source {archivePath: 'ClaudeFiles\\archives\\armenianweekly.com\\2026-03-02_1dc7ebde562a_article.txt', archiveStatus: 'captured', author: 'Weekly Staff', captureCount: 1, captureMethod: 'http-readability', captureStatus: 'captured', capturedAt: date('2026-03-02T02:08:18.872023000+00:00'), domain: 'armenianweekly.com', htmlPath: 'ClaudeFiles\\archives\\armenianweekly.com\\2026-03-02_1dc7ebde562a.html', lastCaptured: date('2026-03-02T02:08:18.872023000+00:00'), publishedDate: '2010-09-16T14:40:06+00:00', siteName: 'The Armenian Weekly', sourceType: 'unclassified', tags: [], textPreview: 'WASHINGTON—In the spring, Tro Panosian, a 17-year-old high school student at Notre Dame Preparatory in Scottsdale, Az., was nominated as one of two students from his school to attend the American Legion Boys State program in Flagstaff, Az. in June 2010. Each state (except Hawaii) holds a Boys State program, enrolling the top two leaders from every school in the state. After a week full of politics, partaking in a mock state-government, and an extensive interview process, Panosian was selected as', textSize: 4538, title: 'Panosian Passes Genocide Resolution at Boys Nation', url: 'https://armenianweekly.com/2010/09/16/panosian-passes-genocide-resolution-at-boys-nation'})
CREATE (n5115:Source {archivePath: 'ClaudeFiles\\archives\\survivor.fandom.com\\2026-03-02_c73c6955d0e9_article.txt', archiveStatus: 'captured', captureCount: 1, captureMethod: 'chrome-cli', captureStatus: 'captured', capturedAt: date('2026-03-02T02:08:21.308306000+00:00'), domain: 'survivor.fandom.com', htmlPath: 'ClaudeFiles\\archives\\survivor.fandom.com\\2026-03-02_c73c6955d0e9.html', lastCaptured: date('2026-03-02T02:08:21.308306000+00:00'), sourceType: 'unclassified', tags: [], textPreview: 'survivor.fandom.com\nPerforming security verification\nThis website uses a security service to protect against malicious bots. This page is displayed while the website verifies you are not a bot.\nVerification successful. Waiting for survivor.fandom.com to respond', textSize: 261, title: 'Just a moment...', url: 'https://survivor.fandom.com/wiki/Joe_Anglim'})
CREATE (n5116:Source {archivePath: 'ClaudeFiles\\archives\\ndpnews.org\\2026-03-02_6caec6f193f3_article.txt', archiveStatus: 'captured', captureCount: 1, captureMethod: 'chrome-cli', captureStatus: 'captured', capturedAt: date('2026-03-02T02:08:22.341579000+00:00'), domain: 'ndpnews.org', htmlPath: 'ClaudeFiles\\archives\\ndpnews.org\\2026-03-02_6caec6f193f3.html', lastCaptured: date('2026-03-02T02:08:22.341579000+00:00'), sourceType: 'unclassified', tags: [], textPreview: 'ndpnews.org\nThis site can’t be reached\nCheck if there is a typo in ndpnews.org.\nIf spelling is correct, try running Windows Network Diagnostics.\nDNS_PROBE_FINISHED_NXDOMAIN\nReload\nCheck if there is a typo in ndpnews.org.', textSize: 220, title: 'ndpnews.org', url: 'https://ndpnews.org/news/2015/02/24/alumni-joe-anglim-on-survivor'})
CREATE (n5117:Person {addedDate: date('2026-03-02'), birthDate: '1990-04-28', college: 'Duke University', description: 'Former NFL quarterback. NDP Class of 2008. Four-year letterman, team MVP junior and senior year. 2007 Elite 11 Camp alongside Andrew Luck. Led NDP to state championship, throwing for 411 yards and 5 TDs in title game. Named Arizona Big School Player of the Year and Parade All-American. Played college football at Duke (2009-2012), setting multiple school records. Won ACC Jim Tatum Award, NFF Scholar Athlete Award. Drafted 7th round (249th overall) by Atlanta Falcons in 2013 NFL Draft. Appeared in 2 NFL games. Also briefly signed with Tampa Bay Buccaneers (2017).', highSchoolClass: 2008, name: 'Sean Renfree', occupation: 'Former NFL quarterback', provenance: 'archived-verified'})
CREATE (n5118:Person {addedDate: date('2026-03-02'), birthDate: '1987-03-31', description: 'Former MLB center fielder. NDP Class of 2005 (first graduating class). Transferred from Desert Mountain HS. Also played football (WR/kick returner) at NDP. Selected by LA Angels in 10th round of 2005 MLB Draft. Made MLB debut August 2010. Known for elite speed and defense. Career: Angels (2010-2013), Cardinals (2013-2015), Phillies (2016), Rays (2017), Braves (2018), Angels again (2019). When Mike Trout emerged, Bourjos played CF and pushed Trout to LF. Son of former SF Giants outfielder Chris Bourjos. Post-playing: advance scout for Colorado Rockies (2020), roving minor league outfield/baserunning coordinator for Arizona Diamondbacks (2021+).', highSchoolClass: 2005, name: 'Peter Bourjos', occupation: 'Former MLB center fielder, current D-backs minor league coordinator', provenance: 'archived-verified'})
CREATE (n5119:Person {addedDate: date('2026-03-02'), aliases: ['Gottmik'], birthDate: '1996-08-19', description: 'Drag performer and makeup artist known as Gottmik. Born in Scottsdale, AZ; adopted. Raised Catholic, attended NDP where he first started wearing makeup. First trans man to compete on RuPaul\'s Drag Race (Season 13, 2021), reaching top four. Returned for All Stars Season 9 (2024). Celebrity makeup artist for Cindy Crawford, Paris Hilton, Heidi Klum, Lil Nas X. Did makeup for Taylor Swift \'You Need to Calm Down\' video. Performed with Sam Smith and Kim Petras at 2023 Grammys. Degree from FIDM. Co-hosts No Gorge podcast with Violet Chachki. Published The T Guide (Penguin Random House, 2023).', name: 'Kade Gottlieb', occupation: 'Drag performer, makeup artist', provenance: 'archived-verified'})
CREATE (n5120:Person {addedDate: date('2026-03-02'), college: 'Arizona State University (Barrett Honors College)', description: 'Civic leader and NDP Class of 2011. Student Body President, member of 2011 State Championship Soccer Team, recipient of Mater Dei Award. Graduated Summa Cum Laude. Selected as one of two Arizona delegates (from 350 candidates) for American Legion Boys Nation 2010. Introduced S.Res.7 affirming U.S. record on the Armenian Genocide — the only bill to pass unanimously (98-0). Met President Obama at the White House. Named Youth Leader of the Year by Scottsdale/Paradise Valley Rotary Club. Graduated Summa Cum Laude from Barrett Honors College at ASU (2015). Of Armenian heritage.', highSchoolClass: 2011, name: 'Tro Panosian', occupation: 'Civic leader', provenance: 'archived-verified'})
CREATE (n5121:Person {addedDate: date('2026-03-02'), description: 'Reality TV personality and jewelry designer. NDP Class of 2007. Played basketball at NDP, won state championship senior year. Competed on three seasons of Survivor: Worlds Apart (S30), Cambodia (S31), and Edge of Extinction (S38). Known as one of the best physical competitors in Survivor history. Jewelry designer based in Scottsdale. Married fellow Survivor contestant Sierra Dawn Thomas in 2019.', highSchoolClass: 2007, name: 'Joe Anglim', occupation: 'Jewelry designer, reality TV personality', provenance: 'web-search'})
CREATE (n5122:EntryRef {streamEntryId: 'ls-20260301-014', title: 'Notre Dame Prep Notable Alumni — Beyond the Corcoran Circle'})
CREATE (n5123:Source {archivePath: 'ClaudeFiles\\archives\\heartfeltfilms.wixsite.com\\2026-03-02_c79083543e34_article.txt', archiveStatus: 'captured', captureCount: 1, captureMethod: 'http-readability', captureStatus: 'captured', capturedAt: date('2026-03-02T04:42:46.662105000+00:00'), domain: 'heartfeltfilms.wixsite.com', htmlPath: 'ClaudeFiles\\archives\\heartfeltfilms.wixsite.com\\2026-03-02_c79083543e34.html', lastCaptured: date('2026-03-02T04:42:46.662105000+00:00'), siteName: 'black-start', sourceType: 'unclassified', tags: [], textPreview: 'The documentary film BLACK START investigates and follows the trail of information surrounding threats that the US National Electrical Grid faces right now.\nIt is the first documentary to hit the issues head on, examining the science, and the politics and administrative workings that stand in the way of our protection. Recently un-classified and shocking information shows that the entire power grid is extremely vulnerable to attack and to several other dangers, some of which are (100%) certain t', textSize: 2131, title: 'About the Film | black-start', url: 'https://heartfeltfilms.wixsite.com/black-start/about-the-film'})
CREATE (n5124:Source {archivePath: 'ClaudeFiles\\archives\\vornews.com\\2026-03-02_e976b936b6d4_article.txt', archiveStatus: 'captured', captureCount: 1, captureMethod: 'http-readability', captureStatus: 'captured', capturedAt: date('2026-03-02T04:42:51.038716000+00:00'), domain: 'vornews.com', htmlPath: 'ClaudeFiles\\archives\\vornews.com\\2026-03-02_e976b936b6d4.html', lastCaptured: date('2026-03-02T04:42:51.038716000+00:00'), publishedDate: '2026-01-17T12:04:07+07:00', siteName: 'VOR News Media', sourceType: 'unclassified', tags: [], textPreview: 'WASHINGTON, D.C.\n– American conservative politics, plus the online spaces that feed on conspiracy claims, rarely stay quiet for long. A new flashpoint hit in early January 2026 when an old documentary clip resurfaced featuring\nErika Kirk\n, the CEO of Turning Point USA (TPUSA) and the widow of the late Charlie Kirk.\nJimmy Dore\n, a comedian and political commentator known for blunt criticism of establishment power, jumped on the clip and called it a possible “smoking gun.” In his framing, the foot', textSize: 6138, title: 'Erika Kirk’s Early EMP Documentary Fuels CIA Grooming Rumors', url: 'https://vornews.com/news/erika-kirks-cia-ties'})
CREATE (n5125:Source {archivePath: 'ClaudeFiles\\archives\\city-data.com\\2026-03-02_01aac0c9b0c5_article.txt', archiveStatus: 'captured', captureCount: 1, captureMethod: 'http-readability', captureStatus: 'captured', capturedAt: date('2026-03-02T04:42:53.017036000+00:00'), domain: 'city-data.com', htmlPath: 'ClaudeFiles\\archives\\city-data.com\\2026-03-02_01aac0c9b0c5.html', lastCaptured: date('2026-03-02T04:42:53.017036000+00:00'), sourceType: 'unclassified', tags: [], textPreview: 'L22039349 - DESERT SPIRIT TEK, LLC\nEntity Id:\nL22039349\nType:\nDomestic LLC\nStatus:\nIn Good Standing\nRegistration date:\n2017 Jul 19\nOriginal Incorporation Date:\n7/19/2017\nApproval Date:\n8/9/2017\nDomicile State:\nArizona\nLife Period:\nPerpetual\nAdresses\nStreet Address:\nDESRT SPIRIT TE, SACTON, AZ 85147, USA, Pinal\nRegistered Agent\nName:\nLAWRENCE R GUINTA\nStatus:\nActive\nStreet Address:\n9743 E. SHARON DR., SCOTTSDALE, AZ 85260, USA\nMailing Address:\n9743 E. SHARON DR., SCOTTSDALE, AZ 85260, USA\nUpdated', textSize: 983, title: 'L22039349 - DESERT SPIRIT TEK, LLC', url: 'https://city-data.com/business-entities/AZ/DESERT-SPIRIT-TEK-LLC-L22039349-AZ.html'})
CREATE (n5126:Source {archivePath: 'ClaudeFiles\\archives\\candaceowensfan.substack.com\\2026-03-02_d544c102499a_article.txt', archiveStatus: 'captured', author: 'Candace Owens Podcasts', captureCount: 1, captureMethod: 'http-readability', captureStatus: 'captured', capturedAt: date('2026-03-02T04:42:54.386113000+00:00'), domain: 'candaceowensfan.substack.com', htmlPath: 'ClaudeFiles\\archives\\candaceowensfan.substack.com\\2026-03-02_d544c102499a.html', lastCaptured: date('2026-03-02T04:42:54.386113000+00:00'), sourceType: 'unclassified', tags: [], textPreview: 'Podcast title:\nErika’s Inquisition: TPUSA Employees FIRED For…What?! | Candace Ep 295\nYesterday\nCandace revealed she’d received a cease and desist letter from Turning Point, then dedicated the rest of her show to skewering Taylor Swift and Brooklyn Beckham’s millionaire problems.\nToday she presented two exclusives: the texts messages from a Christian TPUSA donor threatening Charlie because of his support for Tucker Carlson and Candace, and secret audio from a former TPUSA employee during her ter', textSize: 12055, title: 'EXCLUSIVE: Candace shows texts from a Turning Point donor berating Charlie about Israel, and a secret recording of a TPUSA employee getting fired', url: 'https://candaceowensfan.substack.com/p/exclusive-candace-shows-texts-from'})
CREATE (n5127:Source {archivePath: 'ClaudeFiles\\archives\\netflixjunkie.com\\2026-03-02_8f7f2ad85388_article.txt', archiveStatus: 'captured', author: 'Soma Mitra', captureCount: 1, captureMethod: 'http-readability', captureStatus: 'captured', capturedAt: date('2026-03-02T04:42:58.331571000+00:00'), domain: 'netflixjunkie.com', htmlPath: 'ClaudeFiles\\archives\\netflixjunkie.com\\2026-03-02_8f7f2ad85388.html', lastCaptured: date('2026-03-02T04:42:58.331571000+00:00'), publishedDate: 'Sat Jan 10 2026 12:23:01 GMT+0000 (Coordinated Universal Time)', siteName: 'Netflix Junkie', sourceType: 'unclassified', tags: [], textPreview: 'Black Start\n, a documentary film, explores the legitimate dangers\nof a long-term electrical grid failure caused by natural events or human\ninterference. The 2017 film by Director Patrea Patrick is trending in 2026, but\nwhy all of a sudden? Are viewers watching a decade-old documentary instead of a\nclassified intelligence leak?\nWhile some viewers claim a long-lost government briefing has\nfinally surfaced, the truth behind this the movie trending reveals a much more\npublic origin.\nWhat is making B', textSize: 2804, title: 'What Is the ‘Black Start’ Documentary by Patrea Patrick? Why Is It Trending?', url: 'https://netflixjunkie.com/hollywood-news-what-is-the-black-start-documentary-by-patrea-patrick-why-is-it-trending'})
CREATE (n5128:Organization {addedDate: date('2026-03-02'), description: 'Independent film production company run by Patrea Patrick. Produced the documentary Black Start (2017) about US electrical grid vulnerabilities.', name: 'Heartfelt Films LLC', type: 'media'})
CREATE (n5129:Event {addedDate: date('2026-03-02'), date: '2017', description: 'Independent documentary directed by Patrea Patrick (Heartfelt Films LLC) investigating threats to the US electrical grid from EMP, cyberattacks, physical attacks, and solar flares. Released ~2017, with some footage dating to ~2013. Featured Erika Frantzve (Kirk) as EMP presenter, fmr CIA Director James Woolsey, fmr FERC head Jon Wellinghoff, Homeland Security EMP Taskforce head Peter Pry, Fox News contributor Jeanine Pirro, fmr Congressman Trent Franks. Went viral in Jan 2026 when clips resurfaced on X, fueling CIA grooming conspiracy theories about Erika Kirk.', eventType: 'documentary production', location: 'various US locations', name: 'Black Start Documentary (2017)'})
CREATE (n5130:Person {addedDate: date('2026-03-02'), description: 'Manager and member of Desert Spirit Tek LLC (formed 2017). Address: PO Box 819, Sacaton, AZ 85147. Business partner of Lawrence Guinta and Lori Frantzve.', location: 'Sacaton, AZ', name: 'Shelly Reams'})
CREATE (n5131:Person {addedDate: date('2026-03-02'), description: 'Member of Desert Spirit Tek LLC (formed 2017). Part of the Tohono O\'odham nation. Per Candace Owens Ep 295: indicted 1998 for sexual conduct with a minor under age 15. Case went through courts for ~18 months, victim gave impact statement, case dismissed without prejudice in 1999. No independent court record verification found. Also co-owns Generation 7 Farms at 21 Rose and Thobi, Sacaton AZ — address not findable on maps.', location: 'Sacaton, AZ', name: 'Lyle Reams', nativeAmerican: 'Tohono O\'odham'})
CREATE (n5132:Event {addedDate: date('2026-03-02'), date: '2017-07-19', description: 'Arizona Domestic LLC formed July 19, 2017, approved Aug 9, 2017. Entity ID L22039349. Registered agent: Lawrence R Guinta at 9743 E Sharon Dr, Scottsdale AZ 85260 (same address as E3TEK Group). Members: Shelly M Reams (Manager), Lawrence R Guinta, Lyle Reams, Lorin Frantzve. Street address listed as \'DESRT SPIRIT TE, SACTON, AZ 85147\' — address does not appear to exist on maps per Candace Owens investigation.', eventType: 'corporate formation', location: 'Sacaton, AZ / Scottsdale, AZ', name: 'Desert Spirit Tek LLC Formation'})
CREATE (n5133:Person {addedDate: date('2026-03-02'), description: 'Former Chairman of the Federal Energy Regulatory Commission (FERC). Featured in Black Start documentary (2017) discussing grid vulnerability.', name: 'Jon Wellinghoff', occupation: 'former FERC Chairman'})
CREATE (n5134:Person {addedDate: date('2026-03-02'), description: 'Head of the Congressional EMP Commission / Homeland Security EMP Taskforce. Featured in Black Start documentary (2017). Leading expert on EMP threats to US infrastructure.', name: 'Peter Pry', occupation: 'EMP policy expert'})
CREATE (n5135:Source {archivePath: 'ClaudeFiles\\archives\\en.wikipedia.org\\2026-03-03_bd2c8810e490_article.txt', archiveStatus: 'captured', captureCount: 1, captureMethod: 'http-readability', captureStatus: 'captured', capturedAt: date('2026-03-03T01:58:35.264061000+00:00'), domain: 'en.wikipedia.org', htmlPath: 'ClaudeFiles\\archives\\en.wikipedia.org\\2026-03-03_bd2c8810e490.html', lastCaptured: date('2026-03-03T01:58:35.264061000+00:00'), sourceType: 'unclassified', tags: ['qa-test', 'corcoran'], textPreview: 'American businesswoman (born 1949)\nBarbara Ann Corcoran\n[\n2\n]\n(born March 10, 1949)\n[\n3\n]\nis an American businesswoman,\n[\n4\n]\ninvestor, syndicated columnist, and television personality. She founded the\nCorcoran Group\n, a real estate\nbrokerage\nin New York City, which she sold to\nNRT\nfor $66 million in 2001 and shortly thereafter exited the company. One of the show\'s original "Shark" investors, Corcoran has appeared in all 15 seasons of\nABC\n\'s\nShark Tank\nto date.\n[\n5\n]\nAs of January 2023, she has ', textSize: 9545, title: 'Barbara Corcoran', url: 'https://en.wikipedia.org/wiki/Barbara_Corcoran'})
CREATE (n5136:Person {addedDate: date('2026-03-02'), description: 'Former US Congressman from Arizona. Appeared in Black Start documentary (2017). Known advocate for EMP grid protection legislation.', name: 'Trent Franks', occupation: 'former US Congressman (AZ)'})
CREATE (n5137:Event {addedDate: date('2026-03-02'), date: '2025-12', description: 'Following Charlie Kirk\'s assassination in Sept 2025, TPUSA conducted mass layoffs allegedly to identify employees leaking information to Candace Owens. Employees fired without cause (Arizona at-will employment), escorted out by security, home visits to collect laptops. Secret audio recordings of termination meetings surfaced. Andrew Kovet and unnamed executives conducted firings. Organization raised $250M since Kirk\'s death per Candace Owens.', eventType: 'organizational purge', location: 'Phoenix, AZ', name: 'TPUSA Mass Firings (Late 2025)'})
CREATE (n5138:Event {addedDate: date('2026-03-02'), date: '2026-01-08', description: 'On January 8, 2026, X user Destiny Rezendes posted a clip from the Black Start documentary showing young Erika Frantzve (Kirk) briefing professionals on EMP grid vulnerability alongside fmr CIA Director James Woolsey. Clip went viral with many viewers falsely believing it was a leaked CIA briefing. Jimmy Dore amplified the clip, framing it as evidence of Kirk\'s unusual early access to national security circles. Fueled conspiracy theories about CIA grooming/recruitment through family defense contractor connections.', eventType: 'viral media event', name: 'Erika Kirk Black Start Clip Goes Viral (Jan 2026)'})
CREATE (n5139:EntryRef {streamEntryId: 'ls-20260301-016', title: 'E3TEK Network Expansion: Black Start Documentary, Desert Spirit Tek, and TPUSA Internal Purge'})
