CREATE (n4783)-[:SUPPORTED_BY {claim: 'Lori Frantzve worked at GE for almost two decades per LinkedIn; works in network security; started her own companies; raised Erika in Scottsdale as single mom and devout Catholic', confidence: 'archived-verified', createdAt: date('2026-02-26T03:53:31.932000000+00:00')}]->(n4786)
CREATE (n4783)-[:SUPPORTED_BY {claim: 'After divorce, Lori raised Erika as single parent; founded several network security companies as CEO/chairman; diagnosed with very rare illness; Erika was with Lori at doctor appointment when Kirk assassinated', confidence: 'archived-verified', createdAt: date('2026-02-26T03:53:31.957000000+00:00')}]->(n4787)
CREATE (n4783)-[:SUPPORTED_BY {claim: 'Lori Frantzve identified as Erika\'s mother; portrayed as devout community-oriented figure; raised Erika as single mother; maintained notable friendship with Charlie Kirk', confidence: 'archived-verified', createdAt: date('2026-02-26T03:53:31.974000000+00:00')}]->(n4788)
