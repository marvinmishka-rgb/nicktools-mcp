CREATE (n5152:Source {archivePath: 'ClaudeFiles\\archives\\patents.google.com\\2026-03-02_2d7ccc8c179e_article.txt', archiveStatus: 'captured', captureCount: 1, captureMethod: 'http-readability', captureStatus: 'captured', capturedAt: date('2026-03-02T05:08:53.299417000+00:00'), domain: 'patents.google.com', htmlPath: 'ClaudeFiles\\archives\\patents.google.com\\2026-03-02_2d7ccc8c179e.html', lastCaptured: date('2026-03-02T05:08:53.299417000+00:00'), sourceType: 'unclassified', tags: [], textPreview: 'This is a continuation of application Ser. No. 08/351,896 filed Dec. 8, 1994, now U.S. Pat. No. 5,737,494.\nBACKGROUND OF THE INVENTION\nI. Field of the Invention\nThis invention relates to various computer-aided methods and apparatus for assessing an organizational process or system. The term "assessing," as used herein, refers to gathering information about, and/or measuring or evaluating, at least one organizational process or system.\nII. Description of the Related Art\nLarge entities such as cor', textSize: 68853, title: 'US6092060A - Computer-aided methods and apparatus for assessing an organizational process or system - Google Patents', url: 'https://patents.google.com/patent/US6092060A/en'})
CREATE (n5153:Source {archivePath: 'ClaudeFiles\\archives\\patents.google.com\\2026-03-02_fc88c553209e_article.txt', archiveStatus: 'captured', captureCount: 1, captureMethod: 'http-readability', captureStatus: 'captured', capturedAt: date('2026-03-02T05:08:58.188918000+00:00'), domain: 'patents.google.com', htmlPath: 'ClaudeFiles\\archives\\patents.google.com\\2026-03-02_fc88c553209e.html', lastCaptured: date('2026-03-02T05:08:58.188918000+00:00'), sourceType: 'unclassified', tags: [], textPreview: 'PRIORITY CLAIM\nThis application claims priority to U.S. Provisional Patent No. 61/169,938 entitled “SYSTEM AND METHOD FOR INFRASTRUCTURE RISK ASSESSMENT AND/OR MITIGATION” filed on Apr. 16, 2009.\nBACKGROUND\n1. Field of the Invention\nThe present invention generally relates to various methods and apparatus for assessing organizational process or system. The term “assessing,” as used herein, refers to gathering information about, and/or measuring or evaluating, at least one organizational process o', textSize: 84634, title: 'US[phone redacted]2A1 - System and method for infrastructure risk assessment and/or mitigation - Google Patents', url: 'https://patents.google.com/patent/US[phone redacted]2A1'})
CREATE (n5154:Source {archivePath: 'ClaudeFiles\\archives\\patents.google.com\\2026-03-02_3fad5dc72fe1_article.txt', archiveStatus: 'captured', captureCount: 1, captureMethod: 'http-readability', captureStatus: 'captured', capturedAt: date('2026-03-02T05:09:02.600057000+00:00'), domain: 'patents.google.com', htmlPath: 'ClaudeFiles\\archives\\patents.google.com\\2026-03-02_3fad5dc72fe1.html', lastCaptured: date('2026-03-02T05:09:02.600057000+00:00'), sourceType: 'unclassified', tags: [], textPreview: 'BACKGROUND OF ME INVENTION\n1. Field of the Invention\nThe invention relates to computer-aided methods and apparatuses for assessing the criticality, vulnerability, and overall associated risk of an organization, its system or processes.\n2. Description of the Relevant Art\nSince September 11, the United States Government and its associated agencies, such as the Department of Defense (DoD), the Department of Homeland Security (DHS), etc., have an increased need to assess and determine the criticalit', textSize: 155306, title: 'US[phone redacted]6A1 - Critically/vulnerability/risk logic analysis methodology for business enterprise and cyber security - Google Patents', url: 'https://patents.google.com/patent/US[phone redacted]6'})
CREATE (n5155:Source {archivePath: 'ClaudeFiles\\archives\\mcassessor.maricopa.gov\\2026-03-02_17d090528aeb_article.txt', archiveStatus: 'captured', captureCount: 1, captureMethod: 'http-readability', captureStatus: 'captured', capturedAt: date('2026-03-02T05:09:03.946264000+00:00'), domain: 'mcassessor.maricopa.gov', htmlPath: 'ClaudeFiles\\archives\\mcassessor.maricopa.gov\\2026-03-02_17d090528aeb.html', lastCaptured: date('2026-03-02T05:09:03.946264000+00:00'), sourceType: 'unclassified', tags: [], textPreview: 'We provide valuation information for the past 5 years. For mobile display, we only show 1 year of valuation information. Should you need more data, please look at our\ndata sales\n.\nThe Valuation Information displayed below may not reflect the taxable value used on the tax bill due to any special valuation relief program.\nCLICK HERE TO PAY YOUR TAXES OR VIEW YOUR TAX BILL\nThis parcel has a pending Notice of Change per ARS-42-15105, that will be mailed in September. No valuation data is available f', textSize: 534, title: 'Maricopa County Assessor\'s Office', url: 'https://mcassessor.maricopa.gov/mcs/?mod=pd&q=21750336'})
CREATE (n5156:Organization {addedDate: date('2026-03-02'), aliases: ['IntelliMet Inc', 'INTELLIMET INTERNATIONAL Inc', 'Intellimet'], location: 'Scottsdale, AZ', name: 'IntelliMet International Inc', notes: 'Renamed from Tech-Metrics International Inc on Dec 5, 2000. Patent holding company for Guinta-Frantzve risk assessment IP. Received security interest from Nevada Bond Investment Corp II in Feb 2002. Later became AZ-Tech International DBA IMET Laboratories.', orgType: 'private-company'})
