CREATE (n2272:Agent {agentIds: ['11088'], bio: 'Full name: Kei Laurie Hashimoto. Event Planner and NYS Notary Public per LinkedIn. Licensed RE Salesperson at Corcoran Chelsea/Flatiron. Minimal online presence — no bio on Corcoran, 404 on profile page. Probable family of Masayo J Hashimoto (same office, same surname, appeared 3 months after Masayo). Departed with no trace — profile removed, no current listings anywhere.', bioEvolution: 'STABLE: Remained at same office, same brokerage since at least 2019. One of 3 ghost cohort members who stayed. Related to Masayo Hashimoto (also Corcoran, Hechter Bar-Lev Team).', bioNotes2019: 'Listed at Chelsea-Flatiron office Dec 2019. Full name: Kei Laurie Hashimoto.', bioNotesCurrent: 'Still at Corcoran Chelsea/Flatiron. Licensed RE Salesperson. Full bio not publicly cached - renders via JS on corcoran.com.', captureCount: 1, careerPath: 'Unknown prior → Corcoran Chelsea-Flatiron (2019-present)', currentBrokerage: 'Corcoran', currentFirm: 'The Corcoran Group (active)', currentOffice: 'Chelsea/Flatiron, 218 West 18th Street 6th Floor', currentStatus: 'departed_no_trace', email: '[redacted]', enrichedAt: '2026-02-19T20:23:00', enrichedFrom: 'wayback-[phone redacted]0023', firstSeen: '20191212', fullName: 'Kei Laurie Hashimoto', ghostCohort: true, ghostCohortNote: 'EXPLAINED: Likely family member of Masayo Hashimoto (same surname, same office, both Japanese-speaking). Masayo arrived 3 months before Kei. Kei had no bio, no mobile, no web presence. Profile now 404. Probably got licensed, tried briefly, quit.', ghostStatus: 'still-at-corcoran', lastSeen: '20191212', lastVerified: '2026-02-23', legalName: 'Kei Laurie Hashimoto', movesCount: 0, name: 'Kei Hashimoto', nameVariants: ['Kei Hashimoto', 'Kei L Hashimoto', 'Kei Laurie Hashimoto'], notes: 'Still at Corcoran Chelsea-Flatiron. Related to Masayo Hashimoto (same office, Hechter Bar-Lev Team member). Ghost in archive (1 capture) but continuously employed.', office: 'Chelsea/Flatiron - 218 West 18th Street 6th Floor', priorCareer: 'Event Planner, NYS Notary Public', researchNotes: 'Ghost cohort. Profile 404. LinkedIn exists but behind auth. No StreetEasy/Zillow presence. No deal history. Public records confirm family link to Masayo via shared relative Kazuma Helena Hashimoto.', researchStatus: 'needs-verification', sampleUrl: 'https://www.corcoran.com/nyc-real-estate/agents/chelsea-flatiron/kei-hashimoto/11088', slug: 'kei-hashimoto', status: 'active', title: 'Licensed RE Salesperson', verificationNotes: 'Confirmed active Corcoran agent at 218 W 18th via corcoran.com/nyc-real-estate/agents/chelsea-flatiron/kei-hashimoto/11088. FAMILY_OF Masayo Hashimoto. No StreetEasy, Zillow, or third-party profiles found — zero visible deal history. Matches ghost cohort pattern of licensed agent with no sales footprint.', verifiedDate: date('2026-02-27')})
