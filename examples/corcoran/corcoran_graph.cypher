CREATE (n4799)-[:SUPPORTED_BY {claim: 'Carl Kenneth Frantzve was Swedish-born WWII/Korean War veteran, Silver Star recipient, father of Kent; Erika used incorrect Swedish terms morfar/mormor instead of farfar', confidence: 'archived-verified', createdAt: date('2026-02-26T04:07:10.870000000+00:00')}]->(n4793)
