CREATE (n4927:Source {archivePath: 'ClaudeFiles\\archives\\npr.org\\2026-02-28_6daa11edd939_article.txt', archiveStatus: 'captured', captureCount: 1, captureMethod: 'http-readability', captureStatus: 'captured', capturedAt: date('2026-02-28T19:37:00.259861000+00:00'), domain: 'npr.org', htmlPath: 'ClaudeFiles\\archives\\npr.org\\2026-02-28_6daa11edd939.html', lastCaptured: date('2026-02-28T19:37:00.259861000+00:00'), publishedDate: '2024-04-24', siteName: 'NPR', sourceType: 'primary-journalism', tags: ['bowyer', 'fake-electors', 'indictment'], textPreview: 'Former Trump White House Chief of Staff Mark Meadows speaks during a forum on Nov. 14, 2022. Meadows has been indicted in Arizona for his alleged efforts to keep former President Donald Trump in power.\nDrew Angerer/Getty Images\nhide caption\ntoggle caption\nDrew Angerer/Getty Images\nFormer Trump White House Chief of Staff Mark Meadows speaks during a forum on Nov. 14, 2022. Meadows has been indicted in Arizona for his alleged efforts to keep former President Donald Trump in power.\nDrew Angerer/Get', textSize: 5713, title: 'Meadows, Giuliani, 11 \'fake electors\' face charges in Arizona : NPR', url: 'https://npr.org/2024/04/24/[phone redacted]/arizona-fake-elector-charges'})
CREATE (n4928:Source {archivePath: 'ClaudeFiles\\archives\\thedailybeast.com\\2026-02-28_0d8a25bb75a4_article.txt', archiveStatus: 'captured', captureCount: 1, captureMethod: 'http-readability', captureStatus: 'captured', capturedAt: date('2026-02-28T19:37:08.945859000+00:00'), domain: 'thedailybeast.com', htmlPath: 'ClaudeFiles\\archives\\thedailybeast.com\\2026-02-28_0d8a25bb75a4.html', lastCaptured: date('2026-02-28T19:37:08.945859000+00:00'), siteName: 'The Daily Beast', sourceType: 'unclassified', tags: [], textPreview: 'Questions have been raised about a series of apps that are providing information on Arizona’s conservative candidates.\nIn fact, thanks to the Trump campaign’s ex-chief operating officer and financial patron to Arizona gubernatorial aspirant\nKari Lake\n, the Grand Canyon State has a whole slew of them.\nThe app Superfeed Technologies developed for Lake appears to be the most popular of the four apps which the Phoenix-based firm has developed for GOP candidates in Arizona—seemingly free of charge.\nM', textSize: 6078, title: 'Kari Lake-Linked Tech Firm Superfeed Wreaking Campaign Finance Havoc in Arizona', url: 'https://thedailybeast.com/kari-lake-linked-tech-firm-superfeed-wreaking-campaign-finance-havoc-in-arizona'})
CREATE (n4929:Source {archivePath: 'ClaudeFiles\\archives\\azcapitoltimes.com\\2026-02-28_70e4f58f2a84_article.txt', archiveStatus: 'captured', author: 'Dan Merica and Brian Slodysko Associated Press', captureCount: 1, captureMethod: 'http-readability', captureStatus: 'captured', capturedAt: date('2026-02-28T19:37:10.949865000+00:00'), domain: 'azcapitoltimes.com', htmlPath: 'ClaudeFiles\\archives\\azcapitoltimes.com\\2026-02-28_70e4f58f2a84.html', lastCaptured: date('2026-02-28T19:37:10.949865000+00:00'), publishedDate: '2024-10-07T18:26:04+00:00', siteName: 'Arizona Capitol Times | Your Inside Source for Arizona Government, Politics and Business', sourceType: 'unclassified', tags: [], textPreview: 'Turning Point’s representatives have made two things clear in meetings with state and local Republican leaders – Donald Trump has blessed their conservative organization to help lead his get-out-the-vote effort, and local party officials ought to use the group’s new voter mobilization app.\nBoth prospects terrify fellow Republicans.\nSoaring to prominence after Trump’s unexpected 2016 win, Turning Point earned a reputation for hosting glitzy events, cultivating hard-right influencers and raising p', textSize: 6307, title: 'Turning Point wants to revolutionize how Republicans turn out voters. Some are skeptical', url: 'https://azcapitoltimes.com/news/2024/10/07/turning-point-wants-to-revolutionize-how-republicans-turn-out-voters-some-are-skeptical'})
CREATE (n4930:Source {archivePath: 'ClaudeFiles\\archives\\phoenixnewtimes.com\\2026-02-28_3bd0b857416d_article.txt', archiveStatus: 'captured', captureCount: 1, captureMethod: 'http-readability', captureStatus: 'captured', capturedAt: date('2026-02-28T19:37:14.258467000+00:00'), domain: 'phoenixnewtimes.com', htmlPath: 'ClaudeFiles\\archives\\phoenixnewtimes.com\\2026-02-28_3bd0b857416d.html', lastCaptured: date('2026-02-28T19:37:14.258467000+00:00'), publishedDate: '2025-03-07T12:07:00+00:00', siteName: 'Phoenix New Times', sourceType: 'unclassified', tags: ['bowyer', 'turning-point', 'fake-electors'], textPreview: 'Tyler Bowyer was indicted as one of Arizona\'s 11 fake electors last year.\nGage Skidmore/Flickr/CC BY-SA 2.0\nTyler Bowyer\nonce described himself\nas “the guy that basically runs everything” at the Arizona-based, national right-wing organization Turning Point USA. Now the group is trying to prevent a batch of his emails from falling into the hands of Arizona Attorney General Kris Mayes, who is\nprosecuting Bowyer and others\nfor their role in trying to overturn Arizona’s 2020 presidential election.\nT', textSize: 4642, title: 'Turning Point sues Arizona attorney general over fake elector emails', url: 'https://phoenixnewtimes.com/news/arizona-turning-point-sues-attorney-general-fake-elector-emails-21346904'})
CREATE (n4931:Source {archivePath: 'ClaudeFiles\\archives\\blogforarizona.net\\2026-02-28_8a2d2da68ea8_article.txt', archiveStatus: 'captured', captureCount: 1, captureMethod: 'http-readability', captureStatus: 'captured', capturedAt: date('2026-02-28T19:37:16.225672000+00:00'), domain: 'blogforarizona.net', htmlPath: 'ClaudeFiles\\archives\\blogforarizona.net\\2026-02-28_8a2d2da68ea8.html', lastCaptured: date('2026-02-28T19:37:16.225672000+00:00'), publishedDate: '2024-03-02T22:47:59+00:00', siteName: 'Blog for Arizona', sourceType: 'unclassified', tags: [], textPreview: 'Every one of these MAGA flakes and freaks seems to be on the grift when you get a peek under the table. So I am not the least bit shocked that the reported $100K paid to Kari Lake by the shady and mysterious company Superfeed is looking ever more suspicious.\nThe DailyBeast has done an very thorough investigation of the finances of Superfeed entitled “Kari Lake’s Bribery Scandal Involves a Shady GOP Tech Firm”\nand what they found raises way more questions – and questionable accounting and finance', textSize: 19347, title: '#LyingLoserLake’s Financial Relationship with Superfeed, and Its Entire Operation, Looks Shady as Hell.', url: 'https://blogforarizona.net/lyingloserlakes-financial-relationship-with-superfeed-and-its-entire-operation-looks-shady-as-hell'})
CREATE (n4932:Source {archivePath: 'ClaudeFiles\\archives\\rawstory.com\\2026-02-28_6b6ba9156e21_article.txt', archiveStatus: 'captured', author: 'https://www.facebook.com/[phone redacted]4', captureCount: 1, captureMethod: 'http-readability', captureStatus: 'captured', capturedAt: date('2026-02-28T19:37:18.964088000+00:00'), domain: 'rawstory.com', htmlPath: 'ClaudeFiles\\archives\\rawstory.com\\2026-02-28_6b6ba9156e21.html', lastCaptured: date('2026-02-28T19:37:18.964088000+00:00'), publishedDate: '2022-11-05T18:42:58+00:00', siteName: 'Raw Story', sourceType: 'unclassified', tags: [], textPreview: 'According to a report from the Daily Beast\'s William Bredderman, Arizona Republican Kari Lake has been receiving free -- and likely illegal -- campaign assistance from a tech company\nthat once paid her for "consulting."\nAt issue is an app developed by Superfeed Technologies for Lake "which provides regular updates from Lake’s social media feed, notifies users of campaign events, and connects them with donation and volunteer sign-up portals."\nThe problem, as Breddeerman reports, is that there is ', textSize: 2292, title: 'Questions raised about Kari Lake receiving unreported free campaign services from tech company: report', url: 'https://rawstory.com/kari-lake-election-[phone redacted]'})
CREATE (n4933:Event {addedDate: date('2026-02-28'), date: '2024-02-21', description: 'Turning Point USA filed a federal lawsuit against Arizona AG Kris Mayes seeking to block a search warrant for Tyler Bowyer\'s four Google email accounts used in the fake electors scheme. TPUSA argued the emails contained privileged organizational communications. Bowyer described himself in a declaration as \'the guy that basically runs everything\' at TPUSA.', location: 'U.S. District Court, Arizona', name: 'TPUSA Sues AG Mayes Over Bowyer Emails'})
CREATE (n4934:Person {addedDate: date('2026-02-28'), description: 'Arizona Attorney General (Democrat). Filed public nuisance lawsuit against Fondomonte LLC in December 2024. Used largely untested legal theory since Fondomonte\'s pumping doesn\'t violate state water laws. Also targeting Riverview Dairy in Cochise County. Republican lawmakers threatened impeachment over her rural water enforcement actions.', name: 'Kris Mayes', provenance: 'archived-verified', title: 'Arizona Attorney General'})
CREATE (n4935:Source {archivePath: 'ClaudeFiles\\archives\\12news.com\\2026-02-28_bb5d0b4cad0c_article.txt', archiveStatus: 'captured', captureCount: 1, captureMethod: 'http-readability', captureStatus: 'captured', capturedAt: date('2026-02-28T20:16:06.249260000+00:00'), domain: '12news.com', htmlPath: 'ClaudeFiles\\archives\\12news.com\\2026-02-28_bb5d0b4cad0c.html', lastCaptured: date('2026-02-28T20:16:06.249260000+00:00'), publishedDate: '11/8/2025 1:26:10 PM', siteName: '12news.com', sourceType: 'unclassified', tags: [], textPreview: 'Mayes has less than 2 weeks to decide whether to keep going. Comments on \'Sunday Square Off\' suggest she\'ll shut down prosecution stemming from 2020 election.\nPHOENIX — Is Arizona Attorney General Kris Mayes on the brink of ending her\nprosecution of the so-called “fake electors”?\nAfter\ncourtroom setbacks\nthat could\nforce her to seek new indictments\n, Mayes now faces a deadline less than two weeks away - on Nov. 21 - to either revive the case or allow it to be dismissed.\n>> Download the\n12News ap', textSize: 5460, title: 'Arizona AG Kris Mayes appears poised to drop \'fake electors\' case', url: 'https://12news.com/article/news/local/arizona/arizona-ag-kris-mayes-appears-poised-to-drop-fake-electors-case/75-05b5d302-6bb7-4929-9f7e-0e22a569302f'})
CREATE (n4936:Source {archivePath: 'ClaudeFiles\\archives\\kawc.org\\2026-02-28_d9c29066f674_article.txt', archiveStatus: 'captured', captureCount: 1, captureMethod: 'chrome-cli', captureStatus: 'captured', capturedAt: date('2026-02-28T20:16:08.923791000+00:00'), domain: 'kawc.org', htmlPath: 'ClaudeFiles\\archives\\kawc.org\\2026-02-28_d9c29066f674.html', lastCaptured: date('2026-02-28T20:16:08.923791000+00:00'), sourceType: 'unclassified', tags: [], textPreview: 'This site can’t be reached\nkawc.org\nunexpectedly closed the connection.\nERR_CONNECTION_CLOSED\nCheck any cables and reboot any routers, modems, or other network\ndevices you may be using.\nIf it is already listed as a program allowed to access the network, try\nremoving it from the list and adding it again.\nGo to\nthe Chrome menu >\nSettings\n>\nSystem\n>\nOpen your computer\'s proxy settings\n>\nNetwork & internet > Proxy\nand deselect "Automatically detect settings".\nkawc.org\nunexpectedly closed the connect', textSize: 504, title: 'kawc.org', url: 'https://kawc.org/news/2025-11-26/az-fake-electors-will-be-off-the-hook-after-26-election-if-ag-loses'})
CREATE (n4937:Source {archivePath: 'ClaudeFiles\\archives\\azmirror.com\\2026-02-28_0e918b0abf1d_article.txt', archiveStatus: 'captured', captureCount: 1, captureMethod: 'chrome-cli', captureStatus: 'captured', capturedAt: date('2026-02-28T20:16:11.874517000+00:00'), domain: 'azmirror.com', htmlPath: 'ClaudeFiles\\archives\\azmirror.com\\2026-02-28_0e918b0abf1d.html', lastCaptured: date('2026-02-28T20:16:11.874517000+00:00'), sourceType: 'unclassified', tags: [], textPreview: 'azmirror.com\nPerforming security verification\nThis website uses a security service to protect against malicious bots. This page is displayed while the website verifies you are not a bot.\nVerification successful. Waiting for azmirror.com to respond', textSize: 247, title: 'Just a moment...', url: 'https://azmirror.com/2025/11/21/mayes-asks-supreme-court-to-overturn-ruling-that-halted-her-fake-electors-case'})
CREATE (n4938:Source {archivePath: 'ClaudeFiles\\archives\\azmirror.com\\2026-02-28_cd5b2358b3aa_article.txt', archiveStatus: 'captured', captureCount: 1, captureMethod: 'chrome-cli', captureStatus: 'captured', capturedAt: date('2026-02-28T20:16:18.064247000+00:00'), domain: 'azmirror.com', htmlPath: 'ClaudeFiles\\archives\\azmirror.com\\2026-02-28_cd5b2358b3aa.html', lastCaptured: date('2026-02-28T20:16:18.064247000+00:00'), sourceType: 'unclassified', tags: [], textPreview: 'azmirror.com\nPerforming security verification\nThis website uses a security service to protect against malicious bots. This page is displayed while the website verifies you are not a bot.\nVerification successful. Waiting for azmirror.com to respond', textSize: 247, title: 'Just a moment...', url: 'https://azmirror.com/2025/11/10/trump-pardons-11-arizona-fake-electors-as-attorney-general-faces-deadline-to-refile-her-case'})
CREATE (n4939:Source {archivePath: 'ClaudeFiles\\archives\\azcapitoltimes.com\\2026-02-28_52d146bc8c5a_article.txt', archiveStatus: 'captured', author: 'bblasdell', captureCount: 1, captureMethod: 'http-readability', captureStatus: 'captured', capturedAt: date('2026-02-28T20:16:19.636170000+00:00'), domain: 'azcapitoltimes.com', htmlPath: 'ClaudeFiles\\archives\\azcapitoltimes.com\\2026-02-28_52d146bc8c5a.html', lastCaptured: date('2026-02-28T20:16:19.636170000+00:00'), publishedDate: '2025-08-22T15:54:36+00:00', siteName: 'Arizona Capitol Times | Your Inside Source for Arizona Government, Politics and Business', sourceType: 'unclassified', tags: [], textPreview: 'Key Points:\nTurning Point Action targets low-key utility board election for 2026\nGroup aims to prevent clean energy candidates from gaining more seats\nSRP’s election process is complicated, with only land-owning customers eligible\nAn often overlooked utility board election will get the Turning Point treatment in 2026 with the conservative group now seeking to prevent clean energy candidates from gaining more seats.\nElections for the Salt River Project’s two boards and two councils are usually qu', textSize: 6549, title: 'Turning Point Action sets sights on SRP board elections in 2026', url: 'https://azcapitoltimes.com/news/2025/08/22/turning-point-usa-sets-sights-on-srp-board-elections-in-2026'})
CREATE (n4940:Source {archivePath: 'ClaudeFiles\\archives\\kawc.org\\2026-02-28_1c408a1af2ec_article.txt', archiveStatus: 'captured', captureCount: 1, captureMethod: 'chrome-cli', captureStatus: 'captured', capturedAt: date('2026-02-28T20:16:22.383280000+00:00'), domain: 'kawc.org', htmlPath: 'ClaudeFiles\\archives\\kawc.org\\2026-02-28_1c408a1af2ec.html', lastCaptured: date('2026-02-28T20:16:22.383280000+00:00'), sourceType: 'unclassified', tags: [], textPreview: 'This site can’t be reached\nkawc.org\nunexpectedly closed the connection.\nERR_CONNECTION_CLOSED\nCheck any cables and reboot any routers, modems, or other network\ndevices you may be using.\nIf it is already listed as a program allowed to access the network, try\nremoving it from the list and adding it again.\nGo to\nthe Chrome menu >\nSettings\n>\nSystem\n>\nOpen your computer\'s proxy settings\n>\nNetwork & internet > Proxy\nand deselect "Automatically detect settings".\nkawc.org\nunexpectedly closed the connect', textSize: 504, title: 'kawc.org', url: 'https://kawc.org/news/2025-10-03/first-of-arizona-fake-electors-freed-from-probation'})
CREATE (n4941:Person {addedDate: date('2026-02-28'), description: 'One of 11 Arizona fake electors. Pled guilty to one misdemeanor count of filing a false instrument. Received 3 years probation, released early Oct 2025. First fake elector to resolve case via plea deal.', name: 'Loraine Pellegrino'})
CREATE (n4942:Event {addedDate: date('2026-02-28'), date: '2025-08-22', description: 'Turning Point Action launches voter registration campaign targeting Salt River Project utility board elections (April 7, 2026). Bowyer stated goal to \'out register the Democrats 10-1.\' Campaign aims to prevent clean energy-backed candidates from gaining seats. Canvassers active since at least June 2025. Represents TPUSA expanding from federal/state politics into local utility governance.', location: 'Arizona', name: 'TP Action Targets SRP Board Elections 2026'})
CREATE (n4943:EntryRef {streamEntryId: 'ls-20260228-007', title: 'Tyler Bowyer: Fake electors case at Supreme Court, TPUSA pivots to utility board politics'})
CREATE (n4944:Source {archivePath: 'ClaudeFiles\\archives\\en.wikipedia.org\\2026-02-28_ade58b778344_article.txt', archiveStatus: 'captured', captureCount: 1, captureMethod: 'http-readability', captureStatus: 'captured', capturedAt: date('2026-02-28T20:48:29.414983000+00:00'), domain: 'en.wikipedia.org', htmlPath: 'ClaudeFiles\\archives\\en.wikipedia.org\\2026-02-28_ade58b778344.html', lastCaptured: date('2026-02-28T20:48:29.414983000+00:00'), sourceType: 'unclassified', tags: [], textPreview: 'Process of managing a task through its life cycle\nExample of a\nkanban board\nused in\nsoftware development\nA\ndigital calendar\nin\nweek view\nwith\n24-hour time\nTask management\nis the process of overseeing a\ntask\nthrough its lifecycle. It involves planning, testing, tracking, and reporting. Task management can help individuals achieve goals or enable groups of individuals to collaborate and share knowledge for the accomplishment of collective goals.\n[\n1\n]\nTasks are also differentiated by complexity, f', textSize: 6691, title: 'Task management - Wikipedia', url: 'https://en.wikipedia.org/wiki/Task_management'})
CREATE (n4945:Source {archivePath: 'ClaudeFiles\\archives\\sltrib.com\\2026-02-28_e8de66cbcd7b_article.txt', archiveStatus: 'captured', captureCount: 1, captureMethod: 'http-readability', captureStatus: 'captured', capturedAt: date('2026-02-28T21:03:12.532026000+00:00'), domain: 'sltrib.com', htmlPath: 'ClaudeFiles\\archives\\sltrib.com\\2026-02-28_e8de66cbcd7b.html', lastCaptured: date('2026-02-28T21:03:12.532026000+00:00'), siteName: 'The Salt Lake Tribune', sourceType: 'unclassified', tags: [], textPreview: 'Minutes before Charlie Kirk was\nshot and killed\nat Utah Valley University, the conservative Christian political activist said, “First of all, I love Mormons.”\nThe 31-year-old evangelical knew he was\nspeaking to an audience\nthat included many members of The Church of Jesus Christ of Latter-day Saints. But he also recognized the contribution of his\nTurning Point Action\nteam, some of whom were Latter-day Saints, particularly his chief operating officer,\nTyler Bowyer\n.\n“I love how Mormons send missi', textSize: 6467, title: 'Can LDS and evangelicals coexist in Charlie Kirk’s Turning Point?', url: 'https://sltrib.com/religion/2025/11/24/can-lds-evangelicals-coexist'})
CREATE (n4946:Source {archivePath: 'ClaudeFiles\\archives\\humanevents.com\\2026-02-28_b925aef2e8a4_article.txt', archiveStatus: 'captured', author: 'Human Events CMS', captureCount: 1, captureMethod: 'http-readability', captureStatus: 'captured', capturedAt: date('2026-02-28T21:03:16.256864000+00:00'), domain: 'humanevents.com', htmlPath: 'ClaudeFiles\\archives\\humanevents.com\\2026-02-28_b925aef2e8a4.html', lastCaptured: date('2026-02-28T21:03:16.256864000+00:00'), siteName: 'Human Events', sourceType: 'unclassified', tags: [], textPreview: 'Human Events Daily with\nJack Posobiec\nkicked off on Wednesday live from CPAC, featuring several speakers who joined Posobiec to discuss global conflicts and health issues, among a variety of topics.\nPosobiec spoke with Tyler Bowyer, COO of Turning Point Action, who shared his unique perspective on the ongoing war in Ukraine, having spent two years in the Donbas region as a Christian missionary.\nPosobiec asked, "You have a unique understanding of all of this situation because you were there, you ', textSize: 3116, title: 'JACK POSOBIEC and TYLER BOWYER: Ukrainians and Russians ‘want nothing more’ than for Trump to get the war ended', url: 'https://humanevents.com/2025/02/20/jack-posobiec-and-tyler-bowyer-ukrainians-and-russians-want-nothing-more-than-for-trump-to-get-the-war-ended'})
CREATE (n4947:Source {archivePath: 'ClaudeFiles\\archives\\kuer.org\\2026-02-28_478077498e0e_article.txt', archiveStatus: 'captured', captureCount: 1, captureMethod: 'chrome-cli', captureStatus: 'captured', capturedAt: date('2026-02-28T21:03:19.047463000+00:00'), domain: 'kuer.org', htmlPath: 'ClaudeFiles\\archives\\kuer.org\\2026-02-28_478077498e0e.html', lastCaptured: date('2026-02-28T21:03:19.047463000+00:00'), sourceType: 'unclassified', tags: [], textPreview: 'This site can’t be reached\nkuer.org\nunexpectedly closed the connection.\nERR_CONNECTION_CLOSED\nCheck any cables and reboot any routers, modems, or other network\ndevices you may be using.\nIf it is already listed as a program allowed to access the network, try\nremoving it from the list and adding it again.\nGo to\nthe Chrome menu >\nSettings\n>\nSystem\n>\nOpen your computer\'s proxy settings\n>\nNetwork & internet > Proxy\nand deselect "Automatically detect settings".\nkuer.org\nunexpectedly closed the connect', textSize: 504, title: 'kuer.org', url: 'https://kuer.org/race-religion-social-justice/2025-09-21/faith-resonates-for-utah-latter-day-saints-gathered-to-watch-charlie-kirks-memorial'})
CREATE (n4948:Event {addedDate: date('2026-02-28'), description: 'Two-year LDS mission to Russia. First area included closest Latter-day Saint congregation to Ukraine\'s border (congregation no longer exists). Lived in Russian town closest to Ukrainian border. Maintains friends on both sides of the Donbas conflict line. Credits mission with providing organizing skills that led to political career.', endDate: '2007', eventType: 'mission', location: 'Russia, near Ukraine border (Donbas region)', name: 'Tyler Bowyer LDS Mission to Russia', significance: 'Formative experience connecting Bowyer to Russia/Ukraine region. Provides personal basis for his public commentary on the Russia-Ukraine war and his claim that people on both sides want Trump to resolve the conflict.', startDate: '2005'})
CREATE (n4949:EntryRef {streamEntryId: 'ls-20260228-012', title: 'Bowyer\'s Russia mission near Ukraine border: personal connection, not family mission work'})
CREATE (n4950:Source {archivePath: 'ClaudeFiles\\archives\\brianference.com\\2026-02-28_c[phone redacted]f_article.txt', archiveStatus: 'captured', author: 'Brian Ference', captureCount: 1, captureMethod: 'http-readability', captureStatus: 'captured', capturedAt: date('2026-02-28T21:15:17.238474000+00:00'), domain: 'brianference.com', htmlPath: 'ClaudeFiles\\archives\\brianference.com\\2026-02-28_c[phone redacted]f.html', lastCaptured: date('2026-02-28T21:15:17.238474000+00:00'), publishedDate: '2025-10-31T20:47:13+00:00', siteName: 'BRIANFERENCE.COM |', sourceType: 'unclassified', tags: [], textPreview: '2015 Vote of No Confidence Reveals Allegations of Misuse of Funds by MCRC Chairman Tyler Bowyer\nby\nBrian Ference\n|\nI have written extensively about the\npattern of lying and corruption from Superfeed Technologies CEO and Turning Point Action CEO Tyler Bowyer\n. In an exclusive interview with a former board member who served with Tyler Bowyer when he was the Maricopa County Republican Chairman in 2015,\nBowyer, who was also an Employee of TPUSA at the time, was accused of misusing GOP County funds i', textSize: 2139, title: '2015 Vote of No Confidence Reveals Allegations of Misuse of Funds by MCRC Chairman Tyler Bowyer', url: 'https://brianference.com/2015-vote-of-no-confidence-reveals-allegations-of-misuse-of-funds-by-mcrc-chairman-tyler-bowyer'})
CREATE (n4951:Source {archivePath: 'ClaudeFiles\\archives\\wildcat.arizona.edu\\2026-02-28_dadcb034c710_article.txt', archiveStatus: 'captured', author: 'Brenna Goth', captureCount: 1, captureMethod: 'http-readability', captureStatus: 'captured', capturedAt: date('2026-02-28T21:15:18.363768000+00:00'), domain: 'wildcat.arizona.edu', htmlPath: 'ClaudeFiles\\archives\\wildcat.arizona.edu\\2026-02-28_dadcb034c710.html', lastCaptured: date('2026-02-28T21:15:18.363768000+00:00'), siteName: 'The Daily Wildcat', sourceType: 'unclassified', tags: [], textPreview: 'Arizona State University student Tyler Bowyer was appointed as the newest student regent on the Arizona Board of Regents by Gov. Jan Brewer last month. A new student regent is selected every year, rotating between the three state universities. Though regents are typically selected from recommendations made by a selection committee at the university, Bowyer applied directly through Gov. Brewer’s office. He will replace Northern Arizona University Student Regent Jennifer Ginther and serve a two-ye', textSize: 4495, title: 'Governor appoints new student regent', url: 'https://wildcat.arizona.edu/104263/news/governor-appoints-new-student-regent'})
CREATE (n4952:Source {archivePath: 'ClaudeFiles\\archives\\wildcat.arizona.edu\\2026-02-28_16b7743691fb_article.txt', archiveStatus: 'captured', author: 'Storm Byrd', captureCount: 1, captureMethod: 'http-readability', captureStatus: 'captured', capturedAt: date('2026-02-28T21:15:22.652381000+00:00'), domain: 'wildcat.arizona.edu', htmlPath: 'ClaudeFiles\\archives\\wildcat.arizona.edu\\2026-02-28_16b7743691fb.html', lastCaptured: date('2026-02-28T21:15:22.652381000+00:00'), siteName: 'The Daily Wildcat', sourceType: 'unclassified', tags: [], textPreview: 'Last month Gov. Jan Brewer set another “”oh no she didn’t”” precedent by appointing Arizona State University student Tyler Bowyer to the Arizona Board of Regents. Bowyer is the current president of the College Republicans at ASU and this semester went on an all-out power grab, running for student body president and going after the student regent position. Bowyer disregarded the traditional application process for the student regent position and just submitted an application to the governor’s off', textSize: 4349, title: 'New regent disrespects Arizona’s students', url: 'https://wildcat.arizona.edu/141687/opinions/new-regent-disrespects-arizonas-students'})
CREATE (n4953:Source {archivePath: 'ClaudeFiles\\archives\\maricopacountyrepublicans.blogspot.com\\2026-02-28_75171eb4d969_article.txt', archiveStatus: 'captured', captureCount: 1, captureMethod: 'http-readability', captureStatus: 'captured', capturedAt: date('2026-02-28T21:15:25.008594000+00:00'), domain: 'maricopacountyrepublicans.blogspot.com', htmlPath: 'ClaudeFiles\\archives\\maricopacountyrepublicans.blogspot.com\\2026-02-28_75171eb4d969.html', lastCaptured: date('2026-02-28T21:15:25.008594000+00:00'), sourceType: 'unclassified', tags: [], textPreview: 'Tyler\nBowyer has taken the first in what has been rumored to be a set of revenge\nmaneuvers against those officer that voted for the recent “no confidence\nresolution” of Chairman Bowyer.\nThe\nArizona Capitol Times’ Yellow Sheet has covered many of Bowyer’s many\nmisrepresentations, failures and missteps, culminating in 14 of his officers\nvoting that they have no confidence in him.  As a result he has begun a revenge\ncampaign.\nFollowing\nthe ‘no confidence vote’ Bowyer directed member-at-large Andrew', textSize: 2106, title: 'Has Chairman Tyler Bowyer Proved Unfit to Lead Maricopa County Republican Party?', url: 'https://maricopacountyrepublicans.blogspot.com/2015/11/has-chairman-tyler-bowyer-proved-unfit.html'})
CREATE (n4954:Source {archivePath: 'ClaudeFiles\\archives\\azcapitoltimes.com\\2026-02-28_ab57cb9c4785_article.txt', archiveStatus: 'captured', captureCount: 1, captureMethod: 'http-readability', captureStatus: 'captured', capturedAt: date('2026-02-28T21:15:26.919788000+00:00'), domain: 'azcapitoltimes.com', htmlPath: 'ClaudeFiles\\archives\\azcapitoltimes.com\\2026-02-28_ab57cb9c4785.html', lastCaptured: date('2026-02-28T21:15:26.919788000+00:00'), sourceType: 'unclassified', tags: [], textPreview: 'Feb 7, 2013\nGov. Jan Brewer asked the Arizona Board of Regents to support her controversial AHCCCS expansion plan, arguing that it would free up general fund money for higher education.\nThe regents, the majority of whom are Brewer appointees, quickly granted her request, passing a resolution in support of both her overall budget plan and her proposal to increase Medicaid coverage under the Affordab[...]', textSize: 406, title: 'Regent Tyler Bowyer', url: 'https://azcapitoltimes.com/news/tag/regent-tyler-bowyer'})
CREATE (n4955:EntryRef {streamEntryId: 'ls-20260228-013', title: 'Bowyer\'s pre-TPUSA political career: a pattern of institutional shortcuts and contested leadership'})
CREATE (n4956:Source {archivePath: 'ClaudeFiles\\archives\\edition.cnn.com\\2026-02-28_e54a6a013fe4_article.txt', archiveStatus: 'captured', author: 'Andrew Kaczynski,Em Steck,Kyung Lah', captureCount: 1, captureMethod: 'http-readability', captureStatus: 'captured', capturedAt: date('2026-02-28T21:27:56.410568000+00:00'), domain: 'edition.cnn.com', htmlPath: 'ClaudeFiles\\archives\\edition.cnn.com\\2026-02-28_e54a6a013fe4.html', lastCaptured: date('2026-02-28T21:27:56.410568000+00:00'), publishedDate: '2023-11-10T13:29:30Z', siteName: 'CNN', sourceType: 'unclassified', tags: [], textPreview: 'CNN\n—\nThey called it “The Signing.” Eleven fake electors for President Donald Trump convened at the state Republican Party headquarters in Phoenix, Arizona, on December 14, 2020. They\nbroadcast themselves\npreparing to sign the documents, allegedly\nprovided by\na Trump campaign attorney, claiming that they were the legitimate representatives of the state’s electoral votes.\nBy that time, Trump’s loss in the state – by less than 11,000 votes – had already been certified by the state’s Republican gov', textSize: 7951, title: 'Arizona fake electors led vocal campaign to overturn the 2020 election - they’re now part of a ‘robust’ state investigation', url: 'https://edition.cnn.com/2023/11/10/politics/arizona-fake-electors-kifle-invs'})
CREATE (n4957:Person {addedDate: date('2026-02-28'), description: 'Republican Governor of Arizona (2009-2015). Appointed Tyler Bowyer to the Arizona Board of Regents as student regent, bypassing the traditional Arizona Students\' Association selection process. Bowyer applied directly to Brewer\'s Office of Boards and Commissions rather than through the ASA rotation system.', endDate: '2015-01', name: 'Jan Brewer', party: 'Republican', role: 'Governor of Arizona', startDate: '2009-01'})
CREATE (n4958:Person {addedDate: date('2026-02-28'), description: 'Member-at-large of the Maricopa County Republican Committee under Chairman Tyler Bowyer. Directed by Bowyer to call for a new election in LD 30 following the no-confidence vote, violating county and district bylaws by ignoring officer nomination procedures, notice requirements, and election procedures.', name: 'Andrew Costanzo', role: 'MCRC Member-at-Large'})
CREATE (n4959:Person {addedDate: date('2026-02-28'), description: 'Arizona attorney who issued a legal opinion finding that the LD 30 election called by Tyler Bowyer and Andrew Costanzo \'deviates substantially\' from county and district bylaws and was not legally binding.', name: 'Kory Langhofer', role: 'Attorney'})
CREATE (n4960:Person {addedDate: date('2026-02-28'), description: 'Arizona Republican Party legal counsel who issued an opinion stating there was nothing legally binding about the rogue LD 30 meeting organized by Tyler Bowyer and Andrew Costanzo at the Maricopa County Republican Committee.', name: 'Tim LaSota', role: 'AZ GOP Legal Counsel'})
CREATE (n4961:EntryRef {streamEntryId: 'ls-20260228-014', title: 'Bowyer\'s Political Rise: Brewer Appointment, MCRC Chairmanship, and Institutional Pattern'})
CREATE (n4962:Source {archivePath: 'ClaudeFiles\\archives\\conandaily.com\\2026-02-28_f61e28e22b39_article.txt', archiveStatus: 'captured', captureCount: 1, captureMethod: 'wayback', captureStatus: 'captured', capturedAt: date('2026-02-28T23:59:34.767142000+00:00'), domain: 'conandaily.com', htmlPath: 'ClaudeFiles\\archives\\conandaily.com\\2026-02-28_f61e28e22b39.html', lastCaptured: date('2026-02-28T23:59:34.767142000+00:00'), publishedDate: '2021-08-20T07:27:00+00:00', siteName: 'CONAN Daily', sourceType: 'unclassified', tags: [], textPreview: 'Xaria Penn biography: 13 things about Miss Universe British Virgin Islands 2021\nXaria Penn is a model and beauty queen from theÂ United States Virgin Islands. Here are 13 more things about her: She attended British Virgin IslandsÂ Seventh-dayÂ Adventist SchoolÂ (BVA SDA School) inÂ Tortola, British Virgin Islands. […]\nNick Maximov biography: 13 things about UFC fighter from Chico, California\nNicholas Ivan “Nick” Maximov is an undefeated professional mixed martial artist from California, United S', textSize: 1603, title: 'Miss New York USA 2021 results: Andreia Gibau crowns Briana Siaca in Monticello', url: 'https://conandaily.com/2021/08/20/miss-new-york-usa-2021-results-andreia-gibau-crowns-briana-siaca-in-monticello', waybackUrl: 'http://web.archive.org/web/[phone redacted]4717/https://conandaily.com/2021/08/20/miss-new-york-usa-2021-results-andreia-gibau-crowns-briana-siaca-in-monticello/'})
CREATE (n4963:Source {archivePath: 'ClaudeFiles\\archives\\yahoo.com\\2026-02-28_feae9191d994_article.txt', archiveStatus: 'captured', captureCount: 1, captureMethod: 'http-readability', captureStatus: 'captured', capturedAt: date('2026-02-28T23:59:36.937909000+00:00'), domain: 'yahoo.com', htmlPath: 'ClaudeFiles\\archives\\yahoo.com\\2026-02-28_feae9191d994.html', lastCaptured: date('2026-02-28T23:59:36.937909000+00:00'), siteName: 'Yahoo Life', sourceType: 'unclassified', tags: [], textPreview: 'For richer or\nbroker\n, Briana Siaca is married to NYC real estate.\nBut closing multimillion-dollar deals on Gotham’s finest addresses wasn’t her first love. Instead, it’s become the former Miss New York USA’s glitzy second act.\n“Pageantry\ngave me a tough skin\n, it boosted my confidence and taught me tenacity,” Siaca, 30, a first-year realtor with luxury brokerage the Corcoran Group, told The Post.\nBriana Siaca developed inner strength and grit while competing for the crown of Miss New York USA f', textSize: 6282, title: 'From the runway to real estate - 3 fashionistas who ditched glam gigs to sell NYC', url: 'https://yahoo.com/lifestyle/runway-real-estate-3-fashionistas-161533468.html'})
CREATE (n4964:Source {archivePath: 'ClaudeFiles\\archives\\thecinemaholic.com\\2026-02-28_b73e68e1bbf8_article.txt', archiveStatus: 'captured', author: 'Kriti Mehrotra', captureCount: 1, captureMethod: 'http-readability', captureStatus: 'captured', capturedAt: date('2026-02-28T23:59:41.997366000+00:00'), domain: 'thecinemaholic.com', htmlPath: 'ClaudeFiles\\archives\\thecinemaholic.com\\2026-02-28_b73e68e1bbf8.html', lastCaptured: date('2026-02-28T23:59:41.997366000+00:00'), publishedDate: '2025-12-06T22:33:26+00:00', siteName: 'The Cinemaholic', sourceType: 'unclassified', tags: [], textPreview: 'As someone who never walks away from a challenge and has a hunger to consistently prove herself, Netflix’s\n‘Owning Manhattan’\nseason 2 star Genesis Suero should never be underestimated. She proves the same throughout her stint in the reality television production, especially by juggling two jobs with the utmost professionalism and never once letting one affect the other. It thus comes as no surprise that fans are now all the more curious about the career trajectory and overall net worth of this ', textSize: 4497, title: 'How Rich is the Owning Manhattan Star?', url: 'https://thecinemaholic.com/genesis-suero-net-worth'})
CREATE (n4965:Person {addedDate: date('2026-03-01'), corcoranAgent: true, corcoranAgentId: '120409', description: 'Miss New York USA 2021. Licensed real estate agent at Corcoran Group (August 2023-present). Native Long Islander. Competed in Miss New York USA for six years before winning in 2021. Also competed at Miss USA 2021. Sold a $3.5M property in her first year at Corcoran. Featured in New York Post article about pageant-to-real-estate career transitions.', name: 'Briana Siaca', pageantTitle: 'Miss New York USA 2021'})
CREATE (n4966:Person {addedDate: date('2026-03-01'), corcoranAgent: true, corcoranAgentId: '18168', corcoranTenure: 'September 2018-September 2020', description: 'Miss New York USA 2018. First Dominican immigrant to win the title. Real estate agent at Corcoran Group (September 2018-September 2020), then joined Nile Lundgren Team at SERHANT (March 2022-present). Star of Netflix Owning Manhattan season 2. Also New York Correspondent for NBCUniversal Telemundo Enterprises (February 2022-present). Born in Dominican Republic, relocated to US at age 13. CUNY Hostos Community College, later City College of New York. Previously Skincare Specialist at Estee Lauder Bloomingdale\'s.', name: 'Genesis Suero', pageantTitle: 'Miss New York USA 2018'})
CREATE (n4967:EntryRef {streamEntryId: 'ls-20260228-016', title: 'Pageant-to-Corcoran Pipeline: Three Miss USA System Titleholders Found in Agent Database'})
CREATE (n4968:Source {archivePath: 'ClaudeFiles\\archives\\whitestationscroll.net\\2026-03-01_7119baeb585a_article.txt', archiveStatus: 'captured', author: 'Rebekah Butler', captureCount: 1, captureMethod: 'http-readability', captureStatus: 'captured', capturedAt: date('2026-03-01T00:55:02.346466000+00:00'), domain: 'whitestationscroll.net', htmlPath: 'ClaudeFiles\\archives\\whitestationscroll.net\\2026-03-01_7119baeb585a.html', lastCaptured: date('2026-03-01T00:55:02.346466000+00:00'), siteName: 'White Station Scroll', sourceType: 'unclassified', tags: [], textPreview: 'Beautiful gowns flow as the teenagers of Tennessee prepare for the annual Miss TN Teen USA pageant. Annie Zhao (11) was one of the many girls chosen to compete for this prestigious title.\nZhao began her journey in pageantry in 2018 when she saw Catriona Gray strut across the stage after winning Miss Universe.\n“I was stunned by her confidence, grace, the things she has done for her community and her compassion,” Zhao said. “I thought that this was very interesting. This isn’t just about looks; th', textSize: 5635, title: 'Zhao wins Miss Tennessee Teen pageant', url: 'https://whitestationscroll.net/6484/student-life/annie-zhao-wins-the-miss-tn-teen-pageant'})
CREATE (n4969:Source {archivePath: 'ClaudeFiles\\archives\\billingsgazette.com\\2026-03-01_b875a78b23e3_article.txt', archiveStatus: 'captured', author: '', captureCount: 1, captureMethod: 'http-readability', captureStatus: 'captured', capturedAt: date('2026-03-01T00:55:03.965707000+00:00'), domain: 'billingsgazette.com', htmlPath: 'ClaudeFiles\\archives\\billingsgazette.com\\2026-03-01_b875a78b23e3.html', lastCaptured: date('2026-03-01T00:55:03.965707000+00:00'), siteName: 'Billings Gazette', sourceType: 'unclassified', tags: [], textPreview: 'State\nAlabama\nAlaska\nArizona\nArkansas\nCalifornia\nColorado\nConnecticut\nDelaware\nFlorida\nGeorgia\nHawaii\nIdaho\nIllinois\nIndiana\nIowa\nKansas\nKentucky\nLouisiana\nMaine\nMaryland\nMassachusetts\nMichigan\nMinnesota\nMississippi\nMissouri\nMontana\nNebraska\nNevada\nNew Hampshire\nNew Jersey\nNew Mexico\nNew York\nNorth Carolina\nNorth Dakota\nOhio\nOklahoma\nOregon\nPennsylvania\nRhode Island\nSouth Carolina\nSouth Dakota\nTennessee\nTexas\nUtah\nVermont\nVirginia\nWashington\nWashington D.C.\nWest Virginia\nWisconsin\nWyoming\nPuerto', textSize: 6213, title: 'Miss Wyoming and Miss Teen Wyoming crowned', url: 'https://billingsgazette.com/news/state-and-regional/wyoming/miss-wyoming-and-miss-teen-wyoming-crowned/article_85a60aa7-e44d-511d-b1ea-87d1a216ec64.html'})
CREATE (n4970:Source {archivePath: 'ClaudeFiles\\archives\\nutrishopusa.com\\2026-03-01_93fba3ae7890_article.txt', archiveStatus: 'captured', captureCount: 1, captureMethod: 'http-readability', captureStatus: 'captured', capturedAt: date('2026-03-01T00:55:05.963964000+00:00'), domain: 'nutrishopusa.com', htmlPath: 'ClaudeFiles\\archives\\nutrishopusa.com\\2026-03-01_93fba3ae7890.html', lastCaptured: date('2026-03-01T00:55:05.963964000+00:00'), siteName: 'NUTRISHOP®', sourceType: 'unclassified', tags: [], textPreview: 'Kelley Johnson was crowned Miss California USA and awarded Top 10 at the 2018 Miss USA competition. Within this role, Kelley has modeled, hosted, and created content for both brand social media and television, and served as a community liaison for the Miss Universe Organization. Previously, she represented\nthe Miss Colorado Organization across the nation as Miss Colorado. Kelley competed for the title of Miss America 2016 and was awarded second runner up.\nKelley is remembered for her nursing mon', textSize: 10659, title: 'Beyond the Crown: Kelley Johnson', url: 'https://nutrishopusa.com/blogs/learning-center/beyond-the-crown-kelley-johnson'})
CREATE (n4971:Source {archivePath: 'ClaudeFiles\\archives\\pageantupdate.info\\2026-03-01_edb9aec2636d_article.txt', archiveStatus: 'captured', captureCount: 1, captureMethod: 'http-readability', captureStatus: 'captured', capturedAt: date('2026-03-01T00:55:09.084570000+00:00'), domain: 'pageantupdate.info', htmlPath: 'ClaudeFiles\\archives\\pageantupdate.info\\2026-03-01_edb9aec2636d.html', lastCaptured: date('2026-03-01T00:55:09.084570000+00:00'), siteName: 'Pageant Update', sourceType: 'unclassified', tags: [], textPreview: 'Miss Tennessee Teen USA 2010 Kristen Rose\nKristen Rose, 18, of Bristol was Miss TN Teen USA 2010 & a semi-finalist at Miss Teen USA 2010\nMiss Tennessee Teen USA 2011 Kaitlin White\nKaitlin White, 18, of Nashville was Miss TN Teen USA 2011\nMiss Tennessee Teen USA 2012 Shanese Brown\nShanese Brown, 17, of Madison was Miss TN Teen USA 2012\nMiss Tennessee Teen USA 2013 Emily Suttle\nEmily Suttle, 17, of Franklin was Miss TN Teen USA 2013 & a semi-finalist at Miss Teen USA 2013\nMiss Tennessee Teen USA 2', textSize: 3822, title: 'Miss Tennessee Teen USA 2021 Annie Zhao', url: 'https://pageantupdate.info/profiles/miss-tennessee-teen-usa-2021'})
CREATE (n4972:Source {archivePath: 'ClaudeFiles\\archives\\en.wikipedia.org\\2026-03-01_be50afeb6af1_article.txt', archiveStatus: 'captured', captureCount: 1, captureMethod: 'http-readability', captureStatus: 'captured', capturedAt: date('2026-03-01T00:55:10.743168000+00:00'), domain: 'en.wikipedia.org', htmlPath: 'ClaudeFiles\\archives\\en.wikipedia.org\\2026-03-01_be50afeb6af1.html', lastCaptured: date('2026-03-01T00:55:10.743168000+00:00'), sourceType: 'unclassified', tags: [], textPreview: 'Miss Colorado 2015\nKelley Elizabeth Johnson\n(born October 22, 1992) is an American nurse, television host and beauty pageant titleholder. In addition to being a Chief Nurse Advocate, she is also a doctoral student, keynote speaker and national spokeswoman.\nKelly Johnson was also crowned\nMiss Colorado\n2015 and placing second runner-up at\nMiss America 2016\n. Johnson later won\nMiss California USA\n2018. She placed in the top 10 at\nMiss USA 2018\n.\nEarly life and education\n[\nedit\n]\nJohnson was born in', textSize: 7027, title: 'Kelley Johnson - Wikipedia', url: 'https://en.wikipedia.org/wiki/Kelley_Johnson'})
CREATE (n4973:Person {addedDate: date('2026-03-01'), corcoranAgentId: '108510', corcoranSlug: 'annie-zhao', description: 'First Asian American crowned in the Tennessee USA system. Senior at White Station High School in Memphis when crowned March 2021. Now a licensed RE salesperson at Corcoran in New York.', hometown: 'Memphis, Tennessee', name: 'Annie Zhao', pageantTitle: 'Miss Tennessee Teen USA 2021'})
CREATE (n4974:Person {addedDate: date('2026-03-01'), alsoKnownAs: 'Jamie Gorman Aronson', corcoranAgentId: '25042', corcoranSlug: 'jamie-gorman', description: 'Miss Wyoming USA 2003. Founder/CEO of Only Nine Apparel and JG HOMES boutique brokerage on Long Island. Former Corcoran agent (Sag Harbor).', name: 'Jamie Gorman', pageantTitle: 'Miss Wyoming USA 2003'})
CREATE (n4975:Person {addedDate: date('2026-03-01'), alsoKnownAs: 'Kelley Elizabeth Johnson', corcoranAgentId: '18240', corcoranSlug: 'kelley-johnson', description: 'Nurse, TV host, pageant titleholder. Miss Colorado 2015, 2nd runner-up Miss America 2016, Miss CA USA 2018, Top 10 Miss USA 2018. RN with MSN. Famous #NursesUnite nursing monologue. Now Corcoran real estate agent.', name: 'Kelley Johnson', pageantTitle: 'Miss California USA 2018'})
CREATE (n4976:EntryRef {streamEntryId: 'ls-20260228-018', title: 'Pageant-to-Corcoran cross-reference: CDX roster analysis confirms 6 total connections'})
CREATE (n4977:Document {addedDate: date('2026-03-01'), createdDate: '2026-02-28', description: '5,909 state titleholders from Miss USA (3,715 records, 1951-2025) and Miss Teen USA (2,194 records, 1983-2025) systems, scraped from Wikipedia state pageant pages. Columns: year, pageant, state, name, placement, hometown, age, notes. Used for cross-referencing against Corcoran agent rosters.', docType: 'dataset', filePath: 'ClaudeFiles/pageant_contestants_missusa_missteenusa.csv', format: 'csv', name: 'Pageant Contestants Dataset (Miss USA / Miss Teen USA)', recordCount: 5909, source: 'Wikipedia state pageant pages (all 51 jurisdictions x 2 systems)'})
CREATE (n4978:Source {archivePath: 'ClaudeFiles\\archives\\eastendli.com\\2026-03-01_06272d8b2f4a_article.txt', archiveStatus: 'captured', captureCount: 1, captureMethod: 'http-readability', captureStatus: 'captured', capturedAt: date('2026-03-01T01:08:47.936058000+00:00'), domain: 'eastendli.com', htmlPath: 'ClaudeFiles\\archives\\eastendli.com\\2026-03-01_06272d8b2f4a.html', lastCaptured: date('2026-03-01T01:08:47.936058000+00:00'), sourceType: 'unclassified', tags: [], textPreview: 'About Jamie Gorman (MR)\nJamie Gorman has a flair for business and an eye for style which allow her to excel in the dynamic world of real estate. As founder and CEO of the highly successful Only Nine Apparel, a women\'s wholesale apparel firm focused on body positivity, Jamie honed her diverse set of skills that elevates her current residential sales practice. With sales leading the way, Jamie\'s strengths also include, the areas of strategic development, design, marketing/public relations (both pr', textSize: 2400, title: 'Jamie Gorman (MR) Of Corcoran Group (Sag Harbor) In Sag Harbor NY', url: 'https://eastendli.com/profiles/ny/sag-harbor/corcoran-group-sag-harbor/jamie-gorman-mr/529031'})
CREATE (n4979:EntryRef {streamEntryId: 'ls-20260228-019', title: 'Pageant-to-Corcoran pipeline: 6 confirmed, remaining matches are name coincidences'})
CREATE (n4980:Source {archivePath: 'ClaudeFiles\\archives\\gazette.com\\2026-03-01_1d9fd36aa498_article.txt', archiveStatus: 'captured', captureCount: 1, captureMethod: 'http-readability', captureStatus: 'captured', capturedAt: date('2026-03-01T01:24:29.629210000+00:00'), domain: 'gazette.com', htmlPath: 'ClaudeFiles\\archives\\gazette.com\\2026-03-01_1d9fd36aa498.html', lastCaptured: date('2026-03-01T01:24:29.629210000+00:00'), siteName: 'Colorado Springs Gazette', sourceType: 'unclassified', tags: [], textPreview: 'A Colorado real estate agent representing Colorado Springs in the Miss Colorado USA 2022 won the pageant held in Greeley this year and will be heading to the 71st Miss USA Pageant.\n“Colorado, it’s us until the end; 12-year-old Alexis is screaming. I think I can finally say this without crying. … We’re going to Miss USA,” pageant winner Alexis Glover said on her Instagram.\nGlover, who is 22, describes the experience of being on stage as “extremely nerve-wracking” but said she also enjoys the adre', textSize: 2337, title: 'Colorado Springs real estate agent named Miss Colorado USA', url: 'https://gazette.com/arts-entertainment/colorado-springs-real-estate-agent-named-miss-colorado-usa/article_fa1e5252-fd92-11ec-a[phone redacted]03ce0.html'})
CREATE (n4981:Source {archivePath: 'ClaudeFiles\\archives\\conandaily.com\\2026-03-01_5581e5e0a3fe_article.txt', archiveStatus: 'captured', captureCount: 1, captureMethod: 'http-readability', captureStatus: 'captured', capturedAt: date('2026-03-01T01:24:30.912426000+00:00'), domain: 'conandaily.com', htmlPath: 'ClaudeFiles\\archives\\conandaily.com\\2026-03-01_5581e5e0a3fe.html', lastCaptured: date('2026-03-01T01:24:30.912426000+00:00'), publishedDate: '2023-07-17T00:30:00+00:00', siteName: 'CONAN Daily', sourceType: 'unclassified', tags: [], textPreview: 'Alexis Glover\nis a real estate agent and a beauty queen from Colorado, United States. She is the proprietor of Alexis, LLC.\nGlover is 5’7″ tall. Here are 10 more things about her:\nShe is originally from Colorado Springs, El Paso County, Colorado.\nWhen she attended\nRampart High School\nin Colorado Springs, she was the captain of the varsity cheerleading team and she was in multiple advanced placement classes.\nShe has three younger siblings.\nShe is\nMiss Colorado High School America 2016\n.\nShe is\nMi', textSize: 1615, title: 'Alexis Glover biography: 10 things about Miss Colorado USA 2022', url: 'https://conandaily.com/2023/07/16/alexis-glover-biography-10-things-about-miss-colorado-usa-2022'})
CREATE (n4982:Person {addedDate: date('2026-03-01'), description: 'Miss Colorado USA 2022 and Miss Colorado Teen USA 2017. Licensed real estate agent at Buy Smart Colorado, Colorado Springs. Proprietor of Alexis LLC. Native of Colorado Springs. Rampart High School graduate, attended University of Northern Colorado before leaving for real estate license. Involved in pageantry since age 12. First runner-up at Miss Colorado USA 2021 before winning in 2022. Unplaced at Miss USA 2022 (Reno). Advocates for youth financial literacy and mental health awareness.', highSchool: 'Rampart High School, Colorado Springs', hometown: 'Colorado Springs, CO', name: 'Alexis Glover', pageantTitle: 'Miss Colorado USA 2022', pageantTitles: ['Miss Colorado High School America 2016', 'Miss Colorado Teen USA 2017', 'National American Miss Colorado Teen 2018', 'Miss Colorado USA 2022'], realEstateBrokerage: 'Buy Smart Colorado', roles: ['Real Estate Agent', 'Beauty Queen', 'Entrepreneur']})
CREATE (n4983:Person {addedDate: date('2026-03-01'), currentRole: 'Regional Business Development Manager, Bolt Security Guard Services (Nashville TN office)', description: 'Miss Arizona Teen USA 2006. Top 10 at Miss Teen USA 2006 (youngest contestant at 15). Notre Dame Preparatory student, Scottsdale. Sister of Alexa Zellers (Miss Arizona Teen USA 2012).', email: '[redacted]', highSchool: 'Notre Dame Preparatory, Scottsdale', location: 'Nashville, TN', name: 'Emerald Zellers', notes: 'Miss AZ Teen USA 2006 (crowned Nov 6, 2005). Top 10 at Miss Teen USA 2006 in Palm Springs — youngest contestant at 15. NDP student. Arizona Angels Dance Team member. Performed at President George W. Bush\'s 2005 inaugural parade. Daughter of Brad and Diana Zellers.', pageantTitle: 'Miss Arizona Teen USA 2006', roles: ['Beauty Queen']})
CREATE (n4984:Person {addedDate: date('2026-03-01'), description: 'Miss Arizona Teen USA 2012. Notre Dame Preparatory student, Scottsdale. Sister of Emerald Zellers (Miss Arizona Teen USA 2006). First runner-up at Miss Arizona USA in both 2018 and 2020.', highSchool: 'Notre Dame Preparatory, Scottsdale', name: 'Alexa Zellers', notes: 'Miss AZ Teen USA 2012 (crowned Nov 20, 2011). Competed at Miss Teen USA 2012 in Bahamas. NDP student. Attended Lindenwood University on titleholder scholarship, member of Lindenwood Lionettes dance team. Now Alexa Alsadek (married Jacob Alsadek). Works as Marketing Assistant at father\'s company BSN Security LLC.', pageantTitle: 'Miss Arizona Teen USA 2012', roles: ['Beauty Queen']})
CREATE (n4985:Source {archivePath: 'ClaudeFiles\\archives\\catholicsun.org\\2026-03-01_95218d75243f_article.txt', archiveStatus: 'captured', author: 'The Catholic Sun', captureCount: 1, captureMethod: 'http-readability', captureStatus: 'captured', capturedAt: date('2026-03-01T01:26:41.180694000+00:00'), domain: 'catholicsun.org', htmlPath: 'ClaudeFiles\\archives\\catholicsun.org\\2026-03-01_95218d75243f.html', lastCaptured: date('2026-03-01T01:26:41.180694000+00:00'), publishedDate: '2016-01-16T02:49:25+00:00', siteName: 'The Catholic Sun', sourceType: 'unclassified', tags: [], textPreview: 'Maddie Schwister, center, poses with Neda Danilovic, 2015 Miss Arizona Teen USA, left and Maureen Montagne, 2015 Miss Arizona USA. (photo courtesy of Schwister family)\nMaddie Schwister, center, poses with Neda Danilovic, 2015 Miss Arizona Teen USA, left and Maureen Montagne, 2015 Miss Arizona USA. (photo courtesy of Schwister family)\nShe didn’t get the crown, but a Notre Dame Preparatory junior certainly clothed herself “with strength and dignity,” as the Psalm goes.\nMadeline Schwister was the o', textSize: 2280, title: 'Fleeting decision for NDP junior ends with near pageant win', url: 'https://catholicsun.org/2016/01/15/fleeting-decision-for-ndp-junior-ends-with-near-pageant-win'})
CREATE (n4986:EntryRef {streamEntryId: 'ls-20260228-020', title: 'AZ/CO Pageant-Real Estate Expansion and Notre Dame Prep Pipeline'})
CREATE (n4987:Source {archivePath: 'ClaudeFiles\\archives\\yourvalley.net\\2026-03-01_f8e1062fc8c6_article.txt', archiveStatus: 'captured', captureCount: 1, captureMethod: 'http-readability', captureStatus: 'captured', capturedAt: date('2026-03-01T01:45:03.201703000+00:00'), domain: 'yourvalley.net', htmlPath: 'ClaudeFiles\\archives\\yourvalley.net\\2026-03-01_f8e1062fc8c6.html', lastCaptured: date('2026-03-01T01:45:03.201703000+00:00'), siteName: 'The Daily Independent at YourValley.net', sourceType: 'unclassified', tags: [], textPreview: 'A view of Mike Nolan as head football coach for Notre Dame Preparatory in north Scottsdale. (File photo)\nNotre Dame Preparatory has fired head football coach Mark Nolan ahead of an Arizona Interscholastic Academy emergency meeting regarding the future of NDP football.\nNDP Communication Coordinator Kimberly Haub confirmed the school no longer employs Mr. Nolan, who was originally suspended Tuesday, Oct. 25 for one game. Additionally, Ms. Haub confirmed the school put athletic director Monica Barr', textSize: 3759, title: 'Scottsdale Notre Dame fires head football coach amid AIA scandal', url: 'https://yourvalley.net/stories/scottsdale-notre-dame-fires-head-football-coach-amid-aia-scandal,95001'})
CREATE (n4988:Source {archivePath: 'ClaudeFiles\\archives\\catholiceducationarizona.org\\2026-03-01_8f603ead0a20_article.txt', archiveStatus: 'captured', author: 'cea_admin', captureCount: 1, captureMethod: 'http-readability', captureStatus: 'captured', capturedAt: date('2026-03-01T01:45:06.286729000+00:00'), domain: 'catholiceducationarizona.org', htmlPath: 'ClaudeFiles\\archives\\catholiceducationarizona.org\\2026-03-01_8f603ead0a20.html', lastCaptured: date('2026-03-01T01:45:06.286729000+00:00'), publishedDate: '2020-06-24T16:31:22+00:00', siteName: 'Catholic Education Arizona', sourceType: 'unclassified', tags: [], textPreview: 'Jill Platt came home when she accepted the position of Principal at Notre Dame Prep in 2017.  Having attended Our Lady of Perpetual Help in Scottsdale and Sacred Heart Catholic School in Prescott once upon a time, Platt spent much of her career in educational leadership outside of Arizona.  Her previous school leadership roles include Brebeuf Jesuit in Indianapolis, Catholic schools in the Archdiocese of Chicago, an adjunct role at DePaul University in Chicago, and a 6- year Catholic elementary ', textSize: 2726, title: 'You CAN Go Home Again: Scottsdale Native Jill Platt Leads Notre Dame Prep as President and Principal', url: 'https://catholiceducationarizona.org/articles/you-can-go-home-again-scottsdale-native-jill-platt-leads-notre-dame-prep-as-president-and-principal'})
CREATE (n4989:Source {archivePath: 'ClaudeFiles\\archives\\ndpsaints.org\\2026-03-01_bcb14fa59953_article.txt', archiveStatus: 'captured', captureCount: 1, captureMethod: 'http-readability', captureStatus: 'captured', capturedAt: date('2026-03-01T01:45:07.548464000+00:00'), domain: 'ndpsaints.org', htmlPath: 'ClaudeFiles\\archives\\ndpsaints.org\\2026-03-01_bcb14fa59953.html', lastCaptured: date('2026-03-01T01:45:07.548464000+00:00'), sourceType: 'unclassified', tags: [], textPreview: 'Bishop Olmsted Establishes New Leadership Structure at Notre Dame Prep\nNotre Dame Preparatory in Scottsdale to Implement President/Principal Model While Also Preparing for Capital Campaign Launch\nThe Most Rev. Thomas J. Olmsted, Bishop of the Roman Catholic Diocese of Phoenix, announced today the establishment of a new executive leadership structure at Notre Dame Preparatory in Scottsdale.\nBishop Olmsted has appointed James M. Gmelich, current Principal at Notre Dame Preparatory, to serve as the', textSize: 5365, title: 'News Post', url: 'https://ndpsaints.org/cf_news/view.cfm?newsid=804'})
CREATE (n4990:Person {addedDate: date('2026-03-01'), description: 'Former President of Notre Dame Preparatory, Scottsdale (founding principal promoted to president under dual leadership model). Officially reprimanded during 2016 AIA football scandal. Removed from athletics/academics oversight, required to donate one week\'s pay to charity. Previously involved with school\'s capital campaigns and expansion.', name: 'James Gmelich', roles: ['School Administrator']})
CREATE (n4991:Person {addedDate: date('2026-03-01'), description: 'President of Notre Dame Preparatory, Scottsdale (2020-present). First woman to lead NDP. Scottsdale native. Joined as Principal in 2017, promoted to President July 2020. 26-year career in Catholic education: Xavier College Prep (1994-98), Brophy College Prep (1998-mid 2000s), Brebeuf Jesuit Prep (VP), Gordon Tech HS (Associate Principal), Alphonsus Academy (VP), All Hallows Academy La Jolla (Principal). Adjunct professor at DePaul University. National Catholic Educators Association Technology Integration Award (2000).', hometown: 'Scottsdale, AZ', name: 'Jill Platt', roles: ['School Administrator', 'Educator']})
CREATE (n4992:Person {addedDate: date('2026-03-01'), description: 'Former head football coach at Notre Dame Preparatory, Scottsdale. Fired October 2016 amid AIA scandal. Violations included illegal fully-padded summer football practice, making unannounced home visit to transferring player with inappropriate offers of assistance, and attempting to recruit an eighth-grader. Initially suspended one game before termination. Additional allegations reported by USA Today HSS in 2017.', name: 'Mark Nolan', roles: ['Coach']})
CREATE (n4993:Person {addedDate: date('2026-03-01'), description: '3rd runner-up Miss Arizona Teen USA 2016. Notre Dame Preparatory junior at time of competition. Only top-5 finalist to do her own hair and makeup. No coaching or prior pageant experience. St. Patrick parishioner. JV soccer team member. Graduated NDP, attended University of Arizona (graduated early May 2020). Credits NDP theology teachers Fr. Ron Hurl and Br. Richard Fornwalt for public speaking skills.', highSchool: 'Notre Dame Preparatory, Scottsdale', name: 'Madeline Schwister', pageantTitle: '3rd Runner-Up Miss Arizona Teen USA 2016', roles: ['Beauty Queen']})
CREATE (n4994:EntryRef {streamEntryId: 'ls-20260228-021', title: 'Notre Dame Preparatory Scottsdale — Institutional Profile, Governance, and Public Records'})
CREATE (n4995:Person {addedDate: date('2026-03-01'), location: 'Scottsdale, AZ', name: 'Brad Zellers', notes: 'Owner of BSN Security LLC (security systems/equipment, est. 2011) and co-owner of Bolt Security Guard Services (est. 2004, DBA of DSZ Enterprises LLC). Both companies at 16101 N 82nd St Ste 3A, Scottsdale. Education: Fort Dodge High School, University of Iowa. NDP Annual Fund co-chair (2008-09, 262% increase). Top-tier donor across all five annual reports reviewed (2008-2013). Father of Emerald (Miss AZ Teen USA 2006) and Alexa (Miss AZ Teen USA 2012).', provenance: 'archived-verified'})
CREATE (n4996:Person {addedDate: date('2026-03-01'), email: '[redacted]', location: 'Scottsdale, AZ', name: 'Diana Zellers', notes: 'President of Bolt Security Guard Services (DSZ Enterprises LLC, founded 2004). National Women\'s Business Enterprise Certification #[phone redacted] — certified majority woman owner. NDP Advisory School Board member 2008-2012 (4 consecutive years). Chaired NDP Auction and Fashion Show 2011-12 (600+ attendees at Westin Kierland). Mothers\' Guild member. Continued as major in-kind donor after board tenure ended.', priorCareer: 'Retail management (risk management and loss control focus)', provenance: 'archived-verified'})
CREATE (n4997:Organization {accFileNumber: 'L-1120715-7', addedDate: date('2026-03-01'), addressHistory: ['2004-2008: initial (unknown)', '2008: 9420 E Doubletree Ranch Rd Ste C-109, Scottsdale AZ 85258', '2018: 7949 E Acoma Dr #105, Scottsdale AZ 85260 (known place of business)', '2019: 16101 N 82nd St A-3, Scottsdale AZ 85260 (statutory agent)'], azBarExpertDirectory: true, blueBookListed: true, certifications: 'WBE, DBE, LBE, WOSB, DPS Licensed', email: '[redacted]', employees: '100-249', entityId: 'L11207157', entityType: 'Domestic LLC', established: '2004', expertWitness: 'Listed in AZ State Bar Expert Witness Directory under Security', founded: '2004-03-04', glassdoorRating: '2.6/5 (20 reviews, 31% recommend)', knownClients: ['Stone Canyon (HOA, per Glassdoor review)', 'unnamed high-end residential community (first contract, 2004)', 'NBA All-Star Jam Session (event security)', 'MLB All-Star Festivities (event security)', 'Super Bowl Phoenix (event security)'], location: 'Scottsdale, AZ', managementType: 'manager-managed', name: 'Bolt Security Guard Services', notableEvents: ['NBA All-Star Jam Session', 'MLB All-Star Festivities', 'Super Bowl (Phoenix)'], notes: 'Founded March 4, 2004. Legal entity: DSZ Enterprises LLC. BBB A+ rating, accredited since Feb 2022. NWBEC #[phone redacted] (woman-owned). President: Diana Zellers. Services: armed/unarmed guards, campus security, mobile patrol, surveillance. AZ DPS License #1003227. Address: 16101 N 82nd St Ste 3A, Scottsdale AZ 85260. NDP auction sponsor and in-kind donor 2008-2013+.', offices: ['Scottsdale AZ (HQ): 16101 N 82nd St Ste 3A', 'Tucson AZ: 3819 S Evans Blvd #402', 'Nashville TN'], operatingStates: ['Arizona', 'Tennessee', 'Texas'], originalMembers: 'Diana Zellers, Susan Zellers (removed Dec 31, 2009)', originalStatutoryAgent: 'Brad Denton c/o Gunderson Denton & Proffitt, 1930 N Arboleda #20, Mesa AZ 85213', phoneNumbers: ['480-860-5470 (Scottsdale)', '520-867-6828 (Tucson)', '615-604-0544 (Nashville)'], projectTypes: 'public and private, new construction, alterations', provenance: 'archived-verified', schoolSecurityExpansion: '2007', selfClaim: 'Largest provider of on-campus school security for the state of Arizona. Secured hundreds of campuses across Tucson and other cities.', serviceAreas: 'Phoenix, Scottsdale, Tucson, Maricopa County, statewide AZ, Nashville TN', services: 'commercial security, campus security, armed/unarmed guards, video surveillance, access control, mobile patrol, robotics/drone deployment, concierge, special events', timeline: '2004: founded, first residential contract. 2007: expanded to commercial and school security. 2009: began event security (NBA All-Star, MLB All-Star, Super Bowl). 2012: added armed security. 2022: BBB accredited.'})
