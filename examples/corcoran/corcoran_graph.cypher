CREATE (n5218:Source {archivePath: 'ClaudeFiles\\archives\\patch.com\\2026-03-02_f6b7bdd5defe_article.txt', archiveStatus: 'captured', captureCount: 1, captureMethod: 'http-readability', captureStatus: 'captured', capturedAt: date('2026-03-02T23:26:49.917411000+00:00'), domain: 'patch.com', htmlPath: 'ClaudeFiles\\archives\\patch.com\\2026-03-02_f6b7bdd5defe.html', lastCaptured: date('2026-03-02T23:26:49.917411000+00:00'), publishedDate: '2011-06-15T03:52:59Z', siteName: 'Tinley Park, IL Patch', sourceType: 'unclassified', tags: [], textPreview: 'The Vikings are coming! The Vikings are coming!\nNo need to sound the alarm ... This time.\nThese Vikings and their spouses are flocking to Southland from as far away as Boston and New York this week as part of the 80th National Convention of the Independent Order of Vikings, which is being hosted this year by the , 6730 W. 175th St.\nThe IOV was formed more than a century ago to provide cultural and fraternal opportunities for those of Scandinavian descent. That provision was dropped some years ag', textSize: 2671, title: 'Vikings Are Descending on Tinley Park', url: 'https://patch.com/illinois/tinleypark/vikings-are-descending-on-tinley-park'})
CREATE (n5219:Organization {addedDate: date('2026-03-02'), archiveFindingAid: 'https://explore.chicagocollections.org/ead/northpark/189/z31q44p/', archiveLocation: 'F.M. Johnson Archives and Special Collections, Brandel Library (Lower Level), 5114 N. Christiana Ave, Chicago, IL 60625', description: 'Swedish-American fraternal organization founded June 2, 1890 in Chicago. Registered fraternal membership-based organization led by Executive Council elected by lodge delegates at biannual convention. Merged with GBU Life in summer 2022, now legally recognized as GBU District 5000. Maintains traditional structure, heritage, and culture under GBU fraternal bylaws. Records (1907-1976) held at North Park University F.M. Johnson Archives.', findingAidNote: 'Chicago Collections portal (Cloudflare-protected, inaccessible to automated capture as of Mar 2026). Records span 1907-1976, bulk 1959-1976. Six categories: history, administration, programs, clippings, correspondence, music.', findingAidUrl: 'https://explore.chicagocollections.org/ead/northpark/189/z31q44p/', foundedLocation: 'Chicago, IL', foundedYear: 1890, lastVerified: '2026-03-03', mergedWith: 'GBU Life (summer 2022), now GBU District 5000', name: 'Independent Order of Vikings', provenanceTier: 'archived', type: 'Fraternal Organization'})
CREATE (n5220:Organization {addedDate: date('2026-03-02'), description: 'IOV lodge #13. Originally in Chicago\'s Roseland community (adjacent to Homewood, IL). Relocated to 6730 W 175th St, Tinley Park, IL 60477 in 1976. Serves Frankfort, Oak Forest, New Lenox, Orland Park, Mokena and surrounding areas. Hosts bingo, banquets, scholarships. Geographic proximity significant: Mokena (Bill Montgomery\'s America Consulting & Graphics) is in its service area, and Homewood (Kent Frantzve\'s early residence) bordered its original Roseland location.', formerLocation: 'Roseland, Chicago (until 1976)', location: '6730 W 175th St, Tinley Park, IL 60477', name: 'Harald Viking Lodge 13', provenanceTier: 'archived', type: 'Fraternal Organization'})
