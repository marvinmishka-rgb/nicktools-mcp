CREATE (n4849:Source {archivePath: 'ClaudeFiles\\archives\\fortune.com\\2026-02-27_f41b452c3864.txt', archiveStatus: 'captured', captureStatus: 'captured', capturedAt: date('2026-02-27T05:45:59.692220000+00:00'), domain: 'fortune.com', lastCaptured: date('2026-02-27T05:45:59.692220000+00:00'), originalUrl: 'https://fortune.com/2025/09/23/erika-kirk-ceo-turning-point-charlie-speech-children-clothing-brand-career/', sourceType: 'unclassified', textPreview: 'Subscribe for $1\nHome\nLatest\nFortune 500\nFinance\nTech\nLeadership\nLifestyle\nRankings\nMultimedia\nSUCCESS\nCHARLIE KIRK\nMeet Erika Kirk, the 36-year-old CEO of Turning Point USA, who has three degrees, two kids, and a clothing brand\nBy Dave Smith\nFormer Editor, U.S. News\nSeptember 23, 2025, 10:51 AM ET\nAdd us on\nErika Kirk, widow of Charlie Kirk and new CEO of Turning Point USA, speaks at the public memorial service for right-wing activist Charlie Kirk at State Farm Stadium in Glendale, Arizona, on ', textSize: 10265, title: 'Meet Erika Kirk, the new 36-year-old CEO of Turning Point USA | Fortune', url: 'https://fortune.com/2025/09/23/erika-kirk-ceo-turning-point-charlie-speech-children-clothing-brand-career'})
