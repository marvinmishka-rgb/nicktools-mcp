CREATE (n4691:Source {archivePath: 'ClaudeFiles\\archives\\nbcchicago.com\\2026-02-25_76e11cc5b829.txt', archiveStatus: 'captured', captureStatus: 'captured', capturedAt: date('2026-02-25T23:00:40.163005000+00:00'), domain: 'nbcchicago.com', lastCaptured: date('2026-02-25T23:50:40.097100000+00:00'), sourceType: 'unclassified', textSize: 11823, title: 'Who was Charlie Kirk? Suburban Chicago conservative activist killed – NBC Chicago', url: 'https://www.nbcchicago.com/news/local/who-was-charlie-kirk-activists-political-roots-started-in-suburban-chicago/3822385/', verifiedAt: date('2026-02-26T16:11:27.366000000+00:00')})
