CREATE (n4856:Source {archivePath: 'ClaudeFiles\\archives\\kold.com\\2026-02-27_88bd4c27d9fe.txt', archiveStatus: 'captured', captureStatus: 'captured', capturedAt: date('2026-02-27T06:03:20.670003000+00:00'), domain: 'kold.com', lastCaptured: date('2026-02-27T14:14:48.767774000+00:00'), originalUrl: 'https://www.kold.com/story/16107030/asu-senior-frantzve-wins-miss-arizona-usa-ua-senior-wilenchik-runner-up/', sourceType: 'unclassified', textPreview: 'Skip to content\n55°\nTucson, AZ\nNancy Guthrie\nWeather\nNews\nSports\nWatch Us Live\nInvestigateTV\nPhoenix Suns\nRodeo Parade\nTucson Now\nTalking Trash\nDan\'s Car Wash\nSurprise Squad\nASU senior wins Miss Arizona USA; UA senior runner-up\nPublished: Nov. 23, 2011 at 1:44 AM MST|Updated: Dec. 3, 2011 at 1:44 AM MST\nCourtesy of Casting Crown Productions\n\nMESA, AZ (Tucson News Now) - Erika Frantzve of Scottsdale was crowned Miss Arizona USA on Sunday night, with University of Arizona senior Caitlin Wilenchik ', textSize: 4910, title: 'ASU senior wins Miss Arizona USA; UA senior runner-up', url: 'https://kold.com/story/16107030/asu-senior-frantzve-wins-miss-arizona-usa-ua-senior-wilenchik-runner-up'})
CREATE (n4857:Source {archivePath: 'ClaudeFiles\\archives\\blogforarizona.net\\2026-02-27_4b3f91c9fce7.txt', archiveStatus: 'captured', captureStatus: 'captured', capturedAt: date('2026-02-27T06:03:40.620719000+00:00'), domain: 'blogforarizona.net', lastCaptured: date('2026-02-27T14:15:06.951539000+00:00'), originalUrl: 'https://blogforarizona.net/turning-point-is-at-a-turning-point-headed-down/', sourceType: 'unclassified', textPreview: 'Skip to content\nFacebook\nYouTube\nMastodon\nBluesky\nMenu\nTurning Point is at a Turning Point — and Headed for Holiness?\nOctober 31, 2025 by Larry Bodine\nErika Frantzve Kirk, a Millennial fashion model with the piety of a Sunday school teacher.\n\nTurning Point USA is spiraling into irrelevance, after peaking in 2023 with a rally of 13,000 right-wing racists and antisemites. Today it is reduced to a feud over a local city council member.\n\nIt may re-emerge as a Christian nationalist megachurch. Withou', textSize: 10236, title: 'Read Turning Point is at a Turning Point — and Headed for Holiness? now from Blog for Arizona for Politics from a Liberal Viewpoint', url: 'https://blogforarizona.net/turning-point-is-at-a-turning-point-headed-down'})
CREATE (n4858:Source {archivePath: 'ClaudeFiles\\archives\\melissamcgarity.substack.com\\2026-03-03_0facc3346d8c_article.txt', archiveStatus: 'captured', author: 'Melissa McGarity', captureCount: 2, captureMethod: 'http-readability', captureStatus: 'captured', capturedAt: date('2026-02-27T06:04:33.343534000+00:00'), domain: 'melissamcgarity.substack.com', htmlPath: 'ClaudeFiles\\archives\\melissamcgarity.substack.com\\2026-03-03_0facc3346d8c.html', lastCaptured: date('2026-03-03T02:39:41.307747000+00:00'), sourceType: 'unclassified', tags: [], textPreview: 'Interesting Coincidences Surrounding the Charlie Kirk Assassination?\nAre there coincidences?\nI’m here to tell you there are NO Coincidences.\nIn this matrix EVERYTHING happens for a reason!\nPlease Consider,\nErika LaneFrantzve Kirk\n, [Charlie Kirk’s widow]\nBirth\nNovember 20, 1988\nBorn in Ohio\nGrowing up Years\nGrew up in\nScottsdale, Arizona\n, after her parents divorced; her grandfather was an immigrant from Sweden.\nShe was raised in a Catholic family, with her mother taking her to soup kitchens to ', textSize: 6731, title: 'Who is Erika Kirk. History and Mother\'s Connection to a Continuity of Government and EMP Mitigation Tech Co.', url: 'https://melissamcgarity.substack.com/p/who-is-erika-kirk-history-and-mothers'})
CREATE (n4859:Source {archivePath: 'ClaudeFiles\\archives\\thedailybeast.com\\2026-02-28_df617cce0ded_article.txt', archiveStatus: 'captured', captureCount: 1, captureMethod: 'http-readability', captureStatus: 'captured', capturedAt: date('2026-02-27T06:05:29.339035000+00:00'), domain: 'thedailybeast.com', htmlPath: 'ClaudeFiles\\archives\\thedailybeast.com\\2026-02-28_df617cce0ded.html', lastCaptured: date('2026-02-28T19:37:03.727628000+00:00'), originalUrl: 'https://www.thedailybeast.com/kari-lakes-bribery-scandal-involves-shady-gop-tech-firm-superfeed-technologies/', siteName: 'The Daily Beast', sourceType: 'unclassified', tags: [], textPreview: 'Pay Dirt\nis a weekly foray into the pigpen of political funding. Subscribe\nhere\nto get it in your inbox every Thursday.\nArizona\nSenate hopeful and inveterate election denier\nKari Lake\npulled off a coup of her own last month, dethroning the chair of the state’s Republican Party after disclosing a recording of what Lake described as a bribe offer last year to keep her out of the race to claim the seat currently held by independent\nSen. Kyrsten Sinema\n.\nAt the time the recording was made, Lake stil', textSize: 19592, title: 'Kari Lake’s Bribery Scandal Involves Shady GOP Tech Firm Superfeed Technologies', url: 'https://thedailybeast.com/kari-lakes-bribery-scandal-involves-shady-gop-tech-firm-superfeed-technologies', waybackUrl: 'http://web.archive.org/web/[phone redacted]4141/https://www.thedailybeast.com/kari-lakes-bribery-scandal-involves-shady-gop-tech-firm-superfeed-technologies/'})
