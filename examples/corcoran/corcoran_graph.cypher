CREATE (n4795:Organization {addedDate: [date('2026-02-26'), date('2026-03-02')], altNames: ['Tech-Metrics International Inc'], description: ['Defense and organizational assessment consulting firm. Assignee on patents 5,737,494 (filed 1994), 6,092,060 (filed 1998), and 6,161,101 (filed 1998) co-invented by Lawrence R. Guinta and Lori A. Frantzve. Predecessor to AZ-Tech International and E3tek Group. Specialized in computer-aided methods for assessing organizational processes and systems.', 'Company co-founded by Lawrence R. Guinta and Lori A. Frantzve, based in Scottsdale AZ. Patented MAXSYS (formerly MAXUS) system for computer-aided assessment of organizational processes, risk, criticality and vulnerability. US Patent 5,737,494 (filed 1996, granted 1998) and US Patent 6,092,060. Later renamed IntelliMet International Inc (~2000). Patent assignee for risk/vulnerability assessment technology — the intellectual precursor to E3TEK\'s risk assessment claims.'], name: 'Tech-Metrics International', source: '', type: ['other', 'technology']})
CREATE (n4796:Source {archivePath: 'ClaudeFiles\\archives\\patents.justia.com\\2026-03-03_7c7b11a0dd28_article.txt', archiveStatus: 'captured', captureCount: 1, captureMethod: 'wayback', captureStatus: 'captured', domain: 'patents.justia.com', htmlPath: 'ClaudeFiles\\archives\\patents.justia.com\\2026-03-03_7c7b11a0dd28.html', lastCaptured: date('2026-03-03T02:41:58.521518000+00:00'), sourceType: 'public-record', tags: [], textPreview: 'Lori A. Frantzve Inventions, Patents and Patent Applications - Justia Patents Search\nLog In\nSign Up\nFind a Lawyer\nAsk a Lawyer\nResearch the Law\nLaw Schools\nLaws & Regs\nNewsletters\nMarketing Solutions\nJustia Connect\nPro Membership\nPractice Membership\nPublic Membership\nJustia Lawyer Directory\nPlatinum Placements\nGold Placements\nJustia Elevate\nSEO\nWebsites\nBlogs\nJustia Amplify\nPPC Management\nGoogle Business Profile\nSocial Media\nJustia Onward Blog\nJustia\nPatents\nLori A. Frantzve Inventions, Patents ', textSize: 9236, title: 'Lori A. Frantzve Inventions, Patents and Patent Applications', url: 'https://patents.justia.com/inventor/lori-a-frantzve', verifiedAt: date('2026-02-26T16:17:17.934000000+00:00')})
CREATE (n4797:Person {deathAge: 83, deathDate: '2007-04-05', deathLocation: 'Cincinnati, OH', description: 'Lori Frantzve\'s father. Lebanese/Syrian heritage. Married to Rita M. Abbas (née Carresscia, Italian). Father of Lori (Frantzve/Guinta), Deborah (Fisher), Patrick Abbas, and Rita (McCormack). Died 2007, Cincinnati, Ohio. Obituary published in Cincinnati Enquirer.', lastVerified: '2026-03-03', name: 'Joseph Anthony Abbas', obituarySource: 'Cincinnati Enquirer via Legacy.com (2007). Lists children: Lori (Larry Guinta) Frantzve, Deborah (Stephen) Fisher, Patrick (Diane) Abbas, Rita (Mark) McCormack.', secondWife: 'Rita M. (née Stubbemann) Abbas (1920-2023), married ~1980. Rita also worked at GE.'})
CREATE (n4798:Person:Firefighter {description: 'Firefighter in Arizona. Son of Lawrence R. Guinta Jr. Erika Kirk\'s stepbrother through Lori Frantzve\'s marriage to Lawrence Guinta.', educationTimeline: 'NAU BS Emergency Service Administration 2013 (90/30 program), PVCC Fire I and II Academy (after 2013)', lastVerified: '2026-03-03', name: 'Travis Guinta', notes: 'Son of Lori Frantzve and Lawrence R. Guinta Jr. Half-sibling to Erika Kirk (née Frantzve). Firefighter, City of Scottsdale Fire Department (2017-2022+). BS Emergency Service Administration from NAU 2013 (90/30 program). Before firefighting, taught music with Arizona Academy Drum & Bugle Corps and Dark Sky Percussion, coached high school soccer. PVCC Fire Science Academy graduate. Birth year unresolved: NAU BS in 2013 could mean born ~1988-1991 (traditional) or ~1980-1985 (non-traditional student going back to school). Grok/X claims he is older than Erika (born 1988) but this is single-source and unverified.', priorCareer: 'Music educator: Arizona Academy Drum & Bugle Corps, Dark Sky Percussion. Volunteer soccer coach for valley high school programs.'})
CREATE (n4799:Person {birthDate: '1922-01-30', birthPlace: 'Falun, Sweden', children: 'Kent, Kendra, Kimberly, Karla', deathDate: '2016-10-04', deathPlace: 'Surprise, Arizona', description: 'Swedish-born American military veteran, manufacturing executive, and fraternal leader. Immigrated to US, settled in Chicago area. Served WWII (Army Corps of Engineers, Pacific Theater) and Korean War. Silver Star and Bronze Star recipient. Knighted by King Carl XVI Gustaf of Sweden for promoting US-Sweden relations. VP of Manufacturing at American Bank Note Co. Grand Chief of Independent Order of Vikings 1977-1979. Grandfather of Erika Kirk (née Frantzve), CEO of TPUSA. Erika described him as \'always super far right\' (CNN). Died age 94 in Surprise, AZ.', employer: 'American Bank Note Co. (VP of Manufacturing)', fullName: 'Carl Kenneth Frantzve', grandchildren: 'Erika (Kirk), Cassandra, Scott, Heather, Jasmine', knighthood: 'Knighted by Carl XVI Gustaf, King of Sweden, for promoting US-Sweden relations', military: 'Captain, Army Corps of Engineers, Pacific Theater (WWII); Korean War veteran. Silver Star, Bronze Star.', name: 'Carl Kenneth Frantzve', spouse: 'Elaine Wicklund Frantzve'})
CREATE (n4800:Source {archivePath: 'ClaudeFiles\\archives\\cnn.com\\2026-02-27_7b4e8f213651.txt', archiveStatus: 'captured', captureStatus: 'captured', capturedAt: date('2026-02-27T14:14:26.179497000+00:00'), domain: 'cnn.com', lastCaptured: date('2026-02-27T14:14:26.179497000+00:00'), originalUrl: 'https://www.cnn.com/2015/07/11/politics/donald-trump-phoenix-rally/', sourceType: 'unclassified', textPreview: 'Politics\nWatch\nSubscribe\nSTART THE DAY HERE\nBill Clinton to testify on dealings with Epstein. Anthropic rejects Pentagon offer. Pokémon at 30. News quiz.\nTrump draws thousands in Phoenix, continues immigration theme\nBy MJ Lee and Pat St. Claire, CNN\n 6 min read \nUpdated 12:40 PM EDT, Sun July 12, 2015\nVideo Ad Feedback\nFather of murder victim to introduce Trump in Phoenix\n01:33 • Source: CNN\nFather of murder victim to introduce Trump in Phoenix\n01:33\nJill Stein raises millions for recount\n01:44\n', textSize: 9899, title: 'Trump draws thousands to Phoenix rally | CNN Politics', url: 'https://cnn.com/2015/07/11/politics/donald-trump-phoenix-rally'})
CREATE (n4801:EntryRef {streamEntryId: 'ls-20260225-012', title: 'Lori Frantzve Deep Dive: The Single Mom Narrative vs the Defense-Tech Family Enterprise'})
CREATE (n4802:Organization {addedDate: date('2026-02-27'), description: 'Pentecostal megachurch, Phoenix AZ. Formerly Phoenix First Assembly of God (renamed 2015). Pastor Luke Barnett. ~21,000 weekly. Hosts TPUSA Faith \'Freedom Night in America\'. 2024 Strong Church Dream Conference with Kirk. Trump rally June 2020. Dream City Christian School with TPUSA (2022). Phoenix Dream Center serves 40,000+ monthly including trafficking survivors.', founded: '1923', name: 'Dream City Church', type: 'religious'})
CREATE (n4803:EntryRef {streamEntryId: 'ls-20260225-013', title: 'Erika Frantzve at Corcoran: Zero Sales, One Capture — A Credential, Not a Career'})
CREATE (n4804:Person {addedDate: date('2026-02-26'), description: 'Former Turning Point USA field director, the only African-American hired as field director during her tenure (~2014-2015). Fired on Martin Luther King Jr. Day by Crystal Clanton. Reported that black recruits she brought in were suddenly disinvited from TPUSA annual student summit. Told Jane Mayer: \'In looking back, I think it was racist.\' Now works as a model. Key witness in the racial bias allegations against TPUSA.', name: 'Gabrielle Fequiere', source: ''})
CREATE (n4805:Person:Operative {addedDate: date('2026-02-26'), description: 'Turning Point USA advisory council member. Former deputy director of the Republican National Committee. Ran a pro-Cruz super PAC during 2016 primary. Asked Charlie Kirk via email (Jan 25, 2016) to \'send as many kids as possible\' for a Wall Street Journal piece in South Carolina — coordinating 501(c)(3) charity resources with a political campaign. Key figure in the TPUSA campaign finance violation allegations.', name: 'Drew Ryun', source: ''})
CREATE (n4806:Organization {addedDate: date('2026-02-27'), name: 'Republican National Committee', researchStatus: 'needs-enrichment', source: 'graph-cleanup-20260227'})
CREATE (n4807:Person {addedDate: date('2026-02-26'), description: 'Former Turning Point USA employee who received the racist text messages from Crystal Clanton (\'I HATE BLACK PEOPLE. Like fuck them all... I hate blacks. End of story.\'). Provided the screenshots to Jane Mayer but requested they not be used. Declined to comment on the messages.', name: 'John Ryan O\'Rourke', source: ''})
CREATE (n4808:Person {addedDate: date('2026-02-26'), description: 'Former Turning Point USA employee during the 2016 presidential campaign. Key witness in campaign finance violation allegations. Reported that Crystal Clanton emailed her at her TPUSA address to coordinate with Ginni Thomas to help Ted Cruz\'s campaign. Ginni Thomas sent 200 Cruz placards to Hall\'s home address (provided by Clanton without permission) for distribution in the Wisconsin primary.', name: 'Payden Hall', source: ''})
CREATE (n4809:Person {addedDate: date('2026-02-26'), description: 'Former Turning Point USA employee in Florida, 2016. Created a list of approximately 700 student supporters while working for TPUSA. The list, with personal notes on each student, was given without her knowledge to someone working for Marco Rubio\'s presidential campaign — a potential 501(c)(3) violation since charity resources cannot be shared with political campaigns.', name: 'Susan Walker', source: ''})
CREATE (n4810:Person:Operative {addedDate: date('2026-02-26'), description: 'Drew Ryun\'s associate at a pro-Cruz super PAC. Headed the PAC\'s operations in South Carolina. Founder and president of Ground Game Strategies. Coordinated with Charlie Kirk via email to get TPUSA students to canvass for Cruz in Greenville/Spartanburg/Anderson Counties, SC (Jan 2016). Confirmed the email exchanges to Jane Mayer.', name: 'Dan Tripp', source: ''})
CREATE (n4811:Organization {addedDate: date('2026-02-27'), name: 'Ground Game Strategies', researchStatus: 'needs-enrichment', source: 'graph-cleanup-20260227'})
CREATE (n4812:Event {addedDate: date('2026-02-26'), date: '2016', description: 'Jane Mayer investigation (New Yorker, Dec 2017) documented multiple instances of TPUSA, a 501(c)(3) charity, allegedly coordinating with Republican presidential campaigns in violation of campaign finance law. Ginni Thomas (TPUSA advisory council) directed employees to distribute 200 Cruz placards in Wisconsin primary. Drew Ryun (advisory council, pro-Cruz super PAC) asked Kirk to send TPUSA students to canvass in SC. Susan Walker\'s 700-student list shared with Rubio campaign. Former FEC commissioner Trevor Potter called the activities potentially illegal.', name: 'TPUSA 2016 Campaign Finance Coordination Allegations', source: '', type: 'legal'})
CREATE (n4813:EntryRef {streamEntryId: 'ls-20260225-014', title: 'Verification Cycle: Feb 25 Session — Frantzve Family, Corcoran Career, Jane Mayer TPUSA Investigation'})
