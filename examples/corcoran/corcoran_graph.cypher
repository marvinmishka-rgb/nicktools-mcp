CREATE (n5163:Organization {addedDate: date('2026-03-02'), name: 'Saxon Capital Group Inc', notes: 'Serial shell company. Nevada corp incorporated Nov 12 2003 as Comlink Communications → USA Superior Energy Holdings (Mar 2007, oil/gas acquisition) → XSilent Solutions (Jun 2014) → Saxon Capital Group (May 2015, Brian Chamberlain gets 86.2% shares) → GTEK Industries (Jul 2016, attempted reverse merger with Frantzve/Guinta GTEK, abandoned) → reverted to Saxon Capital Group under Clifford Paul → current: Energy Glass Solar. SIC 6799 (Shell Companies). OTC: SCGX. Zero revenue from inception (2003) through 2015. Accumulated deficit $2.4M. Zero assets by Dec 2015. $1.89M cumulative professional fees. Address: 7580 E Gray Rd #103, Scottsdale AZ. Clifford Paul is CEO of both Saxon and PK Associates (structural engineering firm). Crowdfunding campaign 2024 for solar glass plant + tiny homes.', orgType: 'public-shell', ticker: 'SCGX'})
CREATE (n5164:Source {archivePath: 'ClaudeFiles\\archives\\en.wikipedia.org\\2026-03-03_0ad8099a0620_article.txt', archiveStatus: 'captured', captureCount: 1, captureMethod: 'http-readability', captureStatus: 'captured', capturedAt: date('2026-03-03T01:59:39.925535000+00:00'), domain: 'en.wikipedia.org', htmlPath: 'ClaudeFiles\\archives\\en.wikipedia.org\\2026-03-03_0ad8099a0620.html', lastCaptured: date('2026-03-03T01:59:39.925535000+00:00'), sourceType: 'unclassified', tags: ['qa-test'], textPreview: 'Property sales intermediary\nLawn signs\nadvertising houses for sale\nReal estate agents\nand\nreal estate brokers\nare people who represent sellers or buyers of\nreal estate\nor\nreal property\n. While a\nbroker\nmay work independently, an agent usually works under a licensed broker to represent clients.\n[\n1\n]\nBrokers and agents are licensed by the state to negotiate sales agreements and manage the documentation required for closing real estate transactions.\nCategories of representation\nA real estate broke', textSize: 14268, title: 'Real estate agent', url: 'https://en.wikipedia.org/wiki/Real_estate_broker'})
CREATE (n5165:Source {archivePath: 'ClaudeFiles\\archives\\pepechiq.substack.com\\2026-03-02_99039ac26357_article.txt', archiveStatus: 'captured', author: 'PepeChiQ', captureCount: 1, captureMethod: 'http-readability', captureStatus: 'captured', capturedAt: date('2026-03-02T05:37:34.012399000+00:00'), domain: 'pepechiq.substack.com', htmlPath: 'ClaudeFiles\\archives\\pepechiq.substack.com\\2026-03-02_99039ac26357.html', lastCaptured: date('2026-03-02T05:37:34.012399000+00:00'), sourceType: 'unclassified', tags: [], textPreview: 'TL;DR:\nPublic records and Erika’s own words raise five simple questions about her family story - nothing more.\nPhoto:\nErika Kirk as Miss Arizona USA winner in 2012.\nSeptember 10, 2025.\nCharlie Kirk assassinated.\nErika Kirk - former Miss Arizona, faith influencer - becomes CEO of\nTurning Point USA\n.\nShe shares a public story:\nBut public records and her own past words create curious gaps. Let’s walk through them - source by source.\nA publicly available PDF titled “NSA Officials and Employees Dox” ', textSize: 5019, title: 'Erika Kirk: Who Is She Really? Her Mom’s NSA Leak, Swedish Grandparents Mix-Up & the Questions No One’s Asking', url: 'https://pepechiq.substack.com/p/erika-kirk-who-is-she-really-her'})
CREATE (n5166:Source {archivePath: 'ClaudeFiles\\archives\\salwasamra.substack.com\\2026-03-03_79ac7949cc80_article.txt', archiveStatus: 'captured', author: 'Salwa Samra - Unscripted', captureCount: 2, captureMethod: 'http-readability', captureStatus: 'captured', capturedAt: date('2026-03-02T05:37:34.765061000+00:00'), domain: 'salwasamra.substack.com', htmlPath: 'ClaudeFiles\\archives\\salwasamra.substack.com\\2026-03-03_79ac7949cc80.html', lastCaptured: date('2026-03-03T03:03:48.978635000+00:00'), sourceType: 'unclassified', tags: [], textPreview: 'The genealogical and public records of Lori and Kent Frantzve, parents of Erika Kirk, reveal more absence than presence. A family line that should be traceable instead leaves only all too many questions. Their trail is fragmented, anomalous, and shadowed, resisting conventional documentation.\nLori Frantzve: A Life in Fragments\nLori Frantzve appears under multiple aliases:\nLori A Frantzve, Lori W Frantzve, Lori A Srantve\n, and\nLori A Walstad\n. All share a consistent birth date: 5 April 1950. Her ', textSize: 2327, title: 'The Shadow Trail of Lori and Kent Frantzve', url: 'https://salwasamra.substack.com/p/the-shadow-trail-of-lori-and-kent'})
CREATE (n5167:Source {archivePath: 'ClaudeFiles\\archives\\razorwirenews.com\\2026-03-02_41612f46fc66_article.txt', archiveStatus: 'captured', author: 'McShane', captureCount: 1, captureMethod: 'http-readability', captureStatus: 'captured', capturedAt: date('2026-03-02T05:37:36.279113000+00:00'), domain: 'razorwirenews.com', htmlPath: 'ClaudeFiles\\archives\\razorwirenews.com\\2026-03-02_41612f46fc66.html', lastCaptured: date('2026-03-02T05:37:36.279113000+00:00'), sourceType: 'unclassified', tags: [], textPreview: 'Personal Background:\nKent Randall Frantzve, born around 1960, is a resident of Surprise, Arizona, and the father of Erika Kirk (née Frantzve), who is married to Charlie Kirk, the founder of Turning Point USA. Kent was previously married to Lori Frantzve (now Lori Abbas), with whom he had Erika, born on November 20, 1988. The couple divorced when Erika was young, and she was primarily raised by her mother in Scottsdale, Arizona. Kent maintains a low public profile, and there is no evidence of dir', textSize: 659, title: 'Summary of Kent Randall Frantzve', url: 'https://razorwirenews.com/p/summary-of-kent-randall-frantzve'})
CREATE (n5168:Document {addedDate: date('2026-03-02'), author: 'Kent R. Frantzve', description: 'Business reference guide to information sources for the information age. Covers databases, directories, online services, government data, industry publications. Dedicated to \'my wife, Lori\' — significant for Frantzve family timeline.', docType: 'book', isbn: '[phone redacted]', name: 'The Desktop Business Intelligence Sourcebook', pages: 188, publisher: 'Hyde Park Marketing Group', year: 1992})
CREATE (n5169:Person {addedDate: date('2026-03-02'), name: 'John Robert Walstad', notes: 'First known husband of Lori Abbas. Marriage license published in Cincinnati Enquirer Jan 12 1974. Marriage in Cincinnati coincides with Lori\'s University of Cincinnati and Xavier University education and GE career.'})
CREATE (n5170:Person {addedDate: date('2026-03-02'), aliases: ['Tonya Lynn Frantzve', 'Tonya Lynn Stanley', 'Tonia Frantzve', 'Tana L Frantzve'], birthDate: '1969-12-05', birthPlace: 'Cincinnati, Ohio', currentAddress: '1039 State Route 131, Milford, OH 45150', name: 'Tonya Lynn Siegrist', notes: 'Daughter of Lori Frantzve (née Abbas) from her first marriage to a Mr. Stanley. Born as Tonya Lynn Stanley. Later took Frantzve surname from stepfather Kent Randall Frantzve. Married Carl E. Siegrist. Also lived in Sun City, AZ (17007 North Pinion La) with mother Lori.', occupation: 'Private Bank Direct Lending Credit Manager; Real Estate Agent'})
CREATE (n5171:Source {archivePath: 'ClaudeFiles\\archives\\gazettedirect.com\\2026-03-02_b8eb70d60204_article.txt', archiveStatus: 'captured', author: 'https://www.twitch.tv/shreeasish', captureCount: 1, captureMethod: 'http-readability', captureStatus: 'captured', domain: 'gazettedirect.com', htmlPath: 'ClaudeFiles\\archives\\gazettedirect.com\\2026-03-02_b8eb70d60204.html', lastCaptured: date('2026-03-02T05:54:41.879318000+00:00'), publishedDate: '2025-09-15T01:47:22+05:45', siteName: 'Gazette Direct', sourceType: 'unclassified', tags: [], textPreview: 'Erika Frantzve Kirk\nemerged into the public eye through a blend of personal achievements and her connection to prominent conservative circles, but her story begins much earlier in the sun-drenched landscapes of Arizona. Born on November 20, 1988, in the vibrant city of Phoenix, she grew up in a household that emphasized faith, discipline, and ambition, shaping her into the multifaceted woman known today as a business leader, podcast host, and devoted family member. Her American nationality is ro', textSize: 5052, title: 'Siblings and Ethnicity', url: 'https://gazettedirect.com/erika-frantzve-kirk-parents-and-siblings'})
CREATE (n5172:Source {archiveStatus: 'unarchived', captureStatus: 'legacy-unverified', domain: 'clustrmaps.com', url: 'https://clustrmaps.com/person/Frantzve-3alrff'})
