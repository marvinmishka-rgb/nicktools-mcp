CREATE (n5012:Source {archivePath: 'ClaudeFiles\\archives\\aitx.ai\\2026-03-01_ee2a8fa39ade_article.txt', archiveStatus: 'captured', captureCount: 1, captureMethod: 'http-readability', captureStatus: 'captured', capturedAt: date('2026-03-01T03:00:31.687964000+00:00'), domain: 'aitx.ai', htmlPath: 'ClaudeFiles\\archives\\aitx.ai\\2026-03-01_ee2a8fa39ade.html', lastCaptured: date('2026-03-01T03:00:31.687964000+00:00'), sourceType: 'unclassified', tags: [], textPreview: '“We are excited to bring to our clients and prospects RAD’s incredible line up of security solutions,” said Brad Zellers, President of BSN Security, LLC. “Many of our clients are experiencing the issues that RAD devices are known to help deter and eliminate. We’re confident that RAD will be a hit with our clients,” Zellers concluded. Zellers indicated that the company anticipates several immediate orders from Arizona-based construction companies presently struggling with an increase in theft and', textSize: 5461, title: 'RAD Announces Dealer Agreement with BSN Security, LLC', url: 'https://aitx.ai/press-releases/rad-announces-dealer-agreement-with-bsn-security-llc'})
