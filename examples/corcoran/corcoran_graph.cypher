CREATE (n5174:Source {archivePath: 'ClaudeFiles\\archives\\cbn.com\\2026-03-02_dcccad34e258_article.txt', archiveStatus: 'captured', captureCount: 1, captureMethod: 'http-readability', captureStatus: 'captured', capturedAt: date('2026-03-02T16:30:42.418096000+00:00'), domain: 'cbn.com', htmlPath: 'ClaudeFiles\\archives\\cbn.com\\2026-03-02_dcccad34e258.html', lastCaptured: date('2026-03-02T16:30:42.418096000+00:00'), publishedDate: '2026-01-05T13:36:33-0500', siteName: 'CBN', sourceType: 'unclassified', tags: [], textPreview: 'Dennis Prager, the conservative radio host, writer, and co-founder of PragerU, shared an update on his health after suffering a fall that has left him paralyzed from the neck down, saying the key to remaining joyful in the midst of suffering is remaining grateful.\nThe 77-year-old gave more details about his health journey in a second interview with PragerU CEO Marissa Streit. The pair discussed a variety of topics, including faith, family, and "America\'s moral crisis," but he also touched on the', textSize: 4523, title: 'Dennis Prager Grateful for \'Miracle\' After Spinal Injury: \'Gratitude is Everything\'', url: 'https://cbn.com/news/health/dennis-prager-grateful-miracle-after-spinal-injury-gratitude-everything'})
CREATE (n5175:Source {archivePath: 'ClaudeFiles\\archives\\en.wikipedia.org\\2026-03-02_cbe90fdf7421_article.txt', archiveStatus: 'captured', captureCount: 1, captureMethod: 'http-readability', captureStatus: 'captured', capturedAt: date('2026-03-02T16:30:51.438662000+00:00'), domain: 'en.wikipedia.org', htmlPath: 'ClaudeFiles\\archives\\en.wikipedia.org\\2026-03-02_cbe90fdf7421.html', lastCaptured: date('2026-03-02T16:30:51.438662000+00:00'), sourceType: 'unclassified', tags: [], textPreview: 'American conservative activist (born 1948)\nDennis Mark Prager\n(; born August 2, 1948) is an American\nconservative\nradio talk show host and writer. He is the host of the nationally syndicated radio talk show\nThe Dennis Prager Show\n. In 2009, he co-founded\nPragerU\n, which creates content advocating\ncapitalism\nand promoting\nconservative\nviewpoints on various political, economic and cultural topics.\nHis initial political work, starting in 1969, focused on the\nRefuseniks\n, Soviet Jews who were denied', textSize: 23785, title: 'Dennis Prager - Wikipedia', url: 'https://en.wikipedia.org/wiki/Dennis_Prager'})
CREATE (n5176:EntryRef {streamEntryId: 'ls-20260302-001', title: 'Browsing architecture overhaul: fetch_page as primary, CDP Tier 2, skill update'})
CREATE (n5177:Source {archivePath: 'ClaudeFiles\\archives\\floodlightnews.org\\2026-03-02_6c39a9cfa16c_article.txt', archiveStatus: 'captured', captureCount: 1, captureMethod: 'http-readability', captureStatus: 'captured', capturedAt: date('2026-03-02T16:46:44.339969000+00:00'), domain: 'floodlightnews.org', htmlPath: 'ClaudeFiles\\archives\\floodlightnews.org\\2026-03-02_6c39a9cfa16c.html', lastCaptured: date('2026-03-02T16:46:44.339969000+00:00'), publishedDate: '2025-10-10T10:00:45.000Z', siteName: 'Floodlight', sourceType: 'unclassified', tags: [], textPreview: 'This far out, there’s no such thing as municipal city water. The afternoon desert sun beats down, hard, as we drive up the gravel road to Tom and Illene Wood’s reddish-brown adobe-style stucco house, nestled off-the-grid within the shrubs and mountains of the Sonoran Desert, with cacti and mastiffs standing guard. Like many residents of rural America, they dug a well. That 400-foot well cost them $10,000. But by 2011, the land had shifted, and they had to dig a new well to the tune of $15,000. L', textSize: 19190, title: 'Saudi-owned corporate farms are draining Arizona’s desert dry', url: 'https://floodlightnews.org/saudi-owned-corporate-farms-are-draining-arizonas-desert-dry'})
CREATE (n5178:Source {archivePath: 'ClaudeFiles\\archives\\news.azpm.org\\2026-03-02_3805f5216918_article.txt', archiveStatus: 'captured', author: 'Zachary Ziegler', captureCount: 1, captureMethod: 'http-readability', captureStatus: 'captured', capturedAt: date('2026-03-02T16:46:47.395195000+00:00'), domain: 'news.azpm.org', htmlPath: 'ClaudeFiles\\archives\\news.azpm.org\\2026-03-02_3805f5216918.html', lastCaptured: date('2026-03-02T16:46:47.395195000+00:00'), sourceType: 'unclassified', tags: [], textPreview: 'KN:\nAnd when I called, What is it well 55 and said, you know, how can somebody get a permit to put that huge of a well in, she was like, Oh, you could do that on your property if you wanted to. I\'m like, I could put an industrial or a commercial depth well on my little 10 acres. And she\'s like, yep, you guys aren\'t under any regulations. That\'s scary to me that every time we see a well trigger out in our area, we go on to the property, we\'re like, what do you drill in the well for? Who are you? ', textSize: 11041, title: 'Hedge funds and foreign farms get water, rural Arizonans get empty wells', url: 'https://news.azpm.org/p/azpmnews/2024/9/4/221650-hedge-funds-and-foreign-farms-get-water-rural-arizonans-get-empty-wells'})
CREATE (n5179:Source {archivePath: 'ClaudeFiles\\archives\\kjzz.org\\2026-03-02_218294d36412_article.txt', archiveStatus: 'captured', author: 'https://www.kjzz.org/people/camryn-sanchez', captureCount: 1, captureMethod: 'http-readability', captureStatus: 'captured', capturedAt: date('2026-03-02T16:46:59.772610000+00:00'), domain: 'kjzz.org', htmlPath: 'ClaudeFiles\\archives\\kjzz.org\\2026-03-02_218294d36412.html', lastCaptured: date('2026-03-02T16:46:59.772610000+00:00'), publishedDate: '2024-12-11T22:17:17.757', siteName: 'KJZZ', sourceType: 'unclassified', tags: [], textPreview: 'Democratic Arizona Attorney General Kris Mayes is going to court with a largely untested legal theory in a bid to force a Saudi company to stop it from "excessively pumping groundwater" at its western Arizona alfalfa operations and require it to set aside funds to compensate neighbors it has damaged.\nShe’s following through on a promise to do so\nlast month.\nHear Camryn Sanchez on The Show with host Lauren Gilger\nThe lawsuit filed Wednesday claims that Fondomonte LLC, the Arizona subsidiary of th', textSize: 9851, title: 'Mayes sues Saudi-backed farm Fondomonte over \'excessive\' groundwater pumping in Arizona', url: 'https://kjzz.org/politics/2024-12-11/mayes-sues-saudi-backed-farm-fondomonte-over-excessive-groundwater-pumping-in-arizona'})
CREATE (n5180:Organization {addedDate: date('2026-03-02'), aliases: ['Fondomonte Arizona', 'Fondomonte'], description: 'Arizona subsidiary of Saudi dairy giant Almarai Co. Grows alfalfa in La Paz County, Arizona for export to Saudi Arabia as cattle feed. Operates in Ranegras Basin near Vicksburg since 2014 on ~10,000 acres purchased for $48 million. In 2023 used ~31,196 acre-feet of groundwater (81% of all extraction in the Ranegras Basin). Multiple wells each capable of pumping up to 4,000 gallons/minute.', name: 'Fondomonte LLC', provenance: 'archived-verified'})
CREATE (n5181:Organization {addedDate: date('2026-03-02'), aliases: ['Almarai', 'Almarai Company'], description: 'Saudi Arabia-based dairy company, parent of Fondomonte LLC. One of the largest dairy operations in the Middle East. Owns ~10,000 acres of Arizona farmland via Fondomonte and ~3,500 acres in Southern California. Grows alfalfa in US to feed livestock in Saudi Arabia after the kingdom banned domestic alfalfa production due to water scarcity.', name: 'Almarai Co.', provenance: 'archived-verified'})
CREATE (n5182:Organization {addedDate: date('2026-03-02'), aliases: ['Al Dahra Agricultural Company', 'Al Dahra UAE'], description: 'UAE-based agricultural conglomerate farming ~3,000 acres of alfalfa on privately-held land near Wenden, Arizona in La Paz County. Estimated water use of 15,000-16,000 acre-feet/year. Leases land from a North Carolina-based corporation, giving Arizona less regulatory leverage than with state-land operations.', name: 'Al Dahra', provenance: 'web-search'})
CREATE (n5183:Organization {addedDate: date('2026-03-02'), aliases: ['Wenden Water District', 'Wenden Water'], description: 'Public water district serving ~242 connections (~450 customers) in Wenden, Arizona. Operates two wells each 1,500 feet deep. Water table dropped from 117 feet in 1946 to 540 feet by 2025. Chairman/GM Gary Saiter reports 30% increase in system repairs due to subsidence. Provides critical water service as private wells in the area go dry.', name: 'Wenden Domestic Water Improvement District', provenance: 'archived-verified'})
CREATE (n5184:Organization {addedDate: date('2026-03-02'), aliases: ['WAM', 'Water Asset Management', 'Emporia III LLC'], description: 'New York City-based private equity firm (hedge fund) registered in Delaware with Cayman Islands ties. Purchased ~13,000 acres near Wenden on July 1, 2024 for $100 million via subsidiary Emporia III LLC. Also holds 500+ acres in Mohave County and ~1,100 acres in Yuma County through various LLCs. Land includes transfer basin water rights allowing water transport out of the basin.', name: 'Water Asset Management LLC', provenance: 'archived-verified'})
CREATE (n5185:Person {addedDate: date('2026-03-02'), description: 'Chairman and general manager of Wenden Domestic Water Improvement District. Also president of local school board and board of adjustments/appeals for La Paz County. Semi-retired Sherwin-Williams executive. Key local voice documenting subsidence and aquifer depletion in Wenden. Reports Wenden is 4 feet lower than when he moved there.', name: 'Gary Saiter', provenance: 'archived-verified'})
CREATE (n5186:Person {addedDate: date('2026-03-02'), description: 'District 3 Supervisor, La Paz County, Arizona (Republican). Leading advocate for rural groundwater regulation. Estimated Fondomonte wells can extract 64,000 gallons/minute. Reports $2.4 million in road repairs from alfalfa truck traffic. Worked with Gov. Hobbs on Rural Groundwater Act legislation.', name: 'Holly Irwin', provenance: 'archived-verified'})
CREATE (n5187:Person {addedDate: date('2026-03-02'), description: 'Governor of Arizona (Democrat). Terminated Fondomonte\'s state land leases on ~3,500 acres of Butler Valley State Land Trust. Introduced Rural Groundwater Act legislation. Vetoed HB 2124 which would have stripped AG of nuisance enforcement authority.', name: 'Katie Hobbs', provenance: 'archived-verified'})
CREATE (n5188:Person {addedDate: date('2026-03-02'), description: 'Director of science, Arizona Water Innovation Initiative at Arizona State University. Global Futures Professor at ASU School of Sustainability. Called groundwater situation \'a ticking time bomb.\' Stated aquifer depletion is \'100 percent caused by these big farms.\'', name: 'Jay Famiglietti', provenance: 'archived-verified'})
CREATE (n5189:Person {addedDate: date('2026-03-02'), description: 'ASU postgraduate researcher, earned master\'s in geoscience at School of Earth and Space Exploration. Researches land subsidence in Phoenix metro area. Explains the mechanics of aquifer compaction and subsidence.', name: 'Grace Carlson', provenance: 'archived-verified'})
CREATE (n5190:Person {addedDate: date('2026-03-02'), description: 'Hydrologist, supervisor of Geophysics-Surveying Unit, Arizona Department of Water Resources. Monitors subsidence via InSAR. Documents three subsidence areas in metro Phoenix: West Valley Feature (Luke AFB), NE Phoenix-Scottsdale, and Hawk Rock (East Valley).', name: 'Brian Conway', provenance: 'archived-verified'})
CREATE (n5191:Event {addedDate: date('2026-03-02'), date: '2024-12-11', description: 'December 2024 lawsuit by AG Kris Mayes against Fondomonte LLC in Maricopa County Superior Court. Claims public nuisance from excessive groundwater pumping causing wells to dry up, 9.8 inches of subsidence near Vicksburg, and infrastructure damage. Uses untested legal theory since pumping doesn\'t violate state water laws. Fondomonte argues activities are legal and filed to dismiss.', name: 'Arizona AG Nuisance Lawsuit vs Fondomonte', provenance: 'archived-verified'})
CREATE (n5192:Event {addedDate: date('2026-03-02'), date: '2024-03-07', description: 'Governor Katie Hobbs terminated Fondomonte\'s leases on ~3,500 acres of Butler Valley State Land Trust. One lease canceled immediately, others not renewed in February 2024. Fondomonte was growing alfalfa shipped to Saudi Arabia on this state-owned land. Company continues operating on its privately-held ~10,000 acres near Vicksburg.', name: 'Fondomonte State Land Lease Termination', provenance: 'archived-verified'})
CREATE (n5193:Event {addedDate: date('2026-03-02'), date: '2018', description: 'Saudi Arabia banned alfalfa cultivation domestically in 2018 due to water scarcity concerns. This drove Saudi agricultural companies to outsource alfalfa production to water-rich or unregulated areas abroad, including Arizona, California, and other US states. Alfalfa is grown overseas and shipped back to Saudi Arabia as cattle feed for the dairy industry.', name: 'Saudi Arabia Domestic Alfalfa Ban', provenance: 'archived-verified'})
CREATE (n5194:Event {addedDate: date('2026-03-02'), date: '2024-07-01', description: 'On July 1, 2024, Water Asset Management LLC purchased ~13,000 acres near Wenden through subsidiary Emporia III LLC for $100 million from Arizona Valley Farm. Land virtually surrounds Wenden. The McMullen Valley aquifer is designated as a \'transfer basin\' meaning water can legally be transported out to metropolitan areas. Corporate records trace to Madison Avenue, NYC.', name: 'Water Asset Management Wenden Land Purchase', provenance: 'archived-verified'})
CREATE (n5195:Event {addedDate: date('2026-03-02'), date: '1980', description: '1980 Arizona law establishing groundwater extraction limits in Active Management Areas (AMAs) covering less than 25% of state land. La Paz County and ~80% of Arizona were excluded, creating the regulatory vacuum that allowed unlimited pumping by agricultural operations. AMAs require developers to demonstrate 100 years of available water for new subdivisions.', name: 'Arizona Groundwater Management Act', provenance: 'archived-verified'})
CREATE (n5196:Organization {addedDate: date('2026-03-02'), description: 'Arizona state agency responsible for water resource management and monitoring. Uses InSAR (interferometric synthetic aperture radar) to map subsidence features. Makes maps publicly available. Monitors groundwater levels and earth fissures statewide.', name: 'Arizona Department of Water Resources', provenance: 'archived-verified'})
CREATE (n5197:Source {archiveStatus: 'unarchived', captureStatus: 'legacy-unverified', domain: 'news.asu.edu', url: 'https://news.asu.edu/20210603-arizona-impact-asu-researchers-land-subsidence-local-abroad'})
CREATE (n5198:EntryRef {streamEntryId: 'ls-20260302-002', title: 'Arizona Land Subsidence: Saudi Alfalfa Exports, Aquifer Depletion, and Wenden\'s Sinking'})
CREATE (n5199:Source {archivePath: 'ClaudeFiles\\archives\\kjzz.org\\2026-03-02_fd2ef4b2b51d_article.txt', archiveStatus: 'captured', author: 'https://www.kjzz.org/people/mark-brodie', captureCount: 1, captureMethod: 'http-readability', captureStatus: 'captured', capturedAt: date('2026-03-02T17:12:37.790390000+00:00'), domain: 'kjzz.org', htmlPath: 'ClaudeFiles\\archives\\kjzz.org\\2026-03-02_fd2ef4b2b51d.html', lastCaptured: date('2026-03-02T17:12:37.790390000+00:00'), publishedDate: '2024-09-04T19:36:04.76', siteName: 'KJZZ', sourceType: 'unclassified', tags: [], textPreview: 'A New York-based investment company earlier this summer bought nearly 13,000 acres of land in La Paz County, and some critics worry the $100 million deal will mean less water for residents of the western Arizona county.\nWater Asset Management describes itself on its website as a “global investor in companies and assets that ensure water quality and supply.” It’s also bought land in other Western states.\nAs the Arizona Daily Star reported\n, the land in La Paz County is in a basin that by law is a', textSize: 5303, title: 'A NY company bought 13,000 acres in La Paz County. This official is worried about the water under it', url: 'https://kjzz.org/2024-09-04/a-ny-company-bought-13-000-acres-in-la-paz-county-critics-about-the-water-that-goes-with-it'})
CREATE (n5200:Source {archivePath: 'ClaudeFiles\\archives\\factually.co\\2026-03-02_e32b06443287_article.txt', archiveStatus: 'captured', captureCount: 1, captureMethod: 'nodriver', captureStatus: 'captured', capturedAt: date('2026-03-02T22:54:38.797031000+00:00'), domain: 'factually.co', htmlPath: 'ClaudeFiles\\archives\\factually.co\\2026-03-02_e32b06443287.html', lastCaptured: date('2026-03-02T22:54:38.797031000+00:00'), siteName: 'Factually', sourceType: 'ai-generated', tags: [], textPreview: '1. Family ties and public attention\nKent Frantzve has become a subject of media interest chiefly because he is the father of Erika Kirk, who has been thrust into the public eye in connection with Turning Point USA and the late Charlie Kirk; multiple outlets identify that relationship as the main reason reporters have scrutinized Kent’s background\n[5]\n[4]\n. The family’s Swedish lineage and the public profile of relatives (including a grandfather, Carl Kenneth Frantzve) are used by several outlets', textSize: 4567, title: 'Who is Kent Frantzve and what is his professional back...', url: 'https://factually.co/fact-checks/business/who-is-kent-frantzve-professional-background-75a838'})
CREATE (n5201:Source {archivePath: 'ClaudeFiles\\archives\\factually.co\\2026-03-02_f7ac804a77bb_article.txt', archiveStatus: 'captured', captureCount: 1, captureMethod: 'nodriver', captureStatus: 'captured', capturedAt: date('2026-03-02T22:54:46.378274000+00:00'), domain: 'factually.co', htmlPath: 'ClaudeFiles\\archives\\factually.co\\2026-03-02_f7ac804a77bb.html', lastCaptured: date('2026-03-02T22:54:46.378274000+00:00'), siteName: 'Factually', sourceType: 'ai-generated', tags: [], textPreview: '1. A family man who appears in public reporting\nMultiple profiles identify Kent Frantzve principally through his relationship to daughter Erika Kirk (née Frantzve); mainstream and aggregation sites describe him as Erika’s father and place him in Surprise, Arizona\n[2]\n[6]\n[3]\n. Public-interest stories about Erika and her husband have repeatedly brought attention to Kent, which is why most modern references to him are biographical or genealogical in nature\n[6]\n[2]\n.\n2. Business affiliations report', textSize: 3918, title: 'Who is Kent Frantzve and what companies or organizatio...', url: 'https://factually.co/fact-checks/business/who-is-kent-frantzve-affiliations-b1da76'})
CREATE (n5202:Source {archivePath: 'ClaudeFiles\\archives\\iloveinfo.net\\2026-03-02_47b825f954c4_article.txt', archiveStatus: 'captured', captureCount: 1, captureMethod: 'http-readability', captureStatus: 'captured', capturedAt: date('2026-03-02T22:54:49.634200000+00:00'), domain: 'iloveinfo.net', htmlPath: 'ClaudeFiles\\archives\\iloveinfo.net\\2026-03-02_47b825f954c4.html', lastCaptured: date('2026-03-02T22:54:49.634200000+00:00'), sourceType: 'unclassified', tags: [], textPreview: 'What do you get when you mix Swedish heritage, military valor, and defense consulting in the Arizona desert? A man like Kent Frantzve—whose name might not ring bells in pop culture, but whose story quietly threads through war history, corporate intrigue, and family legacy. Let’s dig into the life of Kent Frantzve, a figure whose background is more layered than it first appears.\nFrom Falun to Arizona: A Family Rooted in Swedish-American History\nKent Frantzve didn’t just appear out of nowhere—his ', textSize: 5352, title: 'The Curious Legacy of Kent Frantzve', url: 'https://iloveinfo.net/2025/10/the-curious-legacy-of-kent-frantzve.html'})
CREATE (n5203:Source {archivePath: 'ClaudeFiles\\archives\\goaztech.com\\2026-03-02_c842c44f7d29_article.txt', archiveStatus: 'captured', captureCount: 1, captureMethod: 'http-readability', captureStatus: 'captured', capturedAt: date('2026-03-02T22:55:14.802616000+00:00'), domain: 'goaztech.com', htmlPath: 'ClaudeFiles\\archives\\goaztech.com\\2026-03-02_c842c44f7d29.html', lastCaptured: date('2026-03-02T22:55:14.802616000+00:00'), siteName: 'AzTech', sourceType: 'unclassified', tags: [], textPreview: 'Our Team\nEVM Experts —and Much More\nOur AzTech consultants have mastered the art of making the complex simple. We excel at solving the most stubborn project management challenges. A core strength is our skills at leveraging existing technology or developing new technology and processes to streamline all aspects of EVM, scheduling, and project management.\nWith decades of EVM expertise, deep analytics and metrics knowledge, and DOD & DOE domain experience, we know the importance of a rigorous EV c', textSize: 1132, title: 'EVM Consultants | AzTech', url: 'https://goaztech.com/about/our-team'})
CREATE (n5204:Source {archivePath: 'ClaudeFiles\\archives\\factually.co\\2026-03-02_0b8738d13704_article.txt', archiveStatus: 'captured', captureCount: 2, captureMethod: 'nodriver', captureStatus: 'captured', capturedAt: date('2026-03-02T22:55:21.865937000+00:00'), domain: 'factually.co', htmlPath: 'ClaudeFiles\\archives\\factually.co\\2026-03-02_0b8738d13704.html', lastCaptured: date('2026-03-02T23:18:26.606361000+00:00'), siteName: 'Factually', sourceType: 'ai-generated', tags: [], textPreview: '1. What the aggregator records say: a possible tie to Az‑Tech International, Inc.\nPublic people‑search and background aggregation sites list prior residences, phone numbers and sometimes employment entries for Kent Frantzve, and one such profile specifically associates him with Az‑Tech International, Inc., suggesting a prior employment or corporate affiliation of that name appears in compiled public records\n[1]\n. Those entries come from data‑aggregation services that pull from multiple public so', textSize: 4132, title: 'What public records exist for Kent Frantzve’s prior em...', url: 'https://factually.co/fact-checks/business/kent-frantzve-public-records-prior-employment-corporate-affiliations-beyond-ckf-group-828cc4'})
CREATE (n5205:Source {archivePath: 'ClaudeFiles\\archives\\factually.co\\2026-03-02_25f9cbfe732c_article.txt', archiveStatus: 'captured', captureCount: 1, captureMethod: 'nodriver', captureStatus: 'captured', capturedAt: date('2026-03-02T22:55:28.845143000+00:00'), domain: 'factually.co', htmlPath: 'ClaudeFiles\\archives\\factually.co\\2026-03-02_25f9cbfe732c.html', lastCaptured: date('2026-03-02T22:55:28.845143000+00:00'), siteName: 'Factually', sourceType: 'ai-generated', tags: [], textPreview: '1. What the reporting actually says about his corporate roles\nTimes Now’s profile states Kent Frantzve “founded CKF Group, LLC,” presenting him as a businessman and investor associated with that private investment firm\n[1]\n. Other outlets and posts attribute prior defense-industry links to him: IBTimes and social posts report he “headed up Raytheon Israel” and that a resurfaced personal video generated attention tied to that claim\n[2]\n. A blog-like profile on I Love Information traces Frantzve’s', textSize: 3939, title: 'Which companies does Kent Frantzve currently work for ...', url: 'https://factually.co/fact-checks/business/kent-frantzve-current-companies-advisory-roles-79d1ae'})
CREATE (n5206:Source {archivePath: 'ClaudeFiles\\archives\\govtribe.com\\2026-03-02_9959c65c41c2_article.txt', archiveStatus: 'captured', captureCount: 1, captureMethod: 'nodriver', captureStatus: 'captured', capturedAt: date('2026-03-02T22:55:49.212923000+00:00'), domain: 'govtribe.com', htmlPath: 'ClaudeFiles\\archives\\govtribe.com\\2026-03-02_9959c65c41c2.html', lastCaptured: date('2026-03-02T22:55:49.212923000+00:00'), sourceType: 'unclassified', tags: [], textPreview: 'Skip to main content\nLogin\nContact sales\nTry for free\n All Vendors\nHelp\nAztech International, Inc.\n0\nClaim this Vendor\nUEI VML5JAMZSL64\nDBA Aztech International\nOverview\nDetails\nContacts\n2\nPrice Lists\n2\nContract Vehicles\n1\nIDV Awards\n3\nContract Awards\n12\nContract Subawards\n6\nGrant Awards\nGrant Subawards\nPrimes\nSubs\nPrimary NAICS Category\n541611 - Administrative Management and General Management Consulting Services\nSBA Certifications\nNot listed\nSelf-Certifications\nMore +\nMinority Owned Business \n', textSize: 8369, title: 'Aztech International, Inc.', url: 'https://govtribe.com/vendors/aztech-international-inc-dot-aztech-international-1fre7'})
CREATE (n5207:Source {archivePath: 'ClaudeFiles\\archives\\books.google.com\\2026-03-02_1bbb4edd23b5_article.txt', archiveStatus: 'captured', captureCount: 1, captureMethod: 'nodriver', captureStatus: 'captured', capturedAt: date('2026-03-02T22:57:39.273676000+00:00'), domain: 'books.google.com', htmlPath: 'ClaudeFiles\\archives\\books.google.com\\2026-03-02_1bbb4edd23b5.html', lastCaptured: date('2026-03-02T22:57:39.273676000+00:00'), siteName: 'Google Books', sourceType: 'unclassified', tags: [], textPreview: 'Sign in\nTry the new Your Library\nBooks\nAdd to my library\n \nTry the new Your Library\nClassic My Library will soon be turned off. Visit the new Your Library experience to import your bookshelves.\nGo to Your Library\nDismiss\nGET PRINT BOOK\n\nNo eBook available\n\nAmazon.com\nBarnes&Noble.com\nBooks-A-Million\nIndieBound\nFind in a library\nAll sellers »\nGet Textbooks on Google Play\n\nRent and save from the world\'s largest eBookstore. Read, highlight, and take notes, across web, tablet, and phone.\n\nGo to Goog', textSize: 2634, title: 'The Desktop Business Intelligence Sourcebook: A Comprehensive Guidebook for ...', url: 'https://books.google.com/books/about/The_Desktop_Business_Intelligence_Source.html?id=jaR2ZeS4PVcC'})
