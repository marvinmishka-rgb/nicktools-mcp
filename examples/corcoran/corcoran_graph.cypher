CREATE (n4884:Organization {accumulatedDeficit: '$2,383,517 (as of Dec 31, 2015)', addedDate: date('2026-02-27'), altNames: ['GTEK', 'Saxon Capital Group'], ceoHistory: 'Brian Chamberlain (sole officer, May 2015 — ~Jun 2016), Clifford R. Paul (President/Secretary/Treasurer/Chairman, Jun 21 2016 — ?), Joel Borovay (Acting CEO per Oct 2016 Murdock Capital announcement)', description: 'EMP technology company founded by Lori Frantzve (as \'Dr. Lorin Frantzve\') and Larry Gunta. Scottsdale AZ. Reverse-merged into Saxon Capital Group (OTC: SCGX) in 2016. Products for EMP mitigation, critical infrastructure protection.', forwardSplit: '4:1 forward split on July 15, 2016 — 23,190,144 shares outstanding post-split', founded: '~2015', frantzveOwnership: 'Lorin Frantzve — 86.8% majority shareholder (5,034,324 shares) as of June 30, 2016. Address: 9743 E Sharon Dr, Scottsdale AZ 85260', incorporation: 'Nevada, November 12, 2003', location: 'Scottsdale, AZ', murdockCapitalAlliance: 'Consultant agreement Oct 10 2016 with Murdock Capital Partners Corp (NYC). Luis J. Mejia, Managing Director.', name: 'GTEK Industries Inc', org_type: 'defense-tech', principalOffice: '7740 East Evans Road, Scottsdale, AZ 85260', priorAssets: 'Oil & gas properties ($1,040,877 on Dec 2014 balance sheet) written off as worthless by March 2015', revenue: '$0 across all reporting periods (2014-2016). Going concern warning in all filings.', secFilingSource: 'OTC Pink Basic Disclosure, periods ended Dec 31 2015/2014 and Jun 30 2016', shellHistory: 'Comlink Communications (Nov 2003) → USA Superior Energy Holdings Inc (Mar 2007) → XSilent Solutions Inc (Jun 2014) → Saxon Capital Group Inc (May 2015) → GTEK Industries Inc (Jul 2016)', thirdPartyProviders: 'No legal counsel, no accountant/auditor, no investor relations (per OTC disclosure)', tradingSymbol: 'SCGX (OTC Pink)'})
CREATE (n4885:Source {archivePath: 'ClaudeFiles\\archives\\washingtonpost.com\\2026-02-27_84ec7eb776e0.txt', archiveStatus: 'captured', captureStatus: 'captured', capturedAt: date('2026-02-27T14:15:38.252139000+00:00'), domain: 'washingtonpost.com', lastCaptured: date('2026-02-27T14:15:38.252139000+00:00'), originalUrl: 'https://www.washingtonpost.com/politics/2022/11/04/arizona-gop-turning-point-usa/', sourceType: 'primary-journalism', textPreview: 'Accessibility statement\nSkip to main content\nSubscribe\nSign in\nPolitics\nDonald Trump\nWhite House\nDemocracy in America\nCourts & Law\nNational Security\nElections\nEXCLUSIVE\nHow a pro-Trump youth group remade the Arizona GOP, testing democracy\n\nCharlie Kirk’s Turning Point network worked to purge officials who affirmed the 2020 election results\n\nNovember 4, 2022\nMore than \n3 years ago\n20 min\n2,408\nGOP gubernatorial nominee Kari Lake and Turning Point USA founder Charlie Kirk on Tuesday in Chandler, A', textSize: 25632, title: 'How Turning Point, a pro-Trump youth group, remade the Arizona GOP - The Washington Post', url: 'https://washingtonpost.com/politics/2022/11/04/arizona-gop-turning-point-usa'})
