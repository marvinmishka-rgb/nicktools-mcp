CREATE (n4600)-[:SUPPORTED_BY {claim: 'Co-founded TPUSA 2012. Board sec/treasurer until spring 2019. Marketing career. Met Kirk at small college. Provided initial funding. Died COVID-19 July 28, 2020.', confidence: 'archived-verified', createdAt: date('2026-02-25T23:24:00.513000000+00:00')}]->(n4619)
