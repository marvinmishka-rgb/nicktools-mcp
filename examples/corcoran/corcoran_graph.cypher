CREATE (n4685:Source {archivePath: 'ClaudeFiles\\archives\\statepress.com\\2026-02-27_7ac3b9bd730c.txt', archiveStatus: 'captured', captureStatus: 'captured', capturedAt: date('2026-02-27T05:30:57.292833000+00:00'), domain: 'statepress.com', lastCaptured: date('2026-02-27T05:49:23.876551000+00:00'), originalUrl: 'https://www.statepress.com/article/2018/09/sppolitics-turning-point-usa-opens-new-headquarters-in-phoenix', sourceType: 'unclassified', textPreview: 'Skip to Content, Navigation, or Footer.\nPOLITICS\nTURNING POINT USA OPENS NEW HEADQUARTERS IN PHOENIX\nThe conservative student organization picks Phoenix for expansion\n\nCharlie Kirk, founder and executive director of Turning Point USA, cuts the ribbon at the opening of their new downtown Phoenix headquarters in Phoenix, Arizona, on Friday, Aug. 10, 2018. \n\n Jonathan Williams Couresy\nBy Jennifer Carroll | September 19, 2018 | 6:07pm MST\n   \n\nTurning Point USA officially opened its newest headquart', textSize: 5624, title: 'Turning Point USA opens new headquarters in Phoenix - The Arizona State Press', url: 'https://statepress.com/article/2018/09/sppolitics-turning-point-usa-opens-new-headquarters-in-phoenix'})
