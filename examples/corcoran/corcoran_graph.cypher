CREATE (n1372:Agent {activeListings: 1, agentIds: ['18319'], bio: 'Miss Arizona USA 2012. Born Nov 20, 1988 in Scottsdale. NCAA basketball at Regis University. ASU BA (poli sci, intl relations, 2012). Liberty University (Juris Master, DMin Christian Leadership). Model, actress, casting director in LA/China. Founded Everyday Heroes Like You 501(c)(3) in 2006 (Romania orphanage work). CEO of Proclaim Streetwear (faith-based clothing). Summer 2018: Appeared on Bravo\'s Summer House S3 (NYC, set up with Jordan Verroi by Carl Radke). Sep 2018: Met Charlie Kirk at TPUSA HQ Phoenix job interview, first date in NYC. Oct 2018: Licensed NY RE agent. Nov 2019: Single Wayback capture at Corcoran Chelsea-Flatiron (agent ID 18319). 2019: Started attending Kings\' Church Manhattan (Pastor David Engelhardt), launched Midweek Rise Up podcast. Pre-pandemic: Told Engelhardt she met someone and was moving to Phoenix. Summer 2020: During BLM protests and COVID, Erika reconnected with Engelhardt and introduced him to Charlie Kirk. Engelhardt joined TPUSA board 2020. Dec 2020: Engaged. May 8, 2021: Married in Scottsdale. Aug 2022: Daughter. May 2024: Son. Sep 10, 2025: Charlie Kirk assassinated at Utah Valley University. Unanimously elected TPUSA CEO/Chair. Oct 2025: Accepted posthumous Presidential Medal of Freedom for Kirk. KEY: Erika was the bridge between NYC faith community (Engelhardt/Kings\' Church) and TPUSA. Her RE career was a brief side credential while living in NYC, not connected to her faith/political network.', bioEvolution: 'DROPPED: Real estate career entirely gone from public narrative. DROPPED: Entertainment/modeling career de-emphasized. ADDED: Faith, family, conservative politics as central identity. ADDED: TPUSA leadership. TRANSFORMATION: From "multidimensional entrepreneur" NYC agent to conservative political leader and CEO.', bioNotes2019: 'Corcoran bio: "multidimensional entrepreneur...lived all over the world, from Los Angeles to China working in the entertainment industry as an agency represented model, actress, and casting director"', bioNotesCurrent: 'Wikipedia/public: Miss AZ USA 2012, entertainment career, nonprofit founder, faith-based clothing brand (Proclaim Streetwear), BIBLEin365 ministry, married Charlie Kirk 2021, became TPUSA CEO Sept 2025 after his assassination.', businesses: 'Proclaim Streetwear, Midweek Rise Up podcast', captureCount: 1, careerPath: 'Miss Arizona USA 2012 → Entertainment (model/actress/casting director, LA & China) → Everyday Heroes Like You (nonprofit, founded age 18) → BIBLEin365 ministry (2016) → Corcoran Chelsea-Flatiron (2018-2019) → Proclaim Streetwear (2018) → Married Charlie Kirk (2021) → TPUSA CEO (Sept 2025)', currentRole: 'CEO, Turning Point USA', currentStatus: 'inactive_other_career', education: 'ASU (Political Science & International Relations), Liberty University (Juris Master 2017, pursuing doctorate in Biblical Studies)', email: '[redacted]', enrichedAt: '2026-02-19T20:23:38', enrichedFrom: 'wayback-[phone redacted]1228', firstSeen: '20191121', ghostCohort: true, ghostCohortNote: 'EXPLAINED: Licensed Oct 2018, brief Corcoran affiliation. RE was never primary career. Now CEO of TPUSA.', ghostStatus: 'primary-research-subject', lastSeen: '20191121', lastVerified: '2026-02-23', legalName: 'Erika Frantzve', marriedName: 'Erika Kirk', movesCount: 1, name: 'Erika Frantzve', nonprofits: 'Everyday Heroes Like You 501(c)(3)', notableConnections: ['Charlie Kirk (husband, TPUSA founder, d. Sep 2025)', 'David Engelhardt (Kings Church NYC pastor, TPUSA board — met through Erika 2020)', 'Rob McCoy (Kirk pastor, TPUSA Faith co-chair)', 'Mikey McCoy (Kirk Chief of Staff, met driving Kirk+Erika to airport)'], notableRole: 'CEO of Turning Point USA', notes: 'Miss Arizona USA 2012. Married Charlie Kirk (TPUSA founder) May 2021. Charlie Kirk fatally shot Sept 10, 2025 at Utah Valley University. Erika appointed TPUSA Chairman/CEO. Founded PROCLAIM Streetwear. Pursuing Doctorate of Education. Juris Master degree. Corcoran Chelsea-Flatiron office. Epstein property speculation in media debunked — Palm Beach sale handled by Kerry Warwick, NYC townhouse by Adam Modlin. No evidence of Erika involvement in Epstein transactions.', office: 'Chelsea/Flatiron - 218 West 18th Street 6th Floor', pageantTitle: 'Miss Arizona USA 2012', phone: '[redacted]', priorCareer: 'Entertainment industry - model, actress, casting director in LA and China. Miss Arizona USA 2012. Serial entrepreneur.', relatedAgent: 'Kerry Warwick (Epstein property agent)', sampleUrl: 'https://www.corcoran.com/nyc-real-estate/agents/chelsea-flatiron/erika-frantzve/18319', slug: 'erika-frantzve', spouse: 'Charlie Kirk (Turning Point USA founder, engaged Dec 2020, married May 2021)', status: 'active-elsewhere', title: 'Licensed RE Salesperson'})
