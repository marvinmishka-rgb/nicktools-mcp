CREATE (n4549:Brokerage {addedDate: '2026-02-23', city: 'New York', name: 'Warburg Realty', notes: 'Founded 1896. Now Coldwell Banker Warburg after 2020 merger. Charlie Lewis was their No. 2 agent before leaving for Corcoran in July 2016.', source: 'TRD article 2016-07-20', state: 'NY', type: 'brokerage'})
CREATE (n4550:Brokerage {addedDate: '2026-02-23', city: 'New York', name: 'Compass', notes: 'Founded 2012 by Robert Reffkin and Ori Allon. Tech-forward brokerage. Mike Fabbri was Senior Lead of Agent Development before leaving for Corcoran in July 2016.', source: 'TRD article 2016-07-14', state: 'NY', type: 'brokerage'})
CREATE (n4551:Agent {addedDate: '2026-02-23', bio: 'Former Senior Lead of Agent Development at Compass (April 2015 - July 2016), handling agent recruitment, retention, branding, and marketing. Previously Senior Director of Digital & Social Media at Douglas Elliman. Joined Corcoran July 2016 as broker at 660 Madison Ave flagship. Won Manhattan Rookie of the Year Award in first year with $10M+ volume. Later sold $100M+ at Etage and 145CPN condos. Set price/sqft record at Central Park North ($2.6K/sqft). ~$500M career volume. Left Corcoran for The Agency in 2023. Also known for matchmaking 300+ couples since 2020. Featured on Bravo shows. Pam Liebman recruited him to get his license and become a broker.', careerPath: 'Douglas Elliman (Sr Dir Digital/Social) -> Compass (Sr Lead Agent Dev, Apr 2015) -> Corcoran (Broker, Jul 2016, 660 Madison) -> The Agency (2023)', chelseaFlatironAnalysis: 'Fabbri was based at 660 Madison Ave (flagship UES), NOT Chelsea-Flatiron. Joined Corcoran Jul 2016 as producing agent, not in management/recruiting role. However: (1) had deep insider knowledge of agent pipelines from Compass agent development role, (2) arrived same month as Charlie Lewis, suggesting coordinated Corcoran recruiting push mid-2016, (3) Pam Liebman personally recruited him, (4) his Compass role specifically involved recruitment/retention/branding. Connection to Chelsea-Flatiron ghost cohort is circumstantial — his expertise may have informed Corcoran expansion strategy even if he did not directly recruit Chelsea agents.', education: 'Boston College', formerAgent: false, investigativeNote: 'KEY FIGURE: Was Compass top executive for recruiting/grooming agents. Had insider knowledge of agent pipelines. Joined Corcoran July 2016 — same period Chelsea-Flatiron office was being built. May have been involved in recruiting ghost cohort agents.', lifestreamRefs: ['ls-20260223-006'], name: 'Mike Fabbri', office: '660 Madison Avenue', role: 'Former Senior Lead Agent Development at Compass; Broker at Corcoran', source: 'TRD 2016-07-14, RISMedia 2024-11-06, Mann Report 2023-08-22'})
CREATE (n4552:Agent {addedDate: '2026-02-23', bio: 'Was Warburg Realty No. 2 agent and Senior Managing Director of Harlem office, then Tribeca office. No. 1 broker in Tribeca and No. 2 firm-wide in 2015. Had brief 7-month stint at Corcoran before joining Warburg in 2007. Returned to Corcoran July 2016 at 660 Madison Ave flagship. Earned Gold Council status (top 4% of 2,500 agents). Over $600M career volume. Later moved to Compass. Founded The Charlie Lewis Team in 2013. Background in digital marketing (Digitas, Mindshock agency). Featured on HGTV Selling New York.', careerPath: 'Corcoran (7 months, pre-2007) -> Warburg Realty (2007-2016, Sr Managing Dir) -> Corcoran (Jul 2016, 660 Madison) -> Compass', formerAgent: false, lifestreamRefs: ['ls-20260223-006'], name: 'Charlie Lewis', office: '660 Madison Avenue', role: 'Licensed Associate Real Estate Broker', source: 'TRD 2016-07-20, Compass profile, charlielewisnyc.com'})
CREATE (n4553:Brokerage {addedDate: '2026-02-23', city: 'New York', name: 'Douglas Elliman', notes: 'Major NYC luxury brokerage. Mike Fabbri was Sr Director of Digital & Social Media before Compass.', state: 'NY', type: 'brokerage'})
CREATE (n4554:Person:Attorney {addedDate: '2026-02-23', address: '[address redacted]', caseRole: 'plaintiff_counsel', email: '[redacted]', fax: '[redacted]', firm: 'Adam Michael Levy, P.C.', name: 'Adam Michael Levy', nyscefCase: '162223/2018', phone: '[redacted]', role: 'Plaintiff counsel in Roumila v. CIRE (162223/2018)', source: 'NYSCEF Doc 16, docket page', type: 'attorney'})
CREATE (n4555:Person:Attorney {addedDate: '2026-02-23', caseRole: 'defense_counsel', name: 'Sarah Katherine Hook', notes: 'Filed Motion 002 (Dismiss), briefing schedule, reply memo for defendants', nyscefCase: '162223/2018', role: 'Defense counsel in Roumila v. CIRE (162223/2018)', source: 'NYSCEF docket page', type: 'attorney'})
CREATE (n4556:Person:Attorney {addedDate: '2026-02-23', caseRole: 'defense_counsel', name: 'Ravindra K. Shaw', notes: 'Filed opposition affirmation and stipulation for Motion 001', nyscefCase: '162223/2018', role: 'Defense counsel in Roumila v. CIRE (162223/2018)', source: 'NYSCEF docket page', type: 'attorney'})
CREATE (n4557:Person:Attorney {addedDate: '2026-02-23', caseRole: 'defense_counsel', name: 'Wendy Jill Mellk', notes: 'Filed adjournment stipulation and notice of entry', nyscefCase: '162223/2018', role: 'Defense counsel in Roumila v. CIRE (162223/2018)', source: 'NYSCEF docket page', type: 'attorney'})
CREATE (n4558:Person:Judge {addedDate: '2026-02-23', court: 'Supreme Court of the State of New York, County of New York', name: 'Debra A. James', nyscefCase: '162223/2018', role: 'Presiding judge in Roumila v. CIRE (162223/2018)', source: 'NYSCEF docket page', type: 'judge'})
CREATE (n4559:Person {addedDate: '2026-02-23', careerPath: 'Coach Realtors (1990-2006, Sales Manager/Director Luxury) -> CIRE (Sept 2006+, Exec Dir/Broker of Record)', caseRole: 'named_defendant', company: 'Christie\'s International Real Estate', education: 'Queens College BBA', name: 'Kathleen Coumou', notes: 'Accused of changing Roumila listings to herself on StreetEasy after his termination. Sent dissociation email Dec 18, 2018.', nyscefCase: '162223/2018', source: 'NYSCEF Doc 05, Doc 12, Doc 13, Doc 15', title: 'Executive Director, NE Region & Eastern Canada; Broker of Record', type: 'real_estate_executive'})
CREATE (n4560:Person {addedDate: '2026-02-23', careerPath: 'JJG Real Estate Appraisal (2009-2014) -> Warburg Realty (Dec 2014 - Nov 2017) -> CIRE Office Manager (Nov 2017) -> CIRE Business Ops Manager (Jun 2018)', caseRole: 'named_defendant', company: 'Christie\'s International Real Estate', description: 'Business operations manager at Christie\'s International Real Estate. Named as defendant in sexual harassment lawsuit filed by broker Regis Roumila in January 2019, who alleged she repeatedly harassed him and tried to use her authority to pressure him.', education: 'NYU Old Westbury BS International Business', name: 'Sarine Atamian', notes: 'Accused of sexual harassment and unwanted advances toward Roumila. Previously at Warburg Realty.', nyscefCase: '162223/2018', source: 'NYSCEF Doc 05, Doc 12', title: 'Business Operations Manager & Licensed Real Estate Salesperson', type: 'real_estate_operations'})
CREATE (n4561:Agent {addedDate: '2026-02-23', name: 'Steven Martinez', notes: 'Found on live HBL team page Feb 2026. No Corcoran agentId yet.', source: 'hechterbarlev.com/team', title: 'Licensed RE Salesperson'})
CREATE (n4562:Team {lastVerified: '2026-02-23', memberCount: 10, name: 'The Blumstein Team', office: 'Chelsea/Flatiron - 220 West 19th Street'})
CREATE (n4563:Person:Spokesperson:Producer:Communications {addedDate: [date('2026-02-24'), date('2026-03-02')], altNames: ['Andrew Kovet'], description: ['Conservative communications specialist, spokesperson for Turning Point USA, and executive producer of The Charlie Kirk Show. Born June 1984 in Nevada. Fifth-generation Nevada rancher family. Attended University of Washington (Seattle). Traveled to UK and Kenya for mission work. Worked in Hollywood media production for Mark Burnett (United Artist Media Group), including faith-based content (The Bible series, Son of God). Founded ATK Media Inc. (California corporation) specializing in communications, crisis PR, and brand strategy. Earlier career: Financial Analyst at Washington Mutual, Lead Field Marketer at Bolthouse Farms, intern at Agros International. Described as Kirk\'s best friend. After Kirk\'s assassination (Sep 2025), became primary public voice for TPUSA\'s continuation, confirming Kirk had prepared Erika to succeed him.', 'TPUSA executive involved in employee terminations following Charlie Kirk\'s death. Conducted interrogation-style meetings with employees suspected of leaking information to Candace Owens.'], name: 'Andrew Kolvet', occupation: 'TPUSA executive', roles: ['producer', 'spokesperson'], source: 'ls-20260224-014'})
CREATE (n4564:Person {addedDate: date('2026-02-24'), description: 'Evangelical PR executive. Founder/CEO of The KAIROS Company (2015). Former VP/spokesman at Liberty University under Jerry Falwell Sr. Former chief of staff to Mark Burnett (One Two Three media, 2014-2015). Twice-appointed Commissioner on USCIRF. De facto spokesperson for Trump evangelical advisory board. TPUSA was a Kairos PR client. Chairman of Gaza Humanitarian Foundation (2025).', name: 'Johnnie Moore Jr.', nameVariants: ['Johnny Moore', 'Johnny Moor', 'Rev. Johnnie Moore'], roles: ['PR executive', 'commissioner', 'evangelical leader'], source: 'ls-20260224-014'})
CREATE (n4565:Person {addedDate: date('2026-02-24'), description: 'Producer on The Charlie Kirk Show (by June 2023). Co-host of THOUGHTCRIME panel. Former top writer for Tucker Carlson Tonight (4 years, resigned July 2020 after racist posts exposed). Dartmouth College graduate. Daily Caller background. Marine Corps War College connection as wargaming SME.', name: 'Blake Neff', roles: ['producer', 'writer'], source: 'ls-20260224-014'})
CREATE (n4566:Person {addedDate: date('2026-02-24'), companyStarted: '2022', description: 'Kirk security chief. Former Texas police officer (14 years — patrol, tactical ops, criminal/narcotics interdiction, bicycle unit, training, admin). Father was a cop for 47 years. Transitioned to private security in 2008 as operations manager for a Texas-based elite security firm (Shaffer Security Group, ~7 years). Founded Integrity Security Solutions in 2022 (working for Kirk since 2018). Company operates across five continents. Team vetting: sponsored by existing members, train every Wednesday (defensive tactics, emergency medicine, PSB, firearms, etiquette), team vote for admission. Minimum 40 hours/year training (most get 200-400). Background includes NGO work documenting child trafficking in Juarez cartel houses and border documentation. At UVU: deployed 12-13 contractors (up from usual 8-9), built concentric zones with presidential-style double barricades and vehicle barriers. Flagged rooftop vulnerability to UVU Chief Long two days prior via text. Long responded \'I got you covered\' — no officers were ever posted. First to reach Kirk after shooting (~5 seconds), applied direct pressure to carotid wound. Called exfil within 15-16 seconds. Appeared on Shawn Ryan Show (SRS #254, Nov 17, 2025) with detailed account. Company wiped web presence after assassination.', mentors: 'Jerry Venom, Bill Waybourn, Keith Lane', name: 'Brian Harpole', roles: ['security', 'law enforcement'], source: 'ls-20260224-014', workingForKirkSince: '2018'})
CREATE (n4567:Person {addedDate: date('2026-02-24'), description: 'Private security operator on Brian Harpole team. Present during Kirk assassination emergency response.', name: 'Rick Cutler', roles: ['security'], source: 'ls-20260224-014'})
CREATE (n4568:Person {addedDate: date('2026-02-24'), description: 'TPUSA head of security. Best friend of Brian Harpole. Both formerly worked for Shaffer Security Group. TPUSA page no longer active as of mid-2025.', name: 'Dan Flood', roles: ['security'], source: 'ls-20260224-014'})
CREATE (n4569:Person {addedDate: date('2026-02-24'), birthDate: '1948-08-02', birthPlace: 'Brooklyn, New York', description: 'Conservative radio host (KRLA/Salem Media, nationally syndicated since 1999), co-founder of PragerU (2009, with Allen Estrin). Born August 2, 1948 in Brooklyn. Hosts The Dennis Prager Show. Author of multiple books on Judaism and morality. Suffered severe spinal cord injury (C3-C4) from fall Nov 12, 2024, paralyzed below shoulders. Charlie Kirk took over his Salem Radio affiliates March 2025; return delayed indefinitely.', education: 'B.A. Brooklyn College (anthropology/history, 1970); Columbia School of International and Public Affairs (1970-72)', name: 'Dennis Prager', roles: ['media host', 'founder', 'author', 'radio host'], source: 'ls-20260224-014'})
CREATE (n4570:Person {addedDate: date('2026-02-24'), description: 'Television producer (Survivor, The Apprentice, The Voice, Shark Tank). Ran One Two Three media and United Artist Media Group (MGM). Both Johnnie Moore (chief of staff) and Andrew Kolvet (media promotions) worked for Burnett before joining Kirk orbit. Outspoken Christian in Hollywood. No direct TPUSA connection found.', name: 'Mark Burnett', roles: ['producer', 'executive'], source: 'ls-20260224-014'})
CREATE (n4571:Person {addedDate: date('2026-02-24'), description: 'Former FBI agent. Founded Shaffer Security Group which handled TPUSA events 2015-2022. Lost TPUSA contract to Harpole Integrity Security Solutions.', name: 'Greg Shaffer', roles: ['security', 'law enforcement'], source: 'ls-20260224-014'})
CREATE (n4572:Organization {addedDate: date('2026-02-24'), boardSource: '2023 Form 990, ProPublica Nonprofit Explorer, InfluenceWatch', campuses: '~900 college + 1200 high school (by Sept 2025)', confirmedBoard2023: 'From 2023 Form 990 (EIN 80-0835023): Charles Kirk (President/CEO), Tom Sodeika (Secretary & Treasurer), Doug De Groote (Director), Mike Miller (Director), David Engelhardt (Director), Justin Olson (Assistant Treasurer). No Frantzve appears.', description: 'Conservative student organization co-founded by Charlie Kirk in 2012. Revenue $85M (fiscal year ending June 2024). Kirk served as CEO until assassination Sep 10, 2025. Erika Kirk elected CEO Sep 18, 2025. Includes TPUSA Faith division (est. 2021 with Rob McCoy).', founded: '2012', hqPhoenix: 'opened 2018 with ~30 staffers', lastVerified: '2026-03-03', name: 'Turning Point USA', registeredDate: '2012-07-23', registeredState: 'Illinois', revenue2015: '$2M', revenue2016: '$4M (estimated, doubled from 2015)', revenue2017: '$8M', revenue2020: '$55M (40% increase over prior year)', revenue2021: '~$40M', source: 'ls-20260224-014', totalRaised: '$389M (by Sept 2025)', type: 'political'})
CREATE (n4573:Organization {addedDate: date('2026-02-24'), description: 'Conservative 501(c)(3) nonprofit media organization co-founded 2009 by Dennis Prager and Allen Estrin. Produces 5-minute conservative videos. 7 billion+ lifetime views. ~150 staff across two LA floors. Not an academic institution. Approved as supplemental material in 8 state school systems. Kirk was a PragerU presenter.', founded: '2009', name: 'PragerU', nameVariants: ['Prager University', 'Prager University Foundation'], source: 'ls-20260224-014', type: 'publisher'})
CREATE (n4574:Organization {addedDate: date('2026-02-24'), description: 'Conservative media company formed 2018 from merger of Glenn Beck TheBlaze and Mark Levin CRTV. Based in Irving TX. CEO Tyler Cardon. Owned by Mercury Radio Arts (Glenn Beck). Kirk was regular BlazeTV guest since 2019. DeVos family investor.', founded: '2018', name: 'Blaze Media', nameVariants: ['TheBlaze', 'The Blaze', 'BlazeTV'], source: 'ls-20260224-014', type: 'publisher'})
CREATE (n4575:Organization {addedDate: date('2026-02-24'), description: 'PR firm founded 2015 by Johnnie Moore Jr. Represented TPUSA, National Religious Broadcasters, Museum of the Bible, Rev. Sammy Rodriguez. Bought by JDA Worldwide in 2022. Crisis communications specialty.', founded: '2015', name: 'The KAIROS Company', nameVariants: ['Kairos Co.', 'Kairos PR'], source: 'ls-20260224-014', type: 'other'})
CREATE (n4576:Organization {addedDate: date('2026-02-24'), description: 'Private security firm founded 2023 by Brian Harpole. Took TPUSA security contract from Shaffer Security Group. Eric Sardina listed on company formation records. Wiped web presence after Kirk assassination Sep 2025.', founded: '2023', name: 'Integrity Security Solutions', nameVariants: ['Rockhouse Integrity Group'], source: 'ls-20260224-014', type: 'other'})
CREATE (n4577:Organization {addedDate: date('2026-02-24'), description: 'Private security firm founded by former FBI agent Greg Shaffer. Handled TPUSA events 2015-2022. Lost contract to Harpole Integrity Security Solutions.', name: 'Shaffer Security Group', source: 'ls-20260224-014', type: 'other'})
CREATE (n4578:Person:Podcaster:Activist:Author:PoliticalCommentator {addedDate: date('2026-02-24'), born: '1993-10-14', causeOfDeath: 'Assassination at Utah Valley University, Orem UT, by Tyler Robinson (22)', description: 'Charles James Kirk (Oct 14, 1993 – Sep 10, 2025). Co-founder and CEO of Turning Point USA (2012-2025). Conservative activist, author, radio host, political commentator. Born in Arlington Heights, Illinois; raised in Prospect Heights. Father Robert Kirk was an architect (worked on Trump Tower); mother Kimberly (identified in some sources as Kathryn) Kirk was a mental health counselor. Eagle Scout (Boy Scouts). Attended Wheeling High School where he wrote Breitbart op-ed at 17 criticizing liberal textbook economics, leading to first Fox News appearance. Applied to West Point (rejected 2012). Briefly attended Harper College in Palatine, IL (dropped out). Met Bill Montgomery at Benedictine University Youth Government Day May 2012. Co-founded TPUSA June 2012 with Montgomery\'s backing. Met Foster Friess at 2012 RNC, gaining key donor support. Youngest speaker at 2016 RNC (age 22). Hosted The Charlie Kirk Show on Salem Media Group from Oct 2020 (500-750K daily downloads by 2024). Published four books. Signed with Trinity Broadcasting Network Feb 2025 for Charlie Kirk Today TV show. Forbes 30 Under 30 (2018). Honorary D.Hum. from Liberty University (2019). Council for National Policy member. Married Erika Frantzve May 2021; two children (daughter 2022, son 2024). Three properties including $4.75M Scottsdale estate. Posthumously awarded Presidential Medal of Freedom Oct 14, 2025. Assassinated Sep 10, 2025 at Utah Valley University by Tyler Robinson.', died: '2025-09-10', name: 'Charlie Kirk', nameVariants: ['Charles James Kirk'], roles: ['activist', 'media host', 'executive'], source: 'ls-20260224-014'})
CREATE (n4579:Person:Executive:Entrepreneur:Podcaster {addedDate: date('2026-02-24'), altNames: ['Erika Frantzve', 'Erika Lane Frantzve'], birthPlace: 'Ohio', birthplace: 'Scottsdale, AZ', blackStartDocumentary: 'Hosted 2013/2017 EMP documentary \'Black Start USA\' alongside fmr CIA Dir James Woolsey', born: 'November 1988', charity: 'Everyday Heroes Like You (founded by Erika)', corcoranAgent: true, description: 'CEO of TPUSA (Sep 2025-). Born Erika Lane Frantzve. Miss Arizona USA 2012. ASU degrees in political science and international relations. Regis University basketball. Juris Master from Liberty University 2017. Founded Everyday Heroes Like You nonprofit at 18 (2006). Created BIBLEin365 ministry 2016. Launched Proclaim Streetwear 2018. Midweek Rise Up podcast 2019. Brief Summer House (Bravo) S3 cameo 2019 — blind date with Jordan Verroi, declined full cast role. Licensed real estate agent with Corcoran Group NYC (no verified sales). Model/actress/casting director with minimal verifiable credits (one 2012 music video on IMDb). Early Trump supporter 2015. Former classmate of Tyler Bowyer (likely ASU). Called Bowyer to help at Trump\'s first AZ rally 2015, placed behind Trump. Met Charlie Kirk Aug 2018 at TPUSA Phoenix HQ opening, then formal dinner/interview at Bill\'s in NYC where Kirk said \'forget this job interview, I want to date you.\' Married May 2021. Two children.', education: 'Catholic high school (graduated 2007), Regis University Denver CO (Jesuit)', grewUpIn: 'Scottsdale, AZ', highSchool: 'Notre Dame Preparatory, Scottsdale', hsGradYear: '2007', linkedInCaptured: '2026-02-25', linkedInMemberId: '195982015', linkedInUrl: 'https://www.linkedin.com/in/erikafrantzve/', name: 'Erika Kirk', nameVariants: ['Erika Frantzve', 'Erika Frantzve Kirk'], ndpHallOfFame: true, ndpHallOfFameYear: 2021, pageantTitle: 'Miss Arizona USA 2012', pageantTitles: ['Miss Teen Arizona', 'Miss Arizona USA 2012'], realEstateLicense: 'NY, October 2018', roles: ['CEO', 'Real Estate Agent', 'Beauty Queen', 'Entrepreneur', 'Podcast Host'], source: 'ls-20260224-020', summerHouseAppearance: 'Bravo Summer House S3 (2019)'})
CREATE (n4580:Person {addedDate: date('2026-02-24'), description: 'Conservative political commentator and author. Co-hosted THOUGHTCRIME panel show with Andrew Kolvet and Charlie Kirk. Former Navy intelligence officer. Senior editor at Human Events.', name: 'Jack Posobiec', roles: ['commentator', 'author'], source: 'ls-20260224-014'})
CREATE (n4581:Person:Politician:Pastor {addedDate: date('2026-02-24'), description: 'Pastor of Godspeak Calvary Chapel, Thousand Oaks, California. City council member. Kirk\'s primary influence in pivoting from secular conservatism to Christian nationalism. Kirk said hearing McCoy speak (possibly at 2019 CPAC event at Liberty University) \'blew him away.\' McCoy argued that 50 years of Christians merely preaching without engaging in politics had left California in decline. Over a series of conversations, McCoy \'challenged\' Kirk to rethink separating politics and religion. McCoy\'s campaigns blend electoral politics and religion, connected to David Lane\'s American Renewal Project.', name: 'Rob McCoy', roles: ['pastor', 'politician', 'activist'], source: 'ls-20260223-015'})
CREATE (n4582:Person {addedDate: date('2026-02-24'), description: 'Son of Rob McCoy. Works in TPUSA operations. Represents the generational dimension of the McCoy-Kirk network.', name: 'Mikey McCoy', nameVariants: ['Michael McCoy'], roles: ['activist'], source: 'ls-20260223-015'})
CREATE (n4583:Person {addedDate: date('2026-02-24'), description: 'East coast TPUSA network figure. Connected to Kirk through separate pathway from the McCoy west coast network. Details in ls-20260223-016.', name: 'David Engelhardt', roles: ['activist'], source: 'ls-20260223-016'})
CREATE (n4584:Person {addedDate: date('2026-02-24'), description: 'NYC luxury real estate executive. Nearly 26 years at Corcoran (1991-2016) rising from sales agent to Senior Managing Director of Chelsea/Flatiron. EVP to CEO at Douglas Elliman (2016-2024). Terminated Oct 2024 amid financial losses and Alexander brothers scandal. Returned to Corcoran as luxury associate broker and equestrian specialist Oct 2025. Former Pierre Hotel manager. Competitive dressage rider.', name: 'Scott Durkin', source: 'ls-20260224-010'})
CREATE (n4585:Person {addedDate: date('2026-02-24'), description: 'Former senior managing director at Corcoran\'s 660 Madison Avenue office. Replaced Scott Durkin as Chelsea office manager when Durkin left for Douglas Elliman in January 2016.', name: 'Leigh Godwin', source: 'ls-20260224-010'})
CREATE (n4586:Person {addedDate: date('2026-02-24'), description: 'Replaced Scott Durkin as CEO of Douglas Elliman Realty after Durkin\'s termination in October 2024.', name: 'Richard Ferrari', source: 'ls-20260224-010'})
CREATE (n4587:Event {addedDate: date('2026-02-25'), date: '2016-01', description: 'Scott Durkin leaves Corcoran after nearly 26 years to join Douglas Elliman as EVP tasked with national expansion. Leigh Godwin succeeds him as Chelsea office manager.', name: 'Durkin Joins Douglas Elliman', source: 'ls-20260224-010', type: 'career-move'})
CREATE (n4588:Neighborhood {name: 'Chelsea'})
CREATE (n4589:Event {addedDate: date('2026-02-25'), date: '2024-10', description: 'Scott Durkin terminated as CEO of Douglas Elliman effective immediately per SEC filing, amid financial losses (market value dropped from ~$900M to ~$130M since 2021) and scrutiny over alleged mishandling of sexual assault complaints against former agents Oren and Tal Alexander. Richard Ferrari replaces him as CEO.', name: 'Durkin Terminated from Douglas Elliman', source: 'ls-20260224-010', type: 'career-move'})
CREATE (n4590:Event {addedDate: date('2026-02-25'), date: '2024-04', description: 'Corcoran signs 10-year lease at 220 W 19th St (9,200 sq ft, 5th floor, landlord Red Circle NY Corp) to relocate the Chelsea office from 218 W 18th St (13,500 sq ft, opened Oct 2015).', name: 'Corcoran Chelsea Office Relocation', source: 'ls-20260224-007', type: 'corporate'})
CREATE (n4591:Event {addedDate: date('2026-02-25'), date: '2025-10', description: 'Scott Durkin rejoins The Corcoran Group as Licensed Associate Broker at the East Side office, after nearly 27 years previously at Corcoran (1991-2016). Will serve as Corcoran\'s lead equestrian specialist, leveraging 15 years in competitive dressage.', name: 'Durkin Returns to Corcoran', source: 'ls-20260224-010', type: 'career-move'})
CREATE (n4592:Person:Executive {addedDate: date('2026-02-25'), description: 'Former chairman and CEO of Vector Group (Douglas Elliman parent company). Selected Durkin and Dottie Herman for Elliman leadership. Resigned/retired days before Durkin\'s termination in October 2024.', name: 'Howard Lorber', source: 'ls-20260224-010'})
CREATE (n4593:Agent:Person:Broker {addedDate: date('2026-02-25'), agentIds: ['former-roumila'], bio: 'Paris native. Sorbonne law school. Luxury hospitality and advertising for L\'Oréal/Vivendi SA globally. San Francisco 1999, NYC 2000. RE at Citi Habitats, CORE, then Nest Seekers (2011-2016, #2 agent firm-wide behind Ryan Serhant 2015). Moved to Corcoran Chelsea-Flatiron 2016. Multi-Million Dollar Club. Left Corcoran for Christie\'s Aug 2018. Fired from Christie\'s Dec 10, 2018. Filed Roumila v. Christie\'s (Index 162223/2018) Dec 31, 2018 — sexual harassment, discrimination, retaliation, listing theft, commission withholding. Settled April 2022. Team at Corcoran continued under his name after departure (Gabriel Minsky still listed as member). License: [phone redacted]1. 420 W 25th St 1A, NY 10011.', careerPath: 'Sorbonne (Paris) → Advertising → Citi Habitats → CORE → Nest Seekers International (2011-2016, #2 agent) → Corcoran Chelsea (Aug 2016 - Aug 2018) → CIRE (Aug 2018 - Dec 2018, fired) → Roumila Real Estate (own firm, 420 W 25th St)', cireTenure: 'August 9, 2018 - December 10, 2018', corcoranTenure: 'August 2016 - August 2018', currentBrokerage: 'Roumila Real Estate (own firm)', description: 'Real estate broker who worked at Nest Seekers (5 years, #2 agent behind Ryan Serhant in 2015), then the Corcoran Group, then Christie\'s International Real Estate (joined August 2018, fired December 2018). Filed sexual harassment lawsuit against CIRE after claiming he was fired for rejecting advances from business operations manager Sarine Atamian. Procured listings worth $49M and closed $2.8M in sales during his 4 months at CIRE.', education: 'Sorbonne (law school)', email: '[redacted]', formerAgent: true, lifestreamRefs: ['ls-20260223-002', 'ls-20260223-004', 'ls-20260223-006'], name: 'Regis Roumila', nyscefCase: '162223/2018', office: 'Chelsea/Flatiron - 218 West 18th Street 6th Floor', origin: 'Paris, France', priorCareer: 'Advertising, then RE since 2000. Citi Habitats, CORE, Nest Seekers (#2 behind Serhant 2015), Corcoran Chelsea (2016-2018)', researchNotes: 'NYSCEF primary sources extracted: 9 PDFs, ~196K chars. See lifestream ls-20260223-006 for full analysis. Key CIRE personnel: CEO Dan Conn, Exec Dir Kathleen Coumou, Biz Ops Mgr Sarine Atamian, Counsel Keisha Carter. Roumila generated $49.15M in listings during 4 months at CIRE. Ghost cohort connection: Gabriel Minsky (agentId 15917) captured Nov 2019 as \'Regis Roumila Team\' member — stale data, Roumila had left Corcoran 14 months earlier.', source: 'ls-20260224-003'})
CREATE (n4594:Organization {addedDate: date('2026-02-25'), description: 'Luxury real estate brokerage affiliated with Christie\'s auction house. Subject of sexual harassment lawsuit filed by broker Regis Roumila in January 2019.', name: 'Christie\'s International Real Estate', source: 'ls-20260224-003', type: 'brokerage'})
CREATE (n4595:Event {addedDate: date('2026-02-25'), date: '2018-12-31', description: 'Regis Roumila files lawsuit (Index 162223/2018) in Manhattan Supreme Court against Christie\'s International Real Estate alleging sexual harassment by Sarine Atamian, gender/marital status discrimination, retaliation for reporting, and commission withholding (~$46K). Roumila had procured $49M+ in listings and closed $2.8M in 4 months.', name: 'Roumila v. Christie\'s International Real Estate', source: 'ls-20260224-003', type: 'legal'})
CREATE (n4596:Agent:Person {addedDate: date('2026-02-25'), affiliations: ['ARES', 'CoreNet', 'REBNY'], agentIds: ['15917'], bio: 'Born-and-bred Londoner from real estate family. Managed luxury apartments at Stanwood Estates London (business development manager). UCL grad. 15+ years RE in London and NYC. Hebrew speaker. Also had banking and nonprofit experience. Joined Corcoran Chelsea-Flatiron on Regis Roumila Team. Roumila was former #2 agent at Nest Seekers (behind Ryan Serhant), moved to Corcoran 2016. Still listed at Corcoran. Also listed at Triplemint/REAL and on LoopNet for commercial. NY license [phone redacted]4. Currently at Hillmann Consulting LLC per LinkedIn. Active in NYC/NJ markets.', bio2019Full: 'As a born and bred Londoner who grew up in a real estate family, the industry has always been part of Gabriel\'s DNA. Since then, Gabriel has turned his early interest in the business into a wealth of hands-on residential management and sales experience both in the U.S. and abroad. Prior to Corcoran, Gabriel managed a portfolio of high-end luxury apartments in central London. As the business development manager for Stanwood Estates, Gabriel was responsible for business development and marketing strategies. The role allowed him to not only gain a wealth of international sales experience, but also cultivate strong client relationships and build a solid network of industry connections around the world. In both his past and present real estate work, Gabriel has stuck by two guiding principles: honesty and integrity. As a member of Corcoran\'s highly regarded Regis Roumila team, Gabriel continues to be excited at the opportunity to utilize his skills in NYC\'s dynamic real estate market at one of the most respected firms in the industry. Gabriel focuses on luxury residential sales throughout the city.', bio2020Identical: true, bioEvolution: 'DROPPED: Regis Roumila team affiliation (significant - Roumila had sexual harassment lawsuit). DROPPED: Corcoran, Triplemint, The Agency all gone. KEPT: London/property family background. SHIFTED: From residential brokerage to real estate consulting/due diligence. 5 moves in ~5 years = highest mobility in cohort.', bioNotes2019: 'Corcoran 2020 bio: "born and bred Londoner...real estate is in his DNA, having grown up in a property family...member of Corcorans highly regarded Regis Roumila team"', bioNotesCurrent: 'At Hillmann Consulting (nationwide real estate consulting, environmental health & safety, due diligence). Still described as "dynamic, highly competent Real Estate Professional with hands-on sales experience"', captureCount: 1, careerNote: 'WebSearch Feb 2026: now at Triplemint (acquired by The Agency). StreetEasy profile lists Triplemint affiliation. Corcoran data is historical.', careerPath: 'London (property family) → Stanwood Estates (London) → Corcoran Chelsea-Flatiron / Regis Roumila Team (2019-2020) → Triplemint → The Agency → Hillmann Consulting LLC (current)', currentBrokerage: 'Triplemint / The Agency', currentFirm: 'The Agency (formerly Corcoran)', currentStatus: 'active_multi', description: 'Listed as \'Regis Roumila Team\' at Corcoran\'s 218 W 18th Street (Chelsea) address. Ghost team listing — team leader departed 6+ years ago, team name persists. No independent web presence.', education: 'University College London, 2002-2005, Politics & East European Studies (Honors)', email: '[redacted]', enrichedAt: '2026-02-19T20:23:00', enrichedFrom: 'wayback-[phone redacted]4145', first404: '2022-01', firstSeen: '20191112', ghostCohort: true, ghostCohortNote: 'DEBUNKED: Still active in real estate with multiple platform affiliations. Was on Regis Roumila Team at Corcoran.', ghostStatus: 'departed-to-the-agency', languages: ['English', 'Spanish', 'French', 'Hebrew'], lastSeen: '20191112', lastSeenCorcoran: '2020-10', lastVerified: '2026-02-23', legalName: 'Gabriel Minsky', licenseExpires: '2028-01-13', licenseNumber: '[phone redacted]4', markets: ['NYC', 'Northern New Jersey'], mentor: 'Regis Roumila (listed on team, but Roumila left Corcoran Aug 2018 for Christies — fired Dec 2018, lawsuit. Minsky first captured Nov 2019, so joined a team whose leader was already gone.)', movesCount: 5, name: 'Gabriel Minsky', notes: 'Born London, grew up in real estate family. Business development manager at Stanwood Estates UK. Licensed in both NY [phone redacted]4) and NJ. At least 4 brokerage moves since arriving in NYC. Not related to Jerry Minsky (Minsky|Abrishami at Douglas Elliman). Hillmann Consulting is environmental/real estate due diligence firm based in West Orange NJ.', office: 'Chelsea/Flatiron - 218 West 18th Street 6th Floor', origin: 'London, UK', phone: '[redacted]', priorCareer: 'Luxury property management (Stanwood Estates London), banking, nonprofit', priorExperience: '15+ years London property management; Business Development Manager at Stanwood Estates (luxury apartments, central London)', researchNotes: 'Captured Nov 12, 2019 as member of \'Regis Roumila Team\'. However, Roumila left Corcoran for CIRE in Aug 2018 — 14 months before this capture. Team label is stale website data. Minsky may have been solo agent on a defunct team page, or page was never updated. See lifestream ls-20260223-004 for cross-reference analysis.', role: 'Licensed Real Estate Salesperson', roumilaConnection: 'Was explicitly a member of the Regis Roumila team at Corcoran per 2020 bio', roumilaTeamConfirmed: true, roumilaTeamPeriod: '2019-2020', salesRecord: '5 past sales, 18 past rentals (StreetEasy verified)', sampleUrl: 'https://www.corcoran.com/nyc-real-estate/agents/chelsea-flatiron/gabriel-minsky/15917', slug: 'gabriel-minsky', source: 'ls-20260224-003', specialties: ['Investment Sales', 'Landlord Rep (Residential)', 'Multifamily'], status: 'departed', team: 'Regis Roumila Team', title: 'Licensed RE Salesperson', updatedAt: date('2026-02-22T05:11:02.441000000+00:00'), verificationNotes: 'Verified via generic node ops Phase 1 test', verifiedDate: '2026-02-27'})
CREATE (n4597:Event {addedDate: date('2026-02-25'), date: '2015-10', description: 'Corcoran opens 13,500 sq ft loft office at 218 W 18th St, managed by Scott Durkin. Building owned by American Realty Capital. Replaces smaller 9,000 sq ft office at 636 Sixth Avenue. Brings NYC count to 13 offices (8 Manhattan, 5 Brooklyn).', name: 'Corcoran Chelsea Office Opens at 218 W 18th St', source: 'ls-20260224-007', type: 'corporate'})
CREATE (n4598:Organization {addedDate: date('2026-02-25'), description: 'Private Jesuit university in Los Angeles, California. Erika Kirk (Frantzve) attended 2009-2010 between Regis University and ASU.', name: 'Loyola Marymount University', source: 'ls-20260224-020', type: 'educational'})
CREATE (n4599:Person:Executive {addedDate: date('2026-02-25'), description: 'COO and CDO at Turning Point USA, CDO at TP Action. Appeared in LinkedIn suggested profiles for Erika Kirk.', name: 'Justin Streiff', source: 'ls-20260224-020'})
CREATE (n4600:Person:Entrepreneur:Founder:Veteran:Publisher {addedDate: date('2026-02-25'), birthDate: '1940-05-29', birthPlace: 'Lincoln, Nebraska', businesses: 'The Strand Café (103 Stephen St, Lemont, IL — German/Polish/American/Cajun fare, est. mid-1980s); America Consulting & Graphics (Mokena, IL — printing company, received $430K+ from TPUSA 2017-2019); community newspapers across multiple south/southwest Chicago suburbs (from 1986)', careerField: 'marketing, newspaper publishing', causeOfDeath: 'COVID-19 complications', deathDate: '2020-07-28', description: 'William Thomas Montgomery (May 29, 1940 – July 28, 2020). Born Lincoln, Nebraska; grew up Peoria, Illinois. Air Force Reserve veteran (late 1950s-early 1960s, reserve duties only). Colorblind — took great pride in appearance, always wearing a blazer and extraordinarily colorful tie. Serial entrepreneur in Illinois: newspaper publisher (wrote, edited, published multiple local community newspapers); also produced a periodic community newsletter from his restaurant starting ~1986. With wife Edie (married 37 years), bought The Strand Café in downtown Lemont, IL in 1985 — converted from an old drug store, specialized in German, Polish, and American fare plus 45 flavors of ice cream; added Cajun food after a trip to Louisiana, becoming the go-to Cajun spot in Chicago\'s southwest suburbs. Active in Tea Party movement 2009-2010 in Illinois — attended local meetings opposing federal spending and ACA, localized involvement emphasizing limited government. In May 2012, at age 72, attended Youth Government Day at Benedictine University in Lisle, IL where he saw 18-year-old Charlie Kirk speak; encouraged Kirk to skip college and start a political movement. Co-founded TPUSA June 2012 — started in a garage in Lemont. Served as Board Secretary/Treasurer until April 2019. Provided initial funding, leveraged business experience and conservative networks. Also owned America Consulting & Graphics, a printing firm that received $430K+ from TPUSA (July 2017-June 2019). Total compensation from TPUSA exceeded $700K over time plus additional vendor payments and $25K office rental. TPUSA\'s auditor was the Stapleton Group — Montgomery connected to firm since 2010 as business development advisor; firm\'s auditing license expired late 2018. Andrew Kolvet defended arrangements as compliant and discounted market-rate deals. No regulatory findings resulted. Died July 28, 2020 at 8:26am in Downers Grove, IL from COVID-19 complications. Survived by wife Edie, son, daughter, step-daughter, grandchildren, two great-grandchildren. TPUSA memorial Aug 2020 did not mention COVID-19. Known for striking up conversation with every stranger and mentoring hundreds of young adults.', geographicContext: 'Lemont (restaurant) and Mokena (printing) are in the southwest Chicago suburbs. Mokena is ~5 miles from Harald Viking Lodge 13 in Tinley Park and ~15 miles from Homewood, IL (Kent Frantzve\'s early residence). All within the same south/southwest suburban ring.', grewUpIn: 'Peoria, Illinois', hearsaySource: 'Baron Coleman podcast \'70\' at 19:56 on YouTube', name: 'Bill Montgomery', provenanceTier: 'archived', source: 'ls-20260224-022'})
CREATE (n4601:Person:Architect {addedDate: date('2026-02-25'), description: 'Charlie Kirk\'s father. Architect by profession. Major contributor to Mitt Romney\'s 2012 presidential campaign. Reportedly came up with the name \'Turning Point USA\' for his son\'s organization. Supported Charlie\'s decision to take a gap year and pursue political activism instead of college.', education: ['B.Arch, University of Oregon, 1976'], licenses: ['IL', 'FL', 'WI', 'NY', 'GA', 'MN'], name: 'Robert Kirk', notableProjects: ['Trump Tower NYC', 'Tropicana Hotel & Casino Atlantic City'], provenanceCaveat: 'Trump Tower involvement sourced from Factually.co (archived) but underlying firm records not independently verified.', provenanceTier: 'archived-with-caveat', source: 'ls-20260224-022'})
CREATE (n4602:Organization {addedDate: date('2026-02-25'), description: 'Architectural firm in Arlington Heights IL. Robert Kirk serves as President.', name: 'Group A Architects', source: 'ls-20260224-022', type: 'other'})
CREATE (n4603:Organization {addedDate: date('2026-02-25'), description: 'Real estate and hospitality conglomerate. Robert Kirk worked as Project Architect Manager on Trump Tower.', name: 'Trump Organization', source: 'ls-20260224-022', type: 'developer'})
CREATE (n4604:Person:Executive:Engineer {addedDate: [date('2026-02-25'), date('2026-02-27')], aliases: ['Larry Guinta', 'Lawrence R. Guinta'], altNames: ['Lawrence R. Guinta', 'Larry Guinta', 'Larry Gunta'], birthDate: '1951-09-10', description: ['Co-Founder/VP Engineering Technology at E3TEK Group. Principal of Desert Spirit Tek LLC. Also known as Larry Guinta.', 'Co-founder of GTEK Industries. 40+ years experience in mechanical design, electrical power generation, micro grid integration, SCADA systems. Co-filed 2005 patent with Lori Frantzve.'], education: 'BS Illinois State University', familyRole: 'stepfather', ghostCohort: false, name: 'Lawrence Guinta', nameVariants: ['Larry Guinta', 'Lawrence R Guinta'], notes: 'Full career: Tool & Die Engineer at Abrasive Tooling (Jul 1972-Nov 1976) → BS Illinois State University → Lawrence Guinta Engineering consulting (Apr 1983-Dec 1987) → CAD/CAM/Robotics Technical Sales Manager at McDonnell Douglas/Boeing (Aug 1985-Dec 1987) → Automotive Engineering Tech Sales Manager at Plainfield Pixley Richards Inc (Aug 1987-Dec 1989) → co-authored \'The QFD Book\' with Nancy Praizler (1993, AMACOM) → co-founded Tech-Metrics International with Lori Frantzve (~1994) → VP Operations at IntelliMet/iMet Labs → CTO at AZ-Tech International → Director/CTO/EVP at GTEK Industries Inc (OTC: SCGX) → Co-Founder/VP Operations & Engineering at E3TEK Group. Co-inventor on all Frantzve patents (1994-2011). Also listed at Black Pearl Productions (Boston) as 3D & VFX Designer — possibly different person.', provenanceTier: 'search-snippet', role: 'Co-Founder / VP Engineering & Advanced Sciences', roles: ['Executive', 'Engineer', 'Entrepreneur'], source: 'ls-20260224-022'})
CREATE (n4605:Organization {addedDate: date('2026-02-25'), address: '[address redacted]', businessType: 'Small Business 8(a), Women-Owned', colocatedWith: 'ICU Security Group, Armageddon Tactical Solutions LLC', companyConfusion: 'IMPORTANT: AZ-Tech International Inc. (Scottsdale AZ, Women-Owned 8(a), Lori Frantzve founder) is a DIFFERENT company from AzTech International LLC (Dana Point CA, goaztech.com, Hispanic-American owned, Luis Contreras founder/president, $11.3M federal contracts). Many online sources conflate these two firms. The Raytheon subcontract ($64K, 2024 advisory services) belongs to the California AzTech (Contreras), not this firm.', dbaNames: ['IMET Laboratories', 'IMET Labs'], defenseContracts: '$2.6M total, 8 contracts 2000-2020 (DOD). Communications Studies, Professional/Scientific/Technical Services.', description: 'Earned value management consulting firm for US government agencies (DoD, NASA). Founded/chaired by Lori Frantzve. Kent Frantzve is Program Research Director. Related entities: GTEK, E3TEK Group. Specializes in EMP mitigation, network security, continuity of government planning. Conducted 8000+ assessments in 32 countries. Address: 3219 E Camelback Rd #411, Phoenix AZ 85018 (same as E3TEK and Superfeed).', gsaContract: '47QRAA24D003Y', lastVerified: '2026-03-02', name: 'AZ-Tech International', orgType: 'defense-contractor', securityAgencyListing: true, securityOfficerHQCategory: 'Security agency', source: 'ls-20260224-022', type: 'other'})
CREATE (n4606:Source {archivePath: 'ClaudeFiles\\archives\\benzinga.com\\2026-02-27_4366edd869f1.txt', archiveStatus: 'captured', captureStatus: 'captured', capturedAt: date('2026-02-27T06:25:24.764342000+00:00'), domain: 'benzinga.com', lastCaptured: date('2026-02-27T06:25:24.764342000+00:00'), originalUrl: 'https://www.benzinga.com/secfilings/21/01/19140653/superfeed-technologies-inc-notice-of-exempt-offering-formd', sourceType: 'unclassified', textPreview: 'Buy This “Backdoor” AI Play Instead.\nIs Nvidia Still A Good Buy?\nSEE IT NOW ->\nBenzinga\nSPY\n686.27\n0.44%\nQQQ\n606.87\n0.39%\nBTC/USD\n67598.77\n0.1594%\nDIA\n492.00\n0.58%\nGLD\n475.50\n0.41%\nTLT\n90.41\n0.16%\nSuperfeed Technologies, Inc. Notice Of Exempt Offering (FormD)\nAccepted: \nJanuary 13, 2021 at 5:36 AM MST\nForm Type: D\nAccession Number: [phone redacted]-21-000002\nConnect With Us\nAbout Benzinga\nAbout Us\nCareers\nAdvertise\nContact Us\nMarket Resources\nAdvanced Stock Screener Tools\nOptions Trading Chain Analysi', textSize: 1508, title: 'Superfeed Technologies, Inc. Notice Of Exempt Offering (FormD) - Benzinga', url: 'https://benzinga.com/secfilings/21/01/19140653/superfeed-technologies-inc-notice-of-exempt-offering-formd'})
