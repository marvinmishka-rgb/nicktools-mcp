CREATE (n301:Agent {agentIds: ['17698'], bio: 'Boston native, University of Tampa BA. Career path: marketing coordinator at Greater Media (radio events/promotions) → media buyer-to-supervisor at Zenith Media (advertising) → Corcoran Chelsea-Flatiron (Aug 2017 - Mar 2020) → briefly Douglas Elliman → account manager at FreeWheel (ad tech) → senior account manager then Enterprise Account Executive at Rakuten. Now lives in Hoboken. Career pivot from advertising to RE to fintech. No known mentor at Corcoran. Also briefly at Boutique Realty NJ.', bioEvolution: 'GEOGRAPHIC SHIFT: Manhattan luxury → Hoboken/Jersey City market. DROPPED: All NYC/Corcoran references. ADDED: Hudson County expertise, local Hoboken resident angle.', bioNotes2019: 'No 2019 Corcoran bio retrieved. Listed as Chelsea-Flatiron agent Nov 2019.', bioNotesCurrent: 'Hoboken specialist. Born/raised Boston, moved to Manhattan, then Hoboken. Strong reviews for negotiation, organization, Hudson County knowledge. Boutique Realty est. 2009 - full service NJ brokerage.', captureCount: 1, careerPath: 'Boston area (raised) → Manhattan → Corcoran Chelsea-Flatiron (2019) → Boutique Realty LLC, Hoboken NJ', currentBrokerage: 'Boutique Realty LLC', currentFirm: 'Boutique Realty LLC, Hoboken NJ (formerly Corcoran)', currentStatus: 'left_industry', email: '[redacted]', enrichedAt: '2026-02-19T20:23:00', enrichedFrom: 'wayback-[phone redacted]0158', firstSeen: '20191113', ghostCohort: true, ghostCohortNote: 'PARTIAL: Was genuinely brief at Corcoran (2.5 years), then left RE for tech. Not suspicious — career pivot.', ghostStatus: 'departed-to-boutique-realty', lastSeen: '20191113', lastVerified: '2026-02-23', legalName: 'Amy Udell', movesCount: 2, name: 'Amy Udell', notes: 'Boston native, lived in Manhattan, relocated to Hoboken. Specializes in Hoboken/Downtown Jersey City market. Good reviews for neighborhood knowledge and negotiation skills. Geographic shift: Manhattan → Hudson County.', office: 'Chelsea/Flatiron - 218 West 18th Street 6th Floor', origin: 'Boston area, relocated Manhattan then Hoboken', phone: '[redacted]', priorCareer: 'Advertising/media (Zenith Media, Greater Media)', priorExperience: 'Media campaigns/marketing (pre-real estate career)', role: 'Licensed Real Estate Agent', salesRecord: '17 total sales, 0 last 12 months (Zillow verified)', sampleUrl: 'https://www.corcoran.com/nyc-real-estate/agents/chelsea-flatiron/amy-udell/17698', serviceAreas: ['Manhattan', 'Hoboken NJ', 'Jersey City NJ'], slug: 'amy-udell', status: 'departed', title: 'Licensed RE Salesperson', verifiedDate: date('2026-02-27')})
