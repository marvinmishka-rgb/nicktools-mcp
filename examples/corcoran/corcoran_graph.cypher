CREATE (n4693:Source {archivePath: 'ClaudeFiles\\archives\\phoenixnewtimes.com\\2026-02-27_df04e1dbe762.txt', archiveStatus: 'captured', captureStatus: 'captured', capturedAt: date('2026-02-27T05:31:09.491376000+00:00'), domain: 'phoenixnewtimes.com', lastCaptured: date('2026-02-27T05:31:09.491376000+00:00'), originalUrl: 'https://www.phoenixnewtimes.com/news/phoenix-memorial-for-charlie-kirk-turning-point-headquarters-22666810/', sourceType: 'unclassified', textPreview: 'Skip to content\nSUPPORT US\nUser Menu\n\nAfter serving hundreds of underage drinkers, a Tempe bar sues the city for busting them\n\nClose Menu\nSearch\nSearch\nNews\nCannabis\nOpinion\nFood & Drink\nArts & Culture\nMusic\nThings To Do\nBest of Phoenix\nNewsletters\nMore\nfacebook\ninstagram\nx\ntiktok\nbsky\nthreads\nCRIME & POLICE\nCharlie Kirk memorial forms at Turning Point’s Phoenix headquarters\nThe controversial conservative media icon, who based his operation in Arizona, was killed during a college event in Utah.\n', textSize: 10525, title: 'Phoenix memorial for Charlie Kirk forms at Turning Point headquarters | Phoenix New Times', url: 'https://phoenixnewtimes.com/news/phoenix-memorial-for-charlie-kirk-turning-point-headquarters-22666810'})
CREATE (n4694:Organization {addedDate: date('2026-02-27'), name: 'Trinity Broadcasting Network', researchStatus: 'needs-enrichment', source: 'graph-cleanup-20260227'})
CREATE (n4695:Person {addedDate: date('2026-02-27'), born: '1985', description: 'Senior Advancement Director at TPUSA. Born 1985, California. Career: Pepperdine Law School advancement under Dean Kenneth Starr (2005-2012), Gary Sinise Foundation first Dev Director (2011+), Open Hearts Foundation ED, Reagan Presidential Foundation Major Gifts Director (~2018). Married Mike Sheridan. Spoke at Kirk memorial Sep 21 2025.', name: 'Stacy Sheridan', roles: ['Executive']})
CREATE (n4696:Organization {addedDate: date('2026-02-27'), name: '1789 Capital', researchStatus: 'needs-enrichment', source: 'graph-cleanup-20260227'})
CREATE (n4697:Person:Donor:Investor {addedDate: date('2026-02-25'), description: 'Republican mega-donor and multimillionaire investor. Spent $2.1 million on Rick Santorum\'s failed 2012 GOP presidential bid. Met Charlie Kirk at the 2012 RNC in Tampa (Kirk spotted him in a stairwell), gave him a five-figure check three weeks later that launched TPUSA. Called Kirk \'the ultimate role model for us all.\' Co-hosted dinner for 100 TPUSA activists at Washington\'s Metropolitan Club during CPAC with Mike Miller.', name: 'Foster Friess', source: ''})
CREATE (n4698:Person:Activist {addedDate: date('2026-02-25'), description: 'Former national field director of Turning Point USA. Raised in Gurnee, IL by grandparents. Attended Marquette University. Expelled from TPUSA in summer 2017 after text messages including \'I hate black people\' were reported (she denied recalling them; Kirk later claimed they were fakes). Taken in by Clarence and Ginni Thomas, lived in their home for nearly a year. Worked at Ginni Thomas\'s firm Liberty Consulting. Enrolled at Antonin Scalia Law School (George Mason) fall 2019 on full merit scholarship. Top 5% of class; received top grade in Justice Kavanaugh\'s summer course. Clerked for Judge Corey Maze (Alabama) then Judge William Pryor (11th Circuit). Selected as Justice Thomas\'s law clerk for the October 2024 term. The Thomases refer to her as their \'nearly adopted daughter.\'', name: 'Crystal Clanton', source: ''})
CREATE (n4699:Person:Podcaster:Activist:PoliticalCommentator {addedDate: date('2026-02-25'), description: 'Conservative commentator and podcaster. Former TPUSA communications director who co-presented with Kirk at events. Later became independent right-wing media figure. Kirk\'s widow Erika publicly called on Owens to stop spreading conspiracy theories about Kirk\'s death in Dec 2025.', name: 'Candace Owens', source: ''})
CREATE (n4700:Person:Executive:Educator {addedDate: date('2026-02-25'), description: 'Former president of Liberty University. Co-founded the Falkirk Center for Faith and Liberty with Charlie Kirk in 2019. Resigned from Liberty University in August 2020. After his departure, the university did not renew Kirk\'s contract with the center, which was renamed Standing for Freedom Center in 2021.', name: 'Jerry Falwell Jr.', source: ''})
CREATE (n4701:Organization {addedDate: date('2026-02-25'), description: 'Christian and conservative media company. Operated \'The Answer\' radio channel that hosted The Charlie Kirk Show from October 2020 until Kirk\'s assassination in September 2025. The show was among the most popular podcasts on Apple Podcasts with 500-750K daily downloads by 2024.', name: 'Salem Media Group', source: '', type: 'publisher'})
CREATE (n4702:Organization {addedDate: date('2026-02-25'), description: 'Conservative networking organization that has served as a hub for conservative activists and donors. Kirk was a William F. Buckley Jr. council member, listed in the September 2020 membership directory. He was also a spokesperson for CNP Action, the political arm of the CNP.', name: 'Council for National Policy', source: '', type: 'political'})
CREATE (n4703:Event {addedDate: date('2026-02-25'), date: '2011', description: 'At age 17, Charlie Kirk wrote an op-ed for Breitbart News criticizing liberal economics in his high school textbooks. The piece led to his first appearance on Fox News, launching his public profile. Bill Montgomery, a Tea Party supporter, saw Kirk on Fox and subsequently reached out to him.', name: 'Kirk Breitbart Op-Ed and Fox News Debut', source: '', type: 'career-move'})
CREATE (n4704:Event {addedDate: date('2026-02-25'), date: '2012-05', description: 'Charlie Kirk met Bill Montgomery at Benedictine University\'s Youth Government Day in May 2012. Kirk outlined his vision for energizing young conservatives. Montgomery encouraged Kirk to skip college and instead launch a political movement, providing mentorship and initial funding that led to the founding of TPUSA the following month.', name: 'Kirk Meets Montgomery at Benedictine University', source: '', type: 'career-move'})
CREATE (n4705:Event {addedDate: date('2026-02-25'), date: '2012-08', description: 'Charlie Kirk attended the 2012 Republican National Convention in Tampa, where he met Foster Friess, a key Republican donor who became an early financial backer of TPUSA. He also drew the attention of the Trump family, especially Donald Trump Jr., who later hired Kirk to work on social media.', name: 'Kirk at 2012 Republican National Convention', source: '', type: 'career-move'})
CREATE (n4706:Event {addedDate: date('2026-02-25'), date: '2016-07', description: 'At age 22, Charlie Kirk became the youngest speaker at the 2016 Republican National Convention. Though not initially a Trump supporter, Kirk fully embraced Trump at the convention and spent the remainder of the campaign assisting with travel and media arrangements for Donald Trump Jr.', name: 'Kirk Youngest Speaker at 2016 RNC', source: '', type: 'career-move'})
CREATE (n4707:Event {addedDate: date('2026-02-25'), date: '2019', description: 'Charlie Kirk and Liberty University president Jerry Falwell Jr. co-founded the Falkirk Center for Faith and Liberty at Liberty University. The center spent at least $50,000 on Facebook ads promoting Trump and Republican candidates in 2020. After Falwell resigned in August 2020, the university did not renew Kirk\'s contract, and renamed the center to Standing for Freedom Center in 2021.', name: 'Falkirk Center Founded at Liberty University', source: '', type: 'organizational'})
CREATE (n4708:Event {addedDate: date('2026-02-25'), date: '2021', description: 'After Liberty University did not renew Kirk\'s Falkirk Center contract, Kirk and Pentecostal pastor Rob McCoy co-founded Turning Point Faith, an organization encouraging pastors and church leaders to be active in political issues. Budget of $6.4 million per TPUSA\'s 2021 Investor Prospectus. Activities included faith-based voter drives with the stated goal to help churches \'return to foundational Christian values.\'', name: 'Turning Point Faith Founded', source: '', type: 'organizational'})
CREATE (n4709:Event {addedDate: date('2026-02-25'), date: '2020-10', description: 'Charlie Kirk launched The Charlie Kirk Show, a daily three-hour radio talk show on Salem Media Group\'s \'The Answer\' channel. The show became one of the most popular podcasts on Apple Podcasts, with 500,000 to 750,000 daily downloads by 2024. A Brookings Institution study (Feb 2023) found the podcast contained the second-highest proportion of false or misleading statements among 79 political podcasters studied.', name: 'Charlie Kirk Show Launched', source: '', type: 'career-move'})
CREATE (n4710:Event {addedDate: date('2026-02-25'), date: '2021-05', description: 'Charlie Kirk married Erika Frantzve (née Frantzve), a businesswoman, podcaster, and Miss Arizona USA 2012 winner. They met during what was intended as Erika\'s job interview at TPUSA in 2018 at a New York City restaurant. Kirk later recalled saying \'Forget this job interview, I want to date you.\' Engaged December 2020. The couple had two children: a daughter born August 2022 and a son born May 2024.', name: 'Kirk Married Erika Frantzve', source: '', type: 'other'})
CREATE (n4711:Event {addedDate: date('2026-02-25'), date: '2020-03-03', description: 'Kirk published The MAGA Doctrine: The Only Ideas That Will Win the Future through HarperCollins. In the book he wrote that the Republican Party is \'in some sense no longer a conservative party, no longer the party of Reagan, but instead a Trump-remade populist party.\' This was his third book, following Time for a Turning Point (2016, with Brent Hamachek) and Campus Battlefield (2018, foreword by Donald Trump Jr.).', name: 'The MAGA Doctrine Published', source: '', type: 'career-move'})
CREATE (n4712:Event {addedDate: date('2026-02-25'), date: '2021-01-06', description: 'After Trump lost the 2020 election, Charlie Kirk arranged a \'Stop the Steal\' rally in Arizona and sent buses of protesters to the January 6, 2021 storming of the U.S. Capitol in Washington, D.C. Kirk was considered a \'big name\' social influencer in Rudy Giuliani\'s communications plan to overturn the 2020 election.', name: 'Kirk Sends Buses to January 6 Rally', source: '', type: 'other'})
CREATE (n4713:Event {addedDate: date('2026-02-25'), date: '2025-10-14', description: 'President Trump posthumously awarded Charlie Kirk the Presidential Medal of Freedom, the nation\'s highest civilian honor, on what would have been Kirk\'s 32nd birthday. His widow Erika accepted the award on his behalf. Trump had announced the award on September 11, the day after Kirk\'s assassination.', name: 'Kirk Awarded Presidential Medal of Freedom', source: '', type: 'other'})
CREATE (n4714:EntryRef {streamEntryId: 'ls-20260225-002', title: 'Charlie Kirk Biography: From Breitbart Teen to MAGA Movement Leader'})
CREATE (n4715:Source {archivePath: 'ClaudeFiles\\archives\\propublica.org\\2026-02-25_21cc669e9f15.txt', archiveStatus: 'captured', captureStatus: 'captured', capturedAt: date('2026-02-25T23:15:10.873906000+00:00'), domain: 'propublica.org', lastCaptured: date('2026-02-25T23:50:24.074435000+00:00'), sourceType: 'unclassified', textSize: 19825, title: 'At This Trump-Favored Charity, Financial Reporting Is Questionable and Insiders Are Cashing In — ProPublica', url: 'https://www.propublica.org/article/at-this-trump-favored-charity-financial-reporting-is-questionable-and-insiders-are-cashing-in', verifiedAt: date('2026-02-26T16:11:27.366000000+00:00')})
CREATE (n4716:Source {archivePath: 'ClaudeFiles\\archives\\snopes.com\\2026-02-25_f79a8d939155.txt', archiveStatus: 'captured', captureStatus: 'captured', capturedAt: date('2026-02-25T23:15:22.292654000+00:00'), domain: 'snopes.com', lastCaptured: date('2026-02-25T23:15:22.292654000+00:00'), sourceType: 'unclassified', textSize: 6859, title: 'Did Turning Point USA co-founder Bill Montgomery die of COVID-19? Here\'s what we know | Snopes.com', url: 'https://www.snopes.com/news/2026/01/05/turning-point-usa-bill-montgomery-covid-19/', verifiedAt: date('2026-02-26T16:11:27.366000000+00:00')})
CREATE (n4717:Source {archivePath: 'ClaudeFiles\\archives\\influencewatch.org\\2026-02-25_1946d72359b7.txt', archiveStatus: 'captured', captureStatus: 'captured', capturedAt: date('2026-02-25T23:16:11.224390000+00:00'), domain: 'influencewatch.org', lastCaptured: date('2026-02-25T23:16:11.224390000+00:00'), sourceType: 'advocacy-research', textSize: 18016, title: 'Turning Point USA - InfluenceWatch', url: 'https://www.influencewatch.org/non-profit/turning-point-usa/', verifiedAt: date('2026-02-26T16:11:27.366000000+00:00')})
CREATE (n4718:Person:Strategist {addedDate: date('2026-02-25'), description: 'Republican strategist, former Creative Director at Turning Point USA, later social media manager/editor at Independent Journal Review. Mentored closely by Bill and Edie Montgomery — Hull said the Montgomerys \'basically adopted me into their family.\' Montgomery would \'set aside time each day just to talk to me on the phone, always with optimism.\' Hull said Montgomery \'literally changed hundreds of people\'s lives and launched too many careers and businesses to count.\' Announced Montgomery\'s death on Twitter July 28, 2020. Notably confirmed the YAF memo allegations against TPUSA were true on Twitter.', name: 'Caleb Hull', source: ''})
CREATE (n4719:Person:Accountant {addedDate: date('2026-02-25'), description: 'Managing partner of the accounting firm that handled Turning Point USA\'s audits and tax returns. According to ProPublica investigation (July 2020), Stapleton had multiple business relationships with TPUSA co-founder Bill Montgomery: Montgomery served as Stapleton\'s \'business development advisor\' bringing clients to the firm, and Stapleton was Montgomery\'s personal tax preparer. Nonprofit governance experts questioned the independence of TPUSA\'s audits given these ties.', name: 'Robert Stapleton', source: ''})
CREATE (n4720:Event {addedDate: date('2026-02-25'), date: '2020-07-28', description: 'TPUSA co-founder Bill Montgomery died at 8:26am on July 28, 2020 from COVID-19 complications at age 80. The day before his death, TPUSA\'s Twitter account posted and then deleted a meme mocking protective masks. The TPUSA memorial livestream in August 2020 notably did not mention COVID-19 as the cause of death. Montgomery\'s passing came just one week after the ProPublica investigation into TPUSA finances was published, which had detailed Montgomery\'s financial ties to the organization\'s auditor.', name: 'Bill Montgomery Dies of COVID-19', source: '', type: 'other'})
CREATE (n4721:EntryRef {streamEntryId: 'ls-20260225-003', title: 'Bill Montgomery: The Invisible Co-Founder of Turning Point USA'})
CREATE (n4722:Source {archivePath: 'ClaudeFiles\\archives\\chicagobusiness.com\\2026-02-26_f21d866d8960.txt', archiveStatus: 'captured', author: '', captureMethod: 'browser-save-extracted', captureStatus: 'captured', capturedAt: date('2026-02-26T03:03:21.995000000+00:00'), context: 'Bloomberg/Crains 2015 profile of Charlie Kirk founding TPUSA with Bill Montgomery in Lemont garage', domain: 'chicagobusiness.com', extractionMethod: 'semantic-container', htmlFile: 'ClaudeFiles/archives/chicagobusiness.com/2026-02-25_3267e646de43.html', lastCaptured: date('2026-02-26T00:08:11.526462000+00:00'), paywallPatterns: ['Piano/Tinypass paywall vendor detected', 'subscriber/premium markers: 1 elements'], publishedDate: '2015-05-07', sourceType: 'primary-journalism', tags: ['bill-montgomery', 'charlie-kirk', 'tpusa', 'crains', 'bloomberg'], textFile: 'ClaudeFiles/archives/chicagobusiness.com/2026-02-25_3267e646de43_extracted.txt', textSize: 1156, title: 'This boy wonder is building a conservative MoveOn.org in a Lemont garage', url: 'https://www.chicagobusiness.com/article/20150507/NEWS02/150509859/this-boy-wonder-is-building-the-conservative-moveon-org-in-a-garage', verifiedAt: date('2026-02-26T16:11:27.366000000+00:00'), viaWayback: false, waybackUrl: 'http://web.archive.org/web/[phone redacted]3643/https://www.chicagobusiness.com/article/20150507/NEWS02/150509859/this-boy-wonder-is-building-the-conservative-moveon-org-in-a-garage'})
