CREATE (n4789:Source {archivePath: 'ClaudeFiles\\archives\\e3tekgroup.com\\2026-02-27_822191dd4eb0.txt', archiveStatus: 'captured', captureStatus: 'captured', capturedAt: date('2026-02-27T05:30:26.773501000+00:00'), domain: 'e3tekgroup.com', lastCaptured: date('2026-02-27T06:30:59.751341000+00:00'), originalUrl: 'https://www.e3tekgroup.com/aboutus', sourceType: 'unclassified', textPreview: '.Book\ne3tekgroup.com\nis parked free, courtesy of Godaddy.com\nGet This Domain\nBy Staff Writer\n| 2025-12-15\nBook Club Hosting and Discussion Tips for Engaging Meetings\n\nBalance structured discussion with social connection using thoughtful facilitation. This guide covers book selection, discussion preparation, meeting formats, encouragement techniques, and overcoming common hosting challenges to foster engagement and meaningful conversations.\n\nBook clubs transform solitary reading into social exper', textSize: 4868, title: 'Book Club Hosting and Discussion Tips for Engaging Meetings | .Book', url: 'https://e3tekgroup.com/aboutus'})
CREATE (n4790:Organization {addedDate: date('2026-02-26'), description: 'Private investment firm founded by Kent Frantzve, Erika Kirk\'s father.', filingStatus: 'No public filing found online. Arizona Corporation Commission now requires login for entity search (as of March 2026). Illinois Secretary of State blocks automated access. Web searches return no filing details. The entity is referenced in people-search aggregators and factually.co but no state corporation documents have been located.', lastVerified: '2026-03-03', name: 'CKF Group LLC', source: '', type: 'other'})
CREATE (n4791:Organization {addedDate: date('2026-02-26'), address: '[address redacted]', blueRibbonSchool: true, blueRibbonYear: 2022, currentPresident: 'Jill Platt', currentPrincipal: 'Brie Dragonetti', description: 'Private Catholic college preparatory high school in Scottsdale, Arizona. Diocesan school under the Diocese of Phoenix. Opened August 2002, first graduating class of 72 in 2005. Land purchased by Diocese of Phoenix in March 2001 at 9701 E Bell Rd, Scottsdale AZ 85260. 2022 National Blue Ribbon School. Student body ~975. Acceptance rate 80%. Dual leadership model (President/Principal) since 2016. Notable alumni include Erika Kirk (Miss AZ USA 2012, TPUSA CEO), Peter Bourjos (MLB), Gottmik (Drag Race), Joe Anglim (Survivor). Disproportionate pageant pipeline: 4 confirmed competitors including 3 Miss AZ Teen USA winners. 2016 football scandal: AIA sanctions for recruiting violations and illegal summer practices led to coach firing and president reprimand. Capital campaigns: $7.3M Legacy Continues (2014), Vision 2030 current. Sponsors include Russ Lyon Sotheby\'s International Realty.', diocese: 'Diocese of Phoenix', founded: '2002', foundingPrincipal: 'David D. Gonsalves', name: 'Notre Dame Preparatory', source: '', type: 'educational'})
CREATE (n4792:EntryRef {streamEntryId: 'ls-20260225-011', title: 'Lori Frantzve: Erika Kirk\'s Mother — Single Mom, GE Executive, Network Security Entrepreneur'})
CREATE (n4793:Source {archivePath: 'ClaudeFiles\\archives\\wltreport.com\\2026-02-26_4be174b7cc65.txt', archiveStatus: 'captured', captureStatus: 'captured', capturedAt: date('2026-02-26T04:03:26.112176000+00:00'), domain: 'wltreport.com', lastCaptured: date('2026-02-26T04:03:26.112176000+00:00'), sourceType: 'blog-factual-substrate', textSize: 20110, title: 'FACT-CHECK: Erika Kirk\'s Mom Worked For NSA, 7+ Aliases, Hidden Grandparents and a Faceless Dad? | WLT Report', url: 'https://wltreport.com/2025/10/27/fact-check-erika-kirks-mom-worked-nsa-7/', verifiedAt: date('2026-02-26T16:11:27.366000000+00:00')})
