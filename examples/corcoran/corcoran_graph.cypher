CREATE (n4833:Source {archivePath: 'ClaudeFiles\\archives\\ndpsaints.org\\2026-03-01_ffb9eaa25c8d_article.txt', archiveStatus: 'captured', captureCount: 1, captureMethod: 'http-readability', captureStatus: 'captured', capturedAt: date('2026-02-26T16:16:32.938442000+00:00'), domain: 'ndpsaints.org', htmlPath: 'ClaudeFiles\\archives\\ndpsaints.org\\2026-03-01_ffb9eaa25c8d.html', lastCaptured: date('2026-03-01T01:24:34.338643000+00:00'), originalUrl: 'https://www.ndpsaints.org/alumni/alumni-hall-of-fame', sourceType: 'unclassified', tags: [], textPreview: 'Tro Panosian graduated from Notre Dame Preparatory with Summa Cum Laude Honors in May 2011.  During his time at NDP, Tro served as Student Body President, was a member of the 2011 State Championship Soccer Team, and was a recipient of the prestigious Mater Dei Award. Between his junior and senior year, Tro was also elected to the prestigious American Legion Boys Nation program, considered the most respected and selective educational program of government instruction for U.S. high school students', textSize: 2100, title: 'Alumni Hall of Fame', url: 'https://ndpsaints.org/alumni/alumni-hall-of-fame', verifiedAt: date('2026-02-26T16:17:50.131000000+00:00')})
