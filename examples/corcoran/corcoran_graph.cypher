CREATE (n5080:Person {addedDate: date('2026-03-01'), birthDate: '2003-04-16', description: 'Tyler James Robinson, born April 16, 2003. Charged with aggravated murder of Charlie Kirk on September 10, 2025 at Utah Valley University in Orem, Utah. Age 22 at time of shooting. Fired single .30-06 round from grandfather\'s Mauser-type bolt-action rifle from rooftop ~142-160 yards away. Arrived at UVU in a gray Dodge Challenger. Surrendered September 11, 2025 in Washington, Utah after father convinced him. Left note under keyboard: \'I had the opportunity to take out Charlie Kirk and I\'m going to take it.\' Lived with partner Lance Twiggs in St. George apartment. Briefly attended Utah State University for one semester in 2021. Son of Matt and Amber Jones Robinson, brother to Austin and Logan Robinson. Prosecutors seeking death penalty. Search warrants sealed by Utah judge.', hometown: 'Washington, Utah', name: 'Tyler Robinson', residence: 'St. George, Utah', status: 'incarcerated'})
CREATE (n5081:Document {addedDate: date('2026-03-01'), date: '2025-09-11', description: 'Flock camera ALPR network audit logs from Chelan County SO and Mukilteo PD shared networks. Contains license plate search records from September 11, 2025 showing three plates searched in connection with the Charlie Kirk assassination. Searches by Cedar City PD (UT) officer T. Bon and Ogden City PD (UT) officer J. Chr. Three plates: H106HH (2008 Ford Edge, Canadian VIN 2FMDK4KC18BA47928), Z607DU (2024 RAM 2500 Laramie VIN 3C6UR5PL9RG402343), 5AV759 (2005 Chevy TrailBlazer VIN 1GNDT13S512187847). FBI involvement indicated by \'FBI Charlie Kirk dcap\' reason with case SU4130859.', docType: 'public-records', location: 'ClaudeFiles/User Uploads/Flock Data', name: 'Flock ALPR Search Logs - Kirk Assassination', source: 'Flock Safety ALPR Network Audit Logs'})
CREATE (n5082:Source {archiveStatus: 'unarchived', captureStatus: 'legacy-unverified', domain: 'npr.org', url: 'https://npr.org/2025/09/12/nx-s1-5539285/charlie-kirk-shooting-manhunt-suspect-custody-timeline'})
CREATE (n5083:Source {archiveStatus: 'unarchived', captureStatus: 'legacy-unverified', domain: 'abcnews.com', url: 'https://abcnews.com/US/tyler-robinson-charlie-kirk-suspect-shooter-utah/story?id=125474359'})
CREATE (n5084:EntryRef {streamEntryId: 'ls-20260301-003', title: 'Flock ALPR Logs Reveal Three Vehicles Searched in Kirk Assassination Investigation'})
CREATE (n5085:Source {archivePath: 'ClaudeFiles\\archives\\en.wikipedia.org\\2026-03-01_4fb4b51054e4_article.txt', archiveStatus: 'captured', captureCount: 1, captureMethod: 'http-readability', captureStatus: 'captured', capturedAt: date('2026-03-01T16:46:38.265223000+00:00'), domain: 'en.wikipedia.org', htmlPath: 'ClaudeFiles\\archives\\en.wikipedia.org\\2026-03-01_4fb4b51054e4.html', lastCaptured: date('2026-03-01T16:46:38.265223000+00:00'), sourceType: 'unclassified', tags: [], textPreview: '2025 assassination in Orem, Utah, U.S.\nOn September 10, 2025,\nCharlie Kirk\n, an American\nright-wing\npolitical activist, was\nassassinated\nat\nUtah Valley University\nin\nOrem, Utah\n, while speaking at an outdoor campus debate planned by\nTurning Point USA\n, the\nconservative\nyouth organization he co-founded and led. Kirk, aged 31, was a close ally of US president\nDonald Trump\nand a highly influential figure in the\nMAGA movement\n.\nShortly after the debate event began, with around 3,000 people in attend', textSize: 154190, title: 'Assassination of Charlie Kirk', url: 'https://en.wikipedia.org/wiki/Assassination_of_Charlie_Kirk'})
CREATE (n5086:Source {archivePath: 'ClaudeFiles\\archives\\newsweek.com\\2026-03-01_d0ebbf3121ab_article.txt', archiveStatus: 'captured', captureCount: 1, captureMethod: 'http-readability', captureStatus: 'captured', capturedAt: date('2026-03-01T16:46:40.733562000+00:00'), domain: 'newsweek.com', htmlPath: 'ClaudeFiles\\archives\\newsweek.com\\2026-03-01_d0ebbf3121ab.html', lastCaptured: date('2026-03-01T16:46:40.733562000+00:00'), publishedDate: '2025-09-12T10:15:16-04:00', siteName: 'Newsweek', sourceType: 'unclassified', tags: [], textPreview: 'Authorities identified\n22-year-old Tyler Robinson\nas the suspect in\nWednesday\'s fatal shooting\nof Charlie Kirk.\nRobinson\'s parents are Amber Jones Robinson and\nMatt Robinson\n, longtime residents of Washington, Utah, in the southwest-most corner of the state. The family owns a six-bedroom home in the suburbs, valued at around $634,400, according to Zillow.\nThe Context\nKirk was fatally shot\nduring a question-and-answer session on the\nUtah Valley University (UVU) campus\nin Orem, Utah, on Wednesday ', textSize: 4834, title: 'Tyler Robinson Family: What We Know About Mom Amber Jones Robinson and Dad Matthew', url: 'https://newsweek.com/charlie-kirk-family-what-we-know-about-mom-amber-jones-robinson-dad-matthew-2128943'})
CREATE (n5087:Source {archivePath: 'ClaudeFiles\\archives\\foxnews.com\\2026-03-01_3ff53398702e_article.txt', archiveStatus: 'captured', captureCount: 1, captureMethod: 'http-readability', captureStatus: 'captured', capturedAt: date('2026-03-01T16:46:42.571854000+00:00'), domain: 'foxnews.com', htmlPath: 'ClaudeFiles\\archives\\foxnews.com\\2026-03-01_3ff53398702e.html', lastCaptured: date('2026-03-01T16:46:42.571854000+00:00'), sourceType: 'primary-journalism', tags: [], textPreview: 'Fox News senior correspondent Claudia Cowan reports on the latest in hearings for accused Charlie Kirk assassin Tyler Robinson on \'Special Report.\'\nNEW\nYou can now listen to Fox News articles!\nPROVO, Utah – The transgender roommate and romantic partner of Charlie Kirk’s alleged assassin\nTyler Robinson\nis no longer being trailed by a four-man security detail, a law enforcement source confirmed to Fox News Digital.\nThe revelation comes amid the FBI pulling its protection of Lance Twiggs more than ', textSize: 5505, title: 'FBI protection ends for Lance Twiggs in Charlie Kirk assassination case', url: 'https://foxnews.com/us/tyler-robinson-lover-lance-twiggs-no-longer-protected-by-fbi-what-we-know-about-alleged-assassins-partner'})
CREATE (n5088:Person {addedDate: date('2026-03-01'), description: 'Tyler Robinson\'s roommate and romantic partner in St. George, Utah. Age 22. Transgender (transitioning male to female). Cooperated with FBI investigation after Charlie Kirk assassination. Turned over incriminating text messages from Robinson discussing rifle retrieval, the shooting, and instructions to delete messages. Had FBI protection which was later ended. Drove an Infiniti FX35. Reported missing from St. George home by late October 2025; vehicle left at shared townhouse with lights on and mail piling up. Sheriff said Twiggs was in a \'safe space very far away from St. George.\'', name: 'Lance Twiggs'})
CREATE (n5089:Person {addedDate: date('2026-03-01'), aliases: 'William Matthew Robinson, William Robinson', description: 'Full legal name: William Matthew Robinson. Father of Tyler Robinson (Charlie Kirk assassination suspect). Age 48 as of April 2025. Runs kitchen countertop, cabinet, and stone surface installation business. Utah business records show: 1-CALL HANDYMAN, LLC (entity 11[phone redacted], formed March 2020, administratively dissolved August 2025) at 646 N 750 W, Provo, UT 84601. Also operated UTAH CUSTOM CABINETS (DBA, entity 12[phone redacted], formed March 2021, dissolved May 2024) at 185 E Saratoga Dr, Saratoga Springs, UT 84045. Registered Republican. LDS member. Lives in ~$634K six-bedroom home in Washington, UT with wife Amber Jones Robinson. Recognized son from news images after Kirk assassination, convinced him to surrender to Washington County Sheriff.', name: 'Matt Robinson'})
CREATE (n5090:Person {addedDate: date('2026-03-01'), description: '71-year-old Utah political gadfly who falsely claimed he shot Charlie Kirk at UVU on September 10, 2025. Approached a detective at the event saying \'I shot him, now shoot me.\' His false confession diverted officers from securing the scene and finding the actual shooter. Known for showing up at and disrupting political events for 30+ years. Charged with obstruction of justice and possession of child sexual abuse material. Pleaded no contest to reduced obstruction charge (third-degree felony). Sentenced to 0-5 years in prison.', name: 'George Zinn'})
CREATE (n5091:Source {archiveStatus: 'unarchived', captureStatus: 'legacy-unverified', domain: 'atty.utahcounty.gov', url: 'https://atty.utahcounty.gov/cms/uploads/TJR_Information_49872215e3.pdf'})
