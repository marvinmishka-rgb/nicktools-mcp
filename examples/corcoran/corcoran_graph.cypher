CREATE (n4601)-[:SUPPORTED_BY {claim: 'Kirk\'s father reportedly came up with the name Turning Point USA', confidence: 'archived-verified', createdAt: date('2026-02-26T03:33:38.809000000+00:00')}]->(n4745)
CREATE (n4751)-[:SUPPORTED_BY {claim: 'TPUSA advisory board member, spoke at 2016 Young Women\'s Leadership Summit in Dallas, employer of Clanton at Liberty Consulting, took Clanton into Thomas home', confidence: 'archived-verified', createdAt: date('2026-02-26T03:32:29.096000000+00:00')}]->(n4748)
CREATE (n4695)-[:SUPPORTED_BY {claim: 'Career trajectory: Pepperdine Law under Dean Kenneth Starr (2005-2012), Gary Sinise Foundation, Open Hearts Foundation, Reagan Library, then TPUSA Senior Advancement Director', confidence: 'archived-verified', createdAt: date('2026-02-27T05:34:53.089000000+00:00')}]->(n4752)
CREATE (n4802)-[:SUPPORTED_BY {claim: 'Church partnered with TPUSA for Strong Church Dream Conference 2024, hosts Freedom Night in America, 2020 Trump rally, TPUSA Faith co-founded with Rob McCoy', confidence: 'archived-verified', createdAt: date('2026-02-27T05:34:57.571000000+00:00')}]->(n4772)
