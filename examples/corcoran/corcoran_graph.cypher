CREATE (n5209:Source {archivePath: 'ClaudeFiles\\archives\\archive.org\\2026-03-02_d33b81d6848e_article.txt', archiveStatus: 'captured', captureCount: 1, captureMethod: 'nodriver', captureStatus: 'captured', capturedAt: date('2026-03-02T23:03:32.898630000+00:00'), domain: 'archive.org', htmlPath: 'ClaudeFiles\\archives\\archive.org\\2026-03-02_d33b81d6848e.html', lastCaptured: date('2026-03-02T23:03:32.898630000+00:00'), siteName: 'Internet Archive', sourceType: 'unclassified', tags: [], textPreview: 'Skip to main content\n Wayback Machine \n Texts \n Video \n Audio \n Software \n Images \n Donate \n More\n"Donate to the archive"\n \nSign up for free\nLog in\n Search metadata\n Search text contents\n Search TV news captions\n Search radio transcripts\n Search archived web sites\nAdvanced Search\nThe desktop business intelligence sourcebook : a comprehensive guidebook for the information age\nBookreader Item Preview\n\nPage — (1/196)\n\nFavorite\n \nShare\n \nFlag\ntexts\n The desktop business intelligence sourcebook : a c', textSize: 2322, title: 'The desktop business intelligence sourcebook : a comprehensive guidebook for the information age', url: 'https://archive.org/details/desktopbusinessi0000fran'})
CREATE (n5210:Source {archivePath: 'ClaudeFiles\\archives\\nationaldefensemegadirectory.com\\2026-03-02_1a51d7f0630b_article.txt', archiveStatus: 'captured', captureCount: 1, captureMethod: 'http-readability', captureStatus: 'captured', capturedAt: date('2026-03-02T23:04:06.809667000+00:00'), domain: 'nationaldefensemegadirectory.com', htmlPath: 'ClaudeFiles\\archives\\nationaldefensemegadirectory.com\\2026-03-02_1a51d7f0630b.html', lastCaptured: date('2026-03-02T23:04:06.809667000+00:00'), sourceType: 'unclassified', tags: [], textPreview: 'Country\nAfghanistan\nAlbania\nAlgeria\nAndorra\nAngola\nAntigua and Barbuda\nArgentina\nArmenia\nAustralia\nAustria\nAzerbaijan\nBahamas\nBahrain\nBangladesh\nBarbados\nBelarus\nBelgium\nBelize\nBenin\nBhutan\nBolivia, Plurinational State Of\nBosnia and Herzegovina\nBotswana\nBrazil\nBrunei Darussalam\nBulgaria\nBurkina Faso\nBurundi\nCambodia\nCameroon\nCanada\nCape Verde\nCayman Islands\nCentral African Republic\nChad\nChile\nChina\nColombia\nComoros\nCongo\nCongo, The Democratic Republic Of The\nCosta Rica\nCôte D\'Ivoire\nCroatia\nCuba', textSize: 2294, title: 'AzTech International, Inc.', url: 'https://nationaldefensemegadirectory.com/Listing/Company/811257'})
CREATE (n5211:Source {archivePath: 'ClaudeFiles\\archives\\cdaily.org\\2026-03-02_2326c5febf7a_article.txt', archiveStatus: 'captured', captureCount: 1, captureMethod: 'http-readability', captureStatus: 'captured', capturedAt: date('2026-03-02T23:05:32.871391000+00:00'), domain: 'cdaily.org', htmlPath: 'ClaudeFiles\\archives\\cdaily.org\\2026-03-02_2326c5febf7a.html', lastCaptured: date('2026-03-02T23:05:32.871391000+00:00'), sourceType: 'unclassified', tags: [], textPreview: 'I know some of you are not going to like this article, but we report FAIRLY and OPENLY and HONESTLY around here, and we also do our homework and fact-check things.\nAnd no topic is off-limits.\nLook folks, I want to like Erika and believe the best about her, but I’m telling you my Spidey Senses are off the charts with this one…\nThe constant fake crying (but never any actual tears)…\nThe Devil Horns at Charlie’s Memorial…\nAnd now the backstory.\nYou might have heard some of this before, but most of i', textSize: 14613, title: 'FACT-CHECK: Erika Kirk’s Mom Worked For NSA, 7+ Aliases, Hidden Grandparents and a Faceless Dad?', url: 'https://cdaily.org/fact-check-erika-kirks-mom-worked-for-nsa-7-aliases-hidden-grandparents-and-a-faceless-dad'})
CREATE (n5212:Organization {addedDate: date('2026-03-02'), description: 'Frantzve family company. Lori Frantzve is Manager. Kent Frantzve listed as retired from here on second LinkedIn profile. Related to IMET Laboratories (DBA of AZ-Tech International Inc.).', location: '7047 E Greenway Pkwy #250, Scottsdale, AZ 85260', name: 'INTELLIMET of Arizona LLC', provenanceTier: 'web-search', type: 'Private Company'})
CREATE (n5213:Organization {addedDate: date('2026-03-02'), description: 'EVM consulting firm co-founded by Luis Contreras and Oscar Banda in 1992. goaztech.com. Hispanic-American owned. $11.3M in federal contracts since 2001. Specializes in earned value management for DoD/DOE. NOT related to the Frantzve family\'s AZ-Tech International Inc. (Scottsdale, AZ). Often conflated online due to similar names.', foundedYear: 1992, founders: 'Luis Contreras, Oscar Banda', location: 'Dana Point, CA (25132 Oceanknoll)', name: 'AzTech International LLC', provenanceTier: 'archived', type: 'Private Company', website: 'goaztech.com'})
