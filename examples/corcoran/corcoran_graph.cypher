CREATE (n4563)-[:SUPPORTED_BY {claim: 'Born June 1984 in Nevada, fifth-generation rancher family, attended UW Seattle, traveled UK and Kenya for missions', confidence: 'archived-verified', createdAt: date('2026-02-25T06:49:35.492000000+00:00')}]->(n4683)
CREATE (n4578)-[:SUPPORTED_BY {claim: 'Born Oct 14, 1993 Arlington Heights IL. Eagle Scout. Wheeling HS. Applied West Point (rejected). Harper College (dropped out). Co-founded TPUSA June 2012. Youngest speaker 2016 RNC. Forbes 30 Under 30 (2018). Married Erika May 2021. Two children. Charlie Kirk Show on Salem Media from Oct 2020. Signed TBN Feb 2025. $4.75M Scottsdale estate. CNP member. Assassinated Sep 10, 2025.', confidence: 'archived-verified', createdAt: date('2026-02-25T23:05:39.431000000+00:00')}]->(n4690)
CREATE (n4578)-[:SUPPORTED_BY {claim: 'Full name Charles James Kirk. Father Robert and mother Kimberly Kirk. Father was major Romney 2012 donor. Wrote Breitbart op-ed at 17 leading to Fox News appearance. Met Bill Montgomery who encouraged him to skip college. Father suggested name Turning Point. Attended 2012 RNC gaining key donor support. Youngest 2016 RNC speaker at 22. Visited Trump White House 100+ times. J.D. Vance Senate endorsement 2022. Two children (girl and boy). Posthumous Medal of Freedom Oct 14, 2025.', confidence: 'archived-verified', createdAt: date('2026-02-25T23:05:39.704000000+00:00')}]->(n4692)
CREATE (n4718)-[:SUPPORTED_BY {claim: 'Hull described as \'conservative influencer\' and Montgomery\'s friend. Posted that Montgomery \'lost his fight against COVID-19.\'', confidence: 'archived-verified', createdAt: date('2026-02-25T23:24:24.512000000+00:00')}]->(n4716)
