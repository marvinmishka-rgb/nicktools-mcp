# nicktools MCP Server -- Environment Configuration
# Copy this file to .env and fill in your values.
# Only NEO4J_PASSWORD is required; everything else has sensible defaults.

# -- Windows Users: Set this system-wide to avoid encoding errors ------
# Python defaults to cp1252 on Windows, which crashes on non-ASCII output.
# Set PYTHONUTF8=1 as a permanent user environment variable:
#   [System.Environment]::SetEnvironmentVariable("PYTHONUTF8", "1", "User")
# This is NOT set in .env because it must be active before Python starts.
# On Linux/macOS this is not needed (UTF-8 is already the default).

# -- Required ----------------------------------------------------------
NEO4J_PASSWORD=your_password_here

# -- Neo4j Connection (Optional) ------------------------------
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USER=neo4j

# -- Database Names (Optional) --------------------------------
# Override to use your own database names.
# NICKTOOLS_GRAPH_DB=nicktools
# NICKTOOLS_ENTRY_DB=nicktools_entries

# -- Workspace Path (Optional) --------------------------------
# Root directory for all nicktools data (archives, lifestream, queue, etc.)
# Default resolution: NICKTOOLS_HOME > ~/nicktools_workspace > ~/ClaudeFiles
# NICKTOOLS_HOME=/path/to/your/workspace

# -- Wayback Machine (Optional) -------------------------------
# Save Page Now API credentials from https://archive.org/account/s3.php
# Without these, local archiving works; only Wayback submission is disabled.
# WAYBACK_S3_ACCESS=
# WAYBACK_S3_SECRET=

# -- Public Records APIs (Optional) ---------------------------
# Each API is skipped if its key is not configured.
# FMCSA motor carrier lookup: https://mobile.fmcsa.dot.gov/QCDevsite/
# FMCSA_WEB_KEY=
# SEC EDGAR user agent (required format: "toolname your-email@example.com")
# SEC searches are skipped until this is set with a real email.
# SEC_USER_AGENT=nicktools-research your-email@example.com
# OpenCorporates: https://opencorporates.com/users/sign_up
# OPENCORPORATES_API_TOKEN=
# CourtListener: https://www.courtlistener.com/sign-in/
# COURTLISTENER_API_TOKEN=
# PlateToVIN ($0.05/lookup): https://platetovin.com
# PLATETOVIN_API_KEY=
